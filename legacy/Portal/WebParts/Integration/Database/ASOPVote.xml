                  </xs:simpleType>
                </xs:element>
                <xs:element name="CandidateId" type="xs:int" />
                <xs:element name="DateVoted" type="xs:dateTime" />
                <xs:element name="UserName">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="250" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="Status" type="xs:int" />
                <xs:element name="CompetitionId" type="xs:int" />
                <xs:element name="IPAddress">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="50" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="Spam" type="xs:int" />
              </xs:sequence>
            </xs:complexType>
          </xs:element>
        </xs:choice>
      </xs:complexType>
      <xs:unique name="Constraint1" msdata:PrimaryKey="true">
        <xs:selector xpath=".//MCVote" />
        <xs:field xpath="Id" />
      </xs:unique>
    </xs:element>
  </xs:schema>
