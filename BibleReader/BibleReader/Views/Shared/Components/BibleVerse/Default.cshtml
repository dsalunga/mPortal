@model WCMS.WebSystem.WebParts.ViewComponents.BibleVerseViewModel

<section class="bible-verse-reader" aria-labelledby="bibleVerseHeading">
    <h2 id="bibleVerseHeading" class="visually-hidden">Bible Verse Reader</h2>

    <form method="get" class="row g-2 mb-3 align-items-end" role="search" aria-label="Bible navigation">
        <div class="col-auto">
            <label for="versionSelect" class="form-label fw-semibold">Version</label>
            <select id="versionSelect" name="versionId" class="form-select" onchange="this.form.submit()" aria-label="Select Bible version">
                @if (Model.Versions == null || Model.Versions.Count == 0)
                {
                    <option value="">No versions available</option>
                }
                else
                {
                    @foreach (var v in Model.Versions)
                    {
                        <option value="@v.Id" selected="@(v.Id == Model.SelectedVersionId ? "selected" : null)">
                            @v.Name (@v.Abbreviation)
                        </option>
                    }
                }
            </select>
        </div>
        <div class="col-auto">
            <label for="bookSelect" class="form-label fw-semibold">Book</label>
            <input type="number" id="bookSelect" name="bookId" class="form-control" min="1"
                   value="@(Model.SelectedBookId > 0 ? Model.SelectedBookId.ToString() : "")"
                   placeholder="Book #" aria-label="Book number" style="width:100px" />
        </div>
        <div class="col-auto">
            <label for="chapterSelect" class="form-label fw-semibold">Chapter</label>
            <input type="number" id="chapterSelect" name="chapter" class="form-control" min="1"
                   value="@(Model.SelectedChapter > 0 ? Model.SelectedChapter.ToString() : "")"
                   placeholder="Ch #" aria-label="Chapter number" style="width:100px" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-book" aria-hidden="true"></i> Read
            </button>
        </div>
    </form>

    @if (Model.Verses != null && Model.Verses.Count > 0)
    {
        <article class="verses card" aria-label="Bible verses">
            <div class="card-body">
                @foreach (var verse in Model.Verses)
                {
                    <p class="verse mb-2 lh-lg">
                        <sup class="verse-number text-primary fw-bold me-1" aria-label="Verse @verse.VerseNumber">@verse.VerseNumber</sup>
                        <span>@verse.Text</span>
                    </p>
                }
            </div>
        </article>
    }
    else if (Model.SelectedBookId > 0 && Model.SelectedChapter > 0)
    {
        <div class="alert alert-info" role="status" aria-live="polite">
            <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
            No verses found for the selected book and chapter. Please try a different selection.
        </div>
    }
    else
    {
        <p class="text-muted fst-italic" role="status">Select a book and chapter to begin reading.</p>
    }
</section>
