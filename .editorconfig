# =============================================================================
# .editorconfig — mPortal .NET 10 Migration Baseline
# =============================================================================
# Created during .NET 4.7 → .NET 10 migration to triage pre-existing analyzer
# warnings. Security rules remain as warnings; style/naming rules are lowered
# to suggestion severity until the team addresses them incrementally.
# =============================================================================

root = true

[*.cs]

# ---------------------------------------------------------------------------
# NAMING / STYLE — lowered from warning to suggestion (pre-existing debt)
# ---------------------------------------------------------------------------

# CA1305: Specify IFormatProvider (1566 instances)
dotnet_diagnostic.CA1305.severity = suggestion

# CA1707: Identifiers should not contain underscores (440)
dotnet_diagnostic.CA1707.severity = suggestion

# CA1822: Mark members as static (252)
dotnet_diagnostic.CA1822.severity = suggestion

# CA1309: Use ordinal StringComparison (218)
dotnet_diagnostic.CA1309.severity = suggestion

# CA1863: Use CompositeFormat (194)
dotnet_diagnostic.CA1863.severity = suggestion

# CA1310: Specify StringComparison for correctness (194)
dotnet_diagnostic.CA1310.severity = suggestion

# CA1716: Identifiers should not match keywords (152)
dotnet_diagnostic.CA1716.severity = suggestion

# CA1051: Do not declare visible instance fields (116)
dotnet_diagnostic.CA1051.severity = suggestion

# CA1859: Use concrete types when possible for improved performance (90)
