# Copy this file to .env and set real values before running docker compose or local hosts.

# Core runtime
ASPNETCORE_ENVIRONMENT=Development
WCMS__DatabaseProvider=PostgreSql

# Database credentials (required by docker-compose.yml)
SA_PASSWORD=<set-strong-sqlserver-password>
PG_USER=postgres
PG_PASSWORD=<set-strong-postgres-password>

# Optional explicit connection string override for web host.
# If omitted, docker-compose uses SA_PASSWORD for SQL Server profile.
CONNECTION_STRING=

# App security values (set these from a secure source in all non-ephemeral environments)
# Security__LoginEncryptionKey must be base64-encoded 32 bytes.
# Security__LoginEncryptionIV must be base64-encoded 16 bytes.
Security__PasswordSalt=<set-random-base64-salt>
Security__LoginEncryptionKey=<set-base64-32-byte-key>
Security__LoginEncryptionIV=<set-base64-16-byte-iv>

# Optional SMS endpoint override (if SMS features are enabled)
HttpSmsUrl=
