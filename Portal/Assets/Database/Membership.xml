<?xml version="1.0" standalone="yes"?>
<mPortal>
  <xs:schema id="mPortal" xmlns="" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xs:element name="mPortal" msdata:IsDataSet="true" msdata:UseCurrentLocale="true">
      <xs:complexType>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
          <xs:element name="Membership">
            <xs:complexType>
              <xs:sequence>
                <xs:element name="MembershipID" msdata:ReadOnly="true" msdata:AutoIncrement="true" type="xs:long" />
                <xs:element name="MemberID" type="xs:long" minOccurs="0" />
                <xs:element name="MemberTypeID" type="xs:short" minOccurs="0" />
                <xs:element name="MembershipStatusID" type="xs:short" minOccurs="0" />
                <xs:element name="LocaleStatusID" type="xs:short" minOccurs="0" />
                <xs:element name="LocaleID" type="xs:int" minOccurs="0" />
                <xs:element name="GroupID" type="xs:short" minOccurs="0" />
                <xs:element name="CommitteeID" type="xs:short" minOccurs="0" />
                <xs:element name="MembershipDate" type="xs:dateTime" minOccurs="0" />
                <xs:element name="MembershipPlace" minOccurs="0">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="200" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="OrientedBy" minOccurs="0">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="100" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="OnboardedBy" minOccurs="0">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="100" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="PreviousOrganization" minOccurs="0">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="200" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
              </xs:sequence>
            </xs:complexType>
          </xs:element>
        </xs:choice>
      </xs:complexType>
      <xs:unique name="Constraint1" msdata:PrimaryKey="true">
        <xs:selector xpath=".//Membership" />
        <xs:field xpath="MembershipID" />
      </xs:unique>
    </xs:element>
  </xs:schema>
</mPortal>