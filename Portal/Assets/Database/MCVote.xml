<?xml version="1.0" standalone="yes"?>
<mPortal>
  <xs:schema id="mPortal" xmlns="" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xs:element name="mPortal" msdata:IsDataSet="true" msdata:UseCurrentLocale="true">
      <xs:complexType>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
          <xs:element name="MCVote">
            <xs:complexType>
              <xs:sequence>
                <xs:element name="Id" msdata:ReadOnly="true" msdata:AutoIncrement="true" type="xs:int" />
                <xs:element name="Code">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="250" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="FirstName">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="250" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="LastName">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="250" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="MobileNumber">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="250" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="Email">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="250" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="CandidateId" type="xs:int" />
                <xs:element name="DateVoted" type="xs:dateTime" />
                <xs:element name="UserName">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="250" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="Status" type="xs:int" />
                <xs:element name="CompetitionId" type="xs:int" />
                <xs:element name="IPAddress">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="50" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="Spam" type="xs:int" />
              </xs:sequence>
            </xs:complexType>
          </xs:element>
        </xs:choice>
      </xs:complexType>
      <xs:unique name="Constraint1" msdata:PrimaryKey="true">
        <xs:selector xpath=".//MCVote" />
        <xs:field xpath="Id" />
      </xs:unique>
    </xs:element>
  </xs:schema>
</mPortal>