{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ConnectionString": "Host=localhost;Database=mPortal;Username=mportal;Password=mportal;Include Error Detail=true",
    "BibleConnection": "Host=localhost;Database=BibleReader;Username=mportal;Password=mportal;Include Error Detail=true",
    "EventCalendar": "Host=localhost;Database=mPortal;Username=mportal;Password=mportal;Include Error Detail=true"
  },
  "WCMS": {
    "Environment": "DEV",
    "DatabaseProvider": "PostgreSQL",
    "PageExt": "",
    "AllowCache": false,
    "AllowFixtureBackupInProduction": false,
    "AssetBasePath": "/Content/Assets/",
    "AgentEnabled": true,
    "AgentAutoStart": false,
    "UserPhotoPath": "/Content/Assets/User-Photos",
    "FileCachePath": "Content/Assets/Cache/",
    "MinDiskFreeMB": 10240
  },
  "WebObject": {
    "DataProvider": "WCMS.Framework.Core.SqlProvider.WebObjectProvider, WCMS.Framework.Core.SqlProvider",
    "XmlProvider": "WCMS.Framework.Core.XmlProvider",
    "SqlDbName": "mPortal"
  },
  "DbProvider": {
    "Path": "../../Binaries/Database"
  },
  "RichTextEditor": {
    "Provider": "TipTap",
    "UserFilesPath": "/Content/Assets/Uploads/"
  },
  "LogPath": "Content/Admin/Data/Logs/"
}
