@{
    var controlId = (ViewData["ControlId"] as string) ?? $"ckeditor-compat-{Guid.NewGuid():N}";
    var fieldName = (ViewData["FieldName"] as string) ?? "EditorValue";
    var fieldValue = ViewData["Value"]?.ToString() ?? string.Empty;
    var htmlDefault = string.Equals(ViewData["HtmlDefault"]?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
}

<div id="@($"{controlId}-root")" class="card">
    <div class="card-header">
        <ul class="nav nav-tabs card-header-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(!htmlDefault ? "active" : string.Empty)" type="button" data-bs-toggle="tab" data-bs-target="#@($"{controlId}-plain")" role="tab">Plain Text</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(htmlDefault ? "active" : string.Empty)" type="button" data-bs-toggle="tab" data-bs-target="#@($"{controlId}-html")" role="tab">HTML Editor</button>
            </li>
        </ul>
    </div>
    <div class="card-body tab-content">
        <div class="tab-pane fade @(!htmlDefault ? "show active" : string.Empty)" id="@($"{controlId}-plain")" role="tabpanel">
            <textarea class="form-control" rows="10" id="@($"{controlId}-plain-input")">@fieldValue</textarea>
        </div>
        <div class="tab-pane fade @(htmlDefault ? "show active" : string.Empty)" id="@($"{controlId}-html")" role="tabpanel">
            <textarea class="form-control" rows="10" id="@($"{controlId}-html-input")">@fieldValue</textarea>
            <div class="form-text">For rich editing enhancements, wire this field to the TipTap-based editor stack in the host view.</div>
        </div>
        <input type="hidden" id="@controlId" name="@fieldName" value="@fieldValue" />
    </div>
</div>

<script>
(function () {
    var hidden = document.getElementById('@controlId');
    var plain = document.getElementById('@($"{controlId}-plain-input")');
    var html = document.getElementById('@($"{controlId}-html-input")');
    var root = document.getElementById('@($"{controlId}-root")');

    if (!hidden || !plain || !html || !root) {
        return;
    }

    var syncValue = function () {
        var htmlTab = document.getElementById('@($"{controlId}-html")');
        var useHtml = htmlTab && htmlTab.classList.contains('active') && htmlTab.classList.contains('show');
        hidden.value = useHtml ? html.value : plain.value;
    };

    plain.addEventListener('input', syncValue);
    html.addEventListener('input', syncValue);

    var form = root.closest('form');
    if (form) {
        form.addEventListener('submit', syncValue);
    }
})();
</script>
