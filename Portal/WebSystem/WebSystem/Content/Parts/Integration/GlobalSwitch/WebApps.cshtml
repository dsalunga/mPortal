@using WCMS.Framework
@{
    var sessionId = WSession.Current.UserSession?.SessionId.ToString() ?? string.Empty;
    var sessionQuery = string.IsNullOrWhiteSpace(sessionId) ? string.Empty : $"?SessionId={sessionId}";
}

<section class="container" style="padding-top:16px; padding-bottom:24px;">
    <h1>Web Apps &amp; Services</h1>
    <p class="text-muted">Quick access to primary web applications and service endpoints.</p>

    <ul class="list-group">
        <li class="list-group-item"><a href="@($"/chapters{sessionQuery}")">Chapters</a></li>
        <li class="list-group-item"><a href="@($"/BibleReader{sessionQuery}")">Bible Reader</a></li>
        <li class="list-group-item"><a href="@($"/LiveStream{sessionQuery}")">Live Stream</a></li>
        <li class="list-group-item"><a href="@($"/help-feedback{sessionQuery}")">Help &amp; Feedback</a></li>
    </ul>
</section>
