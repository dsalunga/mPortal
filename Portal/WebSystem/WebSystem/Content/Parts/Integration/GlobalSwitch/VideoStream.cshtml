@using WCMS.Framework
@{
    var sessionId = WSession.Current.UserSession?.SessionId.ToString() ?? string.Empty;
    var sessionQuery = string.IsNullOrWhiteSpace(sessionId) ? string.Empty : $"?SessionId={sessionId}";
}

<section class="container" style="padding-top:16px; padding-bottom:24px;">
    <h1>Live Video Streaming</h1>
    <p class="text-muted">Access live broadcasts and stream-related resources.</p>

    <div class="list-group">
        <a class="list-group-item" href="@($"/LiveStream{sessionQuery}")">Open Live Stream</a>
        <a class="list-group-item" href="@($"/Explore{sessionQuery}")">Back to Explore</a>
    </div>
</section>
