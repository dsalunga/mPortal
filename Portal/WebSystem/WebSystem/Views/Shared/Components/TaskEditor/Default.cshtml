@model WCMS.WebSystem.ViewComponents.TaskEditorViewModel

<section class="card shadow-sm admin-panel" aria-label="Task Editor">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-gear" aria-hidden="true"></i> Task Editor</h5>
        <button type="button" class="btn btn-sm btn-primary" id="btnSaveTask" aria-label="Save task"><i class="bi bi-save" aria-hidden="true"></i> Save</button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success" role="status">@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        <form id="taskEditorForm" aria-label="Task configuration">
            <input type="hidden" id="taskId" value="@Model.TaskId" />
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="taskName">Task Name <span class="text-danger" aria-hidden="true">*</span></label>
                    <input type="text" class="form-control" id="taskName" value="@Model.TaskName" required aria-required="true" />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="taskDescription">Description</label>
                    <input type="text" class="form-control" id="taskDescription" value="@Model.Description" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label" for="taskType">Type</label>
                    <select class="form-select" id="taskType" aria-label="Task type">
                        @foreach (var t in Model.AvailableTaskTypes)
                        {
                            <option value="@t" selected="@(t == Model.TaskType)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="taskSchedule">Schedule</label>
                    <select class="form-select" id="taskSchedule" aria-label="Task schedule">
                        @foreach (var s in Model.AvailableSchedules)
                        {
                            <option value="@s" selected="@(s == Model.Schedule)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Enabled</label>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="taskEnabled" checked="@Model.IsEnabled" aria-label="Task enabled" />
                        <label class="form-check-label" for="taskEnabled">Active</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label" for="taskCommand">Command / Query</label>
                <textarea class="form-control font-monospace" id="taskCommand" rows="8" aria-label="Task command or query">@Model.CommandText</textarea>
            </div>
        </form>
    </div>
</section>
