@model WCMS.WebSystem.ViewComponents.QueryAnalyzerViewModel

<section class="card shadow-sm admin-panel" id="pnlQueryAnalyzer" aria-label="Query Analyzer">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-terminal" aria-hidden="true"></i> Query Analyzer</h5>
        <div role="toolbar" aria-label="Query actions">
            <button type="button" class="btn btn-sm btn-primary" id="btnExecuteQuery" aria-label="Execute query"><i class="bi bi-play" aria-hidden="true"></i> Execute</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnClearQuery" aria-label="Clear query"><i class="bi bi-x-lg" aria-hidden="true"></i> Clear</button>
        </div>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        <div class="mb-3">
            <label class="form-label" for="queryText">SQL Query</label>
            <textarea class="form-control font-monospace" id="queryText" rows="8" placeholder="Enter SQL query..." aria-label="SQL query input">@Model.QueryText</textarea>
        </div>
        @if (Model.HasResults)
        {
            <div class="d-flex justify-content-between align-items-center mb-2" id="queryStatusBar" role="status" aria-label="Query results summary">
                <small class="text-muted">
                    <i class="bi bi-check-circle text-success" aria-hidden="true"></i>
                    Rows affected: <strong>@Model.RowsAffected</strong>
                    @if (!string.IsNullOrEmpty(Model.ExecutionTime))
                    {
                        <span class="ms-2">| Execution time: <strong>@Model.ExecutionTime</strong></span>
                    }
                </small>
            </div>
            <div class="table-responsive" style="max-height:400px; overflow-y:auto;" id="queryResultContainer">
                <table class="table table-bordered table-sm table-striped mb-0" id="gvQueryResults" aria-label="Query results">
                    <thead class="table-dark">
                        <tr>
                            @foreach (var col in Model.ResultColumns)
                            {
                                <th scope="col">@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.ResultRows)
                        {
                            <tr>
                                @foreach (var cell in row)
                                {
                                    <td>@cell</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (Model.QueryText != null)
        {
            <p class="text-muted"><i class="bi bi-info-circle" aria-hidden="true"></i> No results to display.</p>
        }
    </div>
</section>
