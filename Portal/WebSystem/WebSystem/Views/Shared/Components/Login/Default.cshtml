@model WCMS.WebSystem.ViewComponents.LoginViewModel
<section class="system-login" aria-label="Authentication">
@if (!string.IsNullOrEmpty(Model.InfoMessage))
{
    <div class="alert alert-info alert-dismissible fade show" role="status">
        <i class="bi bi-info-circle-fill" aria-hidden="true"></i>
        @Model.InfoMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (Model.View == "LoggedOut")
{
    <script>window.location.href = '@Model.RedirectUrl';</script>
}
else if (Model.View == "ForgotPassword")
{
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7 col-sm-9">
                <form method="post" asp-action="ForgotPassword" asp-controller="Account"
                      aria-label="Forgot password form" novalidate>
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-key" aria-hidden="true"></i> Forgot Your Password?</h5>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">Enter your Username or Email to receive your password.</p>
                            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                            {
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                                    @Model.ErrorMessage
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }
                            <div class="mb-3">
                                <label class="form-label" for="txtRetrieveUserName">Username or Email</label>
                                <div class="input-group">
                                    <span class="input-group-text" aria-hidden="true"><i class="bi bi-person"></i></span>
                                    <input type="text" id="txtRetrieveUserName" name="userNameOrEmail"
                                           class="form-control" required aria-required="true"
                                           autocomplete="username" placeholder="Enter your username or email"
                                           aria-describedby="retrieveHelp" />
                                </div>
                                <div id="retrieveHelp" class="form-text">We will send password recovery instructions.</div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <button type="submit" class="btn btn-primary" aria-label="Submit password recovery">
                                    <i class="bi bi-send" aria-hidden="true"></i> Submit
                                </button>
                                @if (!string.IsNullOrEmpty(Model.LoginUrl))
                                {
                                    <a href="@Model.LoginUrl" class="btn btn-outline-secondary" title="Click here to login">
                                        <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Login
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
else if (Model.View == "OtpVerification")
{
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7 col-sm-9">
                <form method="post" asp-action="VerifyOtp" asp-controller="Account"
                      aria-label="OTP verification form" novalidate>
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-shield-lock" aria-hidden="true"></i> Verify Your Identity</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label" for="txtOtpCode">One-time PIN</label>
                                <div class="input-group">
                                    <span class="input-group-text" aria-hidden="true"><i class="bi bi-lock"></i></span>
                                    <input type="text" id="txtOtpCode" name="otpCode" class="form-control"
                                           required aria-required="true" inputmode="numeric" pattern="[0-9]*"
                                           autocomplete="one-time-code" placeholder="Enter your OTP"
                                           aria-describedby="otpHelp" maxlength="8" />
                                </div>
                                <div id="otpHelp" class="form-text">Enter the code sent to your registered contact.</div>
                            </div>
                            <div class="mb-3">
                                <button type="submit" name="action" value="resend" class="btn btn-link p-0"
                                        aria-label="Request a new OTP PIN">
                                    <i class="bi bi-arrow-repeat" aria-hidden="true"></i> Request New PIN
                                </button>
                            </div>
                            <div class="d-flex gap-2 mb-3">
                                <button type="submit" class="btn btn-primary" aria-label="Submit OTP">
                                    <i class="bi bi-check-circle" aria-hidden="true"></i> Submit
                                </button>
                                <button type="submit" name="action" value="cancel" class="btn btn-outline-secondary"
                                        aria-label="Cancel verification">Cancel</button>
                            </div>
                            <div class="alert alert-info d-flex align-items-start" role="status">
                                <i class="bi bi-info-circle-fill me-2 mt-1" aria-hidden="true"></i>
                                <div>Your OTP PIN has been sent to your registered contact. It will expire shortly.</div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
else if (Model.IsLoggedIn)
{
    <div class="login-status d-inline-flex align-items-center gap-2 p-2 rounded bg-light" role="status" aria-label="Login status">
        <i class="bi bi-person-circle" aria-hidden="true"></i>
        <span>Welcome, <strong>@Model.UserDisplayName</strong></span>
        <a href="/logout" class="btn btn-sm btn-outline-danger" aria-label="Sign out">
            <i class="bi bi-box-arrow-right" aria-hidden="true"></i> Sign Out
        </a>
    </div>
}
else
{
    @* GeoIP location tracking - populated by ResolveGeoIp() from the original Login.ascx *@
    <input type="hidden" id="hLocation" value="" />
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7 col-sm-9">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div id="lblError" class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                        @Model.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.PreLoginNote))
                {
                    <div class="mb-3">@Html.Raw(Model.PreLoginNote)</div>
                }
                <form method="post" asp-action="Login" asp-controller="Account"
                      class="needs-validation" aria-label="Login form" novalidate>
                    @if (!string.IsNullOrWhiteSpace(Model.RequestUrl))
                    {
                        <input type="hidden" name="RequestUrl" value="@Model.RequestUrl" />
                    }
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-box-arrow-in-right" aria-hidden="true"></i> Sign In</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label" for="txtUserName">Username</label>
                                <div class="input-group">
                                    <span class="input-group-text" aria-hidden="true"><i class="bi bi-person"></i></span>
                                    <input type="text" id="txtUserName" name="userName" class="form-control"
                                           required aria-required="true" autocomplete="username"
                                           placeholder="Enter your username" />
                                </div>
                                <div class="invalid-feedback">Please enter your username.</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="txtPassword">Password</label>
                                <div class="input-group">
                                    <span class="input-group-text" aria-hidden="true"><i class="bi bi-lock"></i></span>
                                    <input type="password" id="txtPassword" name="password" class="form-control"
                                           required aria-required="true" autocomplete="current-password"
                                           placeholder="Enter your password" />
                                </div>
                                <div class="invalid-feedback">Please enter your password.</div>
                            </div>
                            @if (Model.EnableOtp)
                            {
                                <fieldset class="mb-3" role="radiogroup" aria-label="OTP delivery method">
                                    <legend class="form-label fs-6">Send OTP Via</legend>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="otpType" id="otpEmail" value="0" checked />
                                        <label class="form-check-label" for="otpEmail">
                                            <i class="bi bi-envelope" aria-hidden="true"></i> E-mail
                                        </label>
                                    </div>
                                    @if (Model.EnableSms)
                                    {
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="otpType" id="otpSms" value="1" />
                                            <label class="form-check-label" for="otpSms">
                                                <i class="bi bi-phone" aria-hidden="true"></i> SMS
                                            </label>
                                        </div>
                                    }
                                </fieldset>
                            }
                            @if (Model.EnableRememberMe)
                            {
                                <div class="form-check mb-3">
                                    <input type="checkbox" class="form-check-input" id="chkRememberMe" name="rememberMe" />
                                    <label class="form-check-label" for="chkRememberMe">
                                        @(Model.RememberMeText ?? "Keep me logged in")
                                    </label>
                                </div>
                            }
                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-primary"
                                        data-loading-text="Logging in..." aria-label="Login">
                                    <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i> Login
                                </button>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.ForgotPasswordUrl))
                            {
                                <div class="text-center mb-2">
                                    <a href="@Model.ForgotPasswordUrl" class="text-decoration-none"
                                       title="Click here to recover your password">
                                        <i class="bi bi-question-circle" aria-hidden="true"></i> Forgot your password?
                                    </a>
                                </div>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(Model.SignUpUrl))
                        {
                            <div class="card-footer text-center bg-light">
                                <span>Don't have a login ID?</span>
                                <a href="@Model.SignUpUrl" class="fw-bold text-decoration-none"
                                   title="Click here to Register">Register Now</a>
                            </div>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var txtUserName = document.getElementById('txtUserName');
            if (txtUserName) { txtUserName.focus(); }

            // Bootstrap 5 client-side validation
            var form = document.querySelector('.system-login .needs-validation');
            if (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                });
            }
        });
    </script>
}
</section>
