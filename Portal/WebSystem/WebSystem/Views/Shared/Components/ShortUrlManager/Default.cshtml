@model WCMS.WebSystem.ViewComponents.ShortUrlManagerViewModel

<section class="card shadow-sm admin-panel" aria-label="Short URL Manager">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-link-45deg" aria-hidden="true"></i> Short URLs</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnAddShortUrl" aria-label="Add new short URL"><i class="bi bi-plus-lg" aria-hidden="true"></i> New Short URL</button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Search URLs..." id="shortUrlSearch" value="@Model.SearchTerm" aria-label="Search short URLs" />
                    <button class="btn btn-outline-secondary" type="button" id="btnSearchUrls" aria-label="Search"><i class="bi bi-search" aria-hidden="true"></i></button>
                </div>
            </div>
            <div class="col-md-6 text-end text-muted">
                @Model.TotalCount URL(s) found
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm" aria-label="Short URLs list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Short Code</th>
                        <th scope="col">Target URL</th>
                        <th scope="col">Hits</th>
                        <th scope="col">Active</th>
                        <th scope="col">Created</th>
                        <th scope="col">Expires</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Urls.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted">No short URLs found.</td></tr>
                    }
                    @foreach (var url in Model.Urls)
                    {
                        <tr>
                            <td><code>@url.ShortCode</code></td>
                            <td class="text-truncate" style="max-width:300px;">@url.TargetUrl</td>
                            <td><span class="badge bg-info">@url.HitCount</span></td>
                            <td>
                                @if (url.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@url.CreatedDate.ToString("d")</td>
                            <td>@url.ExpirationDate?.ToString("d")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-url" data-url-id="@url.Id" aria-label="Edit @url.ShortCode"><i class="bi bi-pencil" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-url" data-url-id="@url.Id" aria-label="Delete @url.ShortCode"><i class="bi bi-trash" aria-hidden="true"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Short URL pagination">
                <ul class="pagination pagination-sm justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")" @(i == Model.CurrentPage ? "aria-current=\"page\"" : "")>
                            <a class="page-link" href="javascript:void(0)" data-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</section>
