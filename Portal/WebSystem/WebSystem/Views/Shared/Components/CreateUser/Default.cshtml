@model WCMS.WebSystem.ViewComponents.CreateUserViewModel

<section class="card shadow-sm admin-panel" aria-label="Create User">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-person-plus" aria-hidden="true"></i> Create User</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success" role="status">@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        <form method="post" id="createUserForm" aria-label="Create user form">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="createUserName">Username <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" name="userName" id="createUserName" value="@Model.UserName" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="createEmail">Email <span class="text-danger">*</span></label>
                    <input type="email" class="form-control" name="email" id="createEmail" value="@Model.Email" required />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="createFirstName">First Name</label>
                    <input type="text" class="form-control" name="firstName" id="createFirstName" value="@Model.FirstName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="createLastName">Last Name</label>
                    <input type="text" class="form-control" name="lastName" id="createLastName" value="@Model.LastName" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="createPhone">Phone</label>
                    <input type="tel" class="form-control" name="phone" id="createPhone" value="@Model.Phone" />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="createGroupId">Group</label>
                    <select class="form-select" name="groupId" id="createGroupId">
                        <option value="0">-- None --</option>
                        @foreach (var g in Model.AvailableGroups)
                        {
                            <option value="@g.Id" selected="@(g.Id == Model.SelectedGroupId)">@g.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="createPassword">Password <span class="text-danger">*</span></label>
                    <input type="password" class="form-control" name="password" id="createPassword" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="createConfirmPassword">Confirm Password <span class="text-danger">*</span></label>
                    <input type="password" class="form-control" name="confirmPassword" id="createConfirmPassword" required />
                </div>
            </div>
            @if (Model.AvailableRoles.Count > 0)
            {
                <fieldset class="mb-3">
                    <legend class="form-label fs-6">Roles</legend>
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="roleIds" value="@role.Id" id="role_@role.Id" />
                            <label class="form-check-label" for="role_@role.Id">@role.Name</label>
                        </div>
                    }
                </fieldset>
            }
            <button type="submit" class="btn btn-success"><i class="bi bi-person-plus" aria-hidden="true"></i> Create User</button>
        </form>
    </div>
</section>
