@model WCMS.WebSystem.ViewComponents.WebPageElementsViewModel

<section class="card shadow-sm admin-panel" id="pnlPageItemEditor" aria-label="Page Elements">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bi bi-puzzle" aria-hidden="true"></i> Page Elements
            @if (!string.IsNullOrEmpty(Model.PageName))
            {
                <small class="text-muted fw-normal">— @Model.PageName</small>
            }
        </h5>
        <button type="button" class="btn btn-sm btn-success" id="btnAddElement" data-page-id="@Model.PageId" aria-label="Add new element"><i class="bi bi-plus-lg" aria-hidden="true"></i> Add Element</button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@Model.ErrorMessage</div>
        }
        <input type="hidden" id="pageElementsPageId" value="@Model.PageId" />
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" id="gvPageElements" aria-label="Page elements list">
                <thead class="table-light">
                    <tr>
                        <th scope="col" style="width:30px;"><span class="visually-hidden">Drag handle</span></th>
                        <th scope="col">Name</th>
                        <th scope="col">Type</th>
                        <th scope="col">Panel</th>
                        <th scope="col">Order</th>
                        <th scope="col">Active</th>
                        <th scope="col">Modified</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Elements.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted">No elements defined.</td></tr>
                    }
                    @foreach (var e in Model.Elements)
                    {
                        <tr data-element-id="@e.Id">
                            <td><i class="bi bi-grip-vertical" style="cursor:move;" aria-hidden="true"></i><span class="visually-hidden">Drag to reorder</span></td>
                            <td><i class="bi bi-puzzle" aria-hidden="true"></i> @e.Name</td>
                            <td><span class="badge bg-secondary">@e.ElementType</span></td>
                            <td>@e.PanelName</td>
                            <td>@e.SortOrder</td>
                            <td>
                                @if (e.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@e.ModifiedDate?.ToString("g")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-secondary btn-move-up" data-element-id="@e.Id" title="Move Up" aria-label="Move @e.Name up"><i class="bi bi-arrow-up" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-secondary btn-move-down" data-element-id="@e.Id" title="Move Down" aria-label="Move @e.Name down"><i class="bi bi-arrow-down" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-element" data-element-id="@e.Id" title="Edit" aria-label="Edit @e.Name"><i class="bi bi-pencil" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-element" data-element-id="@e.Id" title="Delete" aria-label="Delete @e.Name"><i class="bi bi-trash" aria-hidden="true"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
