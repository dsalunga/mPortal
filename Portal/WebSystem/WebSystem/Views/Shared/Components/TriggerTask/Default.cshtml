@model WCMS.WebSystem.ViewComponents.TriggerTaskViewModel

<section class="card admin-panel system-trigger-task" aria-label="Background Tasks">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-gear-wide-connected" aria-hidden="true"></i> Background Tasks</h5>
    </div>
    <div class="card-body">
        @if (!Model.IsAdministrator)
        {
            <div class="alert alert-warning mb-0" role="alert">
                <i class="bi bi-shield-exclamation me-1" aria-hidden="true"></i>
                You do not have permission to manage tasks.
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert alert-info alert-dismissible fade show" role="status">
                    <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
                    @Model.StatusMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Dismiss status message"></button>
                </div>
            }

            @if (!Model.Jobs.Any())
            {
                <div class="text-center text-muted py-4" role="status">
                    <i class="bi bi-clipboard-x fs-1 d-block mb-2" aria-hidden="true"></i>
                    <p class="mb-0">No background tasks are configured.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm mb-0" aria-label="Background tasks list">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Name</th>
                                <th scope="col">Description</th>
                                <th scope="col">Status</th>
                                <th scope="col">Enabled</th>
                                <th scope="col"><span class="visually-hidden">Actions</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in Model.Jobs)
                            {
                                <tr>
                                    <td>
                                        <i class="bi bi-gear me-1" aria-hidden="true"></i>
                                        @job.Name
                                    </td>
                                    <td>@job.Description</td>
                                    <td>
                                        @switch (job.ExecutionStatus)
                                        {
                                            case WCMS.Framework.ExecutionStatus.Pending:
                                                <span class="badge bg-secondary">Pending</span>
                                                break;
                                            case WCMS.Framework.ExecutionStatus.Running:
                                                <span class="badge bg-primary">
                                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                                    Running
                                                </span>
                                                break;
                                            case WCMS.Framework.ExecutionStatus.Completed:
                                                <span class="badge bg-success">Completed</span>
                                                break;
                                            case WCMS.Framework.ExecutionStatus.Failed:
                                                <span class="badge bg-danger">Failed</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (job.IsEnabled)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle" aria-hidden="true"></i> Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-x-circle" aria-hidden="true"></i> No</span>
                                        }
                                    </td>
                                    <td>
                                        <form method="post" asp-action="Trigger" asp-controller="Task" class="d-inline">
                                            <input type="hidden" name="jobId" value="@job.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary"
                                                    aria-label="Trigger task @job.Name"
                                                    title="Trigger @job.Name">
                                                <i class="bi bi-play-fill" aria-hidden="true"></i> Trigger
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>
</section>
