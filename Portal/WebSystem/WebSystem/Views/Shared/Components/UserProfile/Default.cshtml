@model WCMS.WebSystem.ViewComponents.UserProfileViewModel

<section class="card shadow-sm admin-panel" aria-label="User Profile">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-person-circle" aria-hidden="true"></i> User Profile</h5>
        <button type="button" class="btn btn-sm btn-primary" id="btnSaveProfile" aria-label="Save profile"><i class="bi bi-save" aria-hidden="true"></i> Save</button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success" role="status">@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        <form method="post" id="userProfileForm" aria-label="User profile form">
            <input type="hidden" name="userId" value="@Model.UserId" />
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="profileUserName">Username</label>
                    <input type="text" class="form-control" id="profileUserName" value="@Model.UserName" readonly aria-readonly="true" />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="profileEmail">Email</label>
                    <input type="email" class="form-control" id="profileEmail" name="email" value="@Model.Email" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="profileFirstName">First Name</label>
                    <input type="text" class="form-control" id="profileFirstName" name="firstName" value="@Model.FirstName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="profileLastName">Last Name</label>
                    <input type="text" class="form-control" id="profileLastName" name="lastName" value="@Model.LastName" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="profilePhone">Phone</label>
                    <input type="tel" class="form-control" id="profilePhone" name="phone" value="@Model.Phone" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" id="statusLabel">Status</label>
                    <div aria-labelledby="statusLabel">
                        @if (Model.IsLockedOut)
                        {
                            <span class="badge bg-danger">Locked Out</span>
                        }
                        else if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label" id="lastLoginLabel">Last Login</label>
                    <div class="text-muted" aria-labelledby="lastLoginLabel">@(Model.LastLoginDate?.ToString("g") ?? "Never")</div>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" id="groupsLabel">Groups</label>
                    <div aria-labelledby="groupsLabel">
                        @if (Model.Groups.Count == 0)
                        {
                            <span class="text-muted">None</span>
                        }
                        @foreach (var g in Model.Groups)
                        {
                            <span class="badge bg-info me-1">@g</span>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label" id="rolesLabel">Roles</label>
                    <div aria-labelledby="rolesLabel">
                        @if (Model.Roles.Count == 0)
                        {
                            <span class="text-muted">None</span>
                        }
                        @foreach (var r in Model.Roles)
                        {
                            <span class="badge bg-primary me-1">@r</span>
                        }
                    </div>
                </div>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="userActive" name="isActive" checked="@Model.IsActive" />
                <label class="form-check-label" for="userActive">Active</label>
            </div>
        </form>
    </div>
</section>
