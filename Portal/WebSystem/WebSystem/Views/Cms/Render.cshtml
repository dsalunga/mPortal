@using Microsoft.AspNetCore.Mvc.ViewFeatures
@using WCMS.Framework
@model object
@{
    Layout = null;
    var renderModel = Model as WCMS.WebSystem.Controllers.CmsPageRenderModel ?? new WCMS.WebSystem.Controllers.CmsPageRenderModel();
    var pageTitle = string.IsNullOrWhiteSpace(renderModel.Page?.Name) ? "mPortal" : renderModel.Page.Name;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="none,noarchive" />
    <title>@pageTitle</title>
    @if (!string.IsNullOrWhiteSpace(renderModel.ResourcesHtml))
    {
        @Html.Raw(renderModel.ResourcesHtml)
    }
</head>
<body>
    <main class="wcms-runtime-page" data-page-id="@renderModel.Page?.Id">
        @if (renderModel.IsStaticPage)
        {
            if (!string.IsNullOrWhiteSpace(renderModel.TemplatePath))
            {
                var staticViewData = new ViewDataDictionary(ViewData)
                {
                    ["Page"] = renderModel.Page,
                    ["Template"] = renderModel.Template,
                    ["Panels"] = renderModel.Panels,
                    ["Elements"] = renderModel.Elements
                };
                @await Html.PartialAsync(renderModel.TemplatePath, model: null, viewData: staticViewData)
            }
        }
        else if (renderModel.Panels != null && renderModel.Panels.Count > 0)
        {
            foreach (var panel in renderModel.Panels)
            {
                var panelViewData = new ViewDataDictionary(ViewData)
                {
                    ["Page"] = renderModel.Page,
                    ["Template"] = renderModel.Template,
                    ["Panels"] = renderModel.Panels,
                    ["Elements"] = renderModel.Elements,
                    ["PanelName"] = panel.PanelName
                };
                <section class="wcms-panel" data-panel-id="@panel.Id" data-panel-name="@panel.PanelName">
                    @await Html.PartialAsync("~/_loader.cshtml", model: null, viewData: panelViewData)
                </section>
            }
        }
        else if (!string.IsNullOrWhiteSpace(renderModel.TemplatePath))
        {
            var fallbackViewData = new ViewDataDictionary(ViewData)
            {
                ["Page"] = renderModel.Page,
                ["Template"] = renderModel.Template,
                ["Panels"] = renderModel.Panels,
                ["Elements"] = renderModel.Elements
            };
            @await Html.PartialAsync(renderModel.TemplatePath, model: null, viewData: fallbackViewData)
        }
        else
        {
            <section class="alert alert-warning" role="status">
                Page template is not available.
            </section>
        }
    </main>
</body>
</html>
