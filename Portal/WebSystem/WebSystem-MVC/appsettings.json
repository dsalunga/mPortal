{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ConnectionString": "Data Source=(local);Initial Catalog=mPortal;Integrated Security=True;Connect Timeout=15;Encrypt=False;TrustServerCertificate=True",
    "BibleConnection": "Data Source=(local);Initial Catalog=BibleReader;Integrated Security=True;Connect Timeout=15;Encrypt=False;TrustServerCertificate=True",
    "EventCalendar": "Data Source=(local);Initial Catalog=mPortal;Integrated Security=True;Encrypt=False;TrustServerCertificate=True"
  },
  "WCMS": {
    "Environment": "DEV",
    "DatabaseProvider": "SqlServer",
    "PageExt": "",
    "AllowCache": false,
    "AssetBasePath": "/Content/Assets/",
    "AgentEnabled": true,
    "AgentAutoStart": false,
    "UserPhotoPath": "/Content/Assets/User-Photos",
    "FileCachePath": "Content/Assets/Cache/",
    "MinDiskFreeMB": 10240
  },
  "WebObject": {
    "DataProvider": "WCMS.Framework.Core.SqlProvider.WebObjectProvider, WCMS.Framework.Core.SqlProvider",
    "SqlDbName": "mPortal"
  },
  "FCKeditor": {
    "BasePath": "/Content/Plugins/fckeditor/",
    "UserFilesPath": "/Content/Assets/Uploads/"
  },
  "LogPath": "Content/Admin/Data/Logs/"
}
