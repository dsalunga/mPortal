@model WCMS.WebSystem.ViewComponents.WebPartConfigViewModel

<section class="card admin-panel" aria-label="Web Part Configuration">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-gear-wide-connected" aria-hidden="true"></i> Web Part Configuration</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success" role="status">@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        <form id="webPartConfigForm" data-webpart-id="@Model.WebPartId" aria-label="Web part settings">
            <div class="mb-3">
                <label for="wpName" class="form-label">Name</label>
                <input type="text" class="form-control" id="wpName" name="Name" value="@Model.Name" aria-label="Web part name" />
            </div>
            <div class="mb-3">
                <label for="wpDescription" class="form-label">Description</label>
                <textarea class="form-control" id="wpDescription" name="Description" rows="3" aria-label="Web part description">@Model.Description</textarea>
            </div>
            <div class="mb-3">
                <label for="wpCategory" class="form-label">Category</label>
                <input type="text" class="form-control" id="wpCategory" name="Category" value="@Model.Category" aria-label="Web part category" />
            </div>
            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="wpIsActive" name="IsActive" @(Model.IsActive ? "checked" : "") />
                <label class="form-check-label" for="wpIsActive">Active</label>
            </div>

            @if (Model.Properties.Count > 0)
            {
                <h6 class="mt-4 mb-3"><i class="bi bi-list-ul" aria-hidden="true"></i> Properties</h6>
                <div class="table-responsive">
                    <table class="table table-striped table-sm mb-0" aria-label="Web part properties">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Key</th>
                                <th scope="col">Value</th>
                                <th scope="col">Type</th>
                                <th scope="col">Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prop in Model.Properties)
                            {
                                <tr>
                                    <td><code>@prop.Key</code></td>
                                    <td><input type="text" class="form-control form-control-sm" name="prop_@prop.Key" value="@prop.Value" /></td>
                                    <td><span class="badge bg-secondary">@prop.DataType</span></td>
                                    <td><small class="text-muted">@prop.Description</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="mt-3">
                <button type="submit" class="btn btn-primary" id="btnSaveConfig" aria-label="Save configuration"><i class="bi bi-save" aria-hidden="true"></i> Save</button>
            </div>
        </form>
    </div>
</section>
