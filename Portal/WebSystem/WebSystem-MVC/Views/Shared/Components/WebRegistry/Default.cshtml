@model WCMS.WebSystem.ViewComponents.WebRegistryViewModel

@{
    void RenderRegistryTree(List<WCMS.WebSystem.ViewComponents.RegistryNode> nodes, string selectedPath)
    {
        if (nodes == null || nodes.Count == 0) return;
        <ul class="list-unstyled ms-3">
            @foreach (var node in nodes)
            {
                var isSelected = node.Path == selectedPath;
                <li class="mb-1">
                    <a href="javascript:void(0)" class="reg-node text-decoration-none @(isSelected ? "fw-bold text-primary" : "")" data-node-id="@node.Id" data-path="@node.Path">
                        <i class="bi @(isSelected ? "bi-folder-fill" : "bi-folder")"></i> @node.Name
                    </a>
                    @if (node.Children != null && node.Children.Count > 0)
                    {
                        RenderRegistryTree(node.Children, selectedPath);
                    }
                </li>
            }
        </ul>
    }
}

<div class="card admin-panel" id="pnlRegistryEditor">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-journal-code"></i> Registry</h5>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3">@Model.ErrorMessage</div>
        }
        <div class="row g-0">
            <div class="col-md-4 border-end">
                <div class="p-3">
                    <h6>Registry Tree</h6>
                    <div id="registryTreeContainer">
                        @if (Model.Nodes.Count == 0)
                        {
                            <p class="text-muted">No registry keys.</p>
                        }
                        else
                        {
                            RenderRegistryTree(Model.Nodes, Model.SelectedPath);
                        }
                    </div>
                    <div class="mt-2">
                        <button type="button" class="btn btn-sm btn-outline-success" id="btnAddKey"><i class="bi bi-plus-lg"></i> New Key</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" id="btnDeleteKey"><i class="bi bi-trash"></i> Delete Key</button>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0">
                            Values
                            @if (!string.IsNullOrEmpty(Model.SelectedPath))
                            {
                                <small class="text-muted">— @Model.SelectedPath</small>
                            }
                        </h6>
                        <button type="button" class="btn btn-sm btn-outline-success" id="btnAddValue"><i class="bi bi-plus-lg"></i> New Value</button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm" id="registryValueGrid">
                            <thead class="table-light">
                                <tr>
                                    <th>Key</th>
                                    <th>Value</th>
                                    <th>Type</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Entries.Count == 0)
                                {
                                    <tr><td colspan="4" class="text-center text-muted">No values in this key.</td></tr>
                                }
                                @foreach (var entry in Model.Entries)
                                {
                                    <tr>
                                        <td><code>@entry.Key</code></td>
                                        <td><input type="text" class="form-control form-control-sm" value="@entry.Value" data-entry-id="@entry.Id" /></td>
                                        <td><span class="badge bg-secondary">@entry.DataType</span></td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-outline-primary btn-save-value" data-entry-id="@entry.Id"><i class="bi bi-save"></i></button>
                                            <button type="button" class="btn btn-sm btn-outline-danger btn-delete-value" data-entry-id="@entry.Id"><i class="bi bi-trash"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
