@model WCMS.WebSystem.ViewComponents.WebRegistryViewModel

<div class="card admin-panel">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-journal-code"></i> Registry</h5>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3">@Model.ErrorMessage</div>
        }
        <div class="row g-0">
            <div class="col-md-4 border-end">
                <div class="p-3">
                    <h6>Registry Tree</h6>
                    <div id="registryTreeContainer">
                        @if (Model.Nodes.Count == 0)
                        {
                            <p class="text-muted">No registry keys.</p>
                        }
                        else
                        {
                            <ul class="list-unstyled" id="registryTree">
                                @foreach (var node in Model.Nodes)
                                {
                                    <li class="mb-1">
                                        <a href="javascript:void(0)" class="reg-node" data-node-id="@node.Id" data-path="@node.Path">
                                            <i class="bi bi-folder"></i> @node.Name
                                        </a>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                    <div class="mt-2">
                        <button type="button" class="btn btn-sm btn-outline-success" id="btnAddKey"><i class="bi bi-plus-lg"></i> New Key</button>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0">
                            Values
                            @if (!string.IsNullOrEmpty(Model.SelectedPath))
                            {
                                <small class="text-muted">— @Model.SelectedPath</small>
                            }
                        </h6>
                        <button type="button" class="btn btn-sm btn-outline-success" id="btnAddValue"><i class="bi bi-plus-lg"></i> New Value</button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Key</th>
                                    <th>Value</th>
                                    <th>Type</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Entries.Count == 0)
                                {
                                    <tr><td colspan="4" class="text-center text-muted">No values in this key.</td></tr>
                                }
                                @foreach (var entry in Model.Entries)
                                {
                                    <tr>
                                        <td>@entry.Key</td>
                                        <td><code>@entry.Value</code></td>
                                        <td><span class="badge bg-secondary">@entry.DataType</span></td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit-value" data-entry-id="@entry.Id"><i class="bi bi-pencil"></i></button>
                                            <button type="button" class="btn btn-sm btn-outline-danger btn-delete-value" data-entry-id="@entry.Id"><i class="bi bi-trash"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
