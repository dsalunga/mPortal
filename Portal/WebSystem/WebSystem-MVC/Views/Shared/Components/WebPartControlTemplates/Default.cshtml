@model WCMS.WebSystem.ViewComponents.WebPartControlTemplatesViewModel

<section class="card shadow-sm admin-panel" aria-label="Control Templates">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-file-earmark-code" aria-hidden="true"></i> Control Templates</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnAddTemplate" aria-label="Add template"><i class="bi bi-plus-lg" aria-hidden="true"></i> New Template</button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@Model.ErrorMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" aria-label="Control templates list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Type</th>
                        <th scope="col">Default</th>
                        <th scope="col">Modified</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Templates.Count == 0)
                    {
                        <tr><td colspan="5" class="text-center text-muted">No control templates defined.</td></tr>
                    }
                    @foreach (var tmpl in Model.Templates)
                    {
                        <tr class="@(tmpl.Id == Model.SelectedTemplateId ? "table-primary" : "")">
                            <td>
                                <i class="bi bi-file-earmark-code" aria-hidden="true"></i> @tmpl.Name
                                @if (!string.IsNullOrEmpty(tmpl.Description))
                                {
                                    <br /><small class="text-muted">@tmpl.Description</small>
                                }
                            </td>
                            <td><span class="badge bg-secondary">@tmpl.ControlType</span></td>
                            <td>
                                @if (tmpl.IsDefault)
                                {
                                    <i class="bi bi-check-circle text-success" aria-hidden="true"></i>
                                }
                            </td>
                            <td>@(tmpl.ModifiedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-template" data-template-id="@tmpl.Id" aria-label="Edit @tmpl.Name"><i class="bi bi-pencil" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-template" data-template-id="@tmpl.Id" aria-label="Delete @tmpl.Name"><i class="bi bi-trash" aria-hidden="true"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
