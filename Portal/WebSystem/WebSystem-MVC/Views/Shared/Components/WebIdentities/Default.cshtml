@model WCMS.WebSystem.ViewComponents.WebIdentitiesViewModel

<section class="card admin-panel" aria-label="Site Identities">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-globe" aria-hidden="true"></i> Site Identities</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnAddIdentity" data-site-id="@Model.SiteId" aria-label="Add identity"><i class="bi bi-plus-lg" aria-hidden="true"></i> Add Identity</button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@Model.ErrorMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" aria-label="Site identities list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Domain</th>
                        <th scope="col">Protocol</th>
                        <th scope="col">SSL</th>
                        <th scope="col">Default</th>
                        <th scope="col">Active</th>
                        <th scope="col">Modified</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Identities.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted">No identities defined.</td></tr>
                    }
                    @foreach (var id in Model.Identities)
                    {
                        <tr>
                            <td><i class="bi bi-globe" aria-hidden="true"></i> @id.DomainName</td>
                            <td>@id.Protocol</td>
                            <td>
                                @if (id.SslEnabled)
                                {
                                    <span class="badge bg-success">SSL</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">No SSL</span>
                                }
                            </td>
                            <td>@(id.IsDefault ? "✓" : "")</td>
                            <td>
                                @if (id.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@id.ModifiedDate?.ToString("g")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-identity" data-identity-id="@id.Id" aria-label="Edit @id.DomainName"><i class="bi bi-pencil" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-identity" data-identity-id="@id.Id" aria-label="Delete @id.DomainName"><i class="bi bi-trash" aria-hidden="true"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
