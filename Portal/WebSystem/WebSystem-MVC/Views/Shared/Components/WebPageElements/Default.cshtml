@model WCMS.WebSystem.ViewComponents.WebPageElementsViewModel

<div class="card admin-panel" id="pnlPageItemEditor">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bi bi-puzzle"></i> Page Elements
            @if (!string.IsNullOrEmpty(Model.PageName))
            {
                <small class="text-muted fw-normal">— @Model.PageName</small>
            }
        </h5>
        <button type="button" class="btn btn-sm btn-success" id="btnAddElement" data-page-id="@Model.PageId"><i class="bi bi-plus-lg"></i> Add Element</button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3">@Model.ErrorMessage</div>
        }
        <input type="hidden" id="pageElementsPageId" value="@Model.PageId" />
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" id="gvPageElements">
                <thead class="table-light">
                    <tr>
                        <th style="width:30px;"></th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Panel</th>
                        <th>Order</th>
                        <th>Active</th>
                        <th>Modified</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Elements.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted">No elements defined.</td></tr>
                    }
                    @foreach (var e in Model.Elements)
                    {
                        <tr data-element-id="@e.Id">
                            <td><i class="bi bi-grip-vertical" style="cursor:move;"></i></td>
                            <td><i class="bi bi-puzzle"></i> @e.Name</td>
                            <td><span class="badge bg-secondary">@e.ElementType</span></td>
                            <td>@e.PanelName</td>
                            <td>@e.SortOrder</td>
                            <td>
                                @if (e.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@e.ModifiedDate?.ToString("g")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-secondary btn-move-up" data-element-id="@e.Id" title="Move Up"><i class="bi bi-arrow-up"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-secondary btn-move-down" data-element-id="@e.Id" title="Move Down"><i class="bi bi-arrow-down"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-element" data-element-id="@e.Id" title="Edit"><i class="bi bi-pencil"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-element" data-element-id="@e.Id" title="Delete"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
