@model WCMS.WebSystem.ViewComponents.WebMasterPagesViewModel

<section class="card admin-panel" aria-label="Master Pages">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-file-earmark-code" aria-hidden="true"></i> Master Pages</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnNewMasterPage" aria-label="Add master page"><i class="bi bi-plus-lg" aria-hidden="true"></i> New Master Page</button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@Model.ErrorMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" aria-label="Master pages list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">File</th>
                        <th scope="col">Default</th>
                        <th scope="col">Active</th>
                        <th scope="col">Modified</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.MasterPages.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted">No master pages defined.</td></tr>
                    }
                    @foreach (var mp in Model.MasterPages)
                    {
                        <tr class="@(mp.Id == Model.SelectedMasterPageId ? "table-primary" : "")">
                            <td><i class="bi bi-file-earmark-code" aria-hidden="true"></i> @mp.Name</td>
                            <td>@mp.FileName</td>
                            <td>@(mp.IsDefault ? "✓" : "")</td>
                            <td>
                                @if (mp.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@mp.ModifiedDate?.ToString("g")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-masterpage" data-masterpage-id="@mp.Id" aria-label="Edit @mp.Name"><i class="bi bi-pencil" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-masterpage" data-masterpage-id="@mp.Id" aria-label="Delete @mp.Name"><i class="bi bi-trash" aria-hidden="true"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
