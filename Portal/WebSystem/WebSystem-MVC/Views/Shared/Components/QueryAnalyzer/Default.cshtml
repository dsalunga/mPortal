@model WCMS.WebSystem.ViewComponents.QueryAnalyzerViewModel

<div class="card admin-panel">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-terminal"></i> Query Analyzer</h5>
        <button type="button" class="btn btn-sm btn-primary" id="btnExecuteQuery"><i class="bi bi-play"></i> Execute</button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <div class="mb-3">
            <textarea class="form-control font-monospace" id="queryText" rows="6" placeholder="Enter SQL query...">@Model.QueryText</textarea>
        </div>
        @if (Model.HasResults)
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <small class="text-muted">
                    Rows affected: @Model.RowsAffected
                    @if (!string.IsNullOrEmpty(Model.ExecutionTime))
                    {
                        <span class="ms-2">| Time: @Model.ExecutionTime</span>
                    }
                </small>
            </div>
            <div class="table-responsive" style="max-height:400px; overflow-y:auto;">
                <table class="table table-bordered table-sm table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            @foreach (var col in Model.ResultColumns)
                            {
                                <th>@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.ResultRows)
                        {
                            <tr>
                                @foreach (var cell in row)
                                {
                                    <td>@cell</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (Model.QueryText != null)
        {
            <p class="text-muted">No results to display.</p>
        }
    </div>
</div>
