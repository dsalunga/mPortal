@model WCMS.WebSystem.ViewComponents.WebTemplatePanelsViewModel

<div class="card admin-panel">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-layout-three-columns"></i> Template Panels</h5>
        <div>
            <button type="button" class="btn btn-sm btn-primary" id="btnSaveTemplatePanels"><i class="bi bi-save"></i> Save</button>
            <button type="button" class="btn btn-sm btn-success" id="btnAddTemplatePanel"><i class="bi bi-plus-lg"></i> Add Panel</button>
        </div>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <input type="hidden" id="templateId" value="@Model.TemplateId" />
        @if (!string.IsNullOrEmpty(Model.TemplateName))
        {
            <p><strong>Template:</strong> @Model.TemplateName</p>
        }
        <div class="table-responsive">
            <table class="table table-bordered table-sm">
                <thead class="table-light">
                    <tr>
                        <th style="width: 30px;"></th>
                        <th>Name</th>
                        <th>Zone</th>
                        <th>Order</th>
                        <th>Required</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="templatePanelList">
                    @if (Model.Panels.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted">No panels defined for this template.</td></tr>
                    }
                    @foreach (var panel in Model.Panels)
                    {
                        <tr data-panel-id="@panel.Id">
                            <td><i class="bi bi-grip-vertical" style="cursor:move;"></i></td>
                            <td><input type="text" class="form-control form-control-sm" value="@panel.Name" /></td>
                            <td><input type="text" class="form-control form-control-sm" value="@panel.Zone" /></td>
                            <td><input type="number" class="form-control form-control-sm" value="@panel.SortOrder" style="width:70px;" /></td>
                            <td class="text-center"><input type="checkbox" class="form-check-input" checked="@panel.IsRequired" /></td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-remove-tpl-panel"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
