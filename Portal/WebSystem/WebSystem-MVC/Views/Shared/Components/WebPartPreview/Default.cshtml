@model WCMS.WebSystem.ViewComponents.WebPartPreviewViewModel

<section class="card admin-panel" aria-label="Web Part Preview">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bi bi-eye" aria-hidden="true"></i> Web Part Preview
            @if (!string.IsNullOrEmpty(Model.WebPartName))
            {
                <span class="text-muted fw-normal">— @Model.WebPartName</span>
            }
        </h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted">@Model.Description</p>
        }

        <div class="border rounded p-3 mb-3 bg-light" id="webPartPreviewArea">
            @if (Model.IsLoaded && !string.IsNullOrEmpty(Model.PreviewHtml))
            {
                @Html.Raw(Model.PreviewHtml)
            }
            else
            {
                <p class="text-muted text-center mb-0"><i class="bi bi-image" aria-hidden="true"></i> No preview available.</p>
            }
        </div>

        @if (Model.Properties.Count > 0)
        {
            <div class="mb-0">
                <a class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" href="#webPartProperties" role="button" aria-expanded="false" aria-controls="webPartProperties">
                    <i class="bi bi-list-ul" aria-hidden="true"></i> Properties (@Model.Properties.Count)
                </a>
                <div class="collapse mt-2" id="webPartProperties">
                    <div class="table-responsive">
                        <table class="table table-striped table-sm mb-0" aria-label="Web part properties">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">Key</th>
                                    <th scope="col">Value</th>
                                    <th scope="col">Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var prop in Model.Properties)
                                {
                                    <tr>
                                        <td><code>@prop.Key</code></td>
                                        <td>@prop.Value</td>
                                        <td><span class="badge bg-secondary">@prop.DataType</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
