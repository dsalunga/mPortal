@model WCMS.WebSystem.ViewComponents.WebSecurityTreeViewModel

@{
    void RenderSecurityNodes(List<WCMS.WebSystem.ViewComponents.SecurityTreeNode> nodes, string selectedId)
    {
        if (nodes == null || nodes.Count == 0) return;
        <ul class="list-unstyled ms-3">
            @foreach (var node in nodes)
            {
                <li class="mb-1">
                    <a href="@(node.Url ?? "javascript:void(0)")" class="sec-node text-decoration-none @(node.Id == selectedId ? "fw-bold text-primary" : "")" data-node-id="@node.Id" data-node-type="@node.NodeType">
                        <i class="bi @(node.Icon ?? "bi-folder")"></i> @node.Text
                    </a>
                    @if (node.Children != null && node.Children.Count > 0)
                    {
                        RenderSecurityNodes(node.Children, selectedId);
                    }
                </li>
            }
        </ul>
    }
}

<div class="card admin-panel" id="pnlSecurityTree">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-shield-shaded"></i> Security</h5>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3">@Model.ErrorMessage</div>
        }
        <div class="security-tree p-3" id="securityTreeContainer">
            @if (Model.Nodes.Count == 0)
            {
                <ul class="list-unstyled">
                    <li class="mb-1"><a href="javascript:void(0)" class="sec-link text-decoration-none" data-section="users"><i class="bi bi-people"></i> Users</a></li>
                    <li class="mb-1"><a href="javascript:void(0)" class="sec-link text-decoration-none" data-section="groups"><i class="bi bi-collection"></i> Groups</a></li>
                    <li class="mb-1"><a href="javascript:void(0)" class="sec-link text-decoration-none" data-section="roles"><i class="bi bi-shield-lock"></i> Roles</a></li>
                    <li class="mb-1"><a href="javascript:void(0)" class="sec-link text-decoration-none" data-section="permissions"><i class="bi bi-key"></i> Permissions</a></li>
                </ul>
            }
            else
            {
                RenderSecurityNodes(Model.Nodes, Model.SelectedNodeId);
            }
        </div>
    </div>
</div>
