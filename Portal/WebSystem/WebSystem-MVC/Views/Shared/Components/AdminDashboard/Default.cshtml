@model WCMS.WebSystem.ViewComponents.AdminDashboardViewModel

<section class="admin-dashboard" aria-label="Admin Dashboard">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <div class="row mb-4" role="region" aria-label="System statistics">
        <div class="col-md">
            <div class="card text-center">
                <div class="card-body">
                    <i class="bi bi-globe fs-2 text-primary"></i>
                    <h3 class="mt-2 mb-0">@Model.SiteCount</h3>
                    <small class="text-muted">Sites</small>
                </div>
            </div>
        </div>
        <div class="col-md">
            <div class="card text-center">
                <div class="card-body">
                    <i class="bi bi-file-earmark fs-2 text-success"></i>
                    <h3 class="mt-2 mb-0">@Model.PageCount</h3>
                    <small class="text-muted">Pages</small>
                </div>
            </div>
        </div>
        <div class="col-md">
            <div class="card text-center">
                <div class="card-body">
                    <i class="bi bi-people fs-2 text-info"></i>
                    <h3 class="mt-2 mb-0">@Model.UserCount</h3>
                    <small class="text-muted">Users</small>
                </div>
            </div>
        </div>
        <div class="col-md">
            <div class="card text-center">
                <div class="card-body">
                    <i class="bi bi-layout-text-window fs-2 text-warning"></i>
                    <h3 class="mt-2 mb-0">@Model.TemplateCount</h3>
                    <small class="text-muted">Templates</small>
                </div>
            </div>
        </div>
        <div class="col-md">
            <div class="card text-center">
                <div class="card-body">
                    <i class="bi bi-puzzle fs-2 text-danger"></i>
                    <h3 class="mt-2 mb-0">@Model.WebPartCount</h3>
                    <small class="text-muted">WebParts</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card admin-panel">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-activity"></i> Recent Activity</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-sm mb-0" aria-label="Recent activity log">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">Description</th>
                                    <th scope="col">User</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentActivity.Count == 0)
                                {
                                    <tr><td colspan="4" class="text-center text-muted">No recent activity.</td></tr>
                                }
                                @foreach (var item in Model.RecentActivity)
                                {
                                    <tr>
                                        <td>@item.Description</td>
                                        <td>@item.UserName</td>
                                        <td>@item.ActivityDate.ToString("g")</td>
                                        <td><span class="badge bg-secondary">@item.ActivityType</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card admin-panel">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-link-45deg"></i> Quick Links</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.QuickLinks.Count == 0)
                    {
                        <p class="text-muted p-3 mb-0">No quick links configured.</p>
                    }
                    <nav class="list-group list-group-flush" aria-label="Quick links">
                        @foreach (var link in Model.QuickLinks)
                        {
                            <a href="@link.Url" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>
                                    @if (!string.IsNullOrEmpty(link.IconClass))
                                    {
                                        <i class="bi @link.IconClass me-2"></i>
                                    }
                                    @link.Name
                                </span>
                                @if (link.BadgeCount > 0)
                                {
                                    <span class="badge bg-primary rounded-pill">@link.BadgeCount</span>
                                }
                            </a>
                        }
                    </nav>
                </div>
            </div>
        </div>
    </div>
</section>
