@model WCMS.WebSystem.ViewComponents.DataSyncDashboardViewModel

<div class="card admin-panel">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-arrow-repeat"></i> Data Sync</h5>
        <div>
            <button type="button" class="btn btn-sm btn-success" id="btnNewSyncJob"><i class="bi bi-plus-lg"></i> New Job</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnRefreshSync"><i class="bi bi-arrow-clockwise"></i></button>
        </div>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3">@Model.ErrorMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Source</th>
                        <th>Target</th>
                        <th>Status</th>
                        <th>Enabled</th>
                        <th>Last Sync</th>
                        <th>Records</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.SyncJobs.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted">No sync jobs configured.</td></tr>
                    }
                    @foreach (var job in Model.SyncJobs)
                    {
                        <tr>
                            <td>@job.Name</td>
                            <td><span class="badge bg-secondary">@job.SourceType</span></td>
                            <td><span class="badge bg-secondary">@job.TargetType</span></td>
                            <td>
                                @if (job.Status == "Running")
                                {
                                    <span class="badge bg-primary">Running</span>
                                }
                                else if (job.Status == "Error")
                                {
                                    <span class="badge bg-danger" title="@job.LastError">Error</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@job.Status</span>
                                }
                            </td>
                            <td>
                                @if (job.IsEnabled)
                                {
                                    <i class="bi bi-check-circle text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle text-muted"></i>
                                }
                            </td>
                            <td>@job.LastSyncTime?.ToString("g")</td>
                            <td>@job.RecordsSynced</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-sync" data-job-id="@job.Id"><i class="bi bi-pencil"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-success btn-run-sync" data-job-id="@job.Id"><i class="bi bi-play"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-sync" data-job-id="@job.Id"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
