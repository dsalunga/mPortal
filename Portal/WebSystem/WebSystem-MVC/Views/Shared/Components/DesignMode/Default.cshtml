@model WCMS.WebSystem.ViewComponents.DesignModeViewModel

<div class="design-mode-toolbar bg-dark text-white p-2 d-flex justify-content-between align-items-center">
    <div>
        <span class="me-3"><i class="bi bi-file-earmark"></i> @(Model.CurrentPageName ?? "No page selected")</span>
        @if (Model.CurrentPageId > 0)
        {
            <small class="text-muted">ID: @Model.CurrentPageId</small>
        }
    </div>
    <div class="d-flex align-items-center gap-2">
        @if (Model.CanEdit)
        {
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="designModeToggle" checked="@Model.IsDesignMode" />
                <label class="form-check-label text-white" for="designModeToggle">
                    @(Model.IsDesignMode ? "Design Mode" : "Preview Mode")
                </label>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.PreviewUrl))
        {
            <a href="@Model.PreviewUrl" class="btn btn-sm btn-outline-light" target="_blank">
                <i class="bi bi-box-arrow-up-right"></i> Preview
            </a>
        }
    </div>
</div>
