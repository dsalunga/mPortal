@model WCMS.WebSystem.ViewComponents.HeaderPanelViewModel

<div class="bg-primary text-white p-3 d-flex justify-content-between align-items-center">
    <div class="header-panel-left">
        <h5 class="mb-0">@Model.SiteName</h5>
    </div>
    <div class="header-panel-right d-flex align-items-center">
        <span class="me-3">
            <i class="bi bi-person-circle me-1"></i> @Model.UserName
        </span>
        @if (!string.IsNullOrEmpty(Model.UserRole))
        {
            <span class="badge bg-light text-dark me-3">@Model.UserRole</span>
        }
        <span class="me-3 position-relative">
            <i class="bi bi-bell fs-5"></i>
            @if (Model.NotificationCount > 0)
            {
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                    @Model.NotificationCount
                </span>
            }
        </span>
        @if (Model.LastLoginDate.HasValue)
        {
            <small class="text-white-50">Last login: @Model.LastLoginDate.Value.ToString("g")</small>
        }
    </div>
</div>
