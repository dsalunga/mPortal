@model WCMS.WebSystem.ViewComponents.WebUsersViewModel

<div class="card admin-panel" id="pnlUserAdmin">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-people"></i> Users</h5>
        <a href="javascript:void(0)" class="btn btn-sm btn-success" id="btnCreateUser"><i class="bi bi-person-plus"></i> New User</a>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <div class="row mb-3">
            <div class="col-md-5">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Search users..." id="userSearch" value="@Model.SearchTerm" />
                    <button class="btn btn-outline-secondary" type="button" id="btnSearchUsers"><i class="bi bi-search"></i></button>
                </div>
            </div>
            <div class="col-md-4">
                <select class="form-select" id="groupFilter">
                    <option value="0">All Groups</option>
                    @foreach (var g in Model.Groups)
                    {
                        <option value="@g.Id" selected="@(g.Id == Model.GroupId)">@g.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3 text-end text-muted">
                <span id="lblUserCount">@Model.TotalCount</span> user(s) found
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm" id="gvUsers">
                <thead class="table-light">
                    <tr>
                        <th>Username</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Active</th>
                        <th>Last Login</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted">No users found.</td></tr>
                    }
                    @foreach (var user in Model.Users)
                    {
                        <tr data-user-id="@user.Id">
                            <td><i class="bi bi-person"></i> @user.UserName</td>
                            <td>@user.FirstName @user.LastName</td>
                            <td><a href="mailto:@user.Email">@user.Email</a></td>
                            <td>
                                @if (user.IsLockedOut)
                                {
                                    <span class="badge bg-danger">Locked</span>
                                }
                                else if (user.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@user.LastLoginDate?.ToString("g")</td>
                            <td>
                                <a href="javascript:void(0)" class="btn btn-sm btn-outline-primary btn-edit-user" data-user-id="@user.Id" title="Edit"><i class="bi bi-pencil"></i></a>
                                @if (user.IsLockedOut)
                                {
                                    <a href="javascript:void(0)" class="btn btn-sm btn-outline-warning btn-unlock-user" data-user-id="@user.Id" title="Unlock"><i class="bi bi-unlock"></i></a>
                                }
                                <a href="javascript:void(0)" class="btn btn-sm btn-outline-danger btn-delete-user" data-user-id="@user.Id" title="Delete"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.TotalPages > 1)
        {
            <nav>
                <ul class="pagination pagination-sm justify-content-center">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="javascript:void(0)" data-page="@(Model.CurrentPage - 1)">&laquo;</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="javascript:void(0)" data-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="javascript:void(0)" data-page="@(Model.CurrentPage + 1)">&raquo;</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
