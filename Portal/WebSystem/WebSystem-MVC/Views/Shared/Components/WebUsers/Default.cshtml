@model WCMS.WebSystem.ViewComponents.WebUsersViewModel

<section class="card shadow-sm admin-panel" id="pnlUserAdmin" aria-label="User Administration">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-people" aria-hidden="true"></i> Users</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnCreateUser" aria-label="Create new user">
            <i class="bi bi-person-plus" aria-hidden="true"></i> New User
        </button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        <form class="row mb-3 g-2 align-items-end" role="search" aria-label="Filter users">
            <div class="col-md-5">
                <label for="userSearch" class="form-label visually-hidden">Search users</label>
                <div class="input-group">
                    <input type="search" class="form-control" placeholder="Search users…" id="userSearch" value="@Model.SearchTerm" aria-label="Search users" />
                    <button class="btn btn-outline-secondary" type="submit" id="btnSearchUsers" aria-label="Search">
                        <i class="bi bi-search" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
            <div class="col-md-4">
                <label for="groupFilter" class="form-label visually-hidden">Filter by group</label>
                <select class="form-select" id="groupFilter" aria-label="Filter by group">
                    <option value="0">All Groups</option>
                    @foreach (var g in Model.Groups)
                    {
                        <option value="@g.Id" selected="@(g.Id == Model.GroupId)">@g.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3 text-end text-muted">
                <span id="lblUserCount" aria-live="polite">@Model.TotalCount</span> user(s) found
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm" id="gvUsers" aria-label="Users list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Username</th>
                        <th scope="col">Name</th>
                        <th scope="col">Email</th>
                        <th scope="col">Status</th>
                        <th scope="col">Last Login</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted">No users found.</td></tr>
                    }
                    @foreach (var user in Model.Users)
                    {
                        <tr data-user-id="@user.Id">
                            <td><i class="bi bi-person" aria-hidden="true"></i> @user.UserName</td>
                            <td>@user.FirstName @user.LastName</td>
                            <td><a href="mailto:@user.Email">@user.Email</a></td>
                            <td>
                                @if (user.IsLockedOut)
                                {
                                    <span class="badge bg-danger">Locked</span>
                                }
                                else if (user.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-nowrap">@user.LastLoginDate?.ToString("g")</td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Actions for @user.UserName">
                                    <button type="button" class="btn btn-outline-primary btn-edit-user" data-user-id="@user.Id" title="Edit" aria-label="Edit @user.UserName">
                                        <i class="bi bi-pencil" aria-hidden="true"></i>
                                    </button>
                                    @if (user.IsLockedOut)
                                    {
                                        <button type="button" class="btn btn-outline-warning btn-unlock-user" data-user-id="@user.Id" title="Unlock" aria-label="Unlock @user.UserName">
                                            <i class="bi bi-unlock" aria-hidden="true"></i>
                                        </button>
                                    }
                                    <button type="button" class="btn btn-outline-danger btn-delete-user" data-user-id="@user.Id" title="Delete" aria-label="Delete @user.UserName">
                                        <i class="bi bi-trash" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="User list pagination">
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="javascript:void(0)" data-page="@(Model.CurrentPage - 1)" aria-label="Previous page">&laquo;</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")" @(i == Model.CurrentPage ? "aria-current=\"page\"" : "")>
                            <a class="page-link" href="javascript:void(0)" data-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="javascript:void(0)" data-page="@(Model.CurrentPage + 1)" aria-label="Next page">&raquo;</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</section>
