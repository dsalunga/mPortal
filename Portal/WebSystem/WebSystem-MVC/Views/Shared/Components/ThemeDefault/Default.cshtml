@* Originally: Default/Default.ascx *@
@model WCMS.WebSystem.ViewComponents.ThemeDefaultModel
<div class="theme-default" data-object-id="@Model.ObjectId">
    <header class="theme-default-header">
        <div class="container">
            <div class="row">
                <div class="col-12" id="LogoZone">
                    @* Logo zone *@
                </div>
            </div>
            <div class="row">
                <div class="col-12" id="NavigationZone">
                    @* Navigation zone *@
                </div>
            </div>
        </div>
    </header>
    <main class="theme-default-content">
        <div class="container">
            <div class="row">
                <div class="col-12" id="ContentZone">
                    @* Full-width content area *@
                </div>
            </div>
        </div>
    </main>
    <footer class="theme-default-footer">
        <div class="container">
            <div class="row">
                <div class="col-12" id="FooterZone">
                    @* Footer zone *@
                </div>
            </div>
        </div>
    </footer>
</div>
