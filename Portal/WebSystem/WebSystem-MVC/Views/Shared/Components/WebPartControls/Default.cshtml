@model WCMS.WebSystem.ViewComponents.WebPartControlsViewModel

<section class="card admin-panel" aria-label="Web Part Controls">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-sliders" aria-hidden="true"></i> Controls</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnAddControl" data-webpart-id="@Model.WebPartId" aria-label="Add new control"><i class="bi bi-plus-lg" aria-hidden="true"></i> New Control</button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.WebPartName))
        {
            <div class="px-3 pt-3">
                <small class="text-muted">Web Part:</small> <strong>@Model.WebPartName</strong>
            </div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" aria-label="Controls list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Type</th>
                        <th scope="col">Order</th>
                        <th scope="col">Active</th>
                        <th scope="col">Modified</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Controls.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted">No controls defined.</td></tr>
                    }
                    @foreach (var ctrl in Model.Controls)
                    {
                        <tr>
                            <td><i class="bi bi-gear" aria-hidden="true"></i> @ctrl.Name</td>
                            <td><span class="badge bg-secondary">@ctrl.ControlType</span></td>
                            <td>@ctrl.SortOrder</td>
                            <td>
                                @if (ctrl.IsActive)
                                {
                                    <i class="bi bi-check-circle text-success" aria-hidden="true"></i><span class="visually-hidden">Active</span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle text-muted" aria-hidden="true"></i><span class="visually-hidden">Inactive</span>
                                }
                            </td>
                            <td>@(ctrl.ModifiedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-control" data-control-id="@ctrl.Id" aria-label="Edit @ctrl.Name"><i class="bi bi-pencil" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-control" data-control-id="@ctrl.Id" aria-label="Delete @ctrl.Name"><i class="bi bi-trash" aria-hidden="true"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
