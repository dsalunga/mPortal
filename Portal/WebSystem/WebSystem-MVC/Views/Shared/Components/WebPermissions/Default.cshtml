@model WCMS.WebSystem.ViewComponents.WebPermissionsViewModel

<div class="card admin-panel" id="pnlPermissionManager">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-key" aria-hidden="true"></i> Permissions</h5>
        <button type="button" class="btn btn-sm btn-primary" id="btnSavePermissions" aria-label="Save permissions">
            <i class="bi bi-save" aria-hidden="true"></i> Save
        </button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        <input type="hidden" id="permObjectId" value="@Model.ObjectId" />
        <div class="card bg-light mb-3">
            <div class="card-body py-2">
                <span id="lblObjectName"><strong>Object:</strong> @(Model.ObjectName ?? "N/A")</span>
                <span class="badge bg-secondary ms-2" id="lblObjectType">@(Model.ObjectType ?? "Unknown")</span>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-sm" id="gvPermissions" aria-label="Permission assignments">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Role</th>
                        <th scope="col" class="text-center">Read</th>
                        <th scope="col" class="text-center">Write</th>
                        <th scope="col" class="text-center">Delete</th>
                        <th scope="col" class="text-center">Admin</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Entries.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted">No permissions assigned.</td></tr>
                    }
                    @foreach (var entry in Model.Entries)
                    {
                        <tr data-perm-id="@entry.Id" data-role-id="@entry.RoleId">
                            <td><i class="bi bi-shield" aria-hidden="true"></i> @entry.RoleName</td>
                            <td class="text-center">
                                <div class="form-check d-flex justify-content-center mb-0">
                                    <input type="checkbox" class="form-check-input perm-read" checked="@entry.CanRead" aria-label="Read permission for @entry.RoleName" />
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="form-check d-flex justify-content-center mb-0">
                                    <input type="checkbox" class="form-check-input perm-write" checked="@entry.CanWrite" aria-label="Write permission for @entry.RoleName" />
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="form-check d-flex justify-content-center mb-0">
                                    <input type="checkbox" class="form-check-input perm-delete" checked="@entry.CanDelete" aria-label="Delete permission for @entry.RoleName" />
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="form-check d-flex justify-content-center mb-0">
                                    <input type="checkbox" class="form-check-input perm-admin" checked="@entry.CanAdmin" aria-label="Admin permission for @entry.RoleName" />
                                </div>
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-remove-perm" data-perm-id="@entry.Id" title="Remove" aria-label="Remove permissions for @entry.RoleName">
                                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <fieldset class="mt-3">
            <legend class="form-label fs-6">Add Role</legend>
            <div class="input-group" style="max-width: 400px;">
                <label for="addRoleSelect" class="visually-hidden">Select a role to add</label>
                <select class="form-select" id="addRoleSelect" aria-label="Select a role to add">
                    <option value="">— Select Role —</option>
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role.Id">@role.Name</option>
                    }
                </select>
                <button class="btn btn-outline-success" type="button" id="btnAddPermission" aria-label="Add selected role">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i> Add
                </button>
            </div>
        </fieldset>
    </div>
</div>
