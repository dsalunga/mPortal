@model WCMS.WebSystem.ViewComponents.WebPermissionsViewModel

<div class="card admin-panel">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-key"></i> Permissions</h5>
        <button type="button" class="btn btn-sm btn-primary" id="btnSavePermissions"><i class="bi bi-save"></i> Save</button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <input type="hidden" id="permObjectId" value="@Model.ObjectId" />
        <div class="mb-3">
            <strong>Object:</strong> @(Model.ObjectName ?? "N/A")
            <small class="text-muted ms-2">(@(Model.ObjectType ?? "Unknown"))</small>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-sm">
                <thead class="table-light">
                    <tr>
                        <th>Role</th>
                        <th class="text-center">Read</th>
                        <th class="text-center">Write</th>
                        <th class="text-center">Delete</th>
                        <th class="text-center">Admin</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Entries.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted">No permissions assigned.</td></tr>
                    }
                    @foreach (var entry in Model.Entries)
                    {
                        <tr>
                            <td>@entry.RoleName</td>
                            <td class="text-center"><input type="checkbox" class="form-check-input" checked="@entry.CanRead" /></td>
                            <td class="text-center"><input type="checkbox" class="form-check-input" checked="@entry.CanWrite" /></td>
                            <td class="text-center"><input type="checkbox" class="form-check-input" checked="@entry.CanDelete" /></td>
                            <td class="text-center"><input type="checkbox" class="form-check-input" checked="@entry.CanAdmin" /></td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-remove-perm" data-perm-id="@entry.Id"><i class="bi bi-x-lg"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="mt-3">
            <div class="input-group" style="max-width: 400px;">
                <select class="form-select" id="addRoleSelect">
                    <option value="">-- Add Role --</option>
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role.Id">@role.Name</option>
                    }
                </select>
                <button class="btn btn-outline-success" type="button" id="btnAddPermission"><i class="bi bi-plus-lg"></i> Add</button>
            </div>
        </div>
    </div>
</div>
