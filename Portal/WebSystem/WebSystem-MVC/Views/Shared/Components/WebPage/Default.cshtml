@model WCMS.WebSystem.ViewComponents.WebPageViewModel

<div class="card admin-panel">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-file-earmark-text"></i> Page Editor</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form method="post" id="pageEditorForm">
            <input type="hidden" name="pageId" value="@Model.PageId" />
            <input type="hidden" name="siteId" value="@Model.SiteId" />
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" class="form-control" name="name" value="@Model.Name" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input type="text" class="form-control" name="title" value="@Model.Title" />
            </div>
            <div class="mb-3">
                <label class="form-label">URL</label>
                <input type="text" class="form-control" name="url" value="@Model.Url" />
            </div>
            <div class="mb-3">
                <label class="form-label">Meta Description</label>
                <textarea class="form-control" name="metaDescription" rows="3">@Model.MetaDescription</textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Meta Keywords</label>
                <textarea class="form-control" name="metaKeywords" rows="2">@Model.MetaKeywords</textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Template</label>
                <select class="form-select" name="templateName">
                    <option value="">-- Select Template --</option>
                    @foreach (var template in Model.AvailableTemplates)
                    {
                        <option value="@template" selected="@(template == Model.TemplateName)">@template</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Sort Order</label>
                <input type="number" class="form-control" name="sortOrder" value="@Model.SortOrder" />
            </div>
            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" name="isActive" id="pageIsActive" checked="@Model.IsActive" />
                <label class="form-check-label" for="pageIsActive">Active</label>
            </div>
            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" name="isDefault" id="pageIsDefault" checked="@Model.IsDefault" />
                <label class="form-check-label" for="pageIsDefault">Default</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save</button>
                <button type="button" class="btn btn-secondary" id="btnCancelPage"><i class="bi bi-x-lg"></i> Cancel</button>
            </div>
        </form>
    </div>
</div>
