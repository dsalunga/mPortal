@model WCMS.WebSystem.ViewComponents.WebPageViewModel

<section class="card admin-panel" id="pnlPageEditor" aria-label="Page Editor">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-file-earmark-text" aria-hidden="true"></i> Page Editor</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success" id="pageSuccessMsg" role="status">@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" id="pageErrorMsg" role="alert">@Model.ErrorMessage</div>
        }
        <form method="post" id="pageEditorForm" aria-label="Page editor form">
            <input type="hidden" name="pageId" id="pageId" value="@Model.PageId" />
            <input type="hidden" name="siteId" id="pageSiteId" value="@Model.SiteId" />
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="pageName">Page Name</label>
                    <input type="text" class="form-control" name="name" id="pageName" value="@Model.Name" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="pageTitle">Title</label>
                    <input type="text" class="form-control" name="title" id="pageTitle" value="@Model.Title" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label" for="pageUrl">URL</label>
                <input type="text" class="form-control" name="url" id="pageUrl" value="@Model.Url" />
            </div>
            <div class="mb-3">
                <label class="form-label" for="pageMetaDescription">Meta Description</label>
                <textarea class="form-control" name="metaDescription" id="pageMetaDescription" rows="3">@Model.MetaDescription</textarea>
            </div>
            <div class="mb-3">
                <label class="form-label" for="pageMetaKeywords">Meta Keywords</label>
                <textarea class="form-control" name="metaKeywords" id="pageMetaKeywords" rows="2">@Model.MetaKeywords</textarea>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="pageTemplate">Template</label>
                    <select class="form-select" name="templateName" id="pageTemplate">
                        <option value="">-- Select Template --</option>
                        @foreach (var template in Model.AvailableTemplates)
                        {
                            <option value="@template" selected="@(template == Model.TemplateName)">@template</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="pageSortOrder">Sort Order</label>
                    <input type="number" class="form-control" name="sortOrder" id="pageSortOrder" value="@Model.SortOrder" />
                </div>
                <div class="col-md-3 d-flex align-items-end gap-3">
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" name="isActive" id="pageIsActive" checked="@Model.IsActive" />
                        <label class="form-check-label" for="pageIsActive">Active</label>
                    </div>
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" name="isDefault" id="pageIsDefault" checked="@Model.IsDefault" />
                        <label class="form-check-label" for="pageIsDefault">Default</label>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" id="btnSavePage"><i class="bi bi-save" aria-hidden="true"></i> Save</button>
                <button type="button" class="btn btn-outline-danger" id="btnDeletePage"><i class="bi bi-trash" aria-hidden="true"></i> Delete</button>
                <button type="button" class="btn btn-secondary" id="btnCancelPage"><i class="bi bi-x-lg" aria-hidden="true"></i> Cancel</button>
            </div>
        </form>
    </div>
</section>
