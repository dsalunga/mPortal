@model WCMS.WebSystem.ViewComponents.WebGroupsViewModel

@{
    void RenderGroupTree(List<WCMS.WebSystem.ViewComponents.WebGroupNode> nodes, int selectedId)
    {
        if (nodes == null || nodes.Count == 0) return;
        <ul class="list-unstyled ms-3">
            @foreach (var g in nodes)
            {
                var active = g.Id == selectedId ? "fw-bold text-primary" : "";
                <li class="mb-1">
                    <a href="javascript:void(0)" class="group-link text-decoration-none @active" data-group-id="@g.Id">
                        <i class="bi @(g.IsActive ? "bi-folder-fill" : "bi-folder text-muted")"></i> @g.Name
                        <span class="badge bg-secondary">@g.UserCount</span>
                    </a>
                    @if (!g.IsActive)
                    {
                        <span class="badge bg-warning text-dark ms-1">Inactive</span>
                    }
                    @if (g.Children != null && g.Children.Count > 0)
                    {
                        RenderGroupTree(g.Children, selectedId);
                    }
                </li>
            }
        </ul>
    }
}

<div class="card admin-panel" id="pnlGroupAdmin">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-collection"></i> Groups</h5>
        <div>
            <button type="button" class="btn btn-sm btn-success" id="btnAddGroup"><i class="bi bi-plus-lg"></i> New Group</button>
            <button type="button" class="btn btn-sm btn-outline-danger" id="btnDeleteGroup"><i class="bi bi-trash"></i> Delete</button>
        </div>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3">@Model.ErrorMessage</div>
        }
        <div class="group-tree p-3" id="groupTreeContainer">
            @if (Model.Groups.Count == 0)
            {
                <p class="text-muted">No groups defined.</p>
            }
            else
            {
                RenderGroupTree(Model.Groups, Model.SelectedGroupId);
            }
        </div>
    </div>
</div>
