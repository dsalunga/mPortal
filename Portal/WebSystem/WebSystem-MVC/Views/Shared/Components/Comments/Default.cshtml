@model WCMS.WebSystem.ViewComponents.CommentsViewModel
<section class="system-comments" aria-label="Comments">
    <h5>Comments</h5>

    @if (Model.Comments.Any())
    {
        <div class="comments-list">
            @foreach (var comment in Model.Comments)
            {
                <div class="card mb-2">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong>@(!string.IsNullOrEmpty(comment.UserName) ? comment.UserName : "Anonymous")</strong>
                            <small class="text-muted">@comment.DateCreated.ToString("g")</small>
                        </div>
                        <p class="mb-0">@comment.Content</p>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No comments yet.</p>
    }

    @if (Model.IsLoggedIn)
    {
        <form method="post" asp-action="PostComment" asp-controller="Comments" aria-label="Post a comment">
            <input type="hidden" name="objectId" value="@Model.ObjectId" />
            <input type="hidden" name="recordId" value="@Model.RecordId" />
            <div class="mb-3">
                <label class="form-label" for="commentContent">Add a comment</label>
                <textarea id="commentContent" name="content" class="form-control" rows="3" required aria-required="true"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" aria-label="Post comment">Post Comment</button>
        </form>
    }
    else
    {
        <p class="text-muted">Please log in to post a comment.</p>
    }
</section>
