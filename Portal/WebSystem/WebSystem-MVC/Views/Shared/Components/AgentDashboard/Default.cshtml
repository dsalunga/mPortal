@model WCMS.WebSystem.ViewComponents.AgentDashboardViewModel

<section class="card admin-panel" id="pnlAgentManager" aria-label="Agent Manager">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-robot" aria-hidden="true"></i> Agent Manager</h5>
        <div>
            <span class="badge @(Model.IsAgentRunning ? "bg-success" : "bg-secondary") me-2" id="lblAgentStatus">
                @(Model.IsAgentRunning ? "Running" : "Stopped")
            </span>
            @if (Model.IsAgentRunning)
            {
                <button type="button" class="btn btn-sm btn-outline-danger" id="btnStopAgent"><i class="bi bi-stop-circle" aria-hidden="true"></i> Stop</button>
            }
            else
            {
                <button type="button" class="btn btn-sm btn-outline-success" id="btnStartAgent"><i class="bi bi-play-circle" aria-hidden="true"></i> Start</button>
            }
            <button type="button" class="btn btn-sm btn-success" id="btnNewTask"><i class="bi bi-plus-lg" aria-hidden="true"></i> New Task</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnRefreshAgent" aria-label="Refresh agent tasks"><i class="bi bi-arrow-clockwise" aria-hidden="true"></i></button>
        </div>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@Model.ErrorMessage</div>
        }
        @if (Model.LastRunTime.HasValue)
        {
            <div class="px-3 pt-2">
                <small class="text-muted"><i class="bi bi-clock" aria-hidden="true"></i> Last agent run: <span id="lblLastRun">@Model.LastRunTime.Value.ToString("g")</span></small>
            </div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" id="gvAgentTasks" aria-label="Agent tasks">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Task</th>
                        <th scope="col">Description</th>
                        <th scope="col">Schedule</th>
                        <th scope="col">Status</th>
                        <th scope="col">Enabled</th>
                        <th scope="col">Last Run</th>
                        <th scope="col">Next Run</th>
                        <th scope="col">Last Result</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Tasks.Count == 0)
                    {
                        <tr><td colspan="9" class="text-center text-muted">No scheduled tasks.</td></tr>
                    }
                    @foreach (var task in Model.Tasks)
                    {
                        <tr data-task-id="@task.Id">
                            <td><i class="bi bi-gear" aria-hidden="true"></i> @task.Name</td>
                            <td><small>@task.Description</small></td>
                            <td><code>@task.Schedule</code></td>
                            <td>
                                @if (task.Status == "Running")
                                {
                                    <span class="badge bg-primary">Running</span>
                                }
                                else if (task.Status == "Failed")
                                {
                                    <span class="badge bg-danger">Failed</span>
                                }
                                else if (task.Status == "Completed")
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@task.Status</span>
                                }
                            </td>
                            <td>
                                <input type="checkbox" class="form-check-input chk-task-enabled" data-task-id="@task.Id" checked="@task.IsEnabled" />
                            </td>
                            <td>@task.LastRunTime?.ToString("g")</td>
                            <td>@task.NextRunTime?.ToString("g")</td>
                            <td><small class="text-muted">@task.LastResult</small></td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-task" data-task-id="@task.Id" title="Edit" aria-label="Edit @task.Name"><i class="bi bi-pencil" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-success btn-run-task" data-task-id="@task.Id" title="Run Now" aria-label="Run @task.Name"><i class="bi bi-play" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-task" data-task-id="@task.Id" title="Delete" aria-label="Delete @task.Name"><i class="bi bi-trash" aria-hidden="true"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
