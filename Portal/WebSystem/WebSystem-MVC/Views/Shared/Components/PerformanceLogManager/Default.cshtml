@model WCMS.WebSystem.ViewComponents.PerformanceLogManagerViewModel

<section class="card admin-panel" aria-label="Performance Log Manager">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-speedometer2" aria-hidden="true"></i> Performance Log</h5>
        <div role="toolbar" aria-label="Log actions">
            <button type="button" class="btn btn-sm btn-outline-danger" id="btnClearPerfLog" aria-label="Clear performance log"><i class="bi bi-trash" aria-hidden="true"></i> Clear</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnRefreshPerfLog" aria-label="Refresh performance log"><i class="bi bi-arrow-clockwise" aria-hidden="true"></i></button>
        </div>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <label class="visually-hidden" for="perfSearch">Search URLs</label>
                    <input type="text" class="form-control" placeholder="Search URLs..." id="perfSearch" value="@Model.SearchTerm" aria-label="Search performance log entries" />
                    <button class="btn btn-outline-secondary" type="button" id="btnSearchPerf" aria-label="Search"><i class="bi bi-search" aria-hidden="true"></i></button>
                </div>
            </div>
            <div class="col-md-8 text-end" role="status" aria-label="Performance summary">
                <span class="badge bg-info me-2">Avg: @Model.AverageResponseTime.ToString("F1") ms</span>
                <span class="badge bg-warning text-dark me-2">Max: @Model.MaxResponseTime.ToString("F1") ms</span>
                <span class="text-muted">@Model.TotalCount entries</span>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-sm" aria-label="Performance log entries">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Time</th>
                        <th scope="col">URL</th>
                        <th scope="col">Method</th>
                        <th scope="col">Status</th>
                        <th scope="col">Response (ms)</th>
                        <th scope="col">User</th>
                        <th scope="col">IP</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Entries.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted">No performance entries found.</td></tr>
                    }
                    @foreach (var entry in Model.Entries)
                    {
                        var statusClass = entry.StatusCode >= 500 ? "text-danger" : entry.StatusCode >= 400 ? "text-warning" : "";
                        <tr>
                            <td><small>@entry.Timestamp.ToString("g")</small></td>
                            <td class="text-truncate" style="max-width:250px;">@entry.Url</td>
                            <td><span class="badge bg-secondary">@entry.Method</span></td>
                            <td><span class="@statusClass">@entry.StatusCode</span></td>
                            <td>
                                @if (entry.ResponseTimeMs > 1000)
                                {
                                    <span class="text-danger fw-bold">@entry.ResponseTimeMs.ToString("F0")</span>
                                }
                                else
                                {
                                    @entry.ResponseTimeMs.ToString("F0")
                                }
                            </td>
                            <td><small>@entry.UserName</small></td>
                            <td><small>@entry.IpAddress</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Performance log pagination">
                <ul class="pagination pagination-sm justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")" @(i == Model.CurrentPage ? "aria-current=\"page\"" : "")>
                            <a class="page-link" href="javascript:void(0)" data-page="@i" aria-label="Go to page @i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</section>
