@model WCMS.WebSystem.ViewComponents.LoginViewModel
@if (Model.View == "LoggedOut")
{
    <script>window.location.href = '@Model.RedirectUrl';</script>
}
else if (Model.View == "ForgotPassword")
{
    <div class="login-container forgot-password">
        <h3>Forgot Password</h3>
        <form method="post" asp-action="ForgotPassword" asp-controller="Account">
            <div class="form-group">
                <label>Username or E-mail</label>
                <input type="text" name="userNameOrEmail" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary">Retrieve Password</button>
        </form>
        @if (!string.IsNullOrEmpty(Model.LoginUrl))
        {
            <p><a href="@Model.LoginUrl">Back to Login</a></p>
        }
    </div>
}
else if (Model.View == "OtpVerification")
{
    <div class="login-container otp-verification">
        <h3>OTP Verification</h3>
        <form method="post" asp-action="VerifyOtp" asp-controller="Account">
            <div class="form-group">
                <label>Enter OTP Code</label>
                <input type="text" name="otpCode" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary">Verify</button>
            <button type="submit" name="action" value="resend" class="btn btn-link">Request New PIN</button>
            <button type="submit" name="action" value="cancel" class="btn btn-link">Cancel</button>
        </form>
    </div>
}
else if (Model.IsLoggedIn)
{
    <div class="login-status">
        <span>Welcome, @Model.UserDisplayName</span>
        <a href="?mode=logoff" class="btn btn-sm btn-outline-secondary">Sign Out</a>
    </div>
}
else
{
    <div class="login-container">
        @if (!string.IsNullOrEmpty(Model.PreLoginNote))
        {
            <div class="alert alert-info">@Model.PreLoginNote</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form method="post" asp-action="Login" asp-controller="Account">
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="userName" class="form-control" required />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" class="form-control" required />
            </div>
            @if (Model.EnableRememberMe)
            {
                <div class="form-check">
                    <input type="checkbox" name="rememberMe" class="form-check-input" id="chkRememberMe" />
                    <label class="form-check-label" for="chkRememberMe">
                        @(Model.RememberMeText ?? "Remember me")
                    </label>
                </div>
            }
            @if (Model.EnableOtp)
            {
                <div class="form-group mt-2">
                    <label>OTP Delivery</label>
                    <select name="otpType" class="form-control">
                        <option value="0">E-mail</option>
                        @if (Model.EnableSms)
                        {
                            <option value="1">SMS</option>
                        }
                    </select>
                </div>
            }
            <button type="submit" class="btn btn-primary mt-2">Sign In</button>
        </form>
        @if (!string.IsNullOrEmpty(Model.ForgotPasswordUrl))
        {
            <p class="mt-2"><a href="@Model.ForgotPasswordUrl">Forgot your password?</a></p>
        }
        @if (!string.IsNullOrEmpty(Model.SignUpUrl))
        {
            <p><a href="@Model.SignUpUrl">Create an Account</a></p>
        }
    </div>
}
