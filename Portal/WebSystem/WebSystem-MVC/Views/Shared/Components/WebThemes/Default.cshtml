@model WCMS.WebSystem.ViewComponents.WebThemesViewModel

<div class="card admin-panel">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-palette"></i> Themes</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnAddTheme"><i class="bi bi-plus-lg"></i> New Theme</button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3">@Model.ErrorMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Active</th>
                        <th>Modified</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Themes.Count == 0)
                    {
                        <tr><td colspan="5" class="text-center text-muted">No themes defined.</td></tr>
                    }
                    @foreach (var theme in Model.Themes)
                    {
                        <tr class="@(theme.Id == Model.SelectedThemeId ? "table-primary" : "")">
                            <td>
                                <i class="bi bi-palette2"></i> @theme.Name
                                @if (!string.IsNullOrEmpty(theme.PreviewUrl))
                                {
                                    <a href="@theme.PreviewUrl" target="_blank" class="ms-1"><i class="bi bi-box-arrow-up-right"></i></a>
                                }
                            </td>
                            <td>@theme.Description</td>
                            <td>
                                @if (theme.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@theme.ModifiedDate?.ToString("g")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-theme" data-theme-id="@theme.Id"><i class="bi bi-pencil"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-theme" data-theme-id="@theme.Id"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
