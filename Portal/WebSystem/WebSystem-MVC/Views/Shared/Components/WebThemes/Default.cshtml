@model WCMS.WebSystem.ViewComponents.WebThemesViewModel

<section class="card admin-panel" id="pnlThemeEditor" aria-label="Themes Manager">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-palette" aria-hidden="true"></i> Themes</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnAddTheme" aria-label="Add new theme"><i class="bi bi-plus-lg" aria-hidden="true"></i> New Theme</button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@Model.ErrorMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" id="gvThemes" aria-label="Themes list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Description</th>
                        <th scope="col">Preview</th>
                        <th scope="col">Active</th>
                        <th scope="col">Modified</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Themes.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted">No themes defined.</td></tr>
                    }
                    @foreach (var theme in Model.Themes)
                    {
                        <tr class="@(theme.Id == Model.SelectedThemeId ? "table-primary" : "")" data-theme-id="@theme.Id">
                            <td><i class="bi bi-palette2" aria-hidden="true"></i> @theme.Name</td>
                            <td>@theme.Description</td>
                            <td>
                                @if (!string.IsNullOrEmpty(theme.PreviewUrl))
                                {
                                    <a href="@theme.PreviewUrl" target="_blank" class="btn btn-sm btn-outline-info" aria-label="Preview @theme.Name in new window"><i class="bi bi-box-arrow-up-right" aria-hidden="true"></i> Preview</a>
                                }
                            </td>
                            <td>
                                @if (theme.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@theme.ModifiedDate?.ToString("g")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-theme" data-theme-id="@theme.Id" title="Edit" aria-label="Edit @theme.Name"><i class="bi bi-pencil" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-theme" data-theme-id="@theme.Id" title="Delete" aria-label="Delete @theme.Name"><i class="bi bi-trash" aria-hidden="true"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
