@model WCMS.WebSystem.ViewComponents.TaskEditorViewModel

<div class="card admin-panel">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-gear"></i> Task Editor</h5>
        <button type="button" class="btn btn-sm btn-primary" id="btnSaveTask"><i class="bi bi-save"></i> Save</button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form id="taskEditorForm">
            <input type="hidden" id="taskId" value="@Model.TaskId" />
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Task Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="taskName" value="@Model.TaskName" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Description</label>
                    <input type="text" class="form-control" id="taskDescription" value="@Model.Description" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">Type</label>
                    <select class="form-select" id="taskType">
                        @foreach (var t in Model.AvailableTaskTypes)
                        {
                            <option value="@t" selected="@(t == Model.TaskType)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Schedule</label>
                    <select class="form-select" id="taskSchedule">
                        @foreach (var s in Model.AvailableSchedules)
                        {
                            <option value="@s" selected="@(s == Model.Schedule)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Enabled</label>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="taskEnabled" checked="@Model.IsEnabled" />
                        <label class="form-check-label" for="taskEnabled">Active</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Command / Query</label>
                <textarea class="form-control font-monospace" id="taskCommand" rows="8">@Model.CommandText</textarea>
            </div>
        </form>
    </div>
</div>
