@model WCMS.WebSystem.ViewComponents.WebRolesViewModel

<section class="card admin-panel" id="pnlRoleAdmin" aria-label="Roles Manager">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-shield-lock" aria-hidden="true"></i> Roles</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnAddRole" aria-label="Add new role">
            <i class="bi bi-plus-lg" aria-hidden="true"></i> New Role
        </button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@Model.ErrorMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" id="gvRoles" aria-label="Roles list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Role Name</th>
                        <th scope="col">Description</th>
                        <th scope="col">Members</th>
                        <th scope="col">Permissions</th>
                        <th scope="col">System</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Roles.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted">No roles defined.</td></tr>
                    }
                    @foreach (var role in Model.Roles)
                    {
                        <tr class="@(role.Id == Model.SelectedRoleId ? "table-primary" : "")" data-role-id="@role.Id">
                            <td><i class="bi bi-shield" aria-hidden="true"></i> @role.Name</td>
                            <td class="text-muted small">@role.Description</td>
                            <td>
                                <span class="badge bg-info" title="@role.MemberCount member(s)">
                                    @role.MemberCount <span class="visually-hidden">members</span>
                                </span>
                            </td>
                            <td>
                                @if (role.Permissions.Count > 0)
                                {
                                    @foreach (var perm in role.Permissions)
                                    {
                                        <span class="badge bg-light text-dark border me-1">@perm</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">None</span>
                                }
                            </td>
                            <td>
                                @if (role.IsSystem)
                                {
                                    <i class="bi bi-check-circle-fill text-success" aria-hidden="true"></i>
                                    <span class="visually-hidden">System role</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Actions for @role.Name">
                                    <button type="button" class="btn btn-outline-primary btn-edit-role" data-role-id="@role.Id" title="Edit" aria-label="Edit @role.Name">
                                        <i class="bi bi-pencil" aria-hidden="true"></i>
                                    </button>
                                    @if (!role.IsSystem)
                                    {
                                        <button type="button" class="btn btn-outline-danger btn-delete-role" data-role-id="@role.Id" title="Delete" aria-label="Delete @role.Name">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
