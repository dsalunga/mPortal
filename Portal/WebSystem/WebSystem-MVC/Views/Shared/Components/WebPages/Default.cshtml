@model WCMS.WebSystem.ViewComponents.WebPagesViewModel

<div class="card admin-panel">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-file-earmark"></i> Pages</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnNewPage" data-site-id="@Model.SiteId"><i class="bi bi-plus-lg"></i> New Page</button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3">@Model.ErrorMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Title</th>
                        <th>URL</th>
                        <th>Order</th>
                        <th>Default</th>
                        <th>Active</th>
                        <th>Modified</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Pages.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted">No pages defined.</td></tr>
                    }
                    @foreach (var p in Model.Pages)
                    {
                        <tr class="@(p.Id == Model.SelectedPageId ? "table-primary" : "")">
                            <td><i class="bi bi-file-earmark"></i> @p.Name</td>
                            <td>@p.Title</td>
                            <td>@p.Url</td>
                            <td>@p.SortOrder</td>
                            <td>@(p.IsDefault ? "✓" : "")</td>
                            <td>
                                @if (p.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@p.ModifiedDate?.ToString("g")</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-page" data-page-id="@p.Id"><i class="bi bi-pencil"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-page" data-page-id="@p.Id"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
