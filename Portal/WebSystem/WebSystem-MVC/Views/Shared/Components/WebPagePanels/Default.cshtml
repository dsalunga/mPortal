@model WCMS.WebSystem.ViewComponents.WebPagePanelsViewModel

<section class="card shadow-sm admin-panel" aria-label="Page Panels">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-layout-three-columns" aria-hidden="true"></i> Page Panels</h5>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@Model.ErrorMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm mb-0" aria-label="Page panels list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Type</th>
                        <th scope="col">Order</th>
                        <th scope="col">Elements</th>
                        <th scope="col">Active</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Panels.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted">No panels defined.</td></tr>
                    }
                    @foreach (var p in Model.Panels)
                    {
                        <tr>
                            <td><i class="bi bi-layout-three-columns" aria-hidden="true"></i> @p.Name</td>
                            <td>@p.PanelType</td>
                            <td>@p.SortOrder</td>
                            <td><span class="badge bg-info">@p.ElementCount</span></td>
                            <td>
                                @if (p.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-edit-panel" data-panel-id="@p.Id" aria-label="Edit @p.Name"><i class="bi bi-pencil" aria-hidden="true"></i></button>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-panel" data-panel-id="@p.Id" aria-label="Delete @p.Name"><i class="bi bi-trash" aria-hidden="true"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
