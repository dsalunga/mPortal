@model WCMS.WebSystem.ViewComponents.WebSitesViewModel

@{
    void RenderSiteTree(List<WCMS.WebSystem.ViewComponents.WebSiteNode> nodes, int selectedId, bool isRoot = false)
    {
        if (nodes == null || nodes.Count == 0) return;
        <ul class="list-unstyled ms-3" role="@(isRoot ? "tree" : "group")" aria-label="@(isRoot ? "Site hierarchy" : "")">
            @foreach (var site in nodes)
            {
                var hasChildren = site.Children != null && site.Children.Count > 0;
                <li class="mb-1" role="treeitem" aria-selected="@(site.Id == selectedId ? "true" : "false")" aria-expanded="@(hasChildren ? "true" : "")">
                    <div class="d-flex align-items-center @(site.Id == selectedId ? "fw-bold text-primary" : "")">
                        <i class="bi bi-globe me-1" aria-hidden="true"></i>
                        <a href="javascript:;" class="text-decoration-none btn-select-site" data-site-id="@site.Id" aria-label="Select site @site.Name">@site.Name</a>
                        <span class="badge bg-info ms-2" title="@site.PageCount page(s)">@site.PageCount <span class="visually-hidden">pages</span></span>
                        @if (site.IsActive)
                        {
                            <span class="badge bg-success ms-1">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ms-1">Inactive</span>
                        }
                        <div class="btn-group btn-group-sm ms-auto" role="group" aria-label="Actions for @site.Name">
                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit-site" data-site-id="@site.Id" title="Edit @site.Name" aria-label="Edit @site.Name">
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger btn-delete-site" data-site-id="@site.Id" title="Delete @site.Name" aria-label="Delete @site.Name">
                                <i class="bi bi-trash" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                    @if (hasChildren)
                    {
                        RenderSiteTree(site.Children, selectedId);
                    }
                </li>
            }
        </ul>
    }
}

<section class="card admin-panel" id="pnlSiteAdmin" aria-label="Web Sites Manager">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-globe2" aria-hidden="true"></i> Web Sites</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnNewSite" aria-label="Add new site">
            <i class="bi bi-plus-lg" aria-hidden="true"></i> New Site
        </button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }
        @if (Model.Sites.Count == 0)
        {
            <p class="text-muted">No sites defined.</p>
        }
        else
        {
            RenderSiteTree(Model.Sites, Model.SelectedSiteId, isRoot: true);
        }
    </div>
</section>
