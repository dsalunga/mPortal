@model WCMS.WebSystem.ViewComponents.WebSitesViewModel

@{
    void RenderSiteTree(List<WCMS.WebSystem.ViewComponents.WebSiteNode> nodes, int selectedId)
    {
        if (nodes == null || nodes.Count == 0) return;
        <ul class="list-unstyled ms-3">
            @foreach (var site in nodes)
            {
                <li class="mb-1">
                    <div class="d-flex align-items-center @(site.Id == selectedId ? "fw-bold text-primary" : "")">
                        <i class="bi bi-globe me-1"></i>
                        <a href="javascript:;" class="text-decoration-none btn-select-site" data-site-id="@site.Id">@site.Name</a>
                        <span class="badge bg-info ms-2">@site.PageCount</span>
                        @if (site.IsActive)
                        {
                            <span class="badge bg-success ms-1">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ms-1">Inactive</span>
                        }
                    </div>
                    @if (site.Children != null && site.Children.Count > 0)
                    {
                        RenderSiteTree(site.Children, selectedId);
                    }
                </li>
            }
        </ul>
    }
}

<div class="card admin-panel">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-globe2"></i> Web Sites</h5>
        <button type="button" class="btn btn-sm btn-success" id="btnNewSite"><i class="bi bi-plus-lg"></i> New Site</button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        @if (Model.Sites.Count == 0)
        {
            <p class="text-muted">No sites defined.</p>
        }
        else
        {
            RenderSiteTree(Model.Sites, Model.SelectedSiteId);
        }
    </div>
</div>
