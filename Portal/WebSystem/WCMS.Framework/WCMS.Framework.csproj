<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <NoWarn>1591</NoWarn>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <Deterministic>false</Deterministic>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|AnyCPU'">
    <DocumentationFile>bin\Debug\WCMS.Framework.xml</DocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.SystemWebAdapters" Version="2.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="9.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\WCMS.Common\WCMS.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Core/ObjectCapsule.cs" />
    <Compile Remove="ObjectRecordPair.cs" />
    <Compile Remove="SiteModel/WebObjectItem.cs" />
    <Compile Remove="Utilities/WebSubstituter.cs" />
    <!-- EF6 generated files excluded; kept as documentation -->
    <Compile Remove="WFrameworkModel.Designer.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="notes.txt" />
    <None Include="App.Config" />
    <None Include="WFrameworkModel.edmx" />
    <None Include="WFrameworkModel.Context.tt" />
    <None Include="WFrameworkModel.edmx.diagram" />
    <None Include="WFrameworkModel.tt" />
    <None Include="WFrameworkModel.Designer.cs" />
  </ItemGroup>
</Project>
