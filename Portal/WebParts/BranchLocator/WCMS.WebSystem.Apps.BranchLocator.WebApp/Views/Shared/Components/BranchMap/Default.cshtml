@model WCMS.WebSystem.WebParts.ViewComponents.BranchMapViewModel
@if (Model.HasCenter)
{
    <div class="map-overlay" onclick="style.display = 'none'">
        <div>Click or touch map to activate</div>
    </div>
    <div id="mapContainer" class="map-container"></div>

    <script src="//maps.googleapis.com/maps/api/js?v=3.exp&sensor=true&libraries=places"></script>
    <script type="text/javascript">
        function branchMapEscape(s) {
            var d = document.createElement('div');
            d.appendChild(document.createTextNode(s));
            return d.innerHTML;
        }
        function branchMapInfoContent(name, address, url) {
            var el = document.createElement('div');
            var strong = document.createElement('strong');
            strong.textContent = name;
            el.appendChild(strong);
            el.appendChild(document.createElement('br'));
            el.appendChild(document.createTextNode(address));
            el.appendChild(document.createElement('br'));
            var a = document.createElement('a');
            a.href = url;
            a.textContent = 'View Details';
            el.appendChild(a);
            return el;
        }
        function initializeBranchMap() {
            var lat = @Json.Serialize(Model.CenterLatitude);
            var lng = @Json.Serialize(Model.CenterLongitude);
            var latLng = new google.maps.LatLng(lat, lng);
            var mapOptions = {
                zoom: 10,
                center: latLng,
                mapTypeId: google.maps.MapTypeId.ROADMAP
            };
            var map = new google.maps.Map(document.getElementById('mapContainer'), mapOptions);
            var bounds = new google.maps.LatLngBounds();

            @foreach (var marker in Model.MapMarkers)
            {
                <text>
                (function() {
                    var markerName = @Json.Serialize(marker.Name);
                    var markerAddress = @Json.Serialize(marker.Address);
                    var detailsUrl = @Json.Serialize("?open=details&id=" + marker.Id);
                    var pos = new google.maps.LatLng(@Json.Serialize(marker.Latitude), @Json.Serialize(marker.Longitude));
                    var infoWindow = new google.maps.InfoWindow({ content: branchMapInfoContent(markerName, markerAddress, detailsUrl) });
                    var mapMarker = new google.maps.Marker({
                        position: pos,
                        map: map,
                        title: markerName
                    });
                    mapMarker.addListener('click', function() { infoWindow.open(map, mapMarker); });
                    bounds.extend(pos);
                })();
                </text>
            }

            @if (Model.MapMarkers.Count > 0)
            {
                <text>map.fitBounds(bounds);</text>
            }
        }
        google.maps.event.addDomListener(window, 'load', initializeBranchMap);
    </script>
}
