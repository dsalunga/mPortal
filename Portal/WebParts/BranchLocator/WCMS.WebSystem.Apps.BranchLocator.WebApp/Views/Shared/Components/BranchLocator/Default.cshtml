@model WCMS.WebSystem.WebParts.ViewComponents.BranchLocatorViewModel

<section class="branch-locator" aria-labelledby="branchLocatorHeading">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h1 id="branchLocatorHeading" class="mb-4">
                    <i class="bi bi-geo-alt me-2" aria-hidden="true"></i>Locale Chapters
                </h1>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="row mb-4">
                    <div class="col-lg-8 col-md-10">
                        <form class="form-search" method="get" action="@Model.BasePath" role="search" aria-label="Search locale chapters">
                            <input type="hidden" name="open" value="search" />
                            <input type="hidden" class="lat" name="lat" value="@Model.Latitude" />
                            <input type="hidden" class="lng" name="lng" value="@Model.Longitude" />
                            <div class="input-group">
                                <label for="txtSearch" class="visually-hidden">Search locale chapters</label>
                                <input id="txtSearch" name="search" type="search" class="form-control"
                                       placeholder="What locale are you searching?" value="@Model.SearchKeyword"
                                       aria-label="Search locale chapters" />
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search me-1" aria-hidden="true"></i> Search
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                @if (Model.SearchResults != null)
                {
                    <h3 class="mb-3">
                        Search Results
                        <span class="badge bg-secondary ms-1">@Model.SearchResults.Count</span>
                    </h3>
                    @if (Model.SearchResults.Count == 0)
                    {
                        <div class="alert alert-info" role="status" aria-live="polite">
                            <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
                            No results found. Try a different search term.
                        </div>
                    }
                    else
                    {
                        <div class="list-group mb-3">
                            @foreach (var item in Model.SearchResults)
                            {
                                <div class="list-group-item">
                                    <h5 class="mb-2">
                                        <a href="?open=details&id=@item.Id" class="text-decoration-none">@item.Name</a>
                                    </h5>
                                    <div class="small text-muted">
                                        @if (!string.IsNullOrEmpty(item.Address))
                                        {
                                            <p class="mb-1"><i class="bi bi-geo-alt me-1" aria-hidden="true"></i> @item.Address</p>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Mobile))
                                        {
                                            <p class="mb-1"><i class="bi bi-phone me-1" aria-hidden="true"></i> <a href="tel:@item.Mobile">@item.Mobile</a></p>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Telephone))
                                        {
                                            <p class="mb-1"><i class="bi bi-telephone me-1" aria-hidden="true"></i> <a href="tel:@item.Telephone">@item.Telephone</a></p>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Email))
                                        {
                                            <p class="mb-1"><i class="bi bi-envelope me-1" aria-hidden="true"></i> <a href="mailto:@item.Email">@item.Email</a></p>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
                else if (Model.HasLocation)
                {
                    <h3 class="mb-3">
                        <i class="bi bi-compass me-1" aria-hidden="true"></i> Nearby Chapters
                    </h3>
                    <p class="text-muted mb-3">
                        <i class="bi bi-geo-alt-fill me-1" aria-hidden="true"></i>
                        Your location: <span id="currentLocation" class="fw-semibold"></span>
                    </p>
                    <div class="list-group mb-3">
                        @foreach (var item in Model.NearbyChapters)
                        {
                            var distanceKM = WCMS.WebSystem.Apps.BranchLocator.FALHelper.GetCoordinatesDistance(
                                Model.Latitude, Model.Longitude, item.Latitude, item.Longitude) * 0.001;
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="mb-0">
                                        <a href="?open=details&id=@item.Id" class="text-decoration-none">@item.Name</a>
                                    </h5>
                                    <span class="badge bg-primary rounded-pill" aria-label="@string.Format("{0:N2}", distanceKM) kilometers away">
                                        @string.Format("{0:N2}", distanceKM) km
                                    </span>
                                </div>
                                <div class="small text-muted">
                                    @if (!string.IsNullOrEmpty(item.Address))
                                    {
                                        <p class="mb-1"><i class="bi bi-geo-alt me-1" aria-hidden="true"></i> @item.Address</p>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Mobile))
                                    {
                                        <p class="mb-1"><i class="bi bi-phone me-1" aria-hidden="true"></i> <a href="tel:@item.Mobile">@item.Mobile</a></p>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Telephone))
                                    {
                                        <p class="mb-1"><i class="bi bi-telephone me-1" aria-hidden="true"></i> <a href="tel:@item.Telephone">@item.Telephone</a></p>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Email))
                                    {
                                        <p class="mb-1"><i class="bi bi-envelope me-1" aria-hidden="true"></i> <a href="mailto:@item.Email">@item.Email</a></p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4" role="status" aria-live="polite">
                        <div class="spinner-border text-primary mb-2" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted">Loading nearby chapters...</p>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                @if (Model.ChapterParents.Count > 0)
                {
                    <aside class="card" aria-label="Browse chapters by region">
                        <div class="card-body">
                            <h4 class="card-title">
                                <i class="bi bi-list-nested me-1" aria-hidden="true"></i> Browse Chapters
                            </h4>
                            <hr class="mt-1" />
                            <nav aria-label="Chapter regions">
                                <ul class="list-unstyled mb-0">
                                    @foreach (var item in Model.ChapterParents)
                                    {
                                        <li class="mb-2">
                                            <i class="bi bi-geo-alt text-primary me-1" aria-hidden="true"></i>
                                            <a href="?open=browse&id=@item.Id" class="text-decoration-none">@item.Name</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        </div>
                    </aside>
                }
            </div>
        </div>
    </div>
</section>
