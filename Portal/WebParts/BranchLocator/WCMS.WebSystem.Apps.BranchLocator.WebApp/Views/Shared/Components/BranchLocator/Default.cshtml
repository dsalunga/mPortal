@model WCMS.WebSystem.WebParts.ViewComponents.BranchLocatorViewModel
<div class="container">
    <div class="row">
        <div class="col-lg-12">
            <h1 class="page-header">Locale Chapters</h1>
        </div>
    </div>
</div>
<div class="container">
    <div class="row">
        <div class="col-lg-8">
            <div class="row">
                <div class="col-lg-6">
                    <form class="form-search" method="get" action="@Model.BasePath">
                        <input type="hidden" name="open" value="search" />
                        <input type="hidden" class="lat" name="lat" value="@Model.Latitude" />
                        <input type="hidden" class="lng" name="lng" value="@Model.Longitude" />
                        <div class="input-group">
                            <input id="txtSearch" name="search" type="text" class="search-query form-control"
                                   placeholder="What locale are you searching?" value="@Model.SearchKeyword" />
                            <span class="input-group-btn">
                                <button type="submit" class="btn btn-default">Search</button>
                            </span>
                        </div>
                    </form>
                </div>
            </div>

            @if (Model.SearchResults != null)
            {
                <h3>Search Results</h3>
                @if (Model.SearchResults.Count == 0)
                {
                    <p>No results found.</p>
                }
                else
                {
                    foreach (var item in Model.SearchResults)
                    {
                        <div>
                            <div class="alert alert-info chapter-title-block">
                                <a href="?open=details&id=@item.Id">@item.Name</a>
                            </div>
                            @if (!string.IsNullOrEmpty(item.Address))
                            {
                                <p><span class="glyphicon glyphicon-map-marker"></span> Address: @item.Address</p>
                            }
                            @if (!string.IsNullOrEmpty(item.Mobile))
                            {
                                <p><span class="glyphicon glyphicon-phone"></span> Mobile: @item.Mobile</p>
                            }
                            @if (!string.IsNullOrEmpty(item.Telephone))
                            {
                                <p><span class="glyphicon glyphicon-earphone"></span> Telephone: @item.Telephone</p>
                            }
                            @if (!string.IsNullOrEmpty(item.Email))
                            {
                                <p><span class="glyphicon glyphicon-envelope"></span> Email: @item.Email</p>
                            }
                            <br />
                        </div>
                    }
                }
            }
            else if (Model.HasLocation)
            {
                <h3>Nearby Chapters</h3>
                <div>
                    <span class="glyphicon glyphicon-map-marker"></span> Your location: <span id="currentLocation"></span>
                </div>
                <br />
                @foreach (var item in Model.NearbyChapters)
                {
                    var distanceKM = WCMS.WebSystem.Apps.BranchLocator.FALHelper.GetCoordinatesDistance(
                        Model.Latitude, Model.Longitude, item.Latitude, item.Longitude) * 0.001;
                    <div>
                        <div class="alert alert-info chapter-title-block">
                            <a href="?open=details&id=@item.Id">@item.Name</a>
                            <span class="label label-default pull-right">@string.Format("{0:N2}", distanceKM) km</span>
                        </div>
                        @if (!string.IsNullOrEmpty(item.Address))
                        {
                            <p><span class="glyphicon glyphicon-map-marker"></span> Address: @item.Address</p>
                        }
                        @if (!string.IsNullOrEmpty(item.Mobile))
                        {
                            <p><span class="glyphicon glyphicon-phone"></span> Mobile: @item.Mobile</p>
                        }
                        @if (!string.IsNullOrEmpty(item.Telephone))
                        {
                            <p><span class="glyphicon glyphicon-earphone"></span> Telephone: @item.Telephone</p>
                        }
                        @if (!string.IsNullOrEmpty(item.Email))
                        {
                            <p><span class="glyphicon glyphicon-envelope"></span> Email: @item.Email</p>
                        }
                        <br />
                    </div>
                }
            }
            else
            {
                <br />
                <div class="loading-content">
                    <span>Loading nearby chapters...</span>
                    <br /><br />
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="well">
                @if (Model.ChapterParents.Count > 0)
                {
                    <h4>Browse Chapters</h4>
                    <hr style="margin-top: 0" />
                    foreach (var item in Model.ChapterParents)
                    {
                        <p><i class="glyphicon glyphicon-map-marker"></i> <a href="?open=browse&id=@item.Id">@item.Name</a></p>
                    }
                }
            </div>
        </div>
    </div>
</div>
