@model WCMS.WebSystem.WebParts.G2.ViewComponents.DownloadDownloadsViewModel
@* Ported from Downloads.ascx (AppBundle2/Download). *@

<div class="component-downloaddownloads">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Downloads</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Downloads component requires configuration.
        </div>
    }
</div>
