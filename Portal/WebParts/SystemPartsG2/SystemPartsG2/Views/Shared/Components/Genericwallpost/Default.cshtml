@model WCMS.WebSystem.WebParts.G2.ViewComponents.GenericwallpostViewModel
@* Ported from GenericWallPost.ascx (AppBundle2/Social/Plugins). *@

<div class="component-genericwallpost">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Generic Wall Post</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Generic Wall Post component requires configuration.
        </div>
    }
</div>
