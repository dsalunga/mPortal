@model WCMS.WebSystem.WebParts.G2.ViewComponents.NewsletterEnewsletterViewModel
@* Ported from eNewsLetter.ascx. *@

<div class="component-newsletter-enewsletter">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_EmailAddress" class="form-label">Email Address</label>
            <input type="text" class="form-control" id="field_EmailAddress" name="EmailAddress" value="@Model.EmailAddress" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="btnSubmit">Submit</button>
        </div>
    </form>
</div>