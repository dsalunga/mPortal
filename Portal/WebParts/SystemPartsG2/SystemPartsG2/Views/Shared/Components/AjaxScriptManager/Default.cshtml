@model WCMS.WebSystem.WebParts.G2.ViewComponents.AjaxScriptManagerViewModel
@* Script references are invisible to users — no visual chrome needed *@
<section id="script-manager-@Model.ObjectId" class="wcms-script-manager" data-object-id="@Model.ObjectId"
         aria-hidden="true" role="presentation">
    @if (Model.Scripts != null && Model.Scripts.Count > 0)
    {
        @foreach (var script in Model.Scripts)
        {
            if (!string.IsNullOrEmpty(script.Src))
            {
                <script src="@script.Src"
                        @(script.IsAsync ? "async" : "")
                        @(script.IsDefer ? "defer" : "")></script>
            }
        }
    }
</section>
