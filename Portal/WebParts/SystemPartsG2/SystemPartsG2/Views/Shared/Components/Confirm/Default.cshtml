@model WCMS.WebSystem.WebParts.G2.ViewComponents.ConfirmViewModel
@* Ported from Confirm.aspx (AppBundle2/Newsletter). *@

<div class="component-confirm">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Confirm</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Confirm component requires configuration.
        </div>
    }
</div>
