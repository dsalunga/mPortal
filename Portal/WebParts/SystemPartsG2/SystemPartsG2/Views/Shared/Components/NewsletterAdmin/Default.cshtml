@model WCMS.WebSystem.WebParts.G2.ViewComponents.NewsletterAdminViewModel
<section id="newsletter-admin-@Model.ObjectId" class="wcms-newsletter-admin" data-object-id="@Model.ObjectId"
         aria-labelledby="newsletter-admin-heading-@Model.ObjectId">
    <div class="card shadow-sm">
        <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
            <h4 class="mb-0" id="newsletter-admin-heading-@Model.ObjectId">
                <i class="bi bi-newspaper" aria-hidden="true"></i> Newsletter Management
            </h4>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-info text-dark" aria-label="@Model.TotalSubscribers total subscribers">
                    <i class="bi bi-people me-1" aria-hidden="true"></i>@Model.TotalSubscribers subscribers
                </span>
                <button type="button" class="btn btn-primary btn-sm" aria-label="Create new newsletter">
                    <i class="bi bi-envelope-plus" aria-hidden="true"></i> New Newsletter
                </button>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Newsletters == null || Model.Newsletters.Count == 0)
            {
                <p class="text-muted text-center py-3" role="status">
                    <i class="bi bi-inbox" aria-hidden="true"></i> No newsletters sent yet.
                </p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle"
                           aria-describedby="newsletter-admin-heading-@Model.ObjectId">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Subject</th>
                                <th scope="col">Status</th>
                                <th scope="col">Sent</th>
                                <th scope="col">Recipients</th>
                                <th scope="col">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Newsletters)
                            {
                                <tr>
                                    <td>@item.Subject</td>
                                    <td>
                                        <span class="badge @(item.Status == "Sent" ? "bg-success" : "bg-warning text-dark")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td>
                                        <time datetime="@item.SentDate">@item.SentDate</time>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary rounded-pill">@item.RecipientCount</span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group" aria-label="Actions for @item.Subject">
                                            <button class="btn btn-outline-primary" aria-label="View @item.Subject">
                                                <i class="bi bi-eye" aria-hidden="true"></i> View
                                            </button>
                                            <button class="btn btn-outline-danger" aria-label="Delete @item.Subject">
                                                <i class="bi bi-trash" aria-hidden="true"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>
