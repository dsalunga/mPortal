@model WCMS.WebSystem.WebParts.G2.ViewComponents.CcmsMailsenderViewModel
@* Ported from CCMS_MailSender.ascx (AppBundle2/Newsletter). *@

<div class="component-ccmsmailsender">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>CCMS Mail Sender</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            CCMS Mail Sender component requires configuration.
        </div>
    }
</div>
