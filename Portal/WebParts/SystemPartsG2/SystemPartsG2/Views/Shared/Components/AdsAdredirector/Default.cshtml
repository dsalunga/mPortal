@model WCMS.WebSystem.WebParts.G2.ViewComponents.AdsAdredirectorViewModel
@* Ported from AdRedirector.aspx (AppBundle2/Ads). *@

<div class="component-adsadredirector">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Ad Redirector</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Ad Redirector component requires configuration.
        </div>
    }
</div>
