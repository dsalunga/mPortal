@model WCMS.WebSystem.WebParts.G2.ViewComponents.MediaMediahomeViewModel
@* Ported from mediahome.ascx. *@

<div class="component-media-mediahome">
    @if (Model.Items.Any())
    {
        <div class="list-group">
            @foreach (var item in Model.Items)
            {
                <div class="list-group-item">
                    <span>@item.Name</span>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted fst-italic">No items available.</p>
    }
</div>