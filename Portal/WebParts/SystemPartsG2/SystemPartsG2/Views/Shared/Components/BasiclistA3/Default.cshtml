@model WCMS.WebSystem.WebParts.G2.ViewComponents.BasiclistA3ViewModel
@* Ported from BasicList_A3.ascx (AppBundle2/Download/Controls). *@

<div class="component-basiclista3">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Basic List A3</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Basic List A3 component requires configuration.
        </div>
    }
</div>
