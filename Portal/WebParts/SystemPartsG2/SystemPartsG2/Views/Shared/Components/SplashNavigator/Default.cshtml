@model WCMS.WebSystem.WebParts.G2.ViewComponents.SplashNavigatorViewModel
<nav id="splash-nav-@Model.ObjectId" class="wcms-splash-navigator" data-object-id="@Model.ObjectId"
     aria-label="Feature navigation">
    @if (Model.Items.Count == 0)
    {
        <p class="text-muted" role="status">No navigation items configured.</p>
    }
    else
    {
        <div class="row g-3" role="list">
            @foreach (var item in Model.Items)
            {
                <div class="col-lg-4 col-md-4 col-sm-6" role="listitem">
                    <a href="@item.Url" class="text-decoration-none" aria-label="@item.Title">
                        <article class="card text-center h-100 shadow-sm">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <figure class="mb-0">
                                    <img src="@item.ImageUrl" alt="@item.Title" class="card-img-top" loading="lazy" />
                                </figure>
                            }
                            <div class="card-body">
                                <h5 class="card-title">@item.Title</h5>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <p class="card-text text-muted">@item.Description</p>
                                }
                            </div>
                        </article>
                    </a>
                </div>
            }
        </div>
    }
</nav>
