@model WCMS.WebSystem.WebParts.G2.ViewComponents.SplashNavigatorViewModel
<nav id="splash-nav-@Model.ObjectId" class="wcms-splash-navigator" data-object-id="@Model.ObjectId"
     aria-label="Feature navigation">
    @if (Model.Items == null || Model.Items.Count == 0)
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <p class="text-muted text-center py-3 mb-0" role="status">
                    <i class="bi bi-signpost-2" aria-hidden="true"></i> No navigation items configured.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3" role="list">
            @foreach (var item in Model.Items)
            {
                <div class="col-xl-3 col-lg-4 col-md-4 col-sm-6" role="listitem">
                    <a href="@item.Url" class="text-decoration-none" aria-label="@item.Title">
                        <article class="card text-center h-100 shadow-sm">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <figure class="mb-0">
                                    <img src="@item.ImageUrl" alt="@item.Title" class="card-img-top"
                                         loading="lazy" decoding="async" />
                                </figure>
                            }
                            <div class="card-body">
                                <h5 class="card-title">@item.Title</h5>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <p class="card-text text-muted small">@item.Description</p>
                                }
                            </div>
                        </article>
                    </a>
                </div>
            }
        </div>
    }
</nav>
