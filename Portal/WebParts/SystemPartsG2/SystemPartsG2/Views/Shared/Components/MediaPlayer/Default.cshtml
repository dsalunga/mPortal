@model WCMS.WebSystem.WebParts.G2.ViewComponents.MediaPlayerViewModel
<div class="wcms-media-player" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
    @if (!string.IsNullOrEmpty(Model.Title))
    {
        <h4>@Model.Title</h4>
    }
    @if (!string.IsNullOrEmpty(Model.MediaUrl))
    {
        @if (Model.MediaType != null && Model.MediaType.StartsWith("audio"))
        {
            <audio controls class="w-100" @(Model.AutoPlay ? "autoplay" : "")>
                <source src="@Model.MediaUrl" type="@Model.MediaType" />
                Your browser does not support the audio element.
            </audio>
        }
        else
        {
            <div class="ratio ratio-16x9">
                <video controls @(Model.AutoPlay ? "autoplay" : "")
                       @if (!string.IsNullOrEmpty(Model.PosterUrl)) { <text>poster="@Model.PosterUrl"</text> }>
                    <source src="@Model.MediaUrl" type="@Model.MediaType" />
                    Your browser does not support the video element.
                </video>
            </div>
        }
    }
    else
    {
        <p class="text-muted">No media source configured.</p>
    }
</div>
