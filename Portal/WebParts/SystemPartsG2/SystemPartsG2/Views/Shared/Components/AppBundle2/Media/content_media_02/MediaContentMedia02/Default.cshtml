@model WCMS.WebSystem.WebParts.G2.ViewComponents.MediaContentMedia02ViewModel
@* Ported from content_media_02.ascx. *@

<div class="component-media-content-media02">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Name" class="form-label">Name</label>
            <input type="text" class="form-control" id="field_Name" name="Name" value="@Model.Name" />
        </div>
        <div class="mb-3">
            <label for="field_Version" class="form-label">Version</label>
            <input type="text" class="form-control" id="field_Version" name="Version" value="@Model.Version" />
        </div>
        <div class="mb-3">
            <label for="field_Length" class="form-label">Length</label>
            <input type="text" class="form-control" id="field_Length" name="Length" value="@Model.Length" />
        </div>
        <div class="mb-3">
            <label for="field_Agency" class="form-label">Agency</label>
            <textarea class="form-control" id="field_Agency" name="Agency" rows="4">@Model.Agency</textarea>
        </div>
        <div class="mb-3">
            <label for="field_Filename" class="form-label">Filename</label>
            <input type="text" class="form-control" id="field_Filename" name="Filename" value="@Model.Filename" />
        </div>
        <div class="mb-3">
            <label for="field_CboSites" class="form-label">Cbo Sites</label>
            <select class="form-select" id="field_CboSites" name="SelectedCboSites">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboSitesOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboSites ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboRank" class="form-label">Cbo Rank</label>
            <select class="form-select" id="field_CboRank" name="SelectedCboRank">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboRankOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboRank ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_Active" name="Active" @(Model.Active ? "checked" : "") />
            <label class="form-check-label" for="field_Active">Active</label>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>