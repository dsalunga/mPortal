@model WCMS.WebSystem.WebParts.G2.ViewComponents.DatedisplayCmsDatedisplayViewModel
@* Ported from CMS_DateDisplay.ascx. *@

<div class="component-datedisplay-cms-datedisplay">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_FormatString" class="form-label">Format String</label>
            <input type="text" class="form-control" id="field_FormatString" name="FormatString" value="@Model.FormatString" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
        </div>
    </form>
</div>