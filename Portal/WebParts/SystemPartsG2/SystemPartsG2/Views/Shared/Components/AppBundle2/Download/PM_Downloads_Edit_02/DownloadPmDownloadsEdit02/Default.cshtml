@model WCMS.WebSystem.WebParts.G2.ViewComponents.DownloadPmDownloadsEdit02ViewModel
@* Ported from PM_Downloads_Edit_02.ascx. *@

<div class="component-download-pm-downloads-edit02">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Name" class="form-label">Name</label>
            <input type="text" class="form-control" id="field_Name" name="Name" value="@Model.Name" />
        </div>
        <div class="mb-3">
            <label for="field_Filename" class="form-label">Filename</label>
            <input type="text" class="form-control" id="field_Filename" name="Filename" value="@Model.Filename" />
        </div>
        <div class="mb-3">
            <label for="field_Date" class="form-label">Date</label>
            <input type="text" class="form-control" id="field_Date" name="Date" value="@Model.Date" />
        </div>
        <div class="mb-3">
            <label for="field_Rank" class="form-label">Rank</label>
            <input type="text" class="form-control" id="field_Rank" name="Rank" value="@Model.Rank" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpload">Upload...</button>
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>