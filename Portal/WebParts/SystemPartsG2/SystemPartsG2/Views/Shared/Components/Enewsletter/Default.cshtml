@model WCMS.WebSystem.WebParts.G2.ViewComponents.EnewsletterViewModel
@* Ported from eNewsLetter.ascx (AppBundle2/Newsletter). *@

<div class="component-enewsletter">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>e News Letter</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            e News Letter component requires configuration.
        </div>
    }
</div>
