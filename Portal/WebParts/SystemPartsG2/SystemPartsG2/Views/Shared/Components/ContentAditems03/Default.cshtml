@model WCMS.WebSystem.WebParts.G2.ViewComponents.ContentAditems03ViewModel
@* Ported from content_aditems_03.ascx. *@

<div class="component-content-aditems03">
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th scope="col" style="width:60px" class="text-center">Actions</th>
                    <th scope="col">ID</th>
                    <th scope="col">&lt;input type=&quot;checkbox&quot; name=&quot;chkCheckedMain&quot; onclick=&quot;CheckAll(this, 'chkChecked');&quot;&gt;</th>
                    <th scope="col">Alternate Text</th>
                    <th scope="col">Link</th>
                    <th scope="col">Image</th>
                    <th scope="col">Keyword</th>
                    <th scope="col">Impressions</th>
                    <th scope="col">Hits</th>
                    <th scope="col">Appearance</th>
                    <th scope="col">Edit</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="text-center">
                                <a href="?action=edit&id=@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                            <td>@item.AdItemID</td>
                            <td>@item.AdItemID</td>
                            <td>@item.AlternateText</td>
                            <td>@item.NavigateUrl</td>
                            <td>@item.ImageUrl</td>
                            <td>@item.Keyword</td>
                            <td>@item.Impressions</td>
                            <td>@item.Hits</td>
                            <td>@item.Appearance</td>
                            <td>@item.Edit</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="11" class="text-center text-muted fst-italic">No records found.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalItems > Model.PageSize)
    {
        var pageCount = (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize);
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center mt-3">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage - 1)" aria-label="Previous">&laquo;</a>
                </li>
                @for (int i = 1; i <= pageCount; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= pageCount ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage + 1)" aria-label="Next">&raquo;</a>
                </li>
            </ul>
        </nav>
    }
</div>