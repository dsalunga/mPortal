@model WCMS.WebSystem.WebParts.G2.ViewComponents.SocialConfigwallViewModel
@* Ported from ConfigWall.ascx (AppBundle2/Social). *@

<div class="component-socialconfigwall">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Config Wall</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
