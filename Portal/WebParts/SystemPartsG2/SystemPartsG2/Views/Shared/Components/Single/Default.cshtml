@model WCMS.WebSystem.WebParts.G2.ViewComponents.SingleViewModel
@* Ported from Single.ascx (AppBundle2/BasicList/ItemTemplates). *@

<div class="component-single">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Single</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Single component requires configuration.
        </div>
    }
</div>
