@model WCMS.WebSystem.WebParts.G2.ViewComponents.NewsletterCcmsEnewsletterViewModel
@* Ported from CCMS_eNewsletter.ascx (AppBundle2/Newsletter). *@

<div class="component-newsletterccmsenewsletter">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>CCMS e Newsletter</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            CCMS e Newsletter component requires configuration.
        </div>
    }
</div>
