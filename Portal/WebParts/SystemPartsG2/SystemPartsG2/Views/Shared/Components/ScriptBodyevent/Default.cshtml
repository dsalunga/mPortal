@model WCMS.WebSystem.WebParts.G2.ViewComponents.ScriptBodyeventViewModel
@* Ported from BodyEvent.ascx (AppBundle2/Misc/Script). *@

<div class="component-scriptbodyevent">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Body Event</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Body Event component requires configuration.
        </div>
    }
</div>
