@model WCMS.WebSystem.WebParts.G2.ViewComponents.DownloadsViewModel
<div class="wcms-downloads" data-object-id="@Model.ObjectId">
    <h4>Downloads</h4>
    @if (Model.Categories.Count > 0)
    {
        <div class="mb-3">
            <select class="form-select" aria-label="Filter by category">
                <option value="">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
        </div>
    }
    @if (Model.Items.Count == 0)
    {
        <p class="text-muted">No downloads available.</p>
    }
    else
    {
        <div class="list-group">
            @foreach (var item in Model.Items)
            {
                <a href="@item.FileUrl" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">@item.Title</h6>
                            <small class="text-muted">@item.FileName &middot; @item.CategoryName</small>
                        </div>
                        <span class="badge bg-primary rounded-pill">@item.DownloadCount</span>
                    </div>
                </a>
            }
        </div>
    }
</div>
