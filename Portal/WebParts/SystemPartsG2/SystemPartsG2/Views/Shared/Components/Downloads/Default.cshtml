@model WCMS.WebSystem.WebParts.G2.ViewComponents.DownloadsViewModel
<div class="wcms-downloads" data-object-id="@Model.ObjectId">
    <h4>Downloads</h4>
    @if (Model.Categories != null && Model.Categories.Count > 0)
    {
        <div class="mb-3">
            <select class="form-select" aria-label="Filter by category">
                <option value="">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
        </div>
    }
    @if (Model.Items == null || Model.Items.Count == 0)
    {
        <p class="text-muted">No downloads available.</p>
    }
    else if (Model.GroupByYear)
    {
        <!-- GroupByYear layout (from GroupByYear.ascx / BasicList.ascx) -->
        var years = Model.Items.Select(i => i.FileYear).Distinct().OrderByDescending(y => y);
        @foreach (var year in years)
        {
            <div class="mb-3">
                <strong>@year</strong><br />
                <ul class="list-unstyled ms-2">
                    @foreach (var item in Model.Items.Where(i => i.FileYear == year))
                    {
                        <li>
                            <img alt="" src="/Assets/Uploads/Image/arrow.gif" width="9" height="9" />
                            <span class="txt11">
                                <a href="@(string.IsNullOrEmpty(item.FileUrl) ? $"/_Sections/Download/Handler.ashx?ID={item.Id}&Force={(Model.ForceDownload ? "true" : "false")}" : item.FileUrl)">
                                    @item.Title
                                </a>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }
    }
    else
    {
        <!-- DetailedList layout (from DetailedList.ascx / BasicList.ascx) -->
        <ul class="list-unstyled">
            @foreach (var item in Model.Items)
            {
                <li class="mb-2">
                    <img alt="" src="/Assets/Uploads/Image/arrow.gif" width="9" height="9" />
                    <span class="txt11">
                        <a href="@(string.IsNullOrEmpty(item.FileUrl) ? $"/_Sections/Download/Handler.ashx?ID={item.Id}&Force={(Model.ForceDownload ? "true" : "false")}" : item.FileUrl)">
                            @item.Title
                        </a>
                    </span>
                    @if (!string.IsNullOrEmpty(item.FileInfo))
                    {
                        <br />
                        <span class="ms-3 text-muted">@item.FileInfo</span>
                    }
                    else if (!string.IsNullOrEmpty(item.FileName))
                    {
                        <br />
                        <span class="ms-3">
                            <small class="text-muted">@item.FileName &middot; @item.CategoryName</small>
                        </span>
                    }
                    @if (item.DownloadCount > 0)
                    {
                        <span class="badge bg-primary rounded-pill ms-1">@item.DownloadCount</span>
                    }
                </li>
            }
        </ul>
    }
</div>
