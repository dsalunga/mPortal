@model WCMS.WebSystem.WebParts.G2.ViewComponents.DetailedlistViewModel
@* Ported from DetailedList.ascx (AppBundle2/Download/Controls). *@

<div class="component-detailedlist">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Detailed List</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Detailed List component requires configuration.
        </div>
    }
</div>
