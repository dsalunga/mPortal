@model WCMS.WebSystem.WebParts.G2.ViewComponents.DownloadAdminViewModel
<section id="download-admin-@Model.ObjectId" class="wcms-download-admin" data-object-id="@Model.ObjectId"
         aria-labelledby="download-admin-heading-@Model.ObjectId">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 id="download-admin-heading-@Model.ObjectId">Download Management</h4>
        <button type="button" class="btn btn-primary btn-sm" aria-label="Upload a new file">
            <i class="bi bi-upload" aria-hidden="true"></i> Upload File
        </button>
    </div>
    @if (Model.Downloads.Count == 0)
    {
        <div class="alert alert-info" role="status">No downloads configured.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle"
                   aria-describedby="download-admin-heading-@Model.ObjectId">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Title</th>
                        <th scope="col">File</th>
                        <th scope="col">Size</th>
                        <th scope="col">Downloads</th>
                        <th scope="col">Active</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Downloads)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td><code>@item.FileName</code></td>
                            <td>@item.FileSize</td>
                            <td>
                                <span class="badge bg-info text-dark rounded-pill">@item.DownloadCount</span>
                            </td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                    @(item.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Actions for @item.Title">
                                    <button class="btn btn-outline-primary" aria-label="Edit @item.Title">Edit</button>
                                    <button class="btn btn-outline-danger" aria-label="Delete @item.Title">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
