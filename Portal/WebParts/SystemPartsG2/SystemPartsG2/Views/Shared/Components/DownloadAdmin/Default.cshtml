@model WCMS.WebSystem.WebParts.G2.ViewComponents.DownloadAdminViewModel
<div class="wcms-download-admin" data-object-id="@Model.ObjectId">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Download Management</h4>
        <button type="button" class="btn btn-primary btn-sm">
            <i class="bi bi-upload"></i> Upload File
        </button>
    </div>
    @if (Model.Downloads.Count == 0)
    {
        <div class="alert alert-info">No downloads configured.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>File</th>
                    <th>Size</th>
                    <th>Downloads</th>
                    <th>Active</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Downloads)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.FileName</td>
                        <td>@item.FileSize</td>
                        <td>@item.DownloadCount</td>
                        <td>
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary">Edit</button>
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
