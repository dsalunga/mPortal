@model WCMS.WebSystem.WebParts.G2.ViewComponents.DatedisplayCmsDatedisplayViewModel
@* Ported from CMS_DateDisplay.ascx (AppBundle2/Misc/DateDisplay). *@

<div class="component-datedisplaycmsdatedisplay">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>CMS Date Display</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            CMS Date Display component requires configuration.
        </div>
    }
</div>
