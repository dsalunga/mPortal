@model WCMS.WebSystem.WebParts.G2.ViewComponents.CommentsViewModel
<section id="comments-@Model.ObjectId-@Model.RecordId" class="wcms-comments"
         data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId"
         aria-labelledby="comments-heading-@Model.ObjectId-@Model.RecordId">
    <h5 id="comments-heading-@Model.ObjectId-@Model.RecordId">
        Comments
        <span class="badge bg-secondary ms-1">@Model.Comments.Count</span>
    </h5>
    @if (Model.Comments.Count == 0)
    {
        <p class="text-muted" role="status">No comments yet.</p>
    }
    else
    {
        <div aria-live="polite">
            @foreach (var comment in Model.Comments)
            {
                <article class="card mb-2" aria-label="Comment by @comment.Author">
                    <div class="card-body">
                        <header class="d-flex justify-content-between align-items-center">
                            <strong>@comment.Author</strong>
                            <time class="text-muted small" datetime="@comment.DatePosted">@comment.DatePosted</time>
                        </header>
                        <p class="mb-0 mt-1">@comment.Text</p>
                    </div>
                </article>
            }
        </div>
    }
    @if (Model.AllowNewComments)
    {
        <form method="post" class="mt-3 card card-body bg-light" aria-label="Post a new comment">
            <div class="mb-2">
                <label for="comment-author-@Model.ObjectId" class="form-label visually-hidden">Your name</label>
                <input type="text" class="form-control" id="comment-author-@Model.ObjectId"
                       name="author" placeholder="Your name" required aria-required="true" />
            </div>
            <div class="mb-2">
                <label for="comment-text-@Model.ObjectId" class="form-label visually-hidden">Comment text</label>
                <textarea class="form-control" id="comment-text-@Model.ObjectId"
                          name="text" rows="3" placeholder="Write a comment..." required aria-required="true"></textarea>
            </div>
            <div>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-chat-dots" aria-hidden="true"></i> Post Comment
                </button>
            </div>
        </form>
    }
</section>
