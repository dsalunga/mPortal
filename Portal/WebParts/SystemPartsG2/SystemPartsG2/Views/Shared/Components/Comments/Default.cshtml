@model WCMS.WebSystem.WebParts.G2.ViewComponents.CommentsViewModel
<section id="comments-@Model.ObjectId-@Model.RecordId" class="wcms-comments"
         data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId"
         aria-labelledby="comments-heading-@Model.ObjectId-@Model.RecordId">
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0" id="comments-heading-@Model.ObjectId-@Model.RecordId">
                <i class="bi bi-chat-dots" aria-hidden="true"></i> Comments
                <span class="badge bg-secondary ms-1">@Model.Comments.Count</span>
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Comments == null || Model.Comments.Count == 0)
            {
                <p class="text-muted text-center py-3" role="status">
                    <i class="bi bi-chat" aria-hidden="true"></i> No comments yet. Be the first to comment.
                </p>
            }
            else
            {
                <div aria-live="polite">
                    @foreach (var comment in Model.Comments)
                    {
                        <article class="d-flex mb-3 pb-3 border-bottom" aria-label="Comment by @comment.Author">
                            <div class="flex-shrink-0 me-3">
                                <span class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width:40px;height:40px;" aria-hidden="true">
                                    <i class="bi bi-person"></i>
                                </span>
                            </div>
                            <div class="flex-grow-1">
                                <header class="d-flex justify-content-between align-items-center">
                                    <strong>@comment.Author</strong>
                                    <time class="text-muted small" datetime="@comment.DatePosted">@comment.DatePosted</time>
                                </header>
                                <p class="mb-0 mt-1">@comment.Text</p>
                            </div>
                        </article>
                    }
                </div>
            }
            @if (Model.AllowNewComments)
            {
                <form method="post" class="border-top pt-3 mt-2" aria-label="Post a new comment">
                    <div class="mb-2">
                        <label for="comment-author-@Model.ObjectId" class="form-label">Your name</label>
                        <input type="text" class="form-control" id="comment-author-@Model.ObjectId"
                               name="author" placeholder="Enter your name" required aria-required="true" />
                    </div>
                    <div class="mb-2">
                        <label for="comment-text-@Model.ObjectId" class="form-label">Comment</label>
                        <textarea class="form-control" id="comment-text-@Model.ObjectId"
                                  name="text" rows="3" placeholder="Write a comment…" required aria-required="true"></textarea>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-send" aria-hidden="true"></i> Post Comment
                        </button>
                    </div>
                </form>
            }
        </div>
    </div>
</section>
