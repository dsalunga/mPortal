@model WCMS.WebSystem.WebParts.G2.ViewComponents.NewsletterCmsEnewsletterViewModel
@* Ported from CMS_Enewsletter.ascx (AppBundle2/Newsletter). *@

<div class="component-newslettercmsenewsletter">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>CMS Enewsletter</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
