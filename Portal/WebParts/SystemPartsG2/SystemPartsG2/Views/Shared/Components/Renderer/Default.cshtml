@model WCMS.WebSystem.WebParts.G2.ViewComponents.RendererViewModel
@* Ported from Renderer.ascx (AppBundle2/FlashBanner). *@

<div class="component-renderer">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Renderer</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Renderer component requires configuration.
        </div>
    }
</div>
