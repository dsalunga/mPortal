@model WCMS.WebSystem.WebParts.G2.ViewComponents.AdManagerViewModel
<div class="wcms-ad-manager" data-object-id="@Model.ObjectId">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Ad Management</h4>
        <button type="button" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Add Ad
        </button>
    </div>
    @if (Model.Ads.Count == 0)
    {
        <div class="alert alert-info">No ads configured.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>URL</th>
                    <th>Order</th>
                    <th>Active</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ad in Model.Ads)
                {
                    <tr>
                        <td>@ad.Title</td>
                        <td><a href="@ad.TargetUrl" target="_blank">@ad.TargetUrl</a></td>
                        <td>@ad.DisplayOrder</td>
                        <td>
                            <span class="badge @(ad.IsActive ? "bg-success" : "bg-secondary")">
                                @(ad.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary">Edit</button>
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
