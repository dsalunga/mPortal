@model WCMS.WebSystem.WebParts.G2.ViewComponents.ListingPageViewModel
<div class="wcms-listing-page" data-object-id="@Model.ObjectId">
    @if (!string.IsNullOrEmpty(Model.Title))
    {
        <h4>@Model.Title</h4>
    }
    @if (Model.Items.Count == 0)
    {
        <p class="text-muted">No items to display.</p>
    }
    else
    {
        <div class="list-group mb-3">
            @foreach (var item in Model.Items)
            {
                <a href="@item.Url" class="list-group-item list-group-item-action">
                    <div class="d-flex">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <div class="flex-shrink-0 me-3">
                                <img src="@item.ImageUrl" alt="@item.Title" class="rounded" style="max-width: 100px;" loading="lazy" />
                            </div>
                        }
                        <div class="flex-grow-1">
                            <h6 class="mb-1">@item.Title</h6>
                            @if (!string.IsNullOrEmpty(item.Summary))
                            {
                                <p class="mb-1 text-muted small">@item.Summary</p>
                            }
                            @if (!string.IsNullOrEmpty(item.Date))
                            {
                                <small class="text-muted">@item.Date</small>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
        @if (Model.TotalItems > Model.PageSize)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="#">Previous</a>
                    </li>
                    <li class="page-item active">
                        <span class="page-link">@Model.CurrentPage</span>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="#">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
