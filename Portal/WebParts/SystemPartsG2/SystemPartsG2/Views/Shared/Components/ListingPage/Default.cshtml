@model WCMS.WebSystem.WebParts.G2.ViewComponents.ListingPageViewModel
@{
    var totalPages = Model.PageSize > 0 ? (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize) : 1;
}
<section id="listing-@Model.ObjectId" class="wcms-listing-page" data-object-id="@Model.ObjectId"
         aria-labelledby="@(string.IsNullOrEmpty(Model.Title) ? "" : $"listing-heading-{Model.ObjectId}")">
    @if (!string.IsNullOrEmpty(Model.Title))
    {
        <h4 id="listing-heading-@Model.ObjectId">@Model.Title</h4>
    }
    @if (Model.Items.Count == 0)
    {
        <p class="text-muted" role="status">No items to display.</p>
    }
    else
    {
        <div class="list-group mb-3" role="list">
            @foreach (var item in Model.Items)
            {
                <a href="@item.Url" class="list-group-item list-group-item-action" role="listitem"
                   aria-label="@item.Title">
                    <div class="d-flex align-items-start">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <figure class="flex-shrink-0 me-3 mb-0">
                                <img src="@item.ImageUrl" alt="@item.Title" class="rounded img-thumbnail" style="max-width: 100px;" loading="lazy" />
                            </figure>
                        }
                        <div class="flex-grow-1">
                            <h6 class="mb-1">@item.Title</h6>
                            @if (!string.IsNullOrEmpty(item.Summary))
                            {
                                <p class="mb-1 text-muted small">@item.Summary</p>
                            }
                            @if (!string.IsNullOrEmpty(item.Date))
                            {
                                <time class="text-muted small" datetime="@item.Date">
                                    <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>@item.Date
                                </time>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
        @if (Model.TotalItems > Model.PageSize)
        {
            <nav aria-label="Listing page navigation for @(string.IsNullOrEmpty(Model.Title) ? "items" : Model.Title)">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="#" aria-label="Previous page">&laquo; Previous</a>
                    </li>
                    <li class="page-item active" aria-current="page">
                        <span class="page-link">
                            @Model.CurrentPage <span class="visually-hidden">(current)</span>
                        </span>
                    </li>
                    <li class="page-item @(Model.CurrentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="#" aria-label="Next page">Next &raquo;</a>
                    </li>
                </ul>
            </nav>
        }
    }
</section>
