@model WCMS.WebSystem.WebParts.G2.ViewComponents.TitleSitesectionViewModel
@* Ported from SiteSection.ascx (AppBundle2/Misc/Title). *@

<div class="component-titlesitesection">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Site Section</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Site Section component requires configuration.
        </div>
    }
</div>
