@model WCMS.WebSystem.WebParts.G2.ViewComponents.SocialMobilewallViewModel
@* Ported from MobileWall.ascx (AppBundle2/Social). *@

<div class="component-socialmobilewall">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Mobile Wall</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Mobile Wall component requires configuration.
        </div>
    }
</div>
