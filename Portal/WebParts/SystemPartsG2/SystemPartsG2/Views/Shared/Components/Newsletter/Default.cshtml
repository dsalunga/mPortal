@model WCMS.WebSystem.WebParts.G2.ViewComponents.NewsletterViewModel
<div class="wcms-newsletter content_wrap" data-object-id="@Model.ObjectId">
    @if (Model.ViewState == "success")
    {
        <!-- Success view (from Newsletter.ascx viewSuccess) -->
        <div class="splash_section textshadow1">
            <p>
                @(string.IsNullOrEmpty(Model.SuccessMessage) ? "Thank you for subscribing. You will be receiving updates soon." : Model.SuccessMessage)
            </p>
        </div>
    }
    else if (Model.ViewState == "already_subscribed")
    {
        <!-- Already subscribed view (from Newsletter.ascx viewAlreadySubscribed) -->
        <div class="splash_section textshadow1">
            <p>
                @(string.IsNullOrEmpty(Model.AlreadySubscribedMessage) ? "You are already subscribed to this newsletter." : Model.AlreadySubscribedMessage)
            </p>
        </div>
    }
    else
    {
        <!-- Subscribe view (from Newsletter.ascx viewSubscribe + eNewsLetter.ascx) -->
        @if (!string.IsNullOrEmpty(Model.Title))
        {
            <div id="splash_section" class="splash_section textshadow1">
                <p>@Model.Title</p>
            </div>
        }
        <div id="subscribe_section" class="subscribe">
            <form class="form_class needs-validation" action="@Model.SubscribeUrl" method="post" novalidate>
                @if (Model.ShowNameField)
                {
                    <div class="mb-3">
                        <input type="text" class="form-control input_text rounded_corner" id="newsletter-name"
                               name="name" placeholder="Enter your Name" required />
                        <div class="invalid-feedback text-danger">Name is required.</div>
                    </div>
                }
                <div class="mb-3">
                    <input type="email" class="form-control input_text rounded_corner" id="newsletter-email"
                           name="email" placeholder="Enter your Email" required
                           pattern="\w+([-+.']\w+)*@@\w+([-.]\w+)*\.\w+([-.]\w+)*" />
                    <div class="invalid-feedback text-danger">Please provide a valid email address.</div>
                </div>
                @if (Model.ShowGenderField)
                {
                    <div class="mb-3">
                        <label>Gender:&nbsp;</label>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="gender" id="genderMale" value="1" required />
                            <label class="form-check-label" for="genderMale">Male</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="gender" id="genderFemale" value="0" />
                            <label class="form-check-label" for="genderFemale">Female</label>
                        </div>
                        <div class="invalid-feedback text-danger">Gender is required.</div>
                    </div>
                }
                <button type="submit" class="btn btn-primary submit_class">Submit</button>
            </form>
        </div>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="mt-2">@Model.Description</p>
        }
    }
</div>
