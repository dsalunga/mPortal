    <ProjectReference Include="..\WCMS.WebSystem.WebParts.Contact\WCMS.WebSystem.Apps.Contact.csproj" />
    <ProjectReference Include="..\WCMS.WebSystem.WebParts.RemoteIndexer\WCMS.WebSystem.Apps.RemoteIndexer.csproj" />
    <ProjectReference Include="..\WCMS.Framework.FileManager\WCMS.WebSystem.Apps.FileManager.csproj" />
    <ProjectReference Include="..\WCMS.WebSystem.WebParts.Article\WCMS.WebSystem.Apps.Article.csproj" />
    <ProjectReference Include="..\..\..\WebSystem\WCMS.Common\WCMS.Common.csproj" />
