@model WCMS.WebSystem.WebParts.ViewComponents.OfficeBrowserViewModel
<div class="wcms-office-browser">
    @if (Model.Documents.Count == 0)
    {
        <p class="text-muted">No documents available.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Document</th>
                        <th>Type</th>
                        <th>Size</th>
                        <th>Modified</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.Documents)
                    {
                        <tr>
                            <td>
                                <i class="bi bi-file-earmark-richtext"></i>
                                @doc.FileName
                            </td>
                            <td><span class="badge bg-info">@doc.FileType</span></td>
                            <td>@(doc.FileSize < 1024 ? doc.FileSize + " B" : (doc.FileSize / 1024) + " KB")</td>
                            <td><small>@doc.LastModified</small></td>
                            <td>
                                <a href="@doc.FileUrl" class="btn btn-sm btn-outline-primary" target="_blank">View</a>
                                <a href="@doc.FileUrl" class="btn btn-sm btn-outline-secondary" download>Download</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
