@model WCMS.WebSystem.WebParts.ViewComponents.OfficeBrowserViewModel
<section class="wcms-office-browser" aria-label="Document browser">
    @if (Model.Documents.Count == 0)
    {
        <p class="text-muted" role="status">No documents available.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle" aria-label="Office documents">
                <thead>
                    <tr>
                        <th scope="col">Document</th>
                        <th scope="col">Type</th>
                        <th scope="col">Size</th>
                        <th scope="col">Modified</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.Documents)
                    {
                        <tr>
                            <td>
                                <i class="bi bi-file-earmark-richtext" aria-hidden="true"></i>
                                @doc.FileName
                            </td>
                            <td><span class="badge bg-info">@doc.FileType</span></td>
                            <td>@(doc.FileSize < 1024 ? doc.FileSize + " B" : (doc.FileSize / 1024) + " KB")</td>
                            <td><time><small>@doc.LastModified</small></time></td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Actions for @doc.FileName">
                                    <a href="@doc.FileUrl" class="btn btn-outline-primary" target="_blank"
                                       rel="noopener" aria-label="View @doc.FileName">View</a>
                                    <a href="@doc.FileUrl" class="btn btn-outline-secondary" download
                                       aria-label="Download @doc.FileName">Download</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
