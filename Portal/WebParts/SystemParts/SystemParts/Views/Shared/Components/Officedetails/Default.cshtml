@model WCMS.WebSystem.WebParts.ViewComponents.OfficedetailsViewModel
@* Ported from OfficeDetails.ascx (SystemParts). *@

<div class="component-officedetails">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Office Details</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Office:</strong> Office Details component requires configuration.
        </div>
    }
</div>
