@model WCMS.WebSystem.WebParts.ViewComponents.OfficedetailsViewModel
@* Ported from OfficeDetails.ascx. *@

<div class="component-officedetails">
    <div class="mb-2">
        <strong>Email Address:</strong>
        <span>@Model.EmailAddress</span>
    </div>
    <div class="mb-2">
        <strong>Address Line1:</strong>
        <span>@Model.AddressLine1</span>
    </div>
    <div class="mb-2">
        <strong>Phone Number:</strong>
        <span>@Model.PhoneNumber</span>
    </div>
    <div class="mb-2">
        <strong>Mobile Number:</strong>
        <span>@Model.MobileNumber</span>
    </div>
    <div class="mb-2">
        <strong>Contact Person:</strong>
        <span>@Model.ContactPerson</span>
    </div>
    <div class="mb-2">
        <strong>Status:</strong>
        <span>@Model.Status</span>
    </div>
</div>