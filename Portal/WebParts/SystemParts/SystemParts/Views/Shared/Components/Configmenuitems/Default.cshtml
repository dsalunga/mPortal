@model WCMS.WebSystem.WebParts.ViewComponents.ConfigmenuitemsViewModel
@* Ported from ConfigMenuItems.ascx (SystemParts). *@

<div class="component-configmenuitems">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Config Menu Items</em> — ported from legacy WebForms. 
