@model WCMS.WebSystem.WebParts.ViewComponents.FileEditorViewModel
<section class="wcms-file-editor" aria-label="File editor">
    @if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
            Please sign in to edit files.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="bi bi-file-earmark-code" aria-hidden="true"></i>
                    @(string.IsNullOrEmpty(Model.FileName) ? "File Editor" : Model.FileName)
                </h4>
                @if (!string.IsNullOrEmpty(Model.FilePath))
                {
                    <small class="text-muted">
                        <i class="bi bi-folder2" aria-hidden="true"></i> @Model.FilePath
                    </small>
                }
            </div>
            <div class="card-body">
                <form method="post" aria-label="Edit file content">
                    <input type="hidden" name="objectId" value="@Model.ObjectId" />
                    <input type="hidden" name="recordId" value="@Model.RecordId" />
                    <input type="hidden" name="fileId" value="@Model.FileId" />
                    <div class="mb-3">
                        <label for="fileContent-@Model.ObjectId" class="form-label visually-hidden">File content</label>
                        <textarea id="fileContent-@Model.ObjectId" name="content"
                                  class="form-control font-monospace" rows="20"
                                  aria-label="File content editor">@Model.Content</textarea>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="javascript:history.back()" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save" aria-hidden="true"></i> Save
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</section>
