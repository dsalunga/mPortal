@model WCMS.WebSystem.WebParts.ViewComponents.CalendarEventViewModel
<article class="wcms-calendar-event" aria-label="Event details">
    @if (string.IsNullOrEmpty(Model.Title))
    {
        <div class="alert alert-info d-flex align-items-center" role="status">
            <i class="bi bi-info-circle-fill me-2" aria-hidden="true"></i>
            No event selected.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header">
                <h3 class="mb-0" id="eventTitle-@Model.EventId">
                    <i class="bi bi-calendar-event" aria-hidden="true"></i> @Model.Title
                </h3>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">
                        <i class="bi bi-calendar3" aria-hidden="true"></i> Start
                    </dt>
                    <dd class="col-sm-9">
                        <time datetime="@Model.StartDate.ToString("yyyy-MM-ddTHH:mm")">
                            @Model.StartDate.ToString("f")
                        </time>
                    </dd>
                    <dt class="col-sm-3">
                        <i class="bi bi-calendar3" aria-hidden="true"></i> End
                    </dt>
                    <dd class="col-sm-9">
                        <time datetime="@Model.EndDate.ToString("yyyy-MM-ddTHH:mm")">
                            @Model.EndDate.ToString("f")
                        </time>
                    </dd>
                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <dt class="col-sm-3">
                            <i class="bi bi-geo-alt" aria-hidden="true"></i> Location
                        </dt>
                        <dd class="col-sm-9">@Model.Location</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.OrganizerName))
                    {
                        <dt class="col-sm-3">
                            <i class="bi bi-person" aria-hidden="true"></i> Organizer
                        </dt>
                        <dd class="col-sm-9">
                            @Model.OrganizerName
                            @if (!string.IsNullOrEmpty(Model.OrganizerEmail))
                            {
                                <a href="mailto:@Model.OrganizerEmail" class="ms-1"
                                   aria-label="Email @Model.OrganizerName">
                                    <i class="bi bi-envelope" aria-hidden="true"></i>
                                </a>
                            }
                        </dd>
                    }
                </dl>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <hr />
                    <div class="card-text">@Html.Raw(Model.Description)</div>
                }
            </div>
            <div class="card-footer bg-transparent">
                <a href="@Model.BasePath" class="btn btn-outline-secondary btn-sm"
                   aria-label="Back to calendar">
                    <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Calendar
                </a>
            </div>
        </div>
    }
</article>
