@model WCMS.WebSystem.WebParts.ViewComponents.AdmincategoryeditViewModel
@* Ported from AdminCategoryEdit.ascx. *@

<div class="component-admincategoryedit">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Name" class="form-label">Name</label>
            <input type="text" class="form-control" id="field_Name" name="Name" value="@Model.Name" />
        </div>
        <div class="mb-3">
            <label for="field_CboTemplates" class="form-label">Cbo Templates</label>
            <select class="form-select" id="field_CboTemplates" name="SelectedCboTemplates">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboTemplatesOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboTemplates ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>