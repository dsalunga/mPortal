@model WCMS.WebSystem.WebParts.ViewComponents.AdmincalendarhomeViewModel

<section class="component-admincalendarhome" aria-label="Admin Calendar Home">
    <h3 class="Header-Main">@Model.Header</h3>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <div class="list-group">
        <a class="list-group-item list-group-item-action" href="@Model.ConfigUrl">
            <img src="/Content/Assets/Images/file_edit.png" class="TaskListIcon" alt="" />
            <strong class="ms-1">Properties</strong>
            <div class="small text-muted ms-4">Configure this calendar.</div>
        </a>

        @if (Model.CalendarId > 0)
        {
            <form method="post" asp-controller="@Model.PostController" asp-action="@Model.PostAction" class="list-group-item">
                <input type="hidden" name="objectId" value="@Model.ObjectId" />
                <input type="hidden" name="recordId" value="@Model.RecordId" />
                <input type="hidden" name="calendarId" value="@Model.CalendarId" />
                <button type="submit"
                        class="btn btn-link p-0 text-decoration-none"
                        name="action"
                        value="cmdDelete"
                        onclick="return confirm('Are you sure you want to delete this item?');">
                    <img src="/Content/Assets/Images/delete-folder.png" class="TaskListIcon" alt="" />
                    <strong class="ms-1">Delete this</strong>
                </button>
                <div class="small text-muted ms-4">Permanently remove this calendar.</div>
            </form>
        }

        <a class="list-group-item list-group-item-action" href="@Model.ParametersUrl">
            <img src="/Content/Assets/Images/piece.png" class="TaskListIcon" alt="" />
            <strong class="ms-1">Parameters</strong>
            <div class="small text-muted ms-4">Manage runtime parameters.</div>
        </a>
    </div>
</section>
