@model WCMS.WebSystem.WebParts.ViewComponents.AdmineventviewViewModel

<section class="wp-Event-Manager component-admineventview">
    <div class="field">
        <h2 style="padding: 3px; display: inline; @Model.SubjectStyle">@Model.Subject</h2>
    </div>

    <div class="field">
        <div><strong>Date</strong></div>
        <div>@Model.EventDate</div>
    </div>
    <div class="field">
        <div><strong>Time</strong></div>
        <div>@Model.EventTime</div>
    </div>
    <div class="field">
        <div><strong>Location</strong></div>
        <div>@Model.Location</div>
    </div>
    <div class="field">
        <div><strong>Description</strong></div>
        <div>@Model.Description</div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success mt-3" role="status">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger mt-3" role="alert">@Model.ErrorMessage</div>
    }

    <form method="post" asp-controller="@Model.PostController" asp-action="@Model.PostAction" class="control-box mt-3">
        <input type="hidden" name="objectId" value="@Model.ObjectId" />
        <input type="hidden" name="recordId" value="@Model.RecordId" />
        <input type="hidden" name="eventId" value="@Model.EventId" />

        <button type="submit" class="btn btn-default btn-secondary me-2" name="action" value="cmdEdit">Edit</button>
        <button type="submit"
                class="btn btn-default btn-secondary me-2"
                name="action"
                value="cmdDelete"
                onclick="return confirm('Are you sure you want to delete this item?');">
            Delete
        </button>
        <button type="submit" class="btn btn-default btn-secondary me-2" name="action" value="cmdCancel">Close</button>
        <button type="submit"
                class="btn btn-default btn-outline-secondary"
                name="action"
                value="cmdSendReminder"
                onclick="return confirm('Are you sure you want to send a reminder now?');">
            Send Reminder
        </button>
    </form>
</section>
