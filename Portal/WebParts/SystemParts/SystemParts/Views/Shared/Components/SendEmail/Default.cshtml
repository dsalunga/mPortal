@model WCMS.WebSystem.WebParts.ViewComponents.SendEmailViewModel
<div class="wcms-send-email">
    @if (Model.IsSent)
    {
        <div class="alert alert-success">Your email has been sent successfully.</div>
    }
    else if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning">Please sign in to send emails.</div>
    }
    else
    {
        <h4>Send Email</h4>
        <form method="post">
            <input type="hidden" name="objectId" value="@Model.ObjectId" />
            <input type="hidden" name="recordId" value="@Model.RecordId" />
            <div class="mb-3">
                <label for="emailRecipient" class="form-label">To</label>
                <input type="email" id="emailRecipient" name="recipient" class="form-control"
                       value="@Model.Recipient" required />
            </div>
            <div class="mb-3">
                <label for="emailSubject" class="form-label">Subject</label>
                <input type="text" id="emailSubject" name="subject" class="form-control"
                       value="@Model.Subject" required />
            </div>
            <div class="mb-3">
                <label for="emailBody" class="form-label">Message</label>
                <textarea id="emailBody" name="body" class="form-control" rows="6" required>@Model.Body</textarea>
            </div>
            <p class="text-muted small">Sending as: @Model.SenderName</p>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-envelope"></i> Send
            </button>
        </form>
    }
</div>
