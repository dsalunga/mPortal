@model WCMS.WebSystem.WebParts.ViewComponents.CalendarEventViewModel
<article class="wcms-calendar-event" aria-label="Event details">
    @if (string.IsNullOrEmpty(Model.Title))
    {
        <div class="alert alert-info" role="status">No event selected.</div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <h3 class="card-title" id="eventTitle-@Model.EventId">@Model.Title</h3>
                <dl class="row mb-0">
                    <dt class="col-sm-3">Start</dt>
                    <dd class="col-sm-9">
                        <time datetime="@Model.StartDate.ToString("yyyy-MM-ddTHH:mm")">@Model.StartDate.ToString("f")</time>
                    </dd>
                    <dt class="col-sm-3">End</dt>
                    <dd class="col-sm-9">
                        <time datetime="@Model.EndDate.ToString("yyyy-MM-ddTHH:mm")">@Model.EndDate.ToString("f")</time>
                    </dd>
                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <dt class="col-sm-3">Location</dt>
                        <dd class="col-sm-9">
                            <i class="bi bi-geo-alt" aria-hidden="true"></i> @Model.Location
                        </dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.OrganizerName))
                    {
                        <dt class="col-sm-3">Organizer</dt>
                        <dd class="col-sm-9">
                            <i class="bi bi-person" aria-hidden="true"></i> @Model.OrganizerName
                            @if (!string.IsNullOrEmpty(Model.OrganizerEmail))
                            {
                                <a href="mailto:@Model.OrganizerEmail" aria-label="Email @Model.OrganizerName">
                                    <i class="bi bi-envelope" aria-hidden="true"></i>
                                </a>
                            }
                        </dd>
                    }
                </dl>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <hr />
                    <div class="card-text">@Html.Raw(Model.Description)</div>
                }
                <div class="mt-3">
                    <a href="@Model.BasePath" class="btn btn-outline-secondary btn-sm"
                       aria-label="Back to calendar">
                        <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Calendar
                    </a>
                </div>
            </div>
        </div>
    }
</article>
