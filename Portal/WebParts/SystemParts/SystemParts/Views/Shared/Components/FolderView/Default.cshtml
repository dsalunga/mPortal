@model WCMS.WebSystem.WebParts.ViewComponents.FolderViewViewModel
<nav class="wcms-folder-view" aria-label="Folder browser">
    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-folder2" aria-hidden="true"></i> Folders
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Folders == null || Model.Folders.Count == 0)
            {
                <p class="text-muted text-center py-3" role="status">
                    <i class="bi bi-folder-x" aria-hidden="true"></i> No folders available.
                </p>
            }
            else
            {
                <ul class="list-group list-group-flush" role="tree" aria-label="Folder tree">
                    @foreach (var folder in Model.Folders)
                    {
                        @await Html.PartialAsync("_FolderNode", folder)
                    }
                </ul>
            }
        </div>
    </div>
</nav>
