@model WCMS.WebSystem.WebParts.ViewComponents.FolderViewViewModel
<nav class="wcms-folder-view" aria-label="Folder browser">
    @if (Model.Folders.Count == 0)
    {
        <p class="text-muted" role="status">No folders available.</p>
    }
    else
    {
        <ul class="list-group" role="tree" aria-label="Folder tree">
            @foreach (var folder in Model.Folders)
            {
                @await Html.PartialAsync("_FolderNode", folder)
            }
        </ul>
    }
</nav>
