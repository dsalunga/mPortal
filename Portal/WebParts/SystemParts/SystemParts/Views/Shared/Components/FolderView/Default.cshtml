@model WCMS.WebSystem.WebParts.ViewComponents.FolderViewViewModel
<div class="wcms-folder-view">
    @if (Model.Folders.Count == 0)
    {
        <p class="text-muted">No folders available.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var folder in Model.Folders)
            {
                @await Html.PartialAsync("_FolderNode", folder)
            }
        </ul>
    }
</div>

@functions {
    static string RenderFolder(WCMS.WebSystem.WebParts.ViewComponents.FolderNodeModel node, string basePath)
    {
        return node.Name;
    }
}
