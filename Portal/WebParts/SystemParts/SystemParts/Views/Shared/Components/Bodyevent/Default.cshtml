@model WCMS.WebSystem.WebParts.ViewComponents.BodyeventViewModel
@* Ported from BodyEvent.ascx (SystemParts). *@

<div class="component-bodyevent">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Body Event</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Script:</strong> Body Event component requires configuration.
        </div>
    }
</div>
