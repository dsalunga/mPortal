@model WCMS.WebSystem.WebParts.ViewComponents.Configdynamicmenu01ViewModel
@* Ported from ConfigDynamicMenu01.ascx. *@

<div class="component-configdynamicmenu01">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Width" class="form-label">Width</label>
            <input type="text" class="form-control" id="field_Width" name="Width" value="@Model.Width" />
        </div>
        <div class="mb-3">
            <label for="field_Height" class="form-label">Height</label>
            <input type="text" class="form-control" id="field_Height" name="Height" value="@Model.Height" />
        </div>
        <div class="mb-3">
            <label for="field_CboMenu" class="form-label">Cbo Menu</label>
            <select class="form-select" id="field_CboMenu" name="SelectedCboMenu">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboMenuOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboMenu ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboRenderMode" class="form-label">Cbo Render Mode</label>
            <select class="form-select" id="field_CboRenderMode" name="SelectedCboRenderMode">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboRenderModeOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboRenderMode ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboOrientation" class="form-label">Cbo Orientation</label>
            <select class="form-select" id="field_CboOrientation" name="SelectedCboOrientation">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboOrientationOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboOrientation ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
        </div>
    </form>
</div>