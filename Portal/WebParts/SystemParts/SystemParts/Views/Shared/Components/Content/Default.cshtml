@model string
@*
    Ported from Content.ascx / Content.ascx.cs
    Original renders element content as a Literal control (raw HTML output).
*@
@if (!string.IsNullOrEmpty(Model))
{
    <div class="wcms-content" role="region" aria-label="Page content">
        @Html.Raw(Model)
    </div>
}
else
{
    <div class="wcms-content wcms-content-empty" aria-hidden="true"></div>
}
