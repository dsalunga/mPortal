@model WCMS.WebSystem.WebParts.ViewComponents.ConfigopenViewModel
@* Ported from ConfigOpen.ascx. *@

<div class="component-configopen">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_ContentId" class="form-label">Content Id</label>
            <input type="text" class="form-control" id="field_ContentId" name="ContentId" value="@Model.ContentId" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdOpenContent">Load Content</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>