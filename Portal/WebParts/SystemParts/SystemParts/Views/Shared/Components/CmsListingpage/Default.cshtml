@model WCMS.WebSystem.WebParts.ViewComponents.CmsListingpageViewModel
@* Ported from CMS_ListingPage.ascx (SystemParts). *@

<div class="component-cmslistingpage">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>CMS Listing Page</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Menu:</strong> CMS Listing Page component requires configuration.
        </div>
    }
</div>
