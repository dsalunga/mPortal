@model WCMS.WebSystem.WebParts.ViewComponents.ArticleEmailPreviewViewModel
@* Ported from EmailPreview.ascx (SystemParts). *@

<div class="component-articleemailpreview">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Email Preview</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Article:</strong> Email Preview component requires configuration.
        </div>
    }
</div>
