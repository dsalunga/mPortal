@model WCMS.WebSystem.WebParts.ViewComponents.AdminPhotosViewModel
<div class="wcms-admin-photos">
    @if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning">Please sign in to manage photos.</div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4>Photo Management</h4>
            <button type="button" class="btn btn-primary btn-sm">
                <i class="bi bi-upload"></i> Upload Photos
            </button>
        </div>
        @if (Model.Photos.Count == 0)
        {
            <p class="text-muted">No photos uploaded yet.</p>
        }
        else
        {
            <div class="row">
                @foreach (var photo in Model.Photos)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                        <div class="card">
                            <img src="@(photo.ThumbnailUrl ?? photo.ImageUrl)" alt="@photo.Title"
                                 class="card-img-top" loading="lazy" />
                            <div class="card-body p-2">
                                <small class="card-title d-block">@photo.Title</small>
                                <small class="text-muted">@photo.AlbumName</small>
                                <div class="mt-1">
                                    <button class="btn btn-sm btn-outline-primary">Edit</button>
                                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
