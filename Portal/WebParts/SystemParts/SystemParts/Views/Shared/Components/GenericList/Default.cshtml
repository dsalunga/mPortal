@model WCMS.WebSystem.WebParts.ViewComponents.GenericListViewModel
<section class="wcms-generic-list" aria-label="@(Model.Title ?? "Data list")">
    <div class="card shadow-sm">
        @if (!string.IsNullOrEmpty(Model.Title))
        {
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="bi bi-list-ul" aria-hidden="true"></i> @Model.Title
                </h4>
            </div>
        }
        <div class="card-body">
            @if (Model.Rows == null || Model.Rows.Count == 0)
            {
                <p class="text-muted text-center py-3" role="status">
                    <i class="bi bi-inbox" aria-hidden="true"></i> No records found.
                </p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0"
                           aria-label="@(Model.Title ?? "Records")">
                        <thead class="table-light">
                            <tr>
                                @foreach (var col in Model.Columns)
                                {
                                    if (col.Visible)
                                    {
                                        <th scope="col">@col.Header</th>
                                    }
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Rows)
                            {
                                <tr>
                                    @foreach (var col in Model.Columns)
                                    {
                                        if (col.Visible)
                                        {
                                            var val = row.ContainsKey(col.Name) ? row[col.Name] : "";
                                            <td>@val</td>
                                        }
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        @if (Model.TotalRecords > Model.PageSize && Model.PageSize > 0)
        {
            var totalPages = (int)System.Math.Ceiling((double)Model.TotalRecords / Model.PageSize);
            <div class="card-footer bg-transparent">
                <nav aria-label="List pagination">
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" href="@Model.BasePath?page=@(Model.CurrentPage - 1)"
                               aria-label="Previous page"
                               @(Model.CurrentPage <= 1 ? "tabindex=-1 aria-disabled=true" : "")>
                                <span aria-hidden="true">&laquo;</span>
                                <span class="visually-hidden">Previous</span>
                            </a>
                        </li>
                        @for (var p = 1; p <= totalPages; p++)
                        {
                            <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@Model.BasePath?page=@p"
                                   @(p == Model.CurrentPage ? "aria-current=page" : "")
                                   aria-label="Page @p">
                                    @p
                                    @if (p == Model.CurrentPage)
                                    {
                                        <span class="visually-hidden">(current)</span>
                                    }
                                </a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage >= totalPages ? "disabled" : "")">
                            <a class="page-link" href="@Model.BasePath?page=@(Model.CurrentPage + 1)"
                               aria-label="Next page"
                               @(Model.CurrentPage >= totalPages ? "tabindex=-1 aria-disabled=true" : "")>
                                <span aria-hidden="true">&raquo;</span>
                                <span class="visually-hidden">Next</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</section>
