@model WCMS.WebSystem.WebParts.ViewComponents.SurveyViewModel
@{
    var surveyAction = "__SURVEY_ACTION";
    var formId = "surveyForm-" + Model.ObjectId;
}
<section class="wcms-survey" aria-label="Survey">
    @if (Model.IsSubmitted)
    {
        <div class="alert alert-success d-flex align-items-center" role="status" aria-live="polite">
            <i class="bi bi-check-circle-fill me-2" aria-hidden="true"></i>
            Thank you for completing the survey!
        </div>
    }
    else
    {
        <script type="text/javascript">
            function SurveyBack() {
                document.getElementById("@surveyAction").value = "BACK";
            }
            function SurveyNext() {
                document.getElementById("@surveyAction").value = "NEXT";
            }
            function SurveyRestart() {
                document.getElementById("@surveyAction").value = "RESTART";
            }
        </script>

        <div class="card shadow-sm">
            <div class="card-body">
                <form method="post" id="@formId" aria-label="Survey form">
                    <input id="@surveyAction" type="hidden" name="@surveyAction" />
                    <input type="hidden" name="objectId" value="@Model.ObjectId" />
                    <input type="hidden" name="recordId" value="@Model.RecordId" />
                    <input type="hidden" name="surveyId" value="@Model.SurveyId" />

                    @if (!string.IsNullOrEmpty(Model.Title))
                    {
                        <h5 class="card-title text-center fw-bold">@Model.Title</h5>
                    }
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="text-muted text-center">@Model.Description</p>
                    }
                    @if (!string.IsNullOrEmpty(Model.PageLabel))
                    {
                        <p class="text-center text-muted small mb-3">@Model.PageLabel</p>
                    }
                    else if (Model.TotalPages > 1)
                    {
                        <p class="text-center text-muted small mb-3">
                            Page <strong>@Model.CurrentPage</strong> of <strong>@Model.TotalPages</strong>
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center" role="alert" aria-live="assertive">
                            <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
                            @Model.ErrorMessage
                        </div>
                    }

                    <fieldset>
                        <legend class="visually-hidden">Survey Questions</legend>
                        @foreach (var question in Model.Questions)
                        {
                            <div class="mb-4 p-3 border rounded bg-light">
                                <label class="form-label fw-bold" id="qlabel-@question.Id">
                                    @question.Text
                                    @if (question.IsRequired)
                                    {
                                        <span class="text-danger" aria-hidden="true">*</span>
                                        <span class="visually-hidden">(required)</span>
                                    }
                                </label>

                                @if (question.QuestionType == "text")
                                {
                                    <input type="text" name="q_@question.Id" class="form-control"
                                           aria-labelledby="qlabel-@question.Id"
                                           @(question.IsRequired ? "required aria-required=true" : "") />
                                }
                                else if (question.QuestionType == "textarea")
                                {
                                    <textarea name="q_@question.Id" class="form-control" rows="3"
                                              aria-labelledby="qlabel-@question.Id"
                                              @(question.IsRequired ? "required aria-required=true" : "")></textarea>
                                }
                                else if (question.QuestionType == "radio" && question.Options != null)
                                {
                                    <div role="radiogroup" aria-labelledby="qlabel-@question.Id">
                                        @foreach (var opt in question.Options)
                                        {
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio"
                                                       name="q_@question.Id" value="@opt.Id" id="opt_@opt.Id"
                                                       @(question.IsRequired ? "required aria-required=true" : "") />
                                                <label class="form-check-label" for="opt_@opt.Id">@opt.Text</label>
                                            </div>
                                        }
                                    </div>
                                }
                                else if (question.QuestionType == "checkbox" && question.Options != null)
                                {
                                    <div role="group" aria-labelledby="qlabel-@question.Id">
                                        @foreach (var opt in question.Options)
                                        {
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox"
                                                       name="q_@question.Id" value="@opt.Id" id="opt_@opt.Id" />
                                                <label class="form-check-label" for="opt_@opt.Id">@opt.Text</label>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </fieldset>

                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted fst-italic">
                            <span class="text-danger" aria-hidden="true">*</span> Required
                        </small>
                        <div class="d-flex gap-2">
                            @if (Model.ShowRestartButton)
                            {
                                <button type="submit" class="btn btn-outline-secondary"
                                        onclick="SurveyRestart()" aria-label="Restart survey">
                                    <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i> Restart
                                </button>
                            }
                            @if (Model.ShowBackButton)
                            {
                                <button type="submit" class="btn btn-secondary"
                                        onclick="SurveyBack()" aria-label="Go to previous page">
                                    <i class="bi bi-arrow-left" aria-hidden="true"></i> Back
                                </button>
                            }
                            <button type="submit" class="btn btn-primary"
                                    onclick="SurveyNext()" aria-label="@(Model.SubmitButtonText ?? "Submit")">
                                @(Model.SubmitButtonText ?? "Submit") <i class="bi bi-arrow-right" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
</section>
