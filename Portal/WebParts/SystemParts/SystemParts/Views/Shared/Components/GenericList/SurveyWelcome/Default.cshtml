@model WCMS.WebSystem.WebParts.ViewComponents.SurveywelcomeViewModel

<section class="component-surveywelcome text-center" aria-label="Survey Welcome">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <h4 class="mb-3">@Model.lblTitle</h4>
    <p>@Model.lblMessage</p>

    <form method="post" asp-action="@Model.PostAction" asp-controller="@Model.PostController" novalidate>
        <input type="hidden" name="objectId" value="@Model.ObjectId" />
        <input type="hidden" name="recordId" value="@Model.RecordId" />
        <input type="hidden" name="listId" value="@Model.ListId" />

        <button type="submit" class="btn btn-secondary" name="action" value="cmdStart">Start Now!</button>
    </form>
</section>
