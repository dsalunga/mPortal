@model WCMS.WebSystem.WebParts.ViewComponents.WmCreatesurveypage04ViewModel
@* Ported from WM_CreateSurveyPage_04.ascx. *@

<div class="component-wm-createsurveypage04">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Title" class="form-label">Title</label>
            <input type="text" class="form-control" id="field_Title" name="Title" value="@Model.Title" />
        </div>
        <div class="mb-3">
            <label for="field_Rank" class="form-label">Rank</label>
            <input type="text" class="form-control" id="field_Rank" name="Rank" value="@Model.Rank" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdQUpdate">Save</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>