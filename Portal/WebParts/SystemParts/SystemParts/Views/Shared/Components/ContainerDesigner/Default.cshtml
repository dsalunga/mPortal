@model WCMS.WebSystem.WebParts.ViewComponents.ContainerDesignerViewModel
<section class="wcms-container-designer" aria-label="Container layout designer">
    @if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle" aria-hidden="true"></i> Please sign in to design layouts.
        </div>
    }
    else
    {
        <div class="mb-3">
            <h4 id="designerHeading-@Model.ObjectId">Container Layout Designer</h4>
            <div class="btn-group mb-3" role="group" aria-label="Layout type selection">
                <button type="button" class="btn btn-outline-secondary @(Model.LayoutType == "two-column" ? "active" : "")"
                        aria-pressed="@(Model.LayoutType == "two-column" ? "true" : "false")">Two Columns</button>
                <button type="button" class="btn btn-outline-secondary @(Model.LayoutType == "three-column" ? "active" : "")"
                        aria-pressed="@(Model.LayoutType == "three-column" ? "true" : "false")">Three Columns</button>
            </div>
        </div>
        <div class="row border rounded p-3" role="region" aria-labelledby="designerHeading-@Model.ObjectId">
            @foreach (var col in Model.Columns)
            {
                <div class="col-md-@col.Width @col.CssClass border p-2 min-vh-25"
                     role="region" aria-label="Column @(col.Index + 1)">
                    <div class="text-muted text-center small">Column @(col.Index + 1) (width: @col.Width)</div>
                    @Html.Raw(col.Content)
                </div>
            }
            @if (Model.Columns.Count == 0)
            {
                <div class="col text-center text-muted p-4" role="status">
                    Select a layout type to begin designing.
                </div>
            }
        </div>
    }
</section>
