@model WCMS.WebSystem.WebParts.ViewComponents.MenuBreadcrumbViewModel
@* Ported from Breadcrumb.ascx (SystemParts). *@

<div class="component-menubreadcrumb">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Breadcrumb</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Menu:</strong> Breadcrumb component requires configuration.
        </div>
    }
</div>
