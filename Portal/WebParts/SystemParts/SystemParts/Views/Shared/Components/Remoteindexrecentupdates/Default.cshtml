@model WCMS.WebSystem.WebParts.ViewComponents.RemoteindexrecentupdatesViewModel
@* Ported from RemoteIndexRecentUpdates.ascx (SystemParts). *@

<div class="component-remoteindexrecentupdates">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Remote Index Recent Updates</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>File Manager:</strong> Remote Index Recent Updates component requires configuration.
        </div>
    }
</div>
