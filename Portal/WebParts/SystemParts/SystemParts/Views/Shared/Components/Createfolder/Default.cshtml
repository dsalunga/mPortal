@model WCMS.WebSystem.WebParts.ViewComponents.CreatefolderViewModel
@* Ported from CreateFolder.ascx (SystemParts). *@

<div class="component-createfolder">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Create Folder</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>File Manager:</strong> Create Folder component requires configuration.
        </div>
    }
</div>
