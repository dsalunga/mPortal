@model WCMS.WebSystem.WebParts.ViewComponents.CreatefolderViewModel
@* Ported from CreateFolder.ascx. *@

<div class="component-createfolder">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_NewFolder" class="form-label">New Folder</label>
            <input type="text" class="form-control" id="field_NewFolder" name="NewFolder" value="@Model.NewFolder" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUploadNow">Create folder</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>