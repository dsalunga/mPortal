@model WCMS.WebSystem.WebParts.ViewComponents.WmCreatesurvey02ViewModel
@* Ported from WM_CreateSurvey_02.ascx. *@

<div class="component-wm-createsurvey02">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Title" class="form-label">Title</label>
            <input type="text" class="form-control" id="field_Title" name="Title" value="@Model.Title" />
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_Active" name="Active" @(Model.Active ? "checked" : "") />
            <label class="form-check-label" for="field_Active">Active</label>
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_PageTitle" name="PageTitle" @(Model.PageTitle ? "checked" : "") />
            <label class="form-check-label" for="field_PageTitle">Show Page Title</label>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdCreate">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>