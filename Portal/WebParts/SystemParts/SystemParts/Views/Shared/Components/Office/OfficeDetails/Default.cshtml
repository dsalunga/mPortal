@model WCMS.WebSystem.WebParts.ViewComponents.OfficedetailsViewModel

<section class="component-officedetails" aria-label="Office Details">
    <h2>Locale Information</h2>
    <h3><strong>@Model.Name</strong></h3>
    <img src="/Content/Assets/Images/Common/generic-building.jpg" style="border: solid 2px #aaa; margin: 2px" alt="Locale" />

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success mt-3" role="status">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger mt-3" role="alert">@Model.ErrorMessage</div>
    }

    <div class="FieldLine mt-3"><strong>Email Address:</strong> @Model.Label4</div>
    <div class="FieldLine"><strong>Address:</strong> @Model.Label1</div>
    <div class="FieldLine"><strong>Phone Number:</strong> @Model.Label6</div>
    <div class="FieldLine"><strong>Mobile Number:</strong> @Model.Label5</div>
    <div class="FieldLine"><strong>Contact Person:</strong> @Model.Label3</div>

    @if (!string.IsNullOrWhiteSpace(Model.CancelRedirect))
    {
        <form method="post" asp-action="@Model.PostAction" asp-controller="@Model.PostController" class="mt-3">
            <input type="hidden" name="objectId" value="@Model.ObjectId" />
            <input type="hidden" name="recordId" value="@Model.RecordId" />
            <button type="submit" class="btn btn-secondary" name="action" value="cmdCancel">OK</button>
        </form>
    }
</section>
