@model WCMS.WebSystem.WebParts.ViewComponents.AdminMenuViewModel
<section class="wcms-admin-menu" aria-label="Menu administration">
    @if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle" aria-hidden="true"></i> Please sign in to manage menu items.
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 id="adminMenuHeading-@Model.ObjectId">Menu Administration</h4>
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal"
                    data-bs-target="#addMenuItem-@Model.ObjectId" aria-label="Add new menu item">
                <i class="bi bi-plus" aria-hidden="true"></i> Add Item
            </button>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover" aria-labelledby="adminMenuHeading-@Model.ObjectId">
                <thead>
                    <tr>
                        <th scope="col">Title</th>
                        <th scope="col">URL</th>
                        <th scope="col">Parent</th>
                        <th scope="col">Order</th>
                        <th scope="col">Visible</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td><small class="text-break">@item.Url</small></td>
                            <td>@item.ParentId</td>
                            <td>@item.SortOrder</td>
                            <td>
                                <span class="badge @(item.IsVisible ? "bg-success" : "bg-secondary")"
                                      aria-label="@(item.IsVisible ? "Visible" : "Hidden")">
                                    @(item.IsVisible ? "Yes" : "No")
                                </span>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Actions for @item.Title">
                                    <button class="btn btn-outline-primary" aria-label="Edit @item.Title">Edit</button>
                                    <button class="btn btn-outline-danger" aria-label="Delete @item.Title">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
