@model WCMS.WebSystem.WebParts.ViewComponents.ImportexportViewModel
@* Ported from ImportExport.ascx. *@

<div class="component-importexport">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.ActiveViewIndex == 0)
    {
        <div class="view-section" id="view-viewExport">
            <h4>Export</h4>
            <div class="view-content p-3">
                @* viewExport content *@
                <p class="text-muted">Section: Export</p>
            </div>
        </div>
    }
    else if (Model.ActiveViewIndex == 1)
    {
        <div class="view-section" id="view-viewImport">
            <h4>Import</h4>
            <div class="view-content p-3">
                @* viewImport content *@
                <p class="text-muted">Section: Import</p>
            </div>
        </div>
    }
</div>