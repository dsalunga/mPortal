@model WCMS.WebSystem.WebParts.ViewComponents.ImportexportViewModel
@* Ported from ImportExport.ascx (SystemParts). *@

<div class="component-importexport">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Import Export</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>System:</strong> Import Export component requires configuration.
        </div>
    }
</div>
