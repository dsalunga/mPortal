@model WCMS.WebSystem.WebParts.ViewComponents.WmCustomViewModel
@* Ported from WM_Custom.ascx (SystemParts). *@

<div class="component-wmcustom">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>WM Custom</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Generic List / Survey:</strong> WM Custom component requires configuration.
        </div>
    }
</div>
