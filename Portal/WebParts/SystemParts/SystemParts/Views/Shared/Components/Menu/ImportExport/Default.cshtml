@model WCMS.WebSystem.WebParts.ViewComponents.ImportexportViewModel

<section class="component-importexport" aria-label="Import Export">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <form method="post" asp-action="@Model.PostAction" asp-controller="@Model.PostController" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="objectId" value="@Model.ObjectId" />
        <input type="hidden" name="recordId" value="@Model.RecordId" />

        <div class="card mb-3">
            <div class="card-header">Export</div>
            <div class="card-body">
                <label class="form-label" for="f-cbomenus">Menu</label>
                <select class="form-select" id="f-cbomenus" name="cboMenus">
                    <option value="">-- Select --</option>
                    @foreach (var menu in Model.Menus)
                    {
                        <option value="@menu.Value" selected="@menu.Selected">@menu.Text</option>
                    }
                </select>
                <button type="submit" class="btn btn-secondary mt-3" name="action" value="cmdExport">Export as XML</button>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Import</div>
            <div class="card-body">
                <label class="form-label" for="f-fileupload1">Import XML</label>
                <input type="file" class="form-control" id="f-fileupload1" name="FileUpload1" />
                <button type="submit" class="btn btn-secondary mt-3" name="action" value="cmdImport">Import from XML</button>
            </div>
        </div>
    </form>
</section>
