@model WCMS.WebSystem.WebParts.ViewComponents.ConfiglinkedmenuViewModel
@* Ported from ConfigLinkedMenu.ascx. *@

<div class="component-configlinkedmenu">
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th scope="col" style="width:60px" class="text-center">Actions</th>
                    <th scope="col">Item</th>
                    <th scope="col">Menu</th>
                    <th scope="col">Actions</th>
                    <th scope="col">Active</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="text-center">
                                <a href="?action=edit&id=@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                            <td>@item.Text</td>
                            <td>@item.MenuName</td>
                            <td>@item.Actions</td>
                            <td>@item.Active</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted fst-italic">No records found.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalItems > Model.PageSize)
    {
        var pageCount = (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize);
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center mt-3">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage - 1)" aria-label="Previous">&laquo;</a>
                </li>
                @for (int i = 1; i <= pageCount; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= pageCount ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage + 1)" aria-label="Next">&raquo;</a>
                </li>
            </ul>
        </nav>
    }
</div>