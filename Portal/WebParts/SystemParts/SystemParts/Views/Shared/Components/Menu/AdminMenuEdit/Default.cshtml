@model WCMS.WebSystem.WebParts.ViewComponents.AdminmenueditViewModel
@* Ported from AdminMenuEdit.ascx. *@

<div class="component-adminmenuedit">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Caption" class="form-label">Caption</label>
            <input type="text" class="form-control" id="field_Caption" name="Caption" value="@Model.Caption" />
        </div>
        <div class="mb-3">
            <label for="field_CboSites" class="form-label">Cbo Sites</label>
            <select class="form-select" id="field_CboSites" name="SelectedCboSites">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboSitesOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboSites ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_IsActive" name="IsActive" @(Model.IsActive ? "checked" : "") />
            <label class="form-check-label" for="field_IsActive">Active</label>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>