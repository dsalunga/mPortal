@model WCMS.WebSystem.WebParts.ViewComponents.Configdynamicmenuv2ViewModel

<section class="component-configdynamicmenuv2" aria-label="Config Dynamic Menu V2">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <form method="post" asp-action="@Model.PostAction" asp-controller="@Model.PostController" novalidate>
        <input type="hidden" name="objectId" value="@Model.ObjectId" />
        <input type="hidden" name="recordId" value="@Model.RecordId" />

        <div class="mb-3">
            <label class="form-label" for="f-cbomenu">Menu</label>
            <div class="d-flex gap-2">
                <select class="form-select" id="f-cbomenu" name="cboMenu">
                    @foreach (var menu in Model.Menus)
                    {
                        <option value="@menu.Value" selected="@menu.Selected">@menu.Text</option>
                    }
                </select>
                <a href="@Model.ManageMenuUrl" class="btn btn-outline-secondary" title="Manage menu">
                    <img src="/Content/Assets/Images/Common/Objects.gif" alt="Manage" class="icon" />
                </a>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label" for="f-parameterSet">Template</label>
            <select class="form-select" id="f-parameterSet" name="parameterSetName">
                <option value="">-- None --</option>
                @foreach (var set in Model.ParameterSets)
                {
                    <option value="@set.Value" selected="@set.Selected">@set.Text</option>
                }
            </select>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary me-2" name="action" value="Save">Save</button>
            <a class="btn btn-outline-secondary" href="javascript:history.back()">Cancel</a>
        </div>
    </form>
</section>
