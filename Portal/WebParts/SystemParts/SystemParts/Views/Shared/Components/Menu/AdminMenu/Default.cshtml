@model WCMS.WebSystem.WebParts.ViewComponents.AdminMenuViewModel
<section class="wcms-admin-menu" aria-label="Menu administration">
    @if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
            Please sign in to manage menu items.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0" id="adminMenuHeading-@Model.ObjectId">
                    <i class="bi bi-list" aria-hidden="true"></i> Menu Administration
                </h4>
                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal"
                        data-bs-target="#addMenuItem-@Model.ObjectId" aria-label="Add new menu item">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Item
                </button>
            </div>
            <div class="card-body">
                @if (Model.Items == null || Model.Items.Count == 0)
                {
                    <p class="text-muted text-center py-3" role="status">
                        <i class="bi bi-inbox" aria-hidden="true"></i> No menu items configured.
                    </p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0"
                               aria-labelledby="adminMenuHeading-@Model.ObjectId">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">Title</th>
                                    <th scope="col">URL</th>
                                    <th scope="col">Parent</th>
                                    <th scope="col">Order</th>
                                    <th scope="col">Visible</th>
                                    <th scope="col"><span class="visually-hidden">Actions</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>@item.Title</td>
                                        <td><small class="text-break">@item.Url</small></td>
                                        <td>@item.ParentId</td>
                                        <td>@item.SortOrder</td>
                                        <td>
                                            <span class="badge @(item.IsVisible ? "bg-success" : "bg-secondary")"
                                                  aria-label="@(item.IsVisible ? "Visible" : "Hidden")">
                                                @(item.IsVisible ? "Yes" : "No")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group"
                                                 aria-label="Actions for @item.Title">
                                                <button class="btn btn-outline-primary" aria-label="Edit @item.Title">
                                                    <i class="bi bi-pencil" aria-hidden="true"></i><span class="visually-hidden"> Edit</span>
                                                </button>
                                                <button class="btn btn-outline-danger" aria-label="Delete @item.Title">
                                                    <i class="bi bi-trash" aria-hidden="true"></i><span class="visually-hidden"> Delete</span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</section>
