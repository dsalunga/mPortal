@model WCMS.WebSystem.WebParts.ViewComponents.CalendarEditViewModel
<section class="wcms-calendar-edit" aria-label="@(Model.EventId > 0 ? "Edit event" : "Create event")">
    @if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle" aria-hidden="true"></i> Please sign in to create or edit events.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">@(Model.EventId > 0 ? "Edit Event" : "New Event")</h4>
                <form method="post" aria-label="Event form">
                    <input type="hidden" name="objectId" value="@Model.ObjectId" />
                    <input type="hidden" name="recordId" value="@Model.RecordId" />
                    <input type="hidden" name="eventId" value="@Model.EventId" />
                    <div class="mb-3">
                        <label for="eventTitle-@Model.ObjectId" class="form-label">
                            Title <span class="text-danger" aria-hidden="true">*</span>
                        </label>
                        <input type="text" id="eventTitle-@Model.ObjectId" name="title" class="form-control"
                               value="@Model.Title" required aria-required="true" />
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="startDate-@Model.ObjectId" class="form-label">
                                Start Date <span class="text-danger" aria-hidden="true">*</span>
                            </label>
                            <input type="datetime-local" id="startDate-@Model.ObjectId" name="startDate" class="form-control"
                                   value="@Model.StartDate.ToString("yyyy-MM-ddTHH:mm")" required aria-required="true" />
                        </div>
                        <div class="col-md-6">
                            <label for="endDate-@Model.ObjectId" class="form-label">
                                End Date <span class="text-danger" aria-hidden="true">*</span>
                            </label>
                            <input type="datetime-local" id="endDate-@Model.ObjectId" name="endDate" class="form-control"
                                   value="@Model.EndDate.ToString("yyyy-MM-ddTHH:mm")" required aria-required="true" />
                        </div>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" id="allDay-@Model.ObjectId" name="allDay" class="form-check-input"
                               @(Model.AllDay ? "checked" : "") />
                        <label for="allDay-@Model.ObjectId" class="form-check-label">All Day Event</label>
                    </div>
                    <div class="mb-3">
                        <label for="eventLocation-@Model.ObjectId" class="form-label">Location</label>
                        <input type="text" id="eventLocation-@Model.ObjectId" name="location" class="form-control"
                               value="@Model.Location" />
                    </div>
                    <div class="mb-3">
                        <label for="eventDescription-@Model.ObjectId" class="form-label">Description</label>
                        <textarea id="eventDescription-@Model.ObjectId" name="description" class="form-control"
                                  rows="4">@Model.Description</textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg" aria-hidden="true"></i> Save Event
                        </button>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    }
</section>
