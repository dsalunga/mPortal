@model WCMS.WebSystem.WebParts.ViewComponents.ThreeColumnViewModel
<section class="wcms-three-column @Model.CssClass" aria-label="Three-column layout">
    <div class="row g-3">
        <div class="col-md-@Model.LeftColumnWidth" role="region" aria-label="Left column">
            @if (!string.IsNullOrEmpty(Model.LeftContent))
            {
                @Html.Raw(Model.LeftContent)
            }
            else
            {
                <span class="visually-hidden">Left column (empty)</span>
            }
        </div>
        <div class="col-md-@Model.CenterColumnWidth" role="region" aria-label="Center column">
            @if (!string.IsNullOrEmpty(Model.CenterContent))
            {
                @Html.Raw(Model.CenterContent)
            }
            else
            {
                <span class="visually-hidden">Center column (empty)</span>
            }
        </div>
        <div class="col-md-@Model.RightColumnWidth" role="region" aria-label="Right column">
            @if (!string.IsNullOrEmpty(Model.RightContent))
            {
                @Html.Raw(Model.RightContent)
            }
            else
            {
                <span class="visually-hidden">Right column (empty)</span>
            }
        </div>
    </div>
</section>
