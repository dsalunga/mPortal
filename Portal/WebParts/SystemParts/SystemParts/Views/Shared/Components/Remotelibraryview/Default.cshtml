@model WCMS.WebSystem.WebParts.ViewComponents.RemotelibraryviewViewModel
@* Ported from RemoteLibraryView.ascx (SystemParts). *@

<div class="component-remotelibraryview">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Remote Library View</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>File Manager:</strong> Remote Library View component requires configuration.
        </div>
    }
</div>
