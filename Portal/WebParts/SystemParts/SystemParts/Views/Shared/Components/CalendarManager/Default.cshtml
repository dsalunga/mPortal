@model WCMS.WebSystem.WebParts.ViewComponents.CalendarManagerViewModel
<div class="wcms-calendar-manager">
    @if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning">Please sign in to manage events.</div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4>Calendar Management</h4>
            <button type="button" class="btn btn-primary btn-sm">
                <i class="bi bi-plus"></i> New Event
            </button>
        </div>
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Location</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Events)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.StartDate</td>
                        <td>@item.EndDate</td>
                        <td>@item.Location</td>
                        <td>
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary">Edit</button>
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
