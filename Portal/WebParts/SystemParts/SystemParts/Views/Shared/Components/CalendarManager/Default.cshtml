@model WCMS.WebSystem.WebParts.ViewComponents.CalendarManagerViewModel
<section class="wcms-calendar-manager" aria-label="Calendar management">
    @if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle" aria-hidden="true"></i> Please sign in to manage events.
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 id="calManagerHeading-@Model.ObjectId">Calendar Management</h4>
            <button type="button" class="btn btn-primary btn-sm" aria-label="Create new event">
                <i class="bi bi-plus" aria-hidden="true"></i> New Event
            </button>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover" aria-labelledby="calManagerHeading-@Model.ObjectId">
                <thead>
                    <tr>
                        <th scope="col">Title</th>
                        <th scope="col">Start</th>
                        <th scope="col">End</th>
                        <th scope="col">Location</th>
                        <th scope="col">Status</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Events)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td><time>@item.StartDate</time></td>
                            <td><time>@item.EndDate</time></td>
                            <td>@item.Location</td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")"
                                      aria-label="@(item.IsActive ? "Active" : "Inactive")">
                                    @(item.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Actions for @item.Title">
                                    <button class="btn btn-outline-primary" aria-label="Edit @item.Title">Edit</button>
                                    <button class="btn btn-outline-danger" aria-label="Delete @item.Title">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
