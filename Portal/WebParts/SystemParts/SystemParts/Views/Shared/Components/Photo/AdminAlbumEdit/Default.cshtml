@model WCMS.WebSystem.WebParts.ViewComponents.AdminalbumeditViewModel
@* Ported from AdminAlbumEdit.ascx. *@

<div class="component-adminalbumedit">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Title" class="form-label">Title</label>
            <input type="text" class="form-control" id="field_Title" name="Title" value="@Model.Title" />
        </div>
        <div class="mb-3">
            <label for="field_FolderName" class="form-label">Folder Name</label>
            <input type="text" class="form-control" id="field_FolderName" name="FolderName" value="@Model.FolderName" />
        </div>
        <div class="mb-3">
            <label for="field_ImageURL" class="form-label">Image U R L</label>
            <input type="text" class="form-control" id="field_ImageURL" name="ImageURL" value="@Model.ImageURL" />
        </div>
        <div class="mb-3">
            <label for="field_Width" class="form-label">Width</label>
            <input type="text" class="form-control" id="field_Width" name="Width" value="@Model.Width" />
        </div>
        <div class="mb-3">
            <label for="field_PhotoHeight" class="form-label">Photo Height</label>
            <input type="text" class="form-control" id="field_PhotoHeight" name="PhotoHeight" value="@Model.PhotoHeight" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="btnImageURL">Upload...</button>
            <button type="submit" class="btn btn-primary" name="action" value="btnUpdate">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="btnCancel">Cancel</button>
        </div>
    </form>
</div>