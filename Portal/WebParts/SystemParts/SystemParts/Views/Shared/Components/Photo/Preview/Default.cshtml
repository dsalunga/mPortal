@model WCMS.WebSystem.WebParts.ViewComponents.PhotoPreviewViewModel
@* Ported from Preview.ascx. *@

<div class="component-photo-preview">
    @if (Model.Items.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach (var item in Model.Items)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(item.Name))
                        {
                            <img src="@item.Name" class="card-img-top" alt="@item.Name" loading="lazy" />
                        }
                        <div class="card-body">
                            <p class="card-text small">@item.Name</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted fst-italic">No items available.</p>
    }
</div>