@model WCMS.WebSystem.WebParts.ViewComponents.SearchRogViewModel
@* Ported from Search_ROG.ascx (SystemParts). *@

<div class="component-searchrog">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Search ROG</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Search:</strong> Search ROG component requires configuration.
        </div>
    }
</div>
