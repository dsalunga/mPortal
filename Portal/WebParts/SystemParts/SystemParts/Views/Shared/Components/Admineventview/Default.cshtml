@model WCMS.WebSystem.WebParts.ViewComponents.AdmineventviewViewModel
@* Ported from AdminEventView.ascx (SystemParts). *@

<div class="component-admineventview">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Admin Event View</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>System:</strong> Admin Event View component requires configuration.
        </div>
    }
</div>
