@model WCMS.WebSystem.WebParts.ViewComponents.ThumbnailsViewModel
@* Ported from Thumbnails.ascx (SystemParts). *@

<div class="component-thumbnails">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Thumbnails</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Photo:</strong> Thumbnails component requires configuration.
        </div>
    }
</div>
