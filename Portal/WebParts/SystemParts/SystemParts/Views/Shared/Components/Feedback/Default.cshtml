@model WCMS.WebSystem.WebParts.ViewComponents.FeedbackViewModel
<section class="wcms-feedback" aria-label="Feedback">
    <div id="pnlContent-@Model.ObjectId" class="card">
        <div class="card-body">
            <form method="post" asp-action="Feedback" asp-controller="ContentApi"
                  id="feedbackForm-@Model.ObjectId" data-success-target="#pnlThank-@Model.ObjectId"
                  aria-label="Submit feedback">
                <input type="hidden" name="objectId" value="@Model.ObjectId" />
                <input type="hidden" name="recordId" value="@Model.RecordId" />
                <h5 class="card-title text-center mb-3">Feedback</h5>
                @if (Model.IsLoggedIn && !string.IsNullOrEmpty(Model.UserName))
                {
                    <p class="text-muted small">Submitting as: <strong>@Model.UserName</strong></p>
                }
                <div class="mb-3">
                    <label for="txtFeed-@Model.ObjectId" class="form-label visually-hidden">Your feedback</label>
                    <textarea id="txtFeed-@Model.ObjectId" name="feedback" class="form-control" rows="6"
                              placeholder="Share your feedback…" required
                              aria-required="true"></textarea>
                </div>
                <div class="text-center">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send"></i> Send Feedback
                    </button>
                </div>
            </form>
        </div>
    </div>
    <div id="pnlThank-@Model.ObjectId" class="card text-center d-none" role="status" aria-live="polite">
        <div class="card-body">
            <p class="fw-bold text-success mb-0">
                <i class="bi bi-check-circle"></i> Thank you for your feedback!
            </p>
        </div>
    </div>
</section>
