@model WCMS.WebSystem.WebParts.ViewComponents.CcmsCategoryViewModel
@* Ported from CCMS_Category.ascx (SystemParts). *@

<div class="component-ccmscategory">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>CCMS Category</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>CMS:</strong> CCMS Category component requires configuration.
        </div>
    }
</div>
