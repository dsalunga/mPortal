@model WCMS.WebSystem.WebParts.ViewComponents.ListdataViewModel
@* Ported from ListData.ascx (SystemParts). *@

<div class="component-listdata">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>List Data</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Generic List / Survey:</strong> List Data component requires configuration.
        </div>
    }
</div>
