@model WCMS.WebSystem.WebParts.ViewComponents.TexteditorViewModel
@* Ported from TextEditor.ascx (SystemParts). *@

<div class="component-texteditor">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Text Editor</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>File Manager:</strong> Text Editor component requires configuration.
        </div>
    }
</div>
