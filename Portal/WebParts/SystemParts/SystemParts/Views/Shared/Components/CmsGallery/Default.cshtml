@model WCMS.WebSystem.WebParts.ViewComponents.CmsGalleryViewModel
@* Ported from CMS_Gallery.ascx (SystemParts). *@

<div class="component-cmsgallery">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>CMS Gallery</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Photo:</strong> CMS Gallery component requires configuration.
        </div>
    }
</div>
