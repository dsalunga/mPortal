@model WCMS.WebSystem.WebParts.ViewComponents.ArticleMultipleMultiNewsroomViewModel
@* Ported from Newsroom.ascx (SystemParts). *@

<div class="component-articlemultiplemultinewsroom">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Newsroom</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Article:</strong> Newsroom component requires configuration.
        </div>
    }
</div>
