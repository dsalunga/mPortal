@model WCMS.WebSystem.WebParts.ViewComponents.TexteditorViewModel
@* Ported from TextEditor.ascx. *@

<div class="component-texteditor">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Content" class="form-label">Content</label>
            <textarea class="form-control" id="field_Content" name="Content" rows="4">@Model.Content</textarea>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>