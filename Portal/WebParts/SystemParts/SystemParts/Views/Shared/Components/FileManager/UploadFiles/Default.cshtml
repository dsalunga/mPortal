@model WCMS.WebSystem.WebParts.ViewComponents.UploadFilesViewModel
<section class="wcms-upload-files" aria-label="File upload">
    @if (!Model.IsLoggedIn)
    {
        <div class="alert alert-warning d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
            Please sign in to upload files.
        </div>
    }
    else
    {
        @if (Model.IsUploaded)
        {
            <div class="alert alert-success d-flex align-items-center" role="status" aria-live="polite">
                <i class="bi bi-check-circle-fill me-2" aria-hidden="true"></i>
                @(Model.Message ?? "Files uploaded successfully.")
            </div>
        }
        <div class="card shadow-sm">
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="bi bi-cloud-arrow-up" aria-hidden="true"></i> Upload Files
                </h4>
            </div>
            <div class="card-body">
                <form method="post" enctype="multipart/form-data" aria-label="File upload form">
                    <input type="hidden" name="objectId" value="@Model.ObjectId" />
                    <input type="hidden" name="recordId" value="@Model.RecordId" />
                    <div class="mb-3">
                        <label for="fileUpload-@Model.ObjectId" class="form-label">Choose files</label>
                        <input type="file" id="fileUpload-@Model.ObjectId" name="files" class="form-control"
                               multiple required aria-required="true"
                               aria-describedby="fileHelp-@Model.ObjectId" />
                        <div id="fileHelp-@Model.ObjectId" class="form-text">
                            <i class="bi bi-info-circle" aria-hidden="true"></i>
                            Max file size: <strong>@Model.MaxFileSizeMb MB</strong>.
                            @if (!string.IsNullOrEmpty(Model.AllowedExtensions))
                            {
                                <span>Allowed: <strong>@Model.AllowedExtensions</strong></span>
                            }
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload" aria-hidden="true"></i> Upload
                    </button>
                </form>
            </div>
        </div>
    }
</section>
