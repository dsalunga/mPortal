@model WCMS.WebSystem.WebParts.ViewComponents.FileManagerViewModel
@*
    Ported from FileManager/FileManager.ascx
    CSS classes preserved: _wp_FileManager, wp-FileManager, control-box, Header, _FileManager_Button
*@
<section class="_wp_FileManager wp-FileManager" aria-label="File manager">
    <nav aria-label="File path breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Model.BasePath"><i class="bi bi-house-door"></i> Root</a>
            </li>
            @if (!string.IsNullOrEmpty(Model.CurrentPath))
            {
                <li class="breadcrumb-item active" aria-current="page">@Model.CurrentPath</li>
            }
        </ol>
    </nav>
    @if (Model.IsLoggedIn)
    {
        <div class="control-box d-flex gap-2 mb-3" role="toolbar" aria-label="File actions">
            <button type="button" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-file-earmark-plus"></i> Add files
            </button>
            <button type="button" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-folder-plus"></i> Create folder
            </button>
        </div>
    }
    @if (Model.Files.Count == 0)
    {
        <p class="text-muted" role="status">No files found.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle" aria-label="File listing">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Size</th>
                        <th scope="col">Type</th>
                        <th scope="col">Date Modified</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in Model.Files)
                    {
                        <tr>
                            <td>
                                @if (file.IsDirectory)
                                {
                                    <i class="bi bi-folder-fill text-warning" aria-hidden="true"></i>
                                    <a href="@Model.BasePath?path=@file.FilePath">@file.FileName</a>
                                }
                                else
                                {
                                    <i class="bi bi-file-earmark text-secondary" aria-hidden="true"></i>
                                    <a href="@file.FilePath" target="_blank" rel="noopener">@file.FileName</a>
                                }
                            </td>
                            <td>
                                @if (!file.IsDirectory)
                                {
                                    @(file.FileSize < 1024 ? file.FileSize + " B" : (file.FileSize / 1024) + " KB")
                                }
                            </td>
                            <td><span class="badge bg-light text-dark">@file.ContentType</span></td>
                            <td><time>@file.LastModified</time></td>
                            <td>
                                @if (!file.IsDirectory)
                                {
                                    <a href="@file.FilePath" class="btn btn-sm btn-outline-secondary" download
                                       aria-label="Download @file.FileName">
                                        <i class="bi bi-download"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    <div aria-live="polite">
        <span class="Header text-danger visually-hidden"></span>
    </div>
</section>
