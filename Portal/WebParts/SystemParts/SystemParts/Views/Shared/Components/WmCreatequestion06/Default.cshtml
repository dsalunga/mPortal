@model WCMS.WebSystem.WebParts.ViewComponents.WmCreatequestion06ViewModel
@* Ported from WM_CreateQuestion_06.ascx. *@

<div class="component-wm-createquestion06">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_QLabel" class="form-label">Q Label</label>
            <textarea class="form-control" id="field_QLabel" name="QLabel" rows="4">@Model.QLabel</textarea>
        </div>
        <div class="mb-3">
            <label for="field_QRanking" class="form-label">Q Ranking</label>
            <input type="text" class="form-control" id="field_QRanking" name="QRanking" value="@Model.QRanking" />
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_Required" name="Required" @(Model.Required ? "checked" : "") />
            <label class="form-check-label" for="field_Required">Required</label>
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_Horizontal" name="Horizontal" @(Model.Horizontal ? "checked" : "") />
            <label class="form-check-label" for="field_Horizontal">Horizontal Orientation</label>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdQUpdate">Save</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>