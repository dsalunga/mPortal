@model WCMS.WebSystem.WebParts.ViewComponents.DrophighlightmenuViewModel
@* Ported from DropHighlightMenu.ascx (SystemParts). *@

<div class="component-drophighlightmenu">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Drop Highlight Menu</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>System:</strong> Drop Highlight Menu component requires configuration.
        </div>
    }
</div>
