@model WCMS.WebSystem.WebParts.ViewComponents.SmSurveysViewModel
@* Ported from SM_Surveys.ascx (SystemParts). *@

<div class="component-smsurveys">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>SM Surveys</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Generic List / Survey:</strong> SM Surveys component requires configuration.
        </div>
    }
</div>
