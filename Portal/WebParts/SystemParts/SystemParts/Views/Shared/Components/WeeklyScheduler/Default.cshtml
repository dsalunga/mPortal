@model WCMS.WebSystem.WebParts.ViewComponents.WeeklySchedulerViewModel
@{
    var days = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
}
<section class="wcms-weekly-scheduler" aria-label="Weekly schedule">
    <div class="card shadow-sm">
        @if (!string.IsNullOrEmpty(Model.Title))
        {
            <div class="card-header">
                <h4 class="mb-0" id="scheduleTitle-@Model.ObjectId">
                    <i class="bi bi-calendar-week" aria-hidden="true"></i> @Model.Title
                </h4>
            </div>
        }
        <div class="card-body p-0">
            @if (Model.Entries == null || Model.Entries.Count == 0)
            {
                <p class="text-muted text-center py-4 mb-0" role="status">
                    <i class="bi bi-calendar-x" aria-hidden="true"></i> No scheduled entries.
                </p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered text-center align-middle mb-0" role="grid"
                           aria-label="@(!string.IsNullOrEmpty(Model.Title) ? Model.Title : "Weekly schedule")">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="fw-bold">Time</th>
                                @foreach (var d in days)
                                {
                                    <th scope="col" abbr="@d.Substring(0, 3)" class="fw-bold">@d</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @for (var h = Model.StartHour; h <= Model.EndHour; h++)
                            {
                                var hour = h;
                                <tr>
                                    <th scope="row" class="text-nowrap fw-bold bg-light">
                                        <time>@(hour.ToString("00")):00</time>
                                    </th>
                                    @for (var di = 0; di < 7; di++)
                                    {
                                        var dayIndex = di;
                                        var hourStr = hour.ToString("00") + ":00";
                                        var entries = Model.Entries.FindAll(e => e.DayOfWeek == dayIndex &&
                                            string.Compare(e.StartTime, hourStr, System.StringComparison.Ordinal) <= 0 &&
                                            string.Compare(e.EndTime, hourStr, System.StringComparison.Ordinal) > 0);
                                        <td class="@(entries.Count > 0 ? "table-info" : "")"
                                            aria-label="@days[dayIndex] @hourStr@(entries.Count > 0 ? ", " + entries.Count + " scheduled" : "")">
                                            @foreach (var entry in entries)
                                            {
                                                <div class="small @entry.CssClass p-1 rounded">
                                                    <strong>@entry.Title</strong>
                                                    @if (!string.IsNullOrEmpty(entry.Location))
                                                    {
                                                        <br />
                                                        <small class="text-muted">
                                                            <i class="bi bi-geo-alt" aria-hidden="true"></i> @entry.Location
                                                        </small>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>
