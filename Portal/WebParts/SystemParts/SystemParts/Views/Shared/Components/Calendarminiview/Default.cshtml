@model WCMS.WebSystem.WebParts.ViewComponents.CalendarminiviewViewModel
@* Ported from CalendarMiniView.ascx (SystemParts). *@

<div class="component-calendarminiview">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Calendar Mini View</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Event Calendar:</strong> Calendar Mini View component requires configuration.
        </div>
    }
</div>
