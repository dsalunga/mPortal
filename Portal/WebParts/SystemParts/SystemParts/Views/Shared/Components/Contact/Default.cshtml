@model WCMS.WebSystem.WebParts.ViewComponents.ContactFormModel
<div class="Contact-Us">
    @if (Model.Submitted)
    {
        <span>Thank you for your message. We will get back to you shortly.</span>
    }
    else
    {
        <form method="post" asp-action="Submit" asp-controller="ContentApi">
            <input type="hidden" name="objectId" value="@Model.ObjectId" />
            <input type="hidden" name="recordId" value="@Model.RecordId" />
            <table cellspacing="5" cellpadding="0" border="0">
                @if (Model.IsLoggedIn)
                {
                    <tr>
                        <td style="width: 120px">Name:</td>
                        <td>
                            <strong><span>@Model.Name</span></strong>
                            <input type="hidden" name="name" value="@Model.Name" />
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td style="width: 120px">Name:<span style="color: red">*</span>&nbsp;</td>
                        <td>
                            <input type="text" name="name" class="span3 input" value="@Model.Name" required />
                        </td>
                    </tr>
                }
                <tr>
                    <td>Email Address:<span style="color: red">*</span>&nbsp;</td>
                    <td>
                        <input type="email" name="email" class="span3 input" value="@Model.Email" required />
                    </td>
                </tr>
                <tr>
                    <td>Contact No:</td>
                    <td>
                        <input type="text" name="contactNo" class="input" />
                    </td>
                </tr>
                <tr>
                    <td style="width: 120px">Subject:<span style="color: red">*</span>&nbsp;</td>
                    <td>
                        <input type="text" name="subject" class="span5 input" required />
                    </td>
                </tr>
                <tr>
                    <td style="vertical-align: top">Message:<span style="color: red">*</span></td>
                    <td>
                        <textarea name="message" class="span5 input" cols="68" rows="8" required></textarea>
                    </td>
                </tr>
                <tr>
                    <td style="font-style: italic">
                        <span style="color: Red">*</span>&nbsp;-&nbsp;required&nbsp;
                    </td>
                    <td align="left">
                        <button type="submit" class="btn btn-primary">Submit</button>
                    </td>
                </tr>
            </table>
        </form>
        <br />
    }
</div>
