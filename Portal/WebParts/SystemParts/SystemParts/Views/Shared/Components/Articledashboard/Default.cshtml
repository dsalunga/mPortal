@model WCMS.WebSystem.WebParts.ViewComponents.ArticledashboardViewModel
@* Ported from ArticleDashboard.ascx (SystemParts). *@

<div class="component-articledashboard">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Article Dashboard</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Article:</strong> Article Dashboard component requires configuration.
        </div>
    }
</div>
