@model WCMS.WebSystem.WebParts.ViewComponents.CmsStdmenu01ViewModel
@* Ported from CMS_StdMenu_01.ascx. *@

<div class="component-cms-stdmenu01">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Home" class="form-label">Home</label>
            <input type="text" class="form-control" id="field_Home" name="Home" value="@Model.Home" />
        </div>
        <div class="mb-3">
            <label for="field_Width" class="form-label">Width</label>
            <input type="text" class="form-control" id="field_Width" name="Width" value="@Model.Width" />
        </div>
        <div class="mb-3">
            <label for="field_Height" class="form-label">Height</label>
            <input type="text" class="form-control" id="field_Height" name="Height" value="@Model.Height" />
        </div>
        <div class="mb-3">
            <label for="field_DropDownList1" class="form-label">Drop Down List1</label>
            <select class="form-select" id="field_DropDownList1" name="SelectedDropDownList1">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.DropDownList1Options)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedDropDownList1 ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_DropDownList2" class="form-label">Drop Down List2</label>
            <select class="form-select" id="field_DropDownList2" name="SelectedDropDownList2">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.DropDownList2Options)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedDropDownList2 ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboOrientation" class="form-label">Cbo Orientation</label>
            <select class="form-select" id="field_CboOrientation" name="SelectedCboOrientation">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboOrientationOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboOrientation ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
        </div>
    </form>
</div>