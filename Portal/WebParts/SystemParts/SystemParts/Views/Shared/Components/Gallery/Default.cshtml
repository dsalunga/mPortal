@model WCMS.WebSystem.WebParts.ViewComponents.GalleryViewModel
<div class="wcms-gallery">
    @if (Model.Items.Count == 0)
    {
        <p class="text-muted">No images in this gallery.</p>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model.Items)
            {
                <div class="col-md-3 col-sm-4 col-6 mb-3">
                    <div class="card gallery-item">
                        <a href="@item.ImageUrl" data-lightbox="gallery" data-title="@item.Title">
                            <img src="@(item.ThumbnailUrl ?? item.ImageUrl)" alt="@item.Title"
                                 class="card-img-top" loading="lazy" />
                        </a>
                        @if (!string.IsNullOrEmpty(item.Title))
                        {
                            <div class="card-body p-2">
                                <small class="card-title">@item.Title</small>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
