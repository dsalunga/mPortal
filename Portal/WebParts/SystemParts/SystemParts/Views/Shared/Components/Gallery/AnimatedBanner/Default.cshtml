@model WCMS.WebSystem.WebParts.ViewComponents.AnimatedBannerViewModel
@{
    var carouselId = "banner-" + Model.ObjectId;
}
<section class="wcms-animated-banner" aria-label="Banner slideshow">
    @if (Model.Slides == null || Model.Slides.Count == 0)
    {
        <div class="text-muted text-center py-4" role="status">
            <i class="bi bi-image" aria-hidden="true"></i> No banner slides configured.
        </div>
    }
    else
    {
        <div id="@carouselId" class="carousel slide shadow-sm rounded overflow-hidden"
             data-bs-ride="carousel" data-bs-interval="@Model.IntervalMs"
             aria-roledescription="carousel" aria-label="Banner slideshow">
            @if (Model.ShowIndicators && Model.Slides.Count > 1)
            {
                <div class="carousel-indicators">
                    @for (var i = 0; i < Model.Slides.Count; i++)
                    {
                        <button type="button" data-bs-target="#@carouselId" data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")"
                                aria-current="@(i == 0 ? "true" : "false")"
                                aria-label="Slide @(i + 1) of @Model.Slides.Count"></button>
                    }
                </div>
            }
            <div class="carousel-inner" aria-live="off">
                @for (var i = 0; i < Model.Slides.Count; i++)
                {
                    var slide = Model.Slides[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")"
                         role="group" aria-roledescription="slide"
                         aria-label="Slide @(i + 1) of @Model.Slides.Count: @slide.Title">
                        @if (!string.IsNullOrEmpty(slide.LinkUrl))
                        {
                            <a href="@slide.LinkUrl" aria-label="@slide.Title">
                                <img src="@slide.ImageUrl" class="d-block w-100"
                                     alt="@(slide.Title ?? "Banner slide")" loading="lazy" decoding="async" />
                            </a>
                        }
                        else
                        {
                            <img src="@slide.ImageUrl" class="d-block w-100"
                                 alt="@(slide.Title ?? "Banner slide")" loading="lazy" decoding="async" />
                        }
                        @if (!string.IsNullOrEmpty(slide.Title) || !string.IsNullOrEmpty(slide.Caption))
                        {
                            <div class="carousel-caption d-none d-md-block">
                                @if (!string.IsNullOrEmpty(slide.Title))
                                {
                                    <h5>@slide.Title</h5>
                                }
                                @if (!string.IsNullOrEmpty(slide.Caption))
                                {
                                    <p class="mb-0">@slide.Caption</p>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
            @if (Model.ShowControls && Model.Slides.Count > 1)
            {
                <button class="carousel-control-prev" type="button"
                        data-bs-target="#@carouselId" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous slide</span>
                </button>
                <button class="carousel-control-next" type="button"
                        data-bs-target="#@carouselId" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next slide</span>
                </button>
            }
        </div>
    }
</section>
