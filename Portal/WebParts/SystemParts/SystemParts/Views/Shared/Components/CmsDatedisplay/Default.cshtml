@model WCMS.WebSystem.WebParts.ViewComponents.CmsDatedisplayViewModel
@* Ported from CMS_DateDisplay.ascx (SystemParts). *@

<div class="component-cmsdatedisplay">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>CMS Date Display</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Date Display:</strong> CMS Date Display component requires configuration.
        </div>
    }
</div>
