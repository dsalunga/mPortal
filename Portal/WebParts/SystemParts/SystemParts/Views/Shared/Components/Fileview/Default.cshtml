@model WCMS.WebSystem.WebParts.ViewComponents.FileviewViewModel
@* Ported from FileView.ascx (SystemParts). *@

<div class="component-fileview">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>File View</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>File Manager:</strong> File View component requires configuration.
        </div>
    }
</div>
