@model WCMS.WebSystem.WebParts.ViewComponents.RenamefileViewModel
@* Ported from RenameFile.ascx. *@

<div class="component-renamefile">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_OldName" class="form-label">Old Name</label>
            <input type="text" class="form-control" id="field_OldName" name="OldName" value="@Model.OldName" />
        </div>
        <div class="mb-3">
            <label for="field_NewName" class="form-label">New Name</label>
            <input type="text" class="form-control" id="field_NewName" name="NewName" value="@Model.NewName" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdRename">Rename</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>