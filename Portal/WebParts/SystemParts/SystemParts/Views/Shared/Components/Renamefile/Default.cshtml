@model WCMS.WebSystem.WebParts.ViewComponents.RenamefileViewModel
@* Ported from RenameFile.ascx (SystemParts). *@

<div class="component-renamefile">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Rename File</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>File Manager:</strong> Rename File component requires configuration.
        </div>
    }
</div>
