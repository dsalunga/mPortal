@model WCMS.WebSystem.WebParts.ViewComponents.SlideshowViewModel
@* Ported from SlideShow.ascx (SystemParts). *@

<div class="component-slideshow">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Slide Show</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Photo:</strong> Slide Show component requires configuration.
        </div>
    }
</div>
