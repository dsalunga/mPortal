@model WCMS.WebSystem.WebParts.ViewComponents.SearchresultsViewModel
@* Ported from SearchResults.ascx (SystemParts). *@

<div class="component-searchresults">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Search Results</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Search:</strong> Search Results component requires configuration.
        </div>
    }
</div>
