@model WCMS.WebSystem.WebParts.ViewComponents.PhotoPreviewViewModel
@* Ported from Preview.ascx (SystemParts). *@

<div class="component-photopreview">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Preview</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Photo:</strong> Preview component requires configuration.
        </div>
    }
</div>
