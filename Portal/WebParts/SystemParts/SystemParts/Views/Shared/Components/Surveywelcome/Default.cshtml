@model WCMS.WebSystem.WebParts.ViewComponents.SurveywelcomeViewModel
@* Ported from SurveyWelcome.ascx (SystemParts). *@

<div class="component-surveywelcome">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Survey Welcome</em> — ported from legacy WebForms. 
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Generic List / Survey:</strong> Survey Welcome component requires configuration.
        </div>
    }
</div>
