@using WCMS.Common.Utilities
@using WCMS.Framework
@using WCMS.WebSystem.Apps.Integration
@{
    WebUser user = null;
    var context = new WContext(this);
    var site = context.Site;
    var portalSite = WSite.Provider.Get("Portal");

    var wsession = WSession.Current;
    var isMember = false;
    var isSG = false;
    var sessionId = string.Empty;
    var portalSessionId = string.Empty;
    if (wsession.IsLoggedIn)
    {
        user = wsession.User;
        isMember = user.IsMemberOf(IntegrationConstants.MEMBERS_GROUP_NAME);
        isSG = user.IsMemberOf("Singapore");
        var userSession = wsession.UserSession;
        if (userSession != null)
        {
            sessionId = "?SessionId=" + userSession.SessionId;
            if (site.Id != portalSite.Id)
            {
                portalSessionId = sessionId;
            }
        }
    }

    var request = context.Context.Request;
    var portalHomeUrl = portalSite.BuildAbsoluteUrl();
    var portalRootUrl = portalHomeUrl;
    var chaptersUrl = "";
    var chaptersPage = WPage.Provider.Get(portalSite.Id, -1, "chapters");
    if (chaptersPage != null)
    {
        chaptersUrl = string.Format("{0}?SiteId={1}&PageId={2}", CentralPages.LoaderMain, portalSite.Id, chaptersPage.Id);
    }
}

@*<h1 class="page-header">Apps, Websites &amp; Services</h1>
    <p class="lead">Here is a list of apps and links available to members.</p>
*@

<style type="text/css">
    /*h1.page-header {margin-top: 70px;}*/
    h1.page-header {
        margin-top: 0px;
    }

    .app-category {
        margin-bottom: 50px;
    }

        .app-category .media .media-body {
            /*font-size: 13px;*/
            color: #999; /*707070*/
        }

    .media a {
        color: #333;
    }

    .app-category .media, .media .media {
        margin-top: 0;
        margin-bottom: 30px;
        min-height: 64px;
    }

        .app-category .media:first-child {
            margin-top: 0;
        }

    .flag-shadow {
        /*box-shadow: 1px 1px #ddd;*/
        border: 1px solid #eee;
    }

    .app-icon {
        width: 64px;
    }

    .glyphicon-icon {
        font-size: 46px;
        width: 64px;
        /*color: #EDA912;*/
        color: #777;
        padding-left: 8px;
        padding-right: 8px;
    }
</style>

<div class="container">
    <div class="row">
        <div class="col-md-12">
            <div class="jumbotron">
                <h1>Settings</h1>
                @*<p>Live gathering video hookup and monitoring service</p>*@
            </div>
        </div>
        <div class="col-xs-12 col-md-12">
            <div class="row app-category">
                <div class="col-md-12">
                    <h1 id="locales" class="page-header">Integration Portal</h1>
                </div>
                <div class="media col-sm-6 col-lg-4">
                    <a class="pull-left" href="/settings/Registration-Approval/">
                        <span class="glyphicon glyphicon-user glyphicon-icon">&nbsp;</span>
                    </a>
                    <div class="media-body">
                        <h4 class="media-heading"><a href="/settings/Registration-Approval/">Registration Approval</a></h4>
                        Review and approve member registration requests
                    </div>
                </div>
                <div class="media col-sm-6 col-lg-4">
                    <a class="pull-left" href="/settings/Group-Approval/">
                        <span class="glyphicon glyphicon-user glyphicon-icon">&nbsp;</span>
                    </a>
                    <div class="media-body">
                        <h4 class="media-heading"><a href="/settings/Group-Approval/">Group Membership Approval</a></h4>
                        Review and approve requests of members to join your groups
                    </div>
                </div>
                <div class="media col-sm-6 col-lg-4">
                    <a class="pull-left" href="/settings/Group-Settings/">
                        <span class="glyphicon glyphicon-user glyphicon-icon">&nbsp;</span>
                    </a>
                    <div class="media-body">
                        <h4 class="media-heading"><a href="/settings/Group-Settings/">Group Settings</a></h4>
                        Change the settigns of your groups including privacy
                    </div>
                </div>
                <div class="media col-sm-6 col-lg-4">
                    <a class="pull-left" href="/ODK/">
                        <span class="glyphicon glyphicon-user glyphicon-icon">&nbsp;</span>
                    </a>
                    <div class="media-body">
                        <h4 class="media-heading"><a href="/ODK/">ODK Visit Log</a></h4>
                        Manage ODK visit records
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(chaptersUrl)) {
                <div class="media col-sm-6 col-lg-4">
                    <a class="pull-left" href="@chaptersUrl">
                        <span class="glyphicon glyphicon-map-marker glyphicon-icon">&nbsp;</span>
                    </a>
                    <div class="media-body">
                        <h4 class="media-heading"><a href="@chaptersUrl">Chapters &amp; Announcements</a></h4>
                        Manage Chapters and Locale Announcements
                    </div>
                </div>
                }
            </div>
            @if (wsession.IsSiteManager)
            {
                <div class="row app-category">
                    <div class="col-md-12">
                        <h1 id="locales" class="page-header">Administration</h1>
                    </div>
                    <div class="media col-sm-6 col-lg-4">
                        <a class="pull-left" href="/Central/">
                            <span class="glyphicon glyphicon-cog glyphicon-icon">&nbsp;</span>
                        </a>
                        <div class="media-body">
                            <h4 class="media-heading"><a href="/Central/">Central Administration</a></h4>
                            Administration of the content management system
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>