  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\WCMS.WebSystem.Apps.Integration\WCMS.WebSystem.Apps.Integration.csproj" />
    <ProjectReference Include="..\WCMS.WebSystem.Apps.BibleReader\WCMS.WebSystem.Apps.BibleReader.csproj" />
    <ProjectReference Include="..\..\..\WebSystem\WCMS.Common\WCMS.Common.csproj" />
    <ProjectReference Include="..\..\..\WebSystem\WCMS.Framework\WCMS.Framework.csproj" />
  </ItemGroup>
</Project>
