@* Originally: area51/Parts/Profile/Profile/UpdateMyGroups.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeArea51UpdateMyGroupsModel

<div id="theme-area51-update-groups-@Model.ObjectId">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">My Groups</h5>
                        @await Component.InvokeAsync("WZone", new { zone = "GroupActions" })
                    </div>
                    <div class="card-body">
                        <!-- Group List -->
                        @await Component.InvokeAsync("WZone", new { zone = "GroupList" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
