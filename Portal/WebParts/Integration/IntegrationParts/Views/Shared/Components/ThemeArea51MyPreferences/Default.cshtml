@* Originally: area51/Parts/Profile/Profile/MyPreferences.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeArea51MyPreferencesModel

<div id="theme-area51-preferences-@Model.ObjectId">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">My Preferences</h5>
                    </div>
                    <div class="card-body">
                        <!-- Settings Sections -->
                        @await Component.InvokeAsync("WZone", new { zone = "PreferenceSettings" })
                    </div>
                    <div class="card-footer text-end">
                        @await Component.InvokeAsync("WZone", new { zone = "PreferenceActions" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
