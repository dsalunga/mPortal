@model WCMS.WebSystem.WebParts.ViewComponents.IntGetAccessModel

<section aria-labelledby="get-access-heading-@Model.ObjectId">
    <div class="card" id="int-get-access-@Model.ObjectId">
        <div class="card-header">
            <h5 class="card-title mb-0" id="get-access-heading-@Model.ObjectId">
                <i class="bi bi-door-open" aria-hidden="true"></i> Request Access
            </h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                    @Model.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <form method="post" novalidate aria-label="Request access form">
                <div class="mb-3">
                    <label for="accessEmail" class="form-label">Email Address <span class="text-danger" aria-hidden="true">*</span></label>
                    <input type="email" class="form-control" id="accessEmail" name="Email" required aria-required="true" />
                </div>
                <div class="mb-3">
                    <label for="accessType" class="form-label">Access Type</label>
                    <select class="form-select" id="accessType" name="AccessType" aria-label="Select access type">
                        <option value="">-- Select --</option>
                        @if (Model.AccessOptions != null)
                        {
                            @foreach (var option in Model.AccessOptions)
                            {
                                <option value="@option">@option</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="accessReason" class="form-label">Reason for Request</label>
                    <textarea class="form-control" id="accessReason" name="Reason" rows="3"></textarea>
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send" aria-hidden="true"></i> Submit Request
                </button>
            </form>
        </div>
    </div>
</section>
