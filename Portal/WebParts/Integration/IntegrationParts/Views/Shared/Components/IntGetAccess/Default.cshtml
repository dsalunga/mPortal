@model WCMS.WebSystem.WebParts.ViewComponents.IntGetAccessModel

<div class="card" id="int-get-access-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Request Access</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        <form method="post" novalidate>
            <div class="mb-3">
                <label for="accessEmail" class="form-label">Email Address</label>
                <input type="email" class="form-control" id="accessEmail" name="Email" required />
            </div>
            <div class="mb-3">
                <label for="accessType" class="form-label">Access Type</label>
                <select class="form-select" id="accessType" name="AccessType">
                    <option value="">-- Select --</option>
                    @if (Model.AccessOptions != null)
                    {
                        @foreach (var option in Model.AccessOptions)
                        {
                            <option value="@option">@option</option>
                        }
                    }
                </select>
            </div>
            <div class="mb-3">
                <label for="accessReason" class="form-label">Reason for Request</label>
                <textarea class="form-control" id="accessReason" name="Reason" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Submit Request</button>
        </form>
    </div>
</div>
