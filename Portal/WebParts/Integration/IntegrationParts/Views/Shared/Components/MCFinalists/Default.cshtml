@model dynamic

<section class="card" id="mc-finalists-@Model.ObjectId" role="region" aria-label="Finalists">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-star-fill text-warning" aria-hidden="true"></i> Finalists</h5>
    </div>
    <div class="card-body">
        <div class="row g-3" role="list" aria-label="Finalist cards">
            <div class="col-md-4 col-sm-6" role="listitem">
                <div class="card h-100 shadow-sm">
                    <img src="/images/placeholder-finalist.png" class="card-img-top" alt="Finalist photo" />
                    <div class="card-body text-center">
                        <h6 class="card-title">Finalist Name</h6>
                        <p class="text-muted small mb-2">Song Title</p>
                        <span class="badge bg-primary">Category</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
