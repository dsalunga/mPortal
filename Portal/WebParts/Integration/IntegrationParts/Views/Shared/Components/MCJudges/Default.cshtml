@model WCMS.WebSystem.WebParts.ViewComponents.MCJudgesModel

<section class="card" id="mc-judges-@Model.ObjectId" aria-labelledby="mc-judges-heading-@Model.ObjectId">
    <div class="card-header">
        <h5 id="mc-judges-heading-@Model.ObjectId" class="card-title mb-0"><i class="bi bi-person-badge-fill" aria-hidden="true"></i> Judges Panel</h5>
    </div>
    <div class="card-body">
        <div class="row g-3" role="list" aria-label="Judges list">
            <div class="col-md-4 col-sm-6" role="listitem">
                <div class="card h-100 text-center shadow-sm">
                    <div class="card-body">
                        <img src="/images/placeholder-judge.png" alt="Judge photo" class="rounded-circle mb-2" width="80" height="80" loading="lazy" />
                        <h6 class="card-title mb-1">Judge Name</h6>
                        <p class="text-muted small mb-0">Specialty / Title</p>
                    </div>
                </div>
            </div>
        </div>
        <p class="text-center text-muted mt-3 mb-0 empty-state">
            <i class="bi bi-inbox" aria-hidden="true"></i> No judges assigned.
        </p>
    </div>
</section>
