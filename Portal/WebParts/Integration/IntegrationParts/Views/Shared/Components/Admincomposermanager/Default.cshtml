@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AdmincomposermanagerViewModel
@* Ported from AdminComposerManager.ascx. *@

<div class="component-admincomposermanager">
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th scope="col" style="width:60px" class="text-center">Actions</th>
                    <th scope="col">Name</th>
                    <th scope="col">Nick Name</th>
                    <th scope="col">Locale</th>
                    <th scope="col">Entry</th>
                    <th scope="col">Work</th>
                    <th scope="col">Photo File</th>
                    <th scope="col">Competition</th>
                    <th scope="col">Active</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="text-center">
                                <a href="?action=edit&id=@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                            <td>@item.Name</td>
                            <td>@item.NickName</td>
                            <td>@item.Locale</td>
                            <td>@item.Entry</td>
                            <td>@item.Work</td>
                            <td>@item.PhotoFile</td>
                            <td>@item.Competition</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>@item.Actions</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="10" class="text-center text-muted fst-italic">No records found.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalItems > Model.PageSize)
    {
        var pageCount = (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize);
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center mt-3">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage - 1)" aria-label="Previous">&laquo;</a>
                </li>
                @for (int i = 1; i <= pageCount; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= pageCount ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage + 1)" aria-label="Next">&raquo;</a>
                </li>
            </ul>
        </nav>
    }
</div>