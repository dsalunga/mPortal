@model WCMS.WebSystem.WebParts.Integration.ViewComponents.RegistrationConfigmemberlinkeditViewModel
@* Ported from ConfigMemberLinkEdit.ascx. *@

<div class="component-registration-configmemberlinkedit">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Name" class="form-label">Name</label>
            <input type="text" class="form-control" id="field_Name" name="Name" value="@Model.Name" />
        </div>
        <div class="mb-3">
            <label for="field_Email" class="form-label">Email</label>
            <input type="text" class="form-control" id="field_Email" name="Email" value="@Model.Email" />
        </div>
        <div class="mb-3">
            <label for="field_ExternalIDNo" class="form-label">External I D No</label>
            <input type="text" class="form-control" id="field_ExternalIDNo" name="ExternalIDNo" value="@Model.ExternalIDNo" />
        </div>
        <div class="mb-3">
            <label for="field_MembershipDate" class="form-label">Membership Date</label>
            <input type="text" class="form-control" id="field_MembershipDate" name="MembershipDate" value="@Model.MembershipDate" />
        </div>
        <div class="mb-3">
            <label for="field_PhotoPath" class="form-label">Photo Path</label>
            <input type="text" class="form-control" id="field_PhotoPath" name="PhotoPath" value="@Model.PhotoPath" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdExternalSync">External Sync</button>
            <button type="submit" class="btn btn-primary" name="action" value="cmdSubmit">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>