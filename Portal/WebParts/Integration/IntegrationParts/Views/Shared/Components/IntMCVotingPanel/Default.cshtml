@model WCMS.WebSystem.WebParts.ViewComponents.IntMCVotingPanelModel

<section id="int-mc-voting-panel-@Model.ObjectId" aria-labelledby="int-mc-voting-panel-heading-@Model.ObjectId">
    <h5 id="int-mc-voting-panel-heading-@Model.ObjectId" class="visually-hidden">Voting Panel</h5>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") d-flex align-items-center" role="status" aria-live="polite">
            <i class="bi @(Model.IsSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2" aria-hidden="true"></i>
            @Model.Message
        </div>
    }

    <!-- Login -->
    <div id="loginboard" class="card shadow-sm mb-3">
        <div class="card-header">
            <h6 class="card-title mb-0"><i class="bi bi-box-arrow-in-right" aria-hidden="true"></i> <span class="textshadow1">Please login</span></h6>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">
                For Singapore users, please log in with your existing Integration SG Portal account.<br />
                <br />
                For users from other countries, you may use this public access:<br />
                Username: <code>MCVoter</code><br />
                Password: <code>asop123</code>
            </p>
            <form aria-label="Voting panel login form">
                <div class="mb-3">
                    <label for="textUsername" class="form-label"><i class="bi bi-person" aria-hidden="true"></i> Username</label>
                    <input name="textUsername" id="textUsername" class="form-control" placeholder="Username" value="" autocomplete="username" />
                </div>
                <div class="mb-3">
                    <label for="textPassword" class="form-label"><i class="bi bi-lock" aria-hidden="true"></i> Password</label>
                    <input type="password" name="textPassword" id="textPassword" class="form-control" placeholder="Password" value="" autocomplete="current-password" />
                </div>
                <div class="d-flex gap-2">
                    <button type="button" id="b1_login" class="btn btn-primary">
                        <i class="bi bi-music-note" aria-hidden="true"></i> Login
                    </button>
                    <button type="button" id="b2_results" class="btn btn-outline-secondary">
                        <i class="bi bi-bar-chart" aria-hidden="true"></i> View Results
                    </button>
                </div>
            </form>
            <div id="eventInfoContent" class="mt-3"></div>
        </div>
    </div>

    <!-- Voting Board -->
    <div id="votingboard" class="card shadow-sm mb-3" style="display: none">
        <div class="card-header">
            <h6 class="card-title mb-0"><i class="bi bi-hand-thumbs-up" aria-hidden="true"></i> Song List</h6>
        </div>
        <div class="card-body">
            <div id="songlist" role="list" aria-label="Songs available for voting">
                <!-- Song entries populated dynamically -->
                <p class="text-center text-muted mb-0 empty-state">
                    <i class="bi bi-music-note" aria-hidden="true"></i> No songs available for voting.
                </p>
            </div>
            <div id="voteActions" class="d-flex gap-2 mt-3">
                <button type="button" id="cmdSubmitVote" class="btn btn-primary">
                    <i class="bi bi-send" aria-hidden="true"></i> Submit Vote
                </button>
                <button type="button" id="cmdLogout" class="btn btn-outline-secondary">
                    <i class="bi bi-box-arrow-right" aria-hidden="true"></i> Logout
                </button>
            </div>
        </div>
    </div>

    <!-- Results Board -->
    <div id="resultsboard" class="card shadow-sm" style="display: none">
        <div class="card-header">
            <h6 class="card-title mb-0"><i class="bi bi-bar-chart-fill" aria-hidden="true"></i> Results</h6>
        </div>
        <div class="card-body">
            <div id="resultsList" role="list" aria-label="Voting results">
                <!-- Results populated dynamically -->
                <p class="text-center text-muted mb-0 empty-state">
                    <i class="bi bi-inbox" aria-hidden="true"></i> No results available.
                </p>
            </div>
        </div>
    </div>
</section>
