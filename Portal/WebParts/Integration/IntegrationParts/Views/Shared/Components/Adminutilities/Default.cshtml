@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AdminutilitiesViewModel
@* Ported from AdminUtilities.ascx (Apps/Integration/Registration). *@

<div class="component-adminutilities">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Admin Utilities</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
