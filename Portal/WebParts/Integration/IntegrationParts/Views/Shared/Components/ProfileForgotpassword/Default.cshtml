@model WCMS.WebSystem.WebParts.Integration.ViewComponents.ProfileForgotpasswordViewModel
@* Ported from ForgotPassword.ascx (Themes/area51/Parts/Profile/Profile). *@

<div class="component-profileforgotpassword">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Forgot Password</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Forgot Password component requires configuration.
        </div>
    }
</div>
