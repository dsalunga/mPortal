@model WCMS.WebSystem.WebParts.ViewComponents.IntMyPreferencesModel

<section aria-labelledby="my-preferences-heading-@Model.ObjectId">
    <div class="card" id="int-my-preferences-@Model.ObjectId">
        <div class="card-header">
            <h5 class="card-title mb-0" id="my-preferences-heading-@Model.ObjectId">
                <i class="bi bi-sliders" aria-hidden="true"></i> My Preferences
            </h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty((string)Model.Message))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                    @Model.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <form method="post" novalidate aria-label="My preferences form">
                <div class="mb-3">
                    <label for="ddlLanguage" class="form-label">Language</label>
                    <select id="ddlLanguage" name="Language" class="form-select" aria-label="Select preferred language">
                        <option value="en">English</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label for="ddlTimezone" class="form-label">Timezone</label>
                    <select id="ddlTimezone" name="Timezone" class="form-select" aria-label="Select timezone">
                        <option value="">-- Select Timezone --</option>
                    </select>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="chkEmailNotifications" name="EmailNotifications" value="true" role="switch" />
                    <label class="form-check-label" for="chkEmailNotifications">Email Notifications</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="chkSmsNotifications" name="SmsNotifications" value="true" role="switch" />
                    <label class="form-check-label" for="chkSmsNotifications">SMS Notifications</label>
                </div>
                <button type="submit" id="cmdSavePreferences" class="btn btn-primary">
                    <i class="bi bi-save" aria-hidden="true"></i> Save Preferences
                </button>
            </form>
        </div>
    </div>
</section>
