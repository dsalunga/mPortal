@model WCMS.WebSystem.WebParts.ViewComponents.IntConfigExternalMembersModel

<section class="card" id="int-config-external-members-@Model.ObjectId" aria-labelledby="int-config-external-members-heading">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="int-config-external-members-heading" class="card-title mb-0"><i class="bi bi-people-fill" aria-hidden="true"></i> External Members</h5>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3" aria-label="Search external members">
            <div class="col-auto">
                <input type="text" class="form-control" name="search" placeholder="Search members..." value="@Model.SearchTerm" aria-label="Search members" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-secondary"><i class="bi bi-search" aria-hidden="true"></i> Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-striped table-hover" aria-label="External members list">
                <thead>
                    <tr>
                        <th scope="col">Member ID</th>
                        <th scope="col">Display Name</th>
                        <th scope="col">Email</th>
                        <th scope="col">Status</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Members != null && Model.Members.Any())
                    {
                        @foreach (var member in Model.Members)
                        {
                            <tr>
                                <td>@member.MemberId</td>
                                <td>@member.DisplayName</td>
                                <td>@member.Email</td>
                                <td>@member.Status</td>
                                <td>
                                    <a href="#" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil" aria-hidden="true"></i> Edit</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">
                                <i class="bi bi-inbox" aria-hidden="true"></i> No external members found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
