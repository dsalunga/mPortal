@model WCMS.WebSystem.WebParts.Integration.ViewComponents.EventviewbasicViewModel
@* Ported from EventViewBasic.ascx (Themes/area51/Parts/EventCalendar/Event). *@

<div class="component-eventviewbasic">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Event View Basic</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Event View Basic component requires configuration.
        </div>
    }
</div>
