@model dynamic

<section class="card" id="int-group-user-manager-@Model.ObjectId" aria-labelledby="int-group-user-manager-heading">
    <div class="card-header">
        <h5 id="int-group-user-manager-heading" class="card-title mb-0"><i class="bi bi-person-gear" aria-hidden="true"></i> Group User Manager</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="row mb-3">
            <div class="col-md-6">
                <label for="ddlGroup" class="form-label">Select Group <span class="text-danger" aria-hidden="true">*</span></label>
                <select id="ddlGroup" name="GroupId" class="form-select" required aria-required="true" aria-label="Select a group">
                    <option value="">-- Select Group --</option>
                </select>
            </div>
            <div class="col-md-6">
                <label for="txtSearchUsers" class="form-label">Search Users</label>
                <input type="text" id="txtSearchUsers" name="Search" class="form-control" placeholder="Search users..." aria-label="Search users to add" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                <h6>Available Users</h6>
                <div class="list-group" id="availableUsers" role="listbox" aria-label="Available users" style="max-height: 300px; overflow-y: auto;">
                </div>
                <p id="availableUsersEmpty" class="text-center text-muted py-2 d-none" role="status"><i class="bi bi-person-x" aria-hidden="true"></i> No available users.</p>
            </div>
            <div class="col-md-6">
                <h6>Assigned Users</h6>
                <div class="list-group" id="assignedUsers" role="listbox" aria-label="Assigned users" style="max-height: 300px; overflow-y: auto;">
                </div>
                <p id="assignedUsersEmpty" class="text-center text-muted py-2 d-none" role="status"><i class="bi bi-person-x" aria-hidden="true"></i> No assigned users.</p>
            </div>
        </div>
        <div class="mt-3">
            <button type="button" id="cmdSaveAssignments" class="btn btn-primary"><i class="bi bi-check-lg" aria-hidden="true"></i> Save Assignments</button>
        </div>
    </div>
</section>
