@model dynamic

<div class="card" id="int-group-user-manager-@Model.ObjectId" role="region" aria-label="Group User Manager">
    <div class="card-header">
        <h5 class="card-title mb-0">Group User Manager</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="row mb-3">
            <div class="col-md-6">
                <label for="ddlGroup" class="form-label">Select Group <span class="text-danger" aria-hidden="true">*</span></label>
                <select id="ddlGroup" name="GroupId" class="form-select" required aria-required="true" aria-label="Select a group">
                    <option value="">-- Select Group --</option>
                </select>
            </div>
            <div class="col-md-6">
                <label for="txtSearchUsers" class="form-label">Search Users</label>
                <input type="text" id="txtSearchUsers" name="Search" class="form-control" placeholder="Search users..." aria-label="Search users to add" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                <h6>Available Users</h6>
                <div class="list-group" id="availableUsers" role="listbox" aria-label="Available users" style="max-height: 300px; overflow-y: auto;">
                </div>
            </div>
            <div class="col-md-6">
                <h6>Assigned Users</h6>
                <div class="list-group" id="assignedUsers" role="listbox" aria-label="Assigned users" style="max-height: 300px; overflow-y: auto;">
                </div>
            </div>
        </div>
        <div class="mt-3">
            <button type="button" id="cmdSaveAssignments" class="btn btn-primary">Save Assignments</button>
        </div>
    </div>
</div>
