@model WCMS.WebSystem.WebParts.Integration.ViewComponents.LessonreviewerLogattendanceViewModel
@* Ported from LogAttendance.ascx. *@

<div class="component-lessonreviewer-logattendance">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_AbsentReason" class="form-label">Absent Reason</label>
            <textarea class="form-control" id="field_AbsentReason" name="AbsentReason" rows="4">@Model.AbsentReason</textarea>
        </div>
        <div class="mb-3">
            <label for="field_CustomNote" class="form-label">Custom Note</label>
            <textarea class="form-control" id="field_CustomNote" name="CustomNote" rows="4">@Model.CustomNote</textarea>
        </div>
        <div class="mb-3">
            <label for="field_CboNotes" class="form-label">Cbo Notes</label>
            <select class="form-select" id="field_CboNotes" name="SelectedCboNotes">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboNotesOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboNotes ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_Note" name="Note" @(Model.Note ? "checked" : "") />
            <label class="form-check-label" for="field_Note">Include notes (use this if you continued a previous session or you'll not be able to complete this one)</label>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdLogin">Submit</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>