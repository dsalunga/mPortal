@model dynamic

<div class="card" id="mc-admin-composer-edit-@Model.ObjectId" role="region" aria-label="Edit Composer">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-pencil-square" aria-hidden="true"></i> Edit Composer</h5>
    </div>
    <div class="card-body">
        <form method="post" novalidate aria-label="Composer edit form">
            <div class="mb-3">
                <label for="txtComposerName-@Model.ObjectId" class="form-label">Composer Name <span class="text-danger" aria-hidden="true">*</span></label>
                <input type="text" id="txtComposerName-@Model.ObjectId" name="ComposerName" class="form-control" required aria-required="true" />
            </div>
            <div class="mb-3">
                <label for="txtBio-@Model.ObjectId" class="form-label">Biography</label>
                <textarea id="txtBio-@Model.ObjectId" name="Biography" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label for="txtEmail-@Model.ObjectId" class="form-label">Email</label>
                <input type="email" id="txtEmail-@Model.ObjectId" name="Email" class="form-control" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg" aria-hidden="true"></i> Save</button>
                <button type="button" class="btn btn-outline-secondary">Cancel</button>
            </div>
        </form>
    </div>
</div>
