@* Originally: area51/Parts/EventCalendar/Event/EventViewBasic.ascx *@
@model dynamic

<article id="theme-area51-event-view-@Model.ObjectId" aria-label="Event details">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        @await Component.InvokeAsync("WZone", new { zone = "EventTitle" })
                    </div>
                    <div class="card-body">
                        <dl>
                            <dt class="text-muted">Date &amp; Time</dt>
                            <dd class="mb-3">
                                @await Component.InvokeAsync("WZone", new { zone = "EventDateTime" })
                            </dd>

                            <dt class="text-muted">Location</dt>
                            <dd class="mb-3">
                                @await Component.InvokeAsync("WZone", new { zone = "EventLocation" })
                            </dd>

                            <dt class="text-muted">Description</dt>
                            <dd class="mb-3">
                                @await Component.InvokeAsync("WZone", new { zone = "EventDescription" })
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
</article>
