@model dynamic

<section aria-labelledby="int-member-sessions-heading-@Model.ObjectId">
<div class="card" id="int-member-sessions-@Model.ObjectId" role="region" aria-label="Member Sessions">
    <div class="card-header">
        <h5 id="int-member-sessions-heading-@Model.ObjectId" class="card-title mb-0">
            <i class="bi bi-display" aria-hidden="true"></i> Active Sessions
        </h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="table-responsive">
            <table class="table table-striped" id="tblSessions" aria-label="Active sessions list">
                <thead>
                    <tr>
                        <th scope="col">Device</th>
                        <th scope="col">IP Address</th>
                        <th scope="col">Last Active</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody id="sessionList">
                </tbody>
            </table>
        </div>
        <div id="noSessionsMessage" class="text-muted text-center py-4" style="display: none;">
            <i class="bi bi-info-circle" aria-hidden="true"></i> No active sessions found.
        </div>
    </div>
</div>
</section>
