@model dynamic

<div class="card" id="int-log-attendance-@Model.ObjectId" role="region" aria-label="Log Attendance">
    <div class="card-header">
        <h5 class="card-title mb-0">Log Attendance</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <form method="post" novalidate aria-label="Log attendance form">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label for="ddlAttService" class="form-label">Service <span class="text-danger" aria-hidden="true">*</span></label>
                    <select id="ddlAttService" name="ServiceId" class="form-select" required aria-required="true">
                        <option value="">-- Select Service --</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label for="txtAttDate" class="form-label">Date <span class="text-danger" aria-hidden="true">*</span></label>
                    <input type="date" id="txtAttDate" name="Date" class="form-control" required aria-required="true" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label d-block">Attendance</label>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="AttendanceStatus" id="radPresent" value="present" checked />
                    <label class="form-check-label" for="radPresent">Present</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="AttendanceStatus" id="radAbsent" value="absent" />
                    <label class="form-check-label" for="radAbsent">Absent</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="AttendanceStatus" id="radExcused" value="excused" />
                    <label class="form-check-label" for="radExcused">Excused</label>
                </div>
            </div>
            <div class="mb-3">
                <label for="txtAttRemarks" class="form-label">Remarks</label>
                <textarea id="txtAttRemarks" name="Remarks" class="form-control" rows="2"></textarea>
            </div>
            <button type="submit" id="cmdLogAttendance" class="btn btn-primary">Log Attendance</button>
        </form>
    </div>
</div>
