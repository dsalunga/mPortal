@model dynamic

<section class="card" id="int-group-manager-@Model.ObjectId" aria-labelledby="int-group-manager-heading">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="int-group-manager-heading" class="card-title mb-0"><i class="bi bi-people" aria-hidden="true"></i> Group Manager</h5>
        <button type="button" id="cmdAddGroup" class="btn btn-sm btn-primary" aria-label="Add new group">
            <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Group
        </button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="mb-3">
            <label for="txtSearchGroups" class="form-label visually-hidden">Search groups</label>
            <input type="text" id="txtSearchGroups" name="Search" class="form-control" placeholder="Search groups..." aria-label="Search groups" />
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="tblGroups" aria-label="Groups list">
                <thead>
                    <tr>
                        <th scope="col">Group Name</th>
                        <th scope="col">Type</th>
                        <th scope="col">Members</th>
                        <th scope="col">Status</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody id="groupList">
                </tbody>
            </table>
        </div>
        <div id="groupListEmpty" class="text-center text-muted py-3 d-none" role="status">
            <i class="bi bi-inbox" aria-hidden="true"></i>
            <p class="mb-0">No groups found.</p>
        </div>
    </div>
</section>
