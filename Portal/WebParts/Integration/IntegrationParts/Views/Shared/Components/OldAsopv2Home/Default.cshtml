@model WCMS.WebSystem.WebParts.Integration.ViewComponents.OldAsopv2HomeViewModel
@* Ported from asopv2-home.ascx (Themes/ASOP/v2/old). *@

<div class="component-oldasopv2home">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>asopv2-home</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            asopv2-home component requires configuration.
        </div>
    }
</div>
