@* Originally: area51/InsideWithSidebar.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeArea51InsideWithSidebarModel

<div id="theme-area51-inside-sidebar-@Model.ObjectId">
    <a href="#area51-sidebar-main-@Model.ObjectId" class="visually-hidden-focusable skip-link">Skip to main content</a>

    <header class="bg-white border-bottom py-3" role="banner" aria-label="Site header">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Header" })
        </div>
    </header>

    <nav class="navbar navbar-expand-lg navbar-light bg-light" aria-label="Main navigation">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Navigation" })
        </div>
    </nav>

    <main id="area51-sidebar-main-@Model.ObjectId" class="container py-4">
        <div class="row">
            <div class="col-md-8">
                @await Component.InvokeAsync("WZone", new { zone = "Content" })
            </div>
            <div class="col-md-4">
                <aside aria-label="Sidebar">
                    @await Component.InvokeAsync("WZone", new { zone = "Sidebar" })
                </aside>
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-3 mt-4" role="contentinfo" aria-label="Site footer">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year All rights reserved.</small></p>
        </div>
    </footer>
</div>
