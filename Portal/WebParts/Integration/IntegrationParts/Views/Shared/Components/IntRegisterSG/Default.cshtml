@model WCMS.WebSystem.WebParts.ViewComponents.IntRegisterSGModel

<div class="card" id="int-register-sg-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Registration</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        <form method="post" novalidate>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="sgFirstName" class="form-label">First Name</label>
                    <input type="text" class="form-control" id="sgFirstName" name="FirstName" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label for="sgLastName" class="form-label">Last Name</label>
                    <input type="text" class="form-control" id="sgLastName" name="LastName" required />
                </div>
            </div>
            <div class="mb-3">
                <label for="sgEmail" class="form-label">Email</label>
                <input type="email" class="form-control" id="sgEmail" name="Email" required />
            </div>
            <div class="mb-3">
                <label for="sgGroup" class="form-label">Group</label>
                <select class="form-select" id="sgGroup" name="GroupName">
                    <option value="">-- Select Group --</option>
                    @if (Model.Groups != null)
                    {
                        @foreach (var group in Model.Groups)
                        {
                            <option value="@group">@group</option>
                        }
                    }
                </select>
            </div>
            <div class="mb-3">
                <label for="sgPassword" class="form-label">Password</label>
                <input type="password" class="form-control" id="sgPassword" name="Password" required />
            </div>
            <div class="mb-3">
                <label for="sgConfirmPassword" class="form-label">Confirm Password</label>
                <input type="password" class="form-control" id="sgConfirmPassword" name="ConfirmPassword" required />
            </div>
            <button type="submit" class="btn btn-primary">Register</button>
        </form>
    </div>
</div>
