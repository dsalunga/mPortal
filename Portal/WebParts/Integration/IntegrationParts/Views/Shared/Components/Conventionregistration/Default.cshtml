@model WCMS.WebSystem.WebParts.Integration.ViewComponents.ConventionregistrationViewModel
@* Ported from ConventionRegistration.ascx (Apps/Integration/Registration). *@

<div class="component-conventionregistration">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Convention Registration</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Convention Registration component requires configuration.
        </div>
    }
</div>
