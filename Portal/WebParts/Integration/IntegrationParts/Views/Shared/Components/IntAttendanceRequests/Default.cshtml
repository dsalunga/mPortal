@model dynamic

<div class="card" id="int-attendance-requests-@Model.ObjectId" role="region" aria-label="Attendance Requests">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Attendance Requests</h5>
        <span class="badge bg-secondary" id="lblTotalRequests">0</span>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="row mb-3">
            <div class="col-md-4">
                <label for="ddlStatusFilter" class="form-label">Status</label>
                <select id="ddlStatusFilter" name="StatusFilter" class="form-select" aria-label="Filter by status">
                    <option value="">All</option>
                    <option value="pending">Pending</option>
                    <option value="approved">Approved</option>
                    <option value="rejected">Rejected</option>
                </select>
            </div>
            <div class="col-md-4">
                <label for="txtDateFrom" class="form-label">From</label>
                <input type="date" id="txtDateFrom" name="DateFrom" class="form-control" />
            </div>
            <div class="col-md-4">
                <label for="txtDateTo" class="form-label">To</label>
                <input type="date" id="txtDateTo" name="DateTo" class="form-control" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="tblAttendanceRequests" aria-label="Attendance requests">
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Service</th>
                        <th scope="col">Date</th>
                        <th scope="col">Status</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody id="attendanceRequestList">
                </tbody>
            </table>
        </div>
    </div>
</div>
