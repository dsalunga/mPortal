@model WCMS.WebSystem.WebParts.ViewComponents.IntAccessRequestModel

<section aria-labelledby="access-request-heading-@Model.ObjectId">
    <div class="card" id="int-access-request-@Model.ObjectId">
        <div class="card-header">
            <h5 class="card-title mb-0" id="access-request-heading-@Model.ObjectId">
                <i class="bi bi-person-plus" aria-hidden="true"></i> Request Access
            </h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty((string)Model.Message))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                    @Model.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <form method="post" novalidate aria-label="Access request form">
                <div class="mb-3">
                    <label for="txtFullName" class="form-label">Full Name <span class="text-danger" aria-hidden="true">*</span></label>
                    <input type="text" id="txtFullName" name="FullName" class="form-control" required aria-required="true" />
                </div>
                <div class="mb-3">
                    <label for="txtEmail" class="form-label">Email Address <span class="text-danger" aria-hidden="true">*</span></label>
                    <input type="email" id="txtEmail" name="Email" class="form-control" required aria-required="true" />
                </div>
                <div class="mb-3">
                    <label for="txtReason" class="form-label">Reason for Access</label>
                    <textarea id="txtReason" name="Reason" class="form-control" rows="3" aria-label="Reason for requesting access"></textarea>
                </div>
                <button type="submit" id="cmdRequestAccess" class="btn btn-primary">
                    <i class="bi bi-send" aria-hidden="true"></i> Submit Request
                </button>
            </form>
        </div>
    </div>
</section>
