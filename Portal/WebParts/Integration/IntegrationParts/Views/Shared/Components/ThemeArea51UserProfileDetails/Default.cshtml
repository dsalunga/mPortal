@* Originally: area51/Parts/Profile/Profile/UserProfileDetails.ascx *@
@model dynamic

<section id="theme-area51-profile-details-@Model.ObjectId" aria-label="User profile details">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0" id="profile-details-heading">Profile Details</h5>
                    </div>
                    <div class="card-body" role="region" aria-labelledby="profile-details-heading">
                        @await Component.InvokeAsync("WZone", new { zone = "ProfileInfo" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
