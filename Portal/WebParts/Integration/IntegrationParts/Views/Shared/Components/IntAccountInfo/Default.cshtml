@model WCMS.WebSystem.WebParts.ViewComponents.IntAccountInfoModel

<div class="card" id="int-account-info-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Account Information</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">User Name</dt>
            <dd class="col-sm-8">@Model.UserName</dd>
            <dt class="col-sm-4">Full Name</dt>
            <dd class="col-sm-8">@Model.FullName</dd>
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>
            <dt class="col-sm-4">Phone</dt>
            <dd class="col-sm-8">@Model.Phone</dd>
            <dt class="col-sm-4">Organization</dt>
            <dd class="col-sm-8">@Model.Organization</dd>
            <dt class="col-sm-4">Last Login</dt>
            <dd class="col-sm-8">@(Model.LastLogin?.ToString("g") ?? "N/A")</dd>
        </dl>
    </div>
</div>
