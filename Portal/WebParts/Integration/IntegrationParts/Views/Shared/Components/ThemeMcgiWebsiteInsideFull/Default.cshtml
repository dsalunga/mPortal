@* Originally: mcgi_website/template_inside_full.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeMcgiWebsiteInsideFullModel

<div id="theme-mcgi-website-inside-full-@Model.ObjectId">
    <a href="#mcgi-inside-full-main-@Model.ObjectId" class="visually-hidden-focusable skip-link">Skip to main content</a>

    <header class="bg-primary text-white py-3" role="banner" aria-label="MCGI site header">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Header" })
        </div>
    </header>

    <div class="container mt-3">
        <nav aria-label="Breadcrumb">
            @await Component.InvokeAsync("WZone", new { zone = "Breadcrumb" })
        </nav>
    </div>

    <main id="mcgi-inside-full-main-@Model.ObjectId" class="container py-4">
        <div class="row">
            <div class="col-12">
                @await Component.InvokeAsync("WZone", new { zone = "Content" })
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-3 mt-4" role="contentinfo" aria-label="MCGI site footer">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year MCGI. All rights reserved.</small></p>
        </div>
    </footer>
</div>
