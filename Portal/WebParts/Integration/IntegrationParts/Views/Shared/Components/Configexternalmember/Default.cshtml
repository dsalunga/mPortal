@model WCMS.WebSystem.WebParts.Integration.ViewComponents.ConfigexternalmemberViewModel
@* Ported from ConfigExternalMember.ascx. *@

<div class="component-configexternalmember">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_FirstName" class="form-label">First Name</label>
            <input type="text" class="form-control" id="field_FirstName" name="FirstName" value="@Model.FirstName" />
        </div>
        <div class="mb-3">
            <label for="field_MiddleName" class="form-label">Middle Name</label>
            <input type="text" class="form-control" id="field_MiddleName" name="MiddleName" value="@Model.MiddleName" />
        </div>
        <div class="mb-3">
            <label for="field_LastName" class="form-label">Last Name</label>
            <input type="text" class="form-control" id="field_LastName" name="LastName" value="@Model.LastName" />
        </div>
        <div class="mb-3">
            <label for="field_ExternalIDNo" class="form-label">External I D No</label>
            <input type="text" class="form-control" id="field_ExternalIDNo" name="ExternalIDNo" value="@Model.ExternalIDNo" />
        </div>
        <div class="mb-3">
            <label for="field_TempExternalID" class="form-label">Temp External I D</label>
            <input type="text" class="form-control" id="field_TempExternalID" name="TempExternalID" value="@Model.TempExternalID" />
        </div>
        <div class="mb-3">
            <label for="field_Email" class="form-label">Email</label>
            <input type="text" class="form-control" id="field_Email" name="Email" value="@Model.Email" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdSubmit">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>