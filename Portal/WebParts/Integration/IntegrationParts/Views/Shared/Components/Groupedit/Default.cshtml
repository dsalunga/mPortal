@model WCMS.WebSystem.WebParts.Integration.ViewComponents.GroupeditViewModel
@* Ported from GroupEdit.ascx. *@

<div class="component-groupedit">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Name" class="form-label">Name</label>
            <input type="text" class="form-control" id="field_Name" name="Name" value="@Model.Name" />
        </div>
        <div class="mb-3">
            <label for="field_Parent" class="form-label">Parent</label>
            <input type="text" class="form-control" id="field_Parent" name="Parent" value="@Model.Parent" />
        </div>
        <div class="mb-3">
            <label for="field_Owner" class="form-label">Owner</label>
            <input type="text" class="form-control" id="field_Owner" name="Owner" value="@Model.Owner" />
        </div>
        <div class="mb-3">
            <label for="field_Mentors" class="form-label">Mentors</label>
            <input type="text" class="form-control" id="field_Mentors" name="Mentors" value="@Model.Mentors" />
        </div>
        <div class="mb-3">
            <label for="field_Conductors" class="form-label">Conductors</label>
            <input type="text" class="form-control" id="field_Conductors" name="Conductors" value="@Model.Conductors" />
        </div>
        <div class="mb-3">
            <label for="field_Description" class="form-label">Description</label>
            <textarea class="form-control" id="field_Description" name="Description" rows="4">@Model.Description</textarea>
        </div>
        <div class="mb-3">
            <label for="field_Managers" class="form-label">Managers</label>
            <input type="text" class="form-control" id="field_Managers" name="Managers" value="@Model.Managers" />
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>