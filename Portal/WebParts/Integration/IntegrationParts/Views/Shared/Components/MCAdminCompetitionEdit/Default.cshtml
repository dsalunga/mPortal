@model dynamic

<div class="card" id="mc-admin-competition-edit-@Model.ObjectId" role="region" aria-label="Edit Competition">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-pencil-square" aria-hidden="true"></i> Edit Competition</h5>
    </div>
    <div class="card-body">
        <form method="post" novalidate aria-label="Competition edit form">
            <div class="mb-3">
                <label for="txtCompName-@Model.ObjectId" class="form-label">Competition Name <span class="text-danger" aria-hidden="true">*</span></label>
                <input type="text" id="txtCompName-@Model.ObjectId" name="CompetitionName" class="form-control" required aria-required="true" />
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label for="dtStart-@Model.ObjectId" class="form-label">Start Date</label>
                    <input type="date" id="dtStart-@Model.ObjectId" name="StartDate" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label for="dtEnd-@Model.ObjectId" class="form-label">End Date</label>
                    <input type="date" id="dtEnd-@Model.ObjectId" name="EndDate" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label for="txtDescription-@Model.ObjectId" class="form-label">Description</label>
                <textarea id="txtDescription-@Model.ObjectId" name="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label for="selStatus-@Model.ObjectId" class="form-label">Status</label>
                <select id="selStatus-@Model.ObjectId" name="Status" class="form-select" aria-label="Competition status">
                    <option value="draft">Draft</option>
                    <option value="active">Active</option>
                    <option value="closed">Closed</option>
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg" aria-hidden="true"></i> Save</button>
                <button type="button" class="btn btn-outline-secondary">Cancel</button>
            </div>
        </form>
    </div>
</div>
