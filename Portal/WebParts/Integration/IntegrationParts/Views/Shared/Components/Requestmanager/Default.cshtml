@model WCMS.WebSystem.WebParts.Integration.ViewComponents.RequestmanagerViewModel
@* Ported from RequestManager.ascx (Apps/Integration/Profile). *@

<div class="component-requestmanager">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Request Manager</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Request Manager component requires configuration.
        </div>
    }
</div>
