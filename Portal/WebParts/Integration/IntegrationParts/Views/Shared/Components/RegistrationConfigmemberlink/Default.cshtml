@model WCMS.WebSystem.WebParts.Integration.ViewComponents.RegistrationConfigmemberlinkViewModel
@* Ported from ConfigMemberLink.ascx. *@

<div class="component-registration-configmemberlink">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_ExternalID" class="form-label">External I D</label>
            <input type="text" class="form-control" id="field_ExternalID" name="ExternalID" value="@Model.ExternalID" />
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_PortalSendEmail" name="PortalSendEmail" @(Model.PortalSendEmail ? "checked" : "") />
            <label class="form-check-label" for="field_PortalSendEmail">Send Email</label>
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_AccountSendEmail" name="AccountSendEmail" @(Model.AccountSendEmail ? "checked" : "") />
            <label class="form-check-label" for="field_AccountSendEmail">Send Email</label>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdLinkExternal">Update External Link</button>
            <button type="submit" class="btn btn-primary" name="action" value="cmdApprove">Approve</button>
            <button type="submit" class="btn btn-primary" name="action" value="cmdAccountApprove">Activate</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">OK</button>
        </div>
    </form>
</div>