@model WCMS.WebSystem.WebParts.ViewComponents.IntMemberDirectoryModel

<div class="masterlist-member-manager" id="int-member-directory-@Model.ObjectId">
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
            @Model.Message
        </div>
    }

    <input type="hidden" id="hUserProfileUrl" name="UserProfileUrl" value="" />
    <input type="hidden" id="hUserProfileEditUrl" name="UserProfileEditUrl" value="" />
    <input type="hidden" id="hGroupId" name="GroupId" value="" />
    <input type="hidden" id="hIsManager" name="IsManager" value="0" />

    <div class="min-bottom-margin">
        <span class="input-append">
            <input type="text" id="txtId" name="MemberId" class="col-md-3" placeholder="Group ID or Email" />
            <div class="btn-group">
                <button type="submit" id="cmdAdd" name="Action" value="Add" class="btn btn-default" onclick="return Add_Click();">Add...</button>
                <button class="btn dropdown-toggle" data-toggle="dropdown">
                    <span class="caret"></span>
                </button>
                <ul class="dropdown-menu">
                    <li><a href="#" id="linkNewMember">Create New Member</a></li>
                </ul>
            </div>
        </span>
        &nbsp;
        <button type="submit" id="cmdRemove" name="Action" value="Remove" class="btn btn-danger delete" style="display: none" onclick="return confirm('Are you sure you want to remove/delete selected items?');">Remove</button>

        <div class="pull-right">
            <span class="input-append">
                <input type="text" id="txtSearch" name="SearchKeyword" class="col-md-2" placeholder="Enter keyword" />
                <div class="btn-group">
                    <button class="btn btn-default" type="button">Search</button>
                    <button class="btn dropdown-toggle" data-toggle="dropdown">
                        <span class="caret"></span>
                    </button>
                    <ul class="dropdown-menu">
                        <li><a href="#" id="cmdDownload">Download</a></li>
                    </ul>
                </div>
            </span>
        </div>
    </div>

    <div id="lblStatus" class="alert alert-success"></div>

    <table class="table image-noscale" id="memberGrid" style="width: 100%">
        <thead>
            <tr style="background-color: #507CD1; color: white; font-weight: bold">
                <th style="width: 10px; text-align: center">
                    <input type="checkbox" class="chk-main" name="chkCheckedMain" onclick="CheckAll(this, 'chkChecked');" />
                </th>
                <th style="width: 64px; text-align: center"></th>
                <th style="text-align: left">Group ID</th>
                <th style="text-align: left">First Name</th>
                <th style="text-align: left">Last Name</th>
                <th style="text-align: left">Email</th>
            </tr>
        </thead>
        <tbody>
            <!-- Member rows populated dynamically -->
        </tbody>
    </table>
</div>
