@model WCMS.WebSystem.WebParts.ViewComponents.IntMemberDirectoryModel

<section aria-labelledby="int-member-directory-heading-@Model.ObjectId">
<div class="masterlist-member-manager" id="int-member-directory-@Model.ObjectId">
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="status" aria-live="polite">
            @Model.Message
        </div>
    }

    <h2 id="int-member-directory-heading-@Model.ObjectId" class="mb-3">
        <i class="bi bi-people" aria-hidden="true"></i> Member Directory
    </h2>

    <input type="hidden" id="hUserProfileUrl" name="UserProfileUrl" value="" />
    <input type="hidden" id="hUserProfileEditUrl" name="UserProfileEditUrl" value="" />
    <input type="hidden" id="hGroupId" name="GroupId" value="" />
    <input type="hidden" id="hIsManager" name="IsManager" value="0" />

    <div class="min-bottom-margin">
        <span class="input-append">
            <input type="text" id="txtId" name="MemberId" class="col-md-3" placeholder="Group ID or Email" aria-label="Group ID or Email" />
            <div class="btn-group">
                <button type="submit" id="cmdAdd" name="Action" value="Add" class="btn btn-outline-secondary" onclick="return Add_Click();">
                    <i class="bi bi-plus-circle" aria-hidden="true"></i> Add...
                </button>
                <button class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-label="More add options">
                    <span class="caret"></span>
                </button>
                <ul class="dropdown-menu">
                    <li><a href="#" id="linkNewMember" class="dropdown-item">Create New Member</a></li>
                </ul>
            </div>
        </span>
        &nbsp;
        <button type="submit" id="cmdRemove" name="Action" value="Remove" class="btn btn-danger delete" style="display: none" onclick="return confirm('Are you sure you want to remove/delete selected items?');">
            <i class="bi bi-trash" aria-hidden="true"></i> Remove
        </button>

        <div class="float-end">
            <span class="input-append">
                <input type="text" id="txtSearch" name="SearchKeyword" class="col-md-2" placeholder="Enter keyword" aria-label="Search members" />
                <div class="btn-group">
                    <button class="btn btn-outline-secondary" type="button">
                        <i class="bi bi-search" aria-hidden="true"></i> Search
                    </button>
                    <button class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-label="More search options">
                        <span class="caret"></span>
                    </button>
                    <ul class="dropdown-menu">
                        <li><a href="#" id="cmdDownload" class="dropdown-item">Download</a></li>
                    </ul>
                </div>
            </span>
        </div>
    </div>

    <div id="lblStatus" class="alert alert-success" role="status" aria-live="polite"></div>

    <table class="table table-striped table-hover image-noscale" id="memberGrid" style="width: 100%" aria-label="Member directory list">
        <thead>
            <tr style="background-color: #507CD1; color: white; font-weight: bold">
                <th scope="col" style="width: 10px; text-align: center">
                    <input type="checkbox" class="chk-main" name="chkCheckedMain" onclick="CheckAll(this, 'chkChecked');" aria-label="Select all members" />
                </th>
                <th scope="col" style="width: 64px; text-align: center"><span class="visually-hidden">Photo</span></th>
                <th scope="col" style="text-align: left">Group ID</th>
                <th scope="col" style="text-align: left">First Name</th>
                <th scope="col" style="text-align: left">Last Name</th>
                <th scope="col" style="text-align: left">Email</th>
            </tr>
        </thead>
        <tbody>
            <!-- Member rows populated dynamically -->
        </tbody>
    </table>
    <div id="noMembersFound" class="text-muted text-center py-4" style="display: none;">
        <i class="bi bi-info-circle" aria-hidden="true"></i> No members found.
    </div>
</div>
</section>
