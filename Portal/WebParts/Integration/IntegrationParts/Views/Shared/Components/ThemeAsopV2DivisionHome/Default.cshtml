@* Originally: ASOP/asopv2-division-home.ascx *@
@model dynamic

<div id="theme-asopv2-division-home-@Model.ObjectId">
    <section class="bg-primary text-white py-5" aria-label="Division banner">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "DivisionBanner" })
        </div>
    </section>

    <main class="container py-4" role="main">
        <div class="row">
            <div class="col-md-4">
                @await Component.InvokeAsync("WZone", new { zone = "Feature1" })
            </div>
            <div class="col-md-4">
                @await Component.InvokeAsync("WZone", new { zone = "Feature2" })
            </div>
            <div class="col-md-4">
                @await Component.InvokeAsync("WZone", new { zone = "Feature3" })
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                @await Component.InvokeAsync("WZone", new { zone = "DivisionInfo" })
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-3 mt-4" role="contentinfo">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year ASOP. All rights reserved.</small></p>
        </div>
    </footer>
</div>
