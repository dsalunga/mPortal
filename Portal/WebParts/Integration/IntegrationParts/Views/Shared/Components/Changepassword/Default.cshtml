@model WCMS.WebSystem.WebParts.Integration.ViewComponents.ChangepasswordViewModel
@* Ported from ChangePassword.ascx. *@

<div class="component-changepassword">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.ActiveViewIndex == 0)
    {
        <div class="view-section" id="view-viewUpdate">
            <h4>Update</h4>
            <div class="view-content p-3">
                @* viewUpdate content *@
                <p class="text-muted">Section: Update</p>
            </div>
        </div>
    }
    else if (Model.ActiveViewIndex == 1)
    {
        <div class="view-section" id="view-viewDisplayNote">
            <h4>Display Note</h4>
            <div class="view-content p-3">
                @* viewDisplayNote content *@
                <p class="text-muted">Section: Display Note</p>
            </div>
        </div>
    }
</div>