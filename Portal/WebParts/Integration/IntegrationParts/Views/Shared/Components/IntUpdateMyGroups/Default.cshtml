@model WCMS.WebSystem.WebParts.ViewComponents.IntUpdateMyGroupsModel

<div class="card" id="int-update-my-groups-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Update My Groups</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        <p>Update group memberships placeholder content.</p>
    </div>
</div>
