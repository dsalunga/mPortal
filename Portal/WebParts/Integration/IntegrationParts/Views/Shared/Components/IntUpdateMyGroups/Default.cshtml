@model dynamic

<div class="card" id="int-update-my-groups-@Model.ObjectId" role="region" aria-label="Update My Groups">
    <div class="card-header">
        <h5 class="card-title mb-0">Update My Groups</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <p>Select the groups you wish to join or leave.</p>
        <form method="post" novalidate aria-label="Update my groups form">
            <div class="list-group mb-3" id="groupCheckList" role="group" aria-label="Available groups">
            </div>
            <button type="submit" id="cmdUpdateGroups" class="btn btn-primary">Save Changes</button>
        </form>
    </div>
</div>
