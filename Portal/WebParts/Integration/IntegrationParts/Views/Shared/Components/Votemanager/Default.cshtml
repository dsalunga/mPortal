@model WCMS.WebSystem.WebParts.Integration.ViewComponents.VotemanagerViewModel
@* Ported from VoteManager.ascx (Apps/Integration/MusicCompetition). *@

<div class="component-votemanager">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Vote Manager</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Vote Manager component requires configuration.
        </div>
    }
</div>
