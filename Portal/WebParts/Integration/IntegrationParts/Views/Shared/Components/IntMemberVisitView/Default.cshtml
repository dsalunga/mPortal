@model WCMS.WebSystem.WebParts.ViewComponents.IntMemberVisitViewModel

<section aria-labelledby="int-member-visit-view-heading-@Model.ObjectId">
<div class="card" id="int-member-visit-view-@Model.ObjectId">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="int-member-visit-view-heading-@Model.ObjectId" class="card-title mb-0">
            <i class="bi bi-journal-text" aria-hidden="true"></i> Member Visits
        </h5>
        @if (!string.IsNullOrEmpty(Model.MemberName))
        {
            <span class="text-muted">@Model.MemberName</span>
        }
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover" aria-label="Member visits list">
                <thead>
                    <tr>
                        <th scope="col">Visit ID</th>
                        <th scope="col">Date</th>
                        <th scope="col">Notes</th>
                        <th scope="col">Recorded By</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Visits != null && Model.Visits.Any())
                    {
                        @foreach (var visit in Model.Visits)
                        {
                            <tr>
                                <td>@visit.VisitId</td>
                                <td>@visit.VisitDate</td>
                                <td>@visit.Notes</td>
                                <td>@visit.RecordedBy</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Visits == null || !Model.Visits.Any())
        {
            <div class="text-muted text-center py-4" role="status">
                <i class="bi bi-info-circle" aria-hidden="true"></i> No visits recorded yet.
            </div>
        }
    </div>
</div>
</section>
