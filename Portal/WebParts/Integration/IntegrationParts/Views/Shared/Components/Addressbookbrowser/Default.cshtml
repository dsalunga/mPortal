@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AddressbookbrowserViewModel
@* Ported from AddressBookBrowser.ascx (Apps/Integration/Profile). *@

<div class="component-addressbookbrowser">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Address Book Browser</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Address Book Browser component requires configuration.
        </div>
    }
</div>
