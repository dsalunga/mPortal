@model WCMS.WebSystem.WebParts.ViewComponents.IntAttendeesModel

<section class="card" id="int-attendees-@Model.ObjectId" aria-labelledby="attendees-heading-@Model.ObjectId">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0" id="attendees-heading-@Model.ObjectId">
            <i class="bi bi-people" aria-hidden="true"></i> Attendees
        </h5>
        <span class="badge bg-secondary" id="lblAttendeeCount">0</span>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="mb-3">
            <label for="txtSearchAttendees" class="form-label visually-hidden">Search attendees</label>
            <div class="input-group">
                <span class="input-group-text" aria-hidden="true"><i class="bi bi-search"></i></span>
                <input type="text" id="txtSearchAttendees" class="form-control" placeholder="Search attendees..." aria-label="Search attendees" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="tblAttendees" aria-label="Attendees list">
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Service</th>
                        <th scope="col">Date</th>
                        <th scope="col">Status</th>
                    </tr>
                </thead>
                <tbody id="attendeeList">
                </tbody>
            </table>
            <div id="attendeesEmpty" class="text-center text-muted py-4 d-none">
                <i class="bi bi-people fs-1" aria-hidden="true"></i>
                <p class="mt-2 mb-0">No attendees found.</p>
            </div>
        </div>
    </div>
</section>
