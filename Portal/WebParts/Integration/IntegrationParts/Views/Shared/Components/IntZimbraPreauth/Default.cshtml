@model WCMS.WebSystem.WebParts.ViewComponents.IntZimbraPreauthModel

<div class="card" id="int-zimbra-preauth-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Zimbra Pre-Authentication</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        <p>Zimbra pre-auth placeholder content.</p>
    </div>
</div>
