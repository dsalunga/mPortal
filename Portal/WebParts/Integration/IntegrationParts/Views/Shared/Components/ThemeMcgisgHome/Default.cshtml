@* Originally: mcgisg/mcgisg_home.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeMcgisgHomeModel

<div id="theme-mcgisg-home-@Model.ObjectId">
    <!-- SG Branded Header -->
    <header class="bg-success text-white py-3">
        <div class="container">
            <div class="row align-items-center">
                <div class="col">
                    @await Component.InvokeAsync("WZone", new { zone = "SgBranding" })
                </div>
            </div>
        </div>
    </header>

    <!-- Hero Banner -->
    <section class="bg-dark text-white py-5">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "HeroBanner" })
        </div>
    </section>

    <!-- Three-Column Content Grid -->
    <main class="container py-4">
        <div class="row">
            <div class="col-md-4 mb-4">
                @await Component.InvokeAsync("WZone", new { zone = "Column1" })
            </div>
            <div class="col-md-4 mb-4">
                @await Component.InvokeAsync("WZone", new { zone = "Column2" })
            </div>
            <div class="col-md-4 mb-4">
                @await Component.InvokeAsync("WZone", new { zone = "Column3" })
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white py-3 mt-4">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
        </div>
    </footer>
</div>
