@* Originally: mcgisg/mcgisg_home.ascx *@
@model dynamic

<div id="theme-mcgisg-home-@Model.ObjectId">
    <a href="#mcgisg-home-main-@Model.ObjectId" class="visually-hidden-focusable skip-link">Skip to main content</a>

    <header class="bg-success text-white py-3" role="banner" aria-label="MCGI Small Groups site header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col">
                    @await Component.InvokeAsync("WZone", new { zone = "SgBranding" })
                </div>
            </div>
        </div>
    </header>

    <section class="bg-dark text-white py-5" aria-label="Hero banner">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "HeroBanner" })
        </div>
    </section>

    <main id="mcgisg-home-main-@Model.ObjectId" class="container py-4">
        <div class="row">
            <div class="col-md-4 mb-4">
                @await Component.InvokeAsync("WZone", new { zone = "Column1" })
            </div>
            <div class="col-md-4 mb-4">
                @await Component.InvokeAsync("WZone", new { zone = "Column2" })
            </div>
            <div class="col-md-4 mb-4">
                @await Component.InvokeAsync("WZone", new { zone = "Column3" })
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-3 mt-4" role="contentinfo" aria-label="MCGI Small Groups site footer">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year MCGI Small Groups. All rights reserved.</small></p>
        </div>
    </footer>
</div>
