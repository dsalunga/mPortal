@model WCMS.WebSystem.WebParts.ViewComponents.IntConfigAttendanceRequestModel

<section class="card" id="int-config-attendance-request-@Model.ObjectId" aria-labelledby="int-config-attendance-request-heading">
    <div class="card-header">
        <h5 id="int-config-attendance-request-heading" class="card-title mb-0"><i class="bi bi-calendar-check" aria-hidden="true"></i> Attendance Request Settings</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <form method="post" novalidate aria-label="Attendance request settings form">
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="chkEnabled" name="IsEnabled" value="true" role="switch" />
                <label class="form-check-label" for="chkEnabled">Enable Attendance Requests</label>
            </div>
            <div class="mb-3">
                <label for="ddlApprovalMode" class="form-label">Approval Mode</label>
                <select id="ddlApprovalMode" name="ApprovalMode" class="form-select" aria-label="Select approval mode">
                    <option value="auto">Auto-Approve</option>
                    <option value="manual">Manual Approval</option>
                </select>
            </div>
            <div class="mb-3">
                <label for="txtMaxRequests" class="form-label">Max Requests per Member</label>
                <input type="number" id="txtMaxRequests" name="MaxRequests" class="form-control" min="0" aria-describedby="maxRequestsHelp" />
                <div id="maxRequestsHelp" class="form-text">Set to 0 for unlimited.</div>
            </div>
            <button type="submit" id="cmdSaveConfig" class="btn btn-primary"><i class="bi bi-check-lg" aria-hidden="true"></i> Save Settings</button>
        </form>
    </div>
</section>
