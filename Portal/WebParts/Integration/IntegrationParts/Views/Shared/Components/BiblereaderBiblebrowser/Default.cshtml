@model WCMS.WebSystem.WebParts.Integration.ViewComponents.BiblereaderBiblebrowserViewModel
@* Ported from BibleBrowser.ascx (Apps/Integration/BibleReader). *@

<div class="component-biblereaderbiblebrowser">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Bible Browser</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Bible Browser component requires configuration.
        </div>
    }
</div>
