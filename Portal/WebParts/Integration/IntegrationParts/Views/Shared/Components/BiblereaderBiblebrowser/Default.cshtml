@model WCMS.WebSystem.WebParts.Integration.ViewComponents.BiblereaderBiblebrowserViewModel
@* Ported from BibleBrowser.ascx. *@

<div class="component-biblereader-biblebrowser">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Search" class="form-label">Search</label>
            <input type="text" class="form-control" id="field_Search" name="Search" value="@Model.Search" />
        </div>
        <div class="mb-3">
            <label for="field_CboLanguages" class="form-label">Cbo Languages</label>
            <select class="form-select" id="field_CboLanguages" name="SelectedCboLanguages">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboLanguagesOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboLanguages ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboVersions" class="form-label">Cbo Versions</label>
            <select class="form-select" id="field_CboVersions" name="SelectedCboVersions">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboVersionsOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboVersions ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboBooks" class="form-label">Cbo Books</label>
            <select class="form-select" id="field_CboBooks" name="SelectedCboBooks">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboBooksOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboBooks ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboChapters" class="form-label">Cbo Chapters</label>
            <select class="form-select" id="field_CboChapters" name="SelectedCboChapters">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboChaptersOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboChapters ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdSearch">Search</button>
        </div>
    </form>
</div>