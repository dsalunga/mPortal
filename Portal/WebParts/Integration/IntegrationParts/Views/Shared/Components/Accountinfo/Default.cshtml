@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AccountinfoViewModel
@* Ported from AccountInfo.ascx (Apps/Integration/Account). *@

<div class="component-accountinfo">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Account Info</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Account Info component requires configuration.
        </div>
    }
</div>
