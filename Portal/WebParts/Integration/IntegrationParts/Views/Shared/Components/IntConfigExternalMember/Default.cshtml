@model WCMS.WebSystem.WebParts.ViewComponents.IntConfigExternalMemberModel

<div class="card" id="int-config-external-member-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Configure External Member</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        <form method="post" novalidate>
            <div class="mb-3">
                <label for="extMemberId" class="form-label">Member ID</label>
                <input type="text" class="form-control" id="extMemberId" name="MemberId" value="@Model.MemberId" />
            </div>
            <div class="mb-3">
                <label for="extExternalId" class="form-label">External ID</label>
                <input type="text" class="form-control" id="extExternalId" name="ExternalId" value="@Model.ExternalId" />
            </div>
            <div class="mb-3">
                <label for="extDisplayName" class="form-label">Display Name</label>
                <input type="text" class="form-control" id="extDisplayName" name="DisplayName" value="@Model.DisplayName" />
            </div>
            <div class="mb-3">
                <label for="extEmail" class="form-label">Email</label>
                <input type="email" class="form-control" id="extEmail" name="Email" value="@Model.Email" />
            </div>
            <div class="mb-3">
                <label for="extStatus" class="form-label">Status</label>
                <input type="text" class="form-control" id="extStatus" name="Status" value="@Model.Status" />
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
</div>
