@model WCMS.WebSystem.WebParts.Integration.ViewComponents.IntegrationServicepickerViewModel
@* Ported from ServicePicker.ascx (Apps/Integration). *@

<div class="component-integrationservicepicker">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Service Picker</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Service Picker component requires configuration.
        </div>
    }
</div>
