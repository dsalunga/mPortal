@model WCMS.WebSystem.WebParts.Integration.ViewComponents.ControlsWebgrouptabViewModel
@* Ported from WebGroupTab.ascx (Apps/Integration/MasterList/Controls). *@

<div class="component-controlswebgrouptab">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Web Group Tab</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Web Group Tab component requires configuration.
        </div>
    }
</div>
