@model dynamic

<section class="card" id="mc-instagram-gallery-@Model.ObjectId" aria-labelledby="mc-instagram-gallery-heading-@Model.ObjectId">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="mc-instagram-gallery-heading-@Model.ObjectId" class="card-title mb-0"><i class="bi bi-camera-fill" aria-hidden="true"></i> Instagram Gallery</h5>
        <a href="#" class="btn btn-sm btn-outline-primary" target="_blank" rel="noopener noreferrer" aria-label="View on Instagram">
            <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i> View All
        </a>
    </div>
    <div class="card-body">
        <div class="row g-2" role="list" aria-label="Gallery photos">
            <div class="col-4 col-md-3" role="listitem">
                <a href="#" data-bs-toggle="modal" aria-label="View photo in full size">
                    <img src="/images/placeholder-gallery.png" class="img-fluid rounded" alt="Gallery photo" loading="lazy" />
                </a>
            </div>
        </div>
        <p class="text-center text-muted mt-3 mb-0 empty-state">
            <i class="bi bi-image" aria-hidden="true"></i> No photos to display.
        </p>
    </div>
</section>
