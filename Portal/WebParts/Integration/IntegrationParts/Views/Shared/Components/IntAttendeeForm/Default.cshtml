@model WCMS.WebSystem.WebParts.ViewComponents.IntAttendeeFormModel

<div class="card" id="int-attendee-form-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Attendee Registration</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        <p>Attendee registration form placeholder content.</p>
    </div>
</div>
