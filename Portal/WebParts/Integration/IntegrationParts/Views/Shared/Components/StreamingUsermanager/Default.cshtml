@model WCMS.WebSystem.WebParts.Integration.ViewComponents.StreamingUsermanagerViewModel
@* Ported from UserManager.ascx (Apps/Integration/Streaming). *@

<div class="component-streamingusermanager">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>User Manager</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            User Manager component requires configuration.
        </div>
    }
</div>
