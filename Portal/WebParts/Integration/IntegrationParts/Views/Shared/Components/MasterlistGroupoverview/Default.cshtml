@model WCMS.WebSystem.WebParts.Integration.ViewComponents.MasterlistGroupoverviewViewModel
@* Ported from GroupOverview.ascx (Apps/Integration/MasterList). *@

<div class="component-masterlistgroupoverview">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Group Overview</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
