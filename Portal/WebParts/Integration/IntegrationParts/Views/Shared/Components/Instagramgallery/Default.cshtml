@model WCMS.WebSystem.WebParts.Integration.ViewComponents.InstagramgalleryViewModel
@* Ported from InstagramGallery.ascx (Apps/Integration/MusicCompetition). *@

<div class="component-instagramgallery">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Instagram Gallery</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Instagram Gallery component requires configuration.
        </div>
    }
</div>
