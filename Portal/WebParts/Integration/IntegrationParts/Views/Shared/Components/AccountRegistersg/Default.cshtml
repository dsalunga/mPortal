@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AccountRegistersgViewModel
@* Ported from RegisterSG.ascx (Apps/Integration/Account). *@

<div class="component-accountregistersg">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Register SG</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Register SG component requires configuration.
        </div>
    }
</div>
