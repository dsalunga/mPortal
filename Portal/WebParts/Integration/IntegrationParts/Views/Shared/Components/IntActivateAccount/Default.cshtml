@model WCMS.WebSystem.WebParts.ViewComponents.IntActivateAccountModel

<section aria-labelledby="activate-account-heading-@Model.ObjectId">
    <div class="card" id="int-activate-account-@Model.ObjectId">
        <div class="card-header">
            <h5 class="card-title mb-0" id="activate-account-heading-@Model.ObjectId">
                <i class="bi bi-check-circle" aria-hidden="true"></i> Activate Account
            </h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                    @Model.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <form method="post" novalidate aria-label="Activate account form">
                <div class="mb-3">
                    <label for="activationCode" class="form-label">Activation Code <span class="text-danger" aria-hidden="true">*</span></label>
                    <input type="text" class="form-control" id="activationCode" name="ActivationCode" value="@Model.ActivationCode" required aria-required="true" />
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg" aria-hidden="true"></i> Activate
                </button>
            </form>
        </div>
    </div>
</section>
