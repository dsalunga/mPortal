@* Originally: ASOP/asopv2-division-content.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeAsopV2DivisionContentModel

<div id="theme-asopv2-division-content-@Model.ObjectId">
    <a href="#asopv2-div-content-main-@Model.ObjectId" class="visually-hidden-focusable skip-link">Skip to main content</a>

    <header class="bg-secondary text-white py-3" role="banner" aria-label="Division header">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "DivisionHeader" })
        </div>
    </header>

    <div class="container mt-3">
        <nav aria-label="Breadcrumb">
            @await Component.InvokeAsync("WZone", new { zone = "Breadcrumb" })
        </nav>
    </div>

    <main id="asopv2-div-content-main-@Model.ObjectId" class="container py-4">
        <div class="row">
            <div class="col-12">
                @await Component.InvokeAsync("WZone", new { zone = "Content" })
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-3 mt-4" role="contentinfo" aria-label="ASOP site footer">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year ASOP. All rights reserved.</small></p>
        </div>
    </footer>
</div>
