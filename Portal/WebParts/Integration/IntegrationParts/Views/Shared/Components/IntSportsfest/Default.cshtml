@model WCMS.WebSystem.WebParts.ViewComponents.IntSportsfestModel

<section class="card" id="int-sportsfest-@Model.ObjectId" aria-labelledby="sportsfest-heading-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0" id="sportsfest-heading-@Model.ObjectId">
            <i class="bi bi-trophy" aria-hidden="true"></i> Sportsfest
        </h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <p>Sportsfest page placeholder content.</p>
    </div>
</section>
