@model WCMS.WebSystem.WebParts.Integration.ViewComponents.GetaccessViewModel
@* Ported from GetAccess.ascx. *@

<div class="component-getaccess">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Email" class="form-label">Email</label>
            <input type="text" class="form-control" id="field_Email" name="Email" value="@Model.Email" />
        </div>
        <div class="mb-3">
            <label for="field_DateOfMembership" class="form-label">Date Of Membership</label>
            <input type="text" class="form-control" id="field_DateOfMembership" name="DateOfMembership" value="@Model.DateOfMembership" />
        </div>
        <div class="mb-3">
            <label for="field_ExternalId" class="form-label">External Id</label>
            <input type="text" class="form-control" id="field_ExternalId" name="ExternalId" value="@Model.ExternalId" />
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_NoExternalId" name="NoExternalId" @(Model.NoExternalId ? "checked" : "") />
            <label class="form-check-label" for="field_NoExternalId">I don't know my Group ID</label>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdRetrieve">Submit</button>
            <button type="submit" class="btn btn-primary" name="action" value="cmdInformAdmin">Submit</button>
            <button type="submit" class="btn btn-primary" name="action" value="cmdPerformReset">Continue</button>
            <button type="submit" class="btn btn-primary" name="action" value="cmdGoToLogin">Proceed to Login using my ONE account</button>
            <button type="submit" class="btn btn-primary" name="action" value="cmdRegisterNewAccount">Register new account</button>
        </div>
    </form>
</div>