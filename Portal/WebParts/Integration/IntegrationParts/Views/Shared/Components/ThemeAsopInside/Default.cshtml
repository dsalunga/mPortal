@* Originally: ASOP/Inside.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeAsopInsideModel

<div id="theme-asop-inside-@Model.ObjectId">
    <a href="#asop-inside-main-@Model.ObjectId" class="visually-hidden-focusable skip-link">Skip to main content</a>

    <header class="bg-primary text-white py-3" role="banner" aria-label="ASOP site header">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Header" })
        </div>
    </header>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Main navigation">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Navigation" })
        </div>
    </nav>

    <main id="asop-inside-main-@Model.ObjectId" class="container py-4">
        <div class="row">
            <div class="col-md-3">
                <aside aria-label="Sidebar navigation">
                    @await Component.InvokeAsync("WZone", new { zone = "Sidebar" })
                </aside>
            </div>
            <div class="col-md-9">
                @await Component.InvokeAsync("WZone", new { zone = "Content" })
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-3 mt-4" role="contentinfo" aria-label="ASOP site footer">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year ASOP. All rights reserved.</small></p>
        </div>
    </footer>
</div>
