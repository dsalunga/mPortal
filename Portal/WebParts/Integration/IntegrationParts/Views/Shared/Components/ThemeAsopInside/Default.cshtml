@* Originally: ASOP/Inside.ascx *@
@model dynamic

<div id="theme-asop-inside-@Model.ObjectId">
    <header class="bg-primary text-white py-3" role="banner">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Header" })
        </div>
    </header>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Main navigation">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Navigation" })
        </div>
    </nav>

    <main class="container py-4" role="main">
        <div class="row">
            <div class="col-md-3">
                <aside aria-label="Sidebar">
                    @await Component.InvokeAsync("WZone", new { zone = "Sidebar" })
                </aside>
            </div>
            <div class="col-md-9">
                @await Component.InvokeAsync("WZone", new { zone = "Content" })
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-3 mt-4" role="contentinfo">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year ASOP. All rights reserved.</small></p>
        </div>
    </footer>
</div>
