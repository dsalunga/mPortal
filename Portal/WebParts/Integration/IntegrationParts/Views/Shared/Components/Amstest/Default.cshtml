@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AmstestViewModel
@* Ported from AMSTest.ascx (Apps/Integration/Profile). *@

<div class="component-amstest">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>AMSTest</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            AMSTest component requires configuration.
        </div>
    }
</div>
