@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AttendeeViewModel
@* Ported from Attendee.ascx (Apps/Integration/EventRegister). *@

<div class="component-attendee">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Attendee</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Attendee component requires configuration.
        </div>
    }
</div>
