@model WCMS.WebSystem.WebParts.Integration.ViewComponents.ProfileUserprofiledetailsViewModel
@* Ported from UserProfileDetails.ascx. *@

<div class="component-profile-userprofiledetails">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_AdditionalInfo" class="form-label">Additional Info</label>
            <textarea class="form-control" id="field_AdditionalInfo" name="AdditionalInfo" rows="4">@Model.AdditionalInfo</textarea>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">OK</button>
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
        </div>
    </form>
</div>