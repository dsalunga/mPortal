@model dynamic

<div class="card" id="int-reminder-templates-@Model.ObjectId" role="region" aria-label="Reminder Templates">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Reminder Templates</h5>
        <button type="button" id="cmdAddTemplate" class="btn btn-sm btn-primary" aria-label="Add new template">
            <span aria-hidden="true">+</span> Add Template
        </button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="tblTemplates" aria-label="Reminder templates list">
                <thead>
                    <tr>
                        <th scope="col">Template Name</th>
                        <th scope="col">Type</th>
                        <th scope="col">Status</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody id="templateList">
                </tbody>
            </table>
        </div>
    </div>
</div>
