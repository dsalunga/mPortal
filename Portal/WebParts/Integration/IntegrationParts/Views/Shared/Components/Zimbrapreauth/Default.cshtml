@model WCMS.WebSystem.WebParts.Integration.ViewComponents.ZimbrapreauthViewModel
@* Ported from ZimbraPreauth.ascx (Apps/Integration/Profile). *@

<div class="component-zimbrapreauth">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Zimbra Preauth</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Zimbra Preauth component requires configuration.
        </div>
    }
</div>
