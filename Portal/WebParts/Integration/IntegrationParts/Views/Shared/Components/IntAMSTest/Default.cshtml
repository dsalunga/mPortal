@model WCMS.WebSystem.WebParts.ViewComponents.IntAMSTestModel

<section aria-labelledby="ams-test-heading-@Model.ObjectId">
    <div class="card" id="int-ams-test-@Model.ObjectId">
        <div class="card-header">
            <h5 class="card-title mb-0" id="ams-test-heading-@Model.ObjectId">
                <i class="bi bi-wrench-adjustable" aria-hidden="true"></i> AMS Test
            </h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                    @Model.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <p class="text-muted mb-3">Use this panel to validate AMS endpoint connectivity and token exchange behavior.</p>
            <dl class="row mb-0 small">
                <dt class="col-sm-4">Endpoint</dt>
                <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Endpoint) ? "Not configured" : Model.Endpoint)</dd>
                <dt class="col-sm-4">Last Result</dt>
                <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.TestResult) ? "No test executed" : Model.TestResult)</dd>
            </dl>
        </div>
    </div>
</section>
