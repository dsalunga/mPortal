@model WCMS.WebSystem.WebParts.Integration.ViewComponents.GroupmanagerViewModel
@* Ported from GroupManager.ascx (Apps/Integration/MasterList). *@

<div class="component-groupmanager">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Group Manager</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Group Manager component requires configuration.
        </div>
    }
</div>
