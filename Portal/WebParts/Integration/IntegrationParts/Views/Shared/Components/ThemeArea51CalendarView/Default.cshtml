@* Originally: area51/Parts/EventCalendar/EventCalendar/CalendarView.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeArea51CalendarViewModel

<section id="theme-area51-calendar-@Model.ObjectId" aria-labelledby="calendar-view-heading-@Model.ObjectId">
    <div class="container py-4">
        <h2 class="visually-hidden" id="calendar-view-heading-@Model.ObjectId">Calendar View</h2>

        <nav class="row mb-3" aria-label="Calendar navigation">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    @await Component.InvokeAsync("WZone", new { zone = "CalendarNavigation" })
                </div>
            </div>
        </nav>

        <div class="row" role="region" aria-label="Calendar grid">
            <div class="col-12">
                <div class="table-responsive">
                    @await Component.InvokeAsync("WZone", new { zone = "CalendarGrid" })
                </div>
            </div>
        </div>

        <div class="row mt-4" role="region" aria-label="Event list">
            <div class="col-12">
                @await Component.InvokeAsync("WZone", new { zone = "EventList" })
            </div>
        </div>
    </div>
</section>
