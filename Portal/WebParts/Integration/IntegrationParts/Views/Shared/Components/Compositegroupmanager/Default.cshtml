@model WCMS.WebSystem.WebParts.Integration.ViewComponents.CompositegroupmanagerViewModel
@* Ported from _CompositeGroupManager.ascx (Apps/Integration/MasterList). *@

<div class="component-compositegroupmanager">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em> Composite Group Manager</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
             Composite Group Manager component requires configuration.
        </div>
    }
</div>
