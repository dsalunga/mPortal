@model dynamic

<section aria-labelledby="int-user-profile-details-heading-@Model.ObjectId">
<div class="card" id="int-user-profile-details-@Model.ObjectId" role="region" aria-label="User Profile Details">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="int-user-profile-details-heading-@Model.ObjectId" class="card-title mb-0">
            <i class="bi bi-person-vcard" aria-hidden="true"></i> Profile Details
        </h5>
        <a href="#" id="linkEditProfile" class="btn btn-sm btn-outline-primary" aria-label="Edit profile">
            <i class="bi bi-pencil" aria-hidden="true"></i> Edit
        </a>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="text-center mb-3">
            <img src="/Content/Assets/Images/nophoto.png" id="userPhoto" class="rounded-circle" width="100" height="100" alt="User profile photo" />
        </div>
        <dl class="row mb-0" id="profileDetails" aria-label="Profile information">
            <dt class="col-sm-4">Full Name</dt>
            <dd class="col-sm-8" id="lblFullName">—</dd>
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8" id="lblEmail">—</dd>
            <dt class="col-sm-4">Phone</dt>
            <dd class="col-sm-8" id="lblPhone">—</dd>
            <dt class="col-sm-4">Address</dt>
            <dd class="col-sm-8" id="lblAddress">—</dd>
            <dt class="col-sm-4">Member Since</dt>
            <dd class="col-sm-8" id="lblMemberSince">—</dd>
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8"><span class="badge bg-success" id="lblProfileStatus">Active</span></dd>
        </dl>
    </div>
</div>
</section>
