@model WCMS.WebSystem.WebParts.ViewComponents.IntUserProfileDetailsModel

<div class="card" id="int-user-profile-details-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">User Profile Details</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        <p>User profile details placeholder content.</p>
    </div>
</div>
