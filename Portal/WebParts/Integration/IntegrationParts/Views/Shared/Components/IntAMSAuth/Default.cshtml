@model WCMS.WebSystem.WebParts.ViewComponents.IntAMSAuthModel

<section aria-labelledby="ams-auth-heading-@Model.ObjectId">
    <div class="card" id="int-ams-auth-@Model.ObjectId">
        <div class="card-header">
            <h5 class="card-title mb-0" id="ams-auth-heading-@Model.ObjectId">
                <i class="bi bi-shield-lock" aria-hidden="true"></i> AMS Authentication
            </h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                    @Model.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <p class="text-muted mb-3">This panel bridges the legacy AMS authentication control to the modern Integration stack.</p>
            <dl class="row mb-0 small">
                <dt class="col-sm-4">Auth Token</dt>
                <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.AuthToken) ? "Pending generation" : Model.AuthToken)</dd>
                <dt class="col-sm-4">Redirect URL</dt>
                <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.RedirectUrl) ? "Not configured" : Model.RedirectUrl)</dd>
            </dl>
        </div>
    </div>
</section>
