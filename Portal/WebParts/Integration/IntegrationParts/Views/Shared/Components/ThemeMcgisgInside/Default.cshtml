@* Originally: mcgisg/mcgisg_inside.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeMcgisgInsideModel

<div id="theme-mcgisg-inside-@Model.ObjectId">
    <a href="#mcgisg-inside-main-@Model.ObjectId" class="visually-hidden-focusable skip-link">Skip to main content</a>

    <header class="bg-success text-white py-3" role="banner" aria-label="MCGI Small Groups site header">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "SgHeader" })
        </div>
    </header>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Main navigation">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Navigation" })
        </div>
    </nav>

    <main id="mcgisg-inside-main-@Model.ObjectId" class="container py-4">
        <div class="row">
            <div class="col-md-8">
                @await Component.InvokeAsync("WZone", new { zone = "Content" })
            </div>
            <div class="col-md-4">
                <aside aria-label="Sidebar">
                    @await Component.InvokeAsync("WZone", new { zone = "Sidebar" })
                </aside>
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-3 mt-4" role="contentinfo" aria-label="MCGI Small Groups site footer">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year MCGI Small Groups. All rights reserved.</small></p>
        </div>
    </footer>
</div>
