@* Originally: mcgisg/mcgisg_inside.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeMcgisgInsideModel

<div id="theme-mcgisg-inside-@Model.ObjectId">
    <!-- SG Header -->
    <header class="bg-success text-white py-3">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "SgHeader" })
        </div>
    </header>

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Navigation" })
        </div>
    </nav>

    <!-- Two-Column Layout -->
    <main class="container py-4">
        <div class="row">
            <div class="col-md-8">
                @await Component.InvokeAsync("WZone", new { zone = "Content" })
            </div>
            <div class="col-md-4">
                <aside>
                    @await Component.InvokeAsync("WZone", new { zone = "Sidebar" })
                </aside>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white py-3 mt-4">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
        </div>
    </footer>
</div>
