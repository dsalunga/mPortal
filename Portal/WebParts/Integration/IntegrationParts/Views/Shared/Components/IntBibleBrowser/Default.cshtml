@model WCMS.WebSystem.WebParts.ViewComponents.IntBibleBrowserModel

<section aria-labelledby="bible-browser-heading-@Model.ObjectId">
    <div class="card" id="int-bible-browser-@Model.ObjectId">
        <div class="card-header">
            <h5 class="card-title mb-0" id="bible-browser-heading-@Model.ObjectId">
                <i class="bi bi-journal-text" aria-hidden="true"></i> Bible Browser
            </h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                    @Model.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <div class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label" for="bible-browser-query-@Model.ObjectId">Book / Chapter / Verse</label>
                    <input id="bible-browser-query-@Model.ObjectId" type="text" class="form-control" placeholder="Example: John 3:16" />
                </div>
                <div class="col-md-4 d-grid">
                    <button type="button" class="btn btn-primary" disabled>Open Passage</button>
                </div>
            </div>
            <div class="form-text">Hook this shell to the Bible integration endpoint used by the host page.</div>
        </div>
    </div>
</section>
