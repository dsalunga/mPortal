@model WCMS.WebSystem.WebParts.Integration.ViewComponents.LessonreviewerServicevideodurationinputViewModel
@* Ported from ServiceVideoDurationInput.ascx. *@

<div class="component-lessonreviewer-servicevideodurationinput">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.ActiveViewIndex == 0)
    {
        <div class="view-section" id="view-viewCalendar">
            <h4>Calendar</h4>
            <div class="view-content p-3">
                @* viewCalendar content *@
                <p class="text-muted">Section: Calendar</p>
            </div>
        </div>
    }
    else if (Model.ActiveViewIndex == 1)
    {
        <div class="view-section" id="view-viewDurationInput">
            <h4>Duration Input</h4>
            <div class="view-content p-3">
                @* viewDurationInput content *@
                <p class="text-muted">Section: Duration Input</p>
            </div>
        </div>
    }
</div>