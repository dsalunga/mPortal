@model dynamic

<section aria-labelledby="global-switch-heading-@Model.ObjectId">
    <div class="card" id="int-global-switch-@Model.ObjectId">
        <div class="card-header">
            <h5 class="card-title mb-0" id="global-switch-heading-@Model.ObjectId">
                <i class="bi bi-toggles" aria-hidden="true"></i> Global Settings
            </h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty((string)Model.Message))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                    @Model.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <form method="post" novalidate aria-label="Global settings form">
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="chkMaintenanceMode" name="MaintenanceMode" value="true" role="switch" />
                    <label class="form-check-label" for="chkMaintenanceMode">Maintenance Mode</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="chkRegistrationOpen" name="RegistrationOpen" value="true" role="switch" />
                    <label class="form-check-label" for="chkRegistrationOpen">Registration Open</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="chkNotifications" name="NotificationsEnabled" value="true" role="switch" />
                    <label class="form-check-label" for="chkNotifications">Enable Notifications</label>
                </div>
                <button type="submit" id="cmdSaveGlobal" class="btn btn-primary">
                    <i class="bi bi-save" aria-hidden="true"></i> Save Settings
                </button>
            </form>
        </div>
    </div>
</section>
