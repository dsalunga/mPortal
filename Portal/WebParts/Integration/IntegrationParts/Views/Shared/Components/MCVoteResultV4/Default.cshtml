@model WCMS.WebSystem.WebParts.ViewComponents.MCVoteResultV4Model

<section class="card" id="mc-vote-result-v4-@Model.ObjectId" aria-labelledby="mc-vote-result-v4-heading-@Model.ObjectId">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="mc-vote-result-v4-heading-@Model.ObjectId" class="card-title mb-0"><i class="bi bi-bar-chart-fill" aria-hidden="true"></i> Vote Results</h5>
        <div class="btn-group btn-group-sm" role="group" aria-label="View toggle">
            <button type="button" class="btn btn-outline-secondary active" aria-label="Table view"><i class="bi bi-table" aria-hidden="true"></i></button>
            <button type="button" class="btn btn-outline-secondary" aria-label="Chart view"><i class="bi bi-graph-up" aria-hidden="true"></i></button>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0" aria-label="Detailed vote results">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Rank</th>
                        <th scope="col">Candidate</th>
                        <th scope="col">Song</th>
                        <th scope="col">Votes</th>
                        <th scope="col">Avg Score</th>
                        <th scope="col">Total</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-inbox" aria-hidden="true"></i> No results available.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <!-- Chart placeholder -->
        <div class="text-center text-muted py-4 d-none" role="img" aria-label="Results chart placeholder">
            <i class="bi bi-graph-up" style="font-size:3rem;" aria-hidden="true"></i>
            <p class="mt-2 mb-0">Chart view will render here.</p>
        </div>
    </div>
</section>
