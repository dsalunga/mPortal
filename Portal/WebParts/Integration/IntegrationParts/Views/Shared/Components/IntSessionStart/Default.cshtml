@model dynamic

<section aria-labelledby="session-start-heading-@Model.ObjectId">
    <div class="card" id="int-session-start-@Model.ObjectId">
        <div class="card-header">
            <h5 class="card-title mb-0" id="session-start-heading-@Model.ObjectId">
                <i class="bi bi-play-circle" aria-hidden="true"></i> Start Session
            </h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty((string)Model.Message))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                    @Model.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <form method="post" novalidate aria-label="Start session form">
                <div class="mb-3">
                    <label for="ddlSessionService" class="form-label">Service <span class="text-danger" aria-hidden="true">*</span></label>
                    <select id="ddlSessionService" name="ServiceId" class="form-select" required aria-required="true" aria-label="Select service for session">
                        <option value="">-- Select Service --</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label for="txtSessionDate" class="form-label">Session Date <span class="text-danger" aria-hidden="true">*</span></label>
                    <input type="date" id="txtSessionDate" name="SessionDate" class="form-control" required aria-required="true" />
                </div>
                <div class="mb-3">
                    <label for="txtSessionRemarks" class="form-label">Remarks</label>
                    <textarea id="txtSessionRemarks" name="Remarks" class="form-control" rows="2"></textarea>
                </div>
                <button type="submit" id="cmdStartSession" class="btn btn-primary">
                    <i class="bi bi-play-fill" aria-hidden="true"></i> Start Session
                </button>
            </form>
        </div>
    </div>
</section>
