@model dynamic

<section class="card" id="int-web-group-list-@Model.ObjectId" aria-labelledby="int-web-group-list-heading">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="int-web-group-list-heading" class="card-title mb-0"><i class="bi bi-globe" aria-hidden="true"></i> Web Groups</h5>
        <button type="button" id="cmdAddWebGroup" class="btn btn-sm btn-primary" aria-label="Add new web group">
            <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Group
        </button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="mb-3">
            <label for="txtSearchWebGroups" class="form-label visually-hidden">Search web groups</label>
            <input type="text" id="txtSearchWebGroups" class="form-control" placeholder="Search web groups..." aria-label="Search web groups" />
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="tblWebGroups" aria-label="Web groups list">
                <thead>
                    <tr>
                        <th scope="col">Group Name</th>
                        <th scope="col">Description</th>
                        <th scope="col">Members</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody id="webGroupList">
                </tbody>
            </table>
        </div>
        <div id="webGroupListEmpty" class="text-center text-muted py-3 d-none" role="status">
            <i class="bi bi-inbox" aria-hidden="true"></i>
            <p class="mb-0">No web groups found.</p>
        </div>
    </div>
</section>
