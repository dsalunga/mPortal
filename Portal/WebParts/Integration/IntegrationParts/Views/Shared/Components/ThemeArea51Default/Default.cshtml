@* Originally: area51/Default.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeArea51DefaultModel

<div id="theme-area51-default-@Model.ObjectId">
    <!-- Header with Logo -->
    <header class="bg-white border-bottom py-3">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-auto">
                    @await Component.InvokeAsync("WZone", new { zone = "Logo" })
                </div>
                <div class="col">
                    @await Component.InvokeAsync("WZone", new { zone = "HeaderRight" })
                </div>
            </div>
        </div>
    </header>

    <!-- Top Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "TopNavigation" })
        </div>
    </nav>

    <!-- Full-Width Content -->
    <main class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                @await Component.InvokeAsync("WZone", new { zone = "Content" })
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white py-3 mt-4">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
        </div>
    </footer>
</div>
