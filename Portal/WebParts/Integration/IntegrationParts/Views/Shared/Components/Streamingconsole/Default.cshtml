@model WCMS.WebSystem.WebParts.Integration.ViewComponents.StreamingconsoleViewModel
@* Ported from StreamingConsole.ascx (Apps/Integration/Streaming). *@

<div class="component-streamingconsole">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Streaming Console</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Streaming Console component requires configuration.
        </div>
    }
</div>
