@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AsopwinnersViewModel
@* Ported from ASOPWinners.ascx (Apps/Integration/MusicCompetition). *@

<div class="component-asopwinners">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>ASOPWinners</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            ASOPWinners component requires configuration.
        </div>
    }
</div>
