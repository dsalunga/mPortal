@model WCMS.WebSystem.WebParts.Integration.ViewComponents.TemplateInsideViewModel
@* Ported from template_inside.ascx (Themes/mcgi_website). *@

<div class="component-templateinside">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>template inside</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            template inside component requires configuration.
        </div>
    }
</div>
