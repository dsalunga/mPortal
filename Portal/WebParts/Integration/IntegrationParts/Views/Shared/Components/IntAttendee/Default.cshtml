@model WCMS.WebSystem.WebParts.ViewComponents.IntAttendeeModel

<section class="card" id="int-attendee-@Model.ObjectId" aria-labelledby="attendee-heading-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0" id="attendee-heading-@Model.ObjectId">
            <i class="bi bi-person-badge" aria-hidden="true"></i> Attendee Details
        </h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <dl class="row mb-0" id="attendeeDetails" aria-label="Attendee information">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8" id="lblAttendeeName">—</dd>
            <dt class="col-sm-4">Service</dt>
            <dd class="col-sm-8" id="lblService">—</dd>
            <dt class="col-sm-4">Date</dt>
            <dd class="col-sm-8" id="lblDate">—</dd>
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8"><span class="badge bg-success" id="lblAttendeeStatus">Present</span></dd>
        </dl>
        <div id="attendeeEmpty" class="text-center text-muted py-4 d-none">
            <i class="bi bi-person-x fs-1" aria-hidden="true"></i>
            <p class="mt-2 mb-0">No attendee details available.</p>
        </div>
    </div>
</section>
