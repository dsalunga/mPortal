@model WCMS.WebSystem.WebParts.ViewComponents.IntRequestManagerRegisterModel

<div class="card" id="int-request-manager-register-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Registration Requests</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        <p>Registration requests placeholder content.</p>
    </div>
</div>
