@model dynamic

<section class="card" id="mc-asop-winners-@Model.ObjectId" aria-labelledby="mc-asop-winners-heading-@Model.ObjectId">
    <div class="card-header">
        <h5 id="mc-asop-winners-heading-@Model.ObjectId" class="card-title mb-0"><i class="bi bi-trophy-fill text-warning" aria-hidden="true"></i> ASOP Winners</h5>
    </div>
    <div class="card-body">
        <div class="row g-4" role="list" aria-label="Winner rankings">
            <div class="col-md-4" role="listitem">
                <div class="card text-center border-warning">
                    <div class="card-body">
                        <span class="badge bg-warning text-dark fs-5 mb-2" aria-label="First place"><i class="bi bi-trophy-fill" aria-hidden="true"></i> 1st</span>
                        <img src="/images/placeholder-winner.png" alt="First place winner photo" class="rounded-circle mb-2" width="96" height="96" loading="lazy" />
                        <h6 class="card-title">Winner Name</h6>
                        <p class="text-muted mb-1">Song Title</p>
                        <span class="badge bg-secondary">Category</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4" role="listitem">
                <div class="card text-center border-secondary">
                    <div class="card-body">
                        <span class="badge bg-secondary fs-5 mb-2" aria-label="Second place"><i class="bi bi-trophy" aria-hidden="true"></i> 2nd</span>
                        <img src="/images/placeholder-winner.png" alt="Second place winner photo" class="rounded-circle mb-2" width="96" height="96" loading="lazy" />
                        <h6 class="card-title">Winner Name</h6>
                        <p class="text-muted mb-1">Song Title</p>
                        <span class="badge bg-secondary">Category</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4" role="listitem">
                <div class="card text-center">
                    <div class="card-body">
                        <span class="badge bg-danger fs-5 mb-2" aria-label="Third place"><i class="bi bi-award" aria-hidden="true"></i> 3rd</span>
                        <img src="/images/placeholder-winner.png" alt="Third place winner photo" class="rounded-circle mb-2" width="96" height="96" loading="lazy" />
                        <h6 class="card-title">Winner Name</h6>
                        <p class="text-muted mb-1">Song Title</p>
                        <span class="badge bg-secondary">Category</span>
                    </div>
                </div>
            </div>
        </div>
        <p class="text-center text-muted mt-3 mb-0 empty-state">
            <i class="bi bi-inbox" aria-hidden="true"></i> No winners to display.
        </p>
    </div>
</section>
