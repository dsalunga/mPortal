@model WCMS.WebSystem.WebParts.Integration.ViewComponents.RegistrationActivateaccountViewModel
@* Ported from ActivateAccount.ascx (Apps/Integration/Registration). *@

<div class="component-registrationactivateaccount">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Activate Account</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Activate Account component requires configuration.
        </div>
    }
</div>
