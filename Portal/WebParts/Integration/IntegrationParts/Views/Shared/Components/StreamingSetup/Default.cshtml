@model WCMS.WebSystem.WebParts.Integration.ViewComponents.StreamingSetupViewModel
@* Ported from Setup.ascx. *@

<div class="component-streaming-setup">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_StartDate" class="form-label">Start Date</label>
            <input type="text" class="form-control" id="field_StartDate" name="StartDate" value="@Model.StartDate" />
        </div>
        <div class="mb-3">
            <label for="field_CboStreamType" class="form-label">Cbo Stream Type</label>
            <select class="form-select" id="field_CboStreamType" name="SelectedCboStreamType">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboStreamTypeOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboStreamType ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboDuration" class="form-label">Cbo Duration</label>
            <select class="form-select" id="field_CboDuration" name="SelectedCboDuration">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboDurationOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboDuration ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
        </div>
    </form>
</div>