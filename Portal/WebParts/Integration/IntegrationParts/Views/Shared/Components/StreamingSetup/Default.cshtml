@model WCMS.WebSystem.WebParts.Integration.ViewComponents.StreamingSetupViewModel
@* Ported from Setup.ascx (Apps/Integration/Streaming). *@

<div class="component-streamingsetup">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Setup</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Setup component requires configuration.
        </div>
    }
</div>
