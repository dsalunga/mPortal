@model dynamic

<div class="card" id="mc-candidate-manager-@Model.ObjectId" role="region" aria-label="Candidate Manager">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0"><i class="bi bi-people-fill" aria-hidden="true"></i> Candidate Manager</h5>
        <button type="button" class="btn btn-sm btn-primary" aria-label="Add new candidate">
            <i class="bi bi-plus-lg" aria-hidden="true"></i> Add
        </button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0" aria-label="Candidates list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Song</th>
                        <th scope="col">Category</th>
                        <th scope="col">Status</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No candidates found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
