@* Originally: ASOP/v2/old/asopv2-home.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeAsopV2HomeModel

<div id="theme-asopv2-home-@Model.ObjectId">
    <a href="#asopv2-home-main-@Model.ObjectId" class="visually-hidden-focusable skip-link">Skip to main content</a>

    <section class="bg-primary text-white py-5" aria-label="Hero banner">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "HeroBanner" })
        </div>
    </section>

    <main id="asopv2-home-main-@Model.ObjectId" class="container py-4">
        <div class="row">
            <div class="col-md-6">
                @await Component.InvokeAsync("WZone", new { zone = "FeatureLeft" })
            </div>
            <div class="col-md-6">
                @await Component.InvokeAsync("WZone", new { zone = "FeatureRight" })
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-3 mt-4" role="contentinfo" aria-label="ASOP site footer">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year ASOP. All rights reserved.</small></p>
        </div>
    </footer>
</div>
