@model WCMS.WebSystem.WebParts.ViewComponents.MCConfirmVoteModel

<section class="card" id="mc-confirm-vote-@Model.ObjectId" aria-labelledby="mc-confirm-vote-heading-@Model.ObjectId">
    <div class="card-header bg-success text-white">
        <h5 id="mc-confirm-vote-heading-@Model.ObjectId" class="card-title mb-0"><i class="bi bi-check-circle-fill" aria-hidden="true"></i> Vote Confirmation</h5>
    </div>
    <div class="card-body text-center py-4">
        <div class="mb-3">
            <i class="bi bi-patch-check-fill text-success" style="font-size:3rem;" aria-hidden="true"></i>
        </div>
        <div role="status" aria-live="polite">
            <h6>Your vote has been recorded</h6>
            <p class="text-muted mb-1">Candidate: <strong>Candidate Name</strong></p>
            <p class="text-muted mb-3">Confirmation #: <code>VOTE-00000</code></p>
        </div>
        <div class="d-flex justify-content-center gap-2">
            <button type="button" class="btn btn-primary"><i class="bi bi-arrow-left" aria-hidden="true"></i> Return to Voting</button>
            <button type="button" class="btn btn-outline-secondary"><i class="bi bi-bar-chart" aria-hidden="true"></i> View Results</button>
        </div>
    </div>
</section>
