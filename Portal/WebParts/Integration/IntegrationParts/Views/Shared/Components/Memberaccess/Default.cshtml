@model WCMS.WebSystem.WebParts.Integration.ViewComponents.MemberaccessViewModel
@* Ported from MemberAccess.ascx (Apps/Integration/MasterList). *@

<div class="component-memberaccess">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Member Access</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Member Access component requires configuration.
        </div>
    }
</div>
