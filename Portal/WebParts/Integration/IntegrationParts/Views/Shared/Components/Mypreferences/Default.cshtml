@model WCMS.WebSystem.WebParts.Integration.ViewComponents.MypreferencesViewModel
@* Ported from MyPreferences.ascx (Apps/Integration/Profile). *@

<div class="component-mypreferences">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>My Preferences</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            My Preferences component requires configuration.
        </div>
    }
</div>
