@model dynamic

<section class="card" id="int-my-attendance-@Model.ObjectId" aria-labelledby="my-attendance-heading-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0" id="my-attendance-heading-@Model.ObjectId">
            <i class="bi bi-journal-check" aria-hidden="true"></i> My Attendance
        </h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <form class="row mb-3 g-2" aria-label="Filter my attendance records">
            <div class="col-md-4">
                <label for="ddlMyAttService" class="form-label">Service</label>
                <select id="ddlMyAttService" name="ServiceId" class="form-select" aria-label="Filter by service">
                    <option value="">All Services</option>
                </select>
            </div>
            <div class="col-md-4">
                <label for="txtMyAttFrom" class="form-label">From</label>
                <input type="date" id="txtMyAttFrom" name="DateFrom" class="form-control" />
            </div>
            <div class="col-md-4">
                <label for="txtMyAttTo" class="form-label">To</label>
                <input type="date" id="txtMyAttTo" name="DateTo" class="form-control" />
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="tblMyAttendance" aria-label="My attendance records">
                <thead>
                    <tr>
                        <th scope="col">Service</th>
                        <th scope="col">Date</th>
                        <th scope="col">Status</th>
                    </tr>
                </thead>
                <tbody id="myAttendanceList">
                </tbody>
            </table>
            <div id="myAttendanceEmpty" class="text-center text-muted py-4 d-none">
                <i class="bi bi-calendar-x fs-1" aria-hidden="true"></i>
                <p class="mt-2 mb-0">No attendance records found.</p>
            </div>
        </div>
    </div>
</section>
