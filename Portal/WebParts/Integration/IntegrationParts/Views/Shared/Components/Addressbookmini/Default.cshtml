@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AddressbookminiViewModel
@* Ported from AddressBookMini.ascx (Apps/Integration/Profile). *@

<div class="component-addressbookmini">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Address Book Mini</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
