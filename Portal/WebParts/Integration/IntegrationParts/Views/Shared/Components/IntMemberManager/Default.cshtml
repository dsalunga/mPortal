@model dynamic

<div class="card" id="int-member-manager-@Model.ObjectId" role="region" aria-label="Member Manager">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Member Manager</h5>
        <button type="button" id="cmdAddMember" class="btn btn-sm btn-primary" aria-label="Add new member">
            <span aria-hidden="true">+</span> Add Member
        </button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="row mb-3">
            <div class="col-md-6">
                <label for="txtSearch" class="form-label visually-hidden">Search members</label>
                <input type="text" id="txtSearch" name="Search" class="form-control" placeholder="Search members..." aria-label="Search members" />
            </div>
            <div class="col-md-3">
                <label for="ddlFilter" class="form-label visually-hidden">Filter by status</label>
                <select id="ddlFilter" name="Filter" class="form-select" aria-label="Filter by status">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="tblMembers" aria-label="Members list">
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Email</th>
                        <th scope="col">Status</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody id="memberList">
                </tbody>
            </table>
        </div>
    </div>
</div>
