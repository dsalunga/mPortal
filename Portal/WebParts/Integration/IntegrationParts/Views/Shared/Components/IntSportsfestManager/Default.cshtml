@model WCMS.WebSystem.WebParts.ViewComponents.IntSportsfestManagerModel

<section class="card" id="int-sportsfest-manager-@Model.ObjectId" aria-labelledby="sportsfest-mgr-heading-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0" id="sportsfest-mgr-heading-@Model.ObjectId">
            <i class="bi bi-trophy-fill" aria-hidden="true"></i> Sportsfest Manager
        </h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="d-flex flex-wrap gap-2 mb-2">
            <button type="button" class="btn btn-sm btn-primary" disabled>Create Event</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" disabled>Manage Teams</button>
            <button type="button" class="btn btn-sm btn-outline-info" disabled>Publish Results</button>
        </div>
        <div class="small text-muted">Action handlers should call the modern Sportsfest integration services.</div>
    </div>
</section>
