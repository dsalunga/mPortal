@model WCMS.WebSystem.WebParts.Integration.ViewComponents.RegistrationRegistrationmanagerViewModel
@* Ported from RegistrationManager.ascx (Apps/Integration/Registration). *@

<div class="component-registrationregistrationmanager">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Registration Manager</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
