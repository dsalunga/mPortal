@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AccessrequestViewModel
@* Ported from AccessRequest.ascx (Apps/Integration/Streaming). *@

<div class="component-accessrequest">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Access Request</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Access Request component requires configuration.
        </div>
    }
</div>
