@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AccessrequestViewModel
@* Ported from AccessRequest.ascx. *@

<div class="component-accessrequest">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Reason" class="form-label">Reason</label>
            <textarea class="form-control" id="field_Reason" name="Reason" rows="4">@Model.Reason</textarea>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdRequest">Submit Request</button>
        </div>
    </form>
</div>