@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AttendeesViewModel
@* Ported from Attendees.ascx (Apps/Integration/EventRegister). *@

<div class="component-attendees">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Attendees</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Attendees component requires configuration.
        </div>
    }
</div>
