@* Originally: mcgi_website/Default.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeMcgiWebsiteDefaultModel

<div id="theme-mcgi-website-default-@Model.ObjectId">
    <!-- MCGI Branded Header -->
    <header class="bg-primary text-white py-3">
        <div class="container">
            <div class="row align-items-center">
                <div class="col">
                    @await Component.InvokeAsync("WZone", new { zone = "McgiBranding" })
                </div>
            </div>
        </div>
    </header>

    <!-- Main Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "MainNavigation" })
        </div>
    </nav>

    <!-- Single-Column Content -->
    <main class="container py-4">
        <div class="row">
            <div class="col-12">
                @await Component.InvokeAsync("WZone", new { zone = "Content" })
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white py-3 mt-4">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
        </div>
    </footer>
</div>
