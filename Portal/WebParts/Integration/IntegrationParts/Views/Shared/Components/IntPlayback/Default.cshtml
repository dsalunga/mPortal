@model WCMS.WebSystem.WebParts.ViewComponents.IntPlaybackModel

<section aria-labelledby="playback-heading-@Model.ObjectId">
    <div class="card" id="int-playback-@Model.ObjectId">
        <div class="card-header">
            <h5 class="card-title mb-0" id="playback-heading-@Model.ObjectId">
                <i class="bi bi-play-circle" aria-hidden="true"></i> Playback
            </h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                    @Model.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <div id="playbackContent-@Model.ObjectId" role="region" aria-label="Media player">
                <p class="text-muted"><i class="bi bi-info-circle" aria-hidden="true"></i> No media available for playback.</p>
            </div>
        </div>
    </div>
</section>
