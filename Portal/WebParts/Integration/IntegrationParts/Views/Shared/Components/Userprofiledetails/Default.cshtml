@model WCMS.WebSystem.WebParts.Integration.ViewComponents.UserprofiledetailsViewModel
@* Ported from UserProfileDetails.ascx (Apps/Integration/Profile). *@

<div class="component-userprofiledetails">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>User Profile Details</em> — ported from legacy WebForms.
