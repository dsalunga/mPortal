@model WCMS.WebSystem.WebParts.ViewComponents.MCAdminInterpreterScoreManagerModel

<section class="card" id="mc-admin-interpreter-score-manager-@Model.ObjectId" aria-labelledby="mc-admin-interpreter-score-heading-@Model.ObjectId">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="mc-admin-interpreter-score-heading-@Model.ObjectId" class="card-title mb-0"><i class="bi bi-mic-fill" aria-hidden="true"></i> Interpreter Score Manager</h5>
        <button type="button" class="btn btn-sm btn-primary" aria-label="Add interpreter score">
            <i class="bi bi-plus-lg" aria-hidden="true"></i> Add
        </button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0" aria-label="Interpreter scores">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Interpreter</th>
                        <th scope="col">Song</th>
                        <th scope="col">Score</th>
                        <th scope="col">Judge</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-inbox" aria-hidden="true"></i> No interpreter scores recorded.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
