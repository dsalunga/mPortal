@model WCMS.WebSystem.WebParts.Integration.ViewComponents.RegistrationMembervisitentryViewModel
@* Ported from MemberVisitEntry.ascx. *@

<div class="component-registration-membervisitentry">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Member" class="form-label">Member</label>
            <input type="text" class="form-control" id="field_Member" name="Member" value="@Model.Member" />
        </div>
        <div class="mb-3">
            <label for="field_Address" class="form-label">Address</label>
            <textarea class="form-control" id="field_Address" name="Address" rows="4">@Model.Address</textarea>
        </div>
        <div class="mb-3">
            <label for="field_ContactNo" class="form-label">Contact No</label>
            <input type="text" class="form-control" id="field_ContactNo" name="ContactNo" value="@Model.ContactNo" />
        </div>
        <div class="mb-3">
            <label for="field_MembershipDate" class="form-label">Membership Date</label>
            <input type="text" class="form-control" id="field_MembershipDate" name="MembershipDate" value="@Model.MembershipDate" />
        </div>
        <div class="mb-3">
            <label for="field_DateVisited" class="form-label">Date Visited</label>
            <input type="text" class="form-control" id="field_DateVisited" name="DateVisited" value="@Model.DateVisited" />
        </div>
        <div class="mb-3">
            <label for="field_Status" class="form-label">Status</label>
            <textarea class="form-control" id="field_Status" name="Status" rows="4">@Model.Status</textarea>
        </div>
        <div class="mb-3">
            <label for="field_ActualReport" class="form-label">Actual Report</label>
            <textarea class="form-control" id="field_ActualReport" name="ActualReport" rows="4">@Model.ActualReport</textarea>
        </div>
        <div class="mb-3">
            <label for="field_ActionTaken" class="form-label">Action Taken</label>
            <textarea class="form-control" id="field_ActionTaken" name="ActionTaken" rows="4">@Model.ActionTaken</textarea>
        </div>
        <div class="mb-3">
            <label for="field_CboGroup" class="form-label">Cbo Group</label>
            <select class="form-select" id="field_CboGroup" name="SelectedCboGroup">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboGroupOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboGroup ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboTimesVisited" class="form-label">Cbo Times Visited</label>
            <select class="form-select" id="field_CboTimesVisited" name="SelectedCboTimesVisited">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboTimesVisitedOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboTimesVisited ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboTag" class="form-label">Cbo Tag</label>
            <select class="form-select" id="field_CboTag" name="SelectedCboTag">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboTagOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboTag ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdVerify">Submit</button>
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>