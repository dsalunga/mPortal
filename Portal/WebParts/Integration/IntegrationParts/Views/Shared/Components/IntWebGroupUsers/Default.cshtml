@model dynamic

<section class="card" id="int-web-group-users-@Model.ObjectId" aria-labelledby="int-web-group-users-heading">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="int-web-group-users-heading" class="card-title mb-0"><i class="bi bi-people" aria-hidden="true"></i> Web Group Users</h5>
        <button type="button" id="cmdAddUserToGroup" class="btn btn-sm btn-primary" aria-label="Add user to group">
            <i class="bi bi-person-plus" aria-hidden="true"></i> Add User
        </button>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="mb-3">
            <label for="ddlWebGroup" class="form-label">Select Group</label>
            <select id="ddlWebGroup" name="GroupId" class="form-select" aria-label="Select a web group">
                <option value="">-- Select Group --</option>
            </select>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="tblWebGroupUsers" aria-label="Web group users list">
                <thead>
                    <tr>
                        <th scope="col">User</th>
                        <th scope="col">Email</th>
                        <th scope="col">Role</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody id="webGroupUserList">
                </tbody>
            </table>
        </div>
        <div id="webGroupUserListEmpty" class="text-center text-muted py-3 d-none" role="status">
            <i class="bi bi-person-x" aria-hidden="true"></i>
            <p class="mb-0">No users in this group.</p>
        </div>
    </div>
</section>
