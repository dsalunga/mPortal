@model WCMS.WebSystem.WebParts.Integration.ViewComponents.MusiccompetitionAdmincompetitionmanagerViewModel
@* Ported from AdminCompetitionManager.ascx. *@

<div class="component-musiccompetition-admincompetitionmanager">
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th scope="col" style="width:60px" class="text-center">Actions</th>
                    <th scope="col">Name</th>
                    <th scope="col">Judges</th>
                    <th scope="col">Event Date</th>
                    <th scope="col">Judging</th>
                    <th scope="col">Voting</th>
                    <th scope="col">ID</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="text-center">
                                <a href="?action=edit&id=@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                            <td>@item.Name</td>
                            <td>@item.Judges</td>
                            <td>@item.CompetitionDate</td>
                            <td>@item.ScoreLocked</td>
                            <td>@item.VotingLocked</td>
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-muted fst-italic">No records found.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalItems > Model.PageSize)
    {
        var pageCount = (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize);
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center mt-3">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage - 1)" aria-label="Previous">&laquo;</a>
                </li>
                @for (int i = 1; i <= pageCount; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= pageCount ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage + 1)" aria-label="Next">&raquo;</a>
                </li>
            </ul>
        </nav>
    }
</div>