@* Originally: area51/Parts/Profile/Profile/ProfileUpdate.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeArea51ProfileUpdateModel

<div id="theme-area51-profile-update-@Model.ObjectId">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Update Profile</h5>
                    </div>
                    <div class="card-body">
                        <!-- Avatar Area -->
                        <div class="text-center mb-4">
                            @await Component.InvokeAsync("WZone", new { zone = "ProfileAvatar" })
                        </div>

                        <!-- Form Fields -->
                        @await Component.InvokeAsync("WZone", new { zone = "ProfileForm" })
                    </div>
                    <div class="card-footer text-end">
                        @await Component.InvokeAsync("WZone", new { zone = "ProfileSubmit" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
