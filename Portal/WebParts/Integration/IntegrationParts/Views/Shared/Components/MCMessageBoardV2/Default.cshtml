@model dynamic

<section class="card" id="mc-message-board-v2-@Model.ObjectId" aria-labelledby="mc-message-board-v2-heading-@Model.ObjectId">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="mc-message-board-v2-heading-@Model.ObjectId" class="card-title mb-0"><i class="bi bi-chat-left-text-fill" aria-hidden="true"></i> Message Board</h5>
        <span class="badge bg-secondary" aria-label="Message count">0</span>
    </div>
    <div class="card-body">
        <form method="post" class="mb-3" aria-label="Post a new message">
            <div class="input-group">
                <label for="txtMessageV2-@Model.ObjectId" class="visually-hidden">New message</label>
                <textarea id="txtMessageV2-@Model.ObjectId" name="Message" class="form-control" rows="1" placeholder="Write a message…" aria-label="Message text"></textarea>
                <button type="submit" class="btn btn-primary" aria-label="Post message"><i class="bi bi-send" aria-hidden="true"></i></button>
            </div>
        </form>
        <div role="list" aria-label="Message thread">
            <div class="d-flex gap-2 mb-3" role="listitem">
                <img src="/images/placeholder-avatar.png" alt="" class="rounded-circle flex-shrink-0" width="40" height="40" aria-hidden="true" />
                <div class="flex-grow-1">
                    <div class="bg-light rounded p-2">
                        <div class="d-flex justify-content-between">
                            <strong class="small">Author Name</strong>
                            <small class="text-muted"><time datetime="">Jan 1, 2025</time></small>
                        </div>
                        <p class="mb-0 small">Message content goes here.</p>
                    </div>
                    <div class="mt-1">
                        <button type="button" class="btn btn-sm btn-link p-0 text-muted small" aria-label="Reply to message">
                            <i class="bi bi-reply" aria-hidden="true"></i> Reply
                        </button>
                    </div>
                </div>
            </div>
            <p class="text-center text-muted mb-0 empty-state">
                <i class="bi bi-chat" aria-hidden="true"></i> No messages yet.
            </p>
        </div>
    </div>
</section>
