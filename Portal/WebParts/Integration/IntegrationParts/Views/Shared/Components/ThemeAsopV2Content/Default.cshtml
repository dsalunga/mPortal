@* Originally: ASOP/v2/old/asopv2-content.ascx *@
@model WCMS.WebSystem.WebParts.ViewComponents.ThemeAsopV2ContentModel

<div id="theme-asopv2-content-@Model.ObjectId">
    <a href="#asopv2-content-main-@Model.ObjectId" class="visually-hidden-focusable skip-link">Skip to main content</a>

    <header class="bg-light border-bottom py-3" role="banner" aria-label="ASOP site header">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Header" })
        </div>
    </header>

    <main id="asopv2-content-main-@Model.ObjectId" class="container py-4">
        <div class="row">
            <div class="col-12">
                @await Component.InvokeAsync("WZone", new { zone = "Content" })
            </div>
        </div>
    </main>

    <footer class="bg-light border-top py-3 mt-4" role="contentinfo" aria-label="ASOP site footer">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year ASOP. All rights reserved.</small></p>
        </div>
    </footer>
</div>
