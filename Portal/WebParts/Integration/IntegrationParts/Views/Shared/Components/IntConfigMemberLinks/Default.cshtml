@model WCMS.WebSystem.WebParts.ViewComponents.IntConfigMemberLinksModel

<section class="card" id="int-config-member-links-@Model.ObjectId" aria-labelledby="int-config-member-links-heading">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="int-config-member-links-heading" class="card-title mb-0"><i class="bi bi-link-45deg" aria-hidden="true"></i> Member Links</h5>
        <a href="#" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg" aria-hidden="true"></i> Add Link</a>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3" aria-label="Search member links">
            <div class="col-auto">
                <input type="text" class="form-control" name="search" placeholder="Search links..." value="@Model.SearchTerm" aria-label="Search links" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-secondary"><i class="bi bi-search" aria-hidden="true"></i> Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-striped table-hover" aria-label="Member links list">
                <thead>
                    <tr>
                        <th scope="col">Link ID</th>
                        <th scope="col">Member ID</th>
                        <th scope="col">Link Type</th>
                        <th scope="col">Linked Member</th>
                        <th scope="col">Status</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Links != null && Model.Links.Any())
                    {
                        @foreach (var link in Model.Links)
                        {
                            <tr>
                                <td>@link.LinkId</td>
                                <td>@link.MemberId</td>
                                <td>@link.LinkType</td>
                                <td>@link.LinkedMemberId</td>
                                <td>@link.Status</td>
                                <td>
                                    <a href="#" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil" aria-hidden="true"></i> Edit</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-3">
                                <i class="bi bi-inbox" aria-hidden="true"></i> No member links found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
