@model WCMS.WebSystem.WebParts.Integration.ViewComponents.MembermanagerViewModel
@* Ported from MemberManager.ascx (Apps/Integration/MasterList). *@

<div class="component-membermanager">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Member Manager</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Member Manager component requires configuration.
        </div>
    }
</div>
