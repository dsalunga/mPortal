@model WCMS.WebSystem.WebParts.Integration.ViewComponents.WebgrouplistViewModel
@* Ported from WebGroupList.ascx. *@

<div class="component-webgrouplist">
    @if (Model.Items.Any())
    {
        <div class="list-group">
            @foreach (var item in Model.Items)
            {
                <div class="list-group-item">
                    <span class="me-3">@item.AccessDeniedContent</span>
                    <span class="me-3">@item.DisplayHTML</span>
                    <span class="me-3">@item.IsPermitted</span>
                    <span class="me-3">@item.PageId</span>
                    <span class="me-3">@item.PageUrl</span>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted fst-italic">No items available.</p>
    }
</div>