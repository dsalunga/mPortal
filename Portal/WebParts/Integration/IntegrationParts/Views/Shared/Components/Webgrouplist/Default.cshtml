@model WCMS.WebSystem.WebParts.Integration.ViewComponents.WebgrouplistViewModel
@* Ported from WebGroupList.ascx (Apps/Integration/Registration). *@

<div class="component-webgrouplist">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Web Group List</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Web Group List component requires configuration.
        </div>
    }
</div>
