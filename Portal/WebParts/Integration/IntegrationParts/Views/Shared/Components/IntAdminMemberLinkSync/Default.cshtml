@model WCMS.WebSystem.WebParts.ViewComponents.IntAdminMemberLinkSyncModel

<section aria-labelledby="int-admin-member-link-sync-heading-@Model.ObjectId">
<div class="card" id="int-admin-member-link-sync-@Model.ObjectId">
    <div class="card-header">
        <h5 id="int-admin-member-link-sync-heading-@Model.ObjectId" class="card-title mb-0">
            <i class="bi bi-arrow-repeat" aria-hidden="true"></i> Member Link Sync
        </h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="status" aria-live="polite">
                @Model.Message
            </div>
        }
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h6 class="card-subtitle mb-1 text-muted">Total Links</h6>
                        <p class="card-text fs-4 mb-0">@Model.TotalLinks</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h6 class="card-subtitle mb-1 text-muted">Synced Links</h6>
                        <p class="card-text fs-4 mb-0">@Model.SyncedLinks</p>
                    </div>
                </div>
            </div>
        </div>
        <form method="post" novalidate aria-label="Run member link sync">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-arrow-repeat" aria-hidden="true"></i> Run Sync
            </button>
        </form>
    </div>
</div>
</section>
