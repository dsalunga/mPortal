@model WCMS.WebSystem.WebParts.ViewComponents.IntAdminMemberLinkSyncModel

<div class="card" id="int-admin-member-link-sync-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Member Link Sync</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h6 class="card-subtitle mb-1 text-muted">Total Links</h6>
                        <p class="card-text fs-4 mb-0">@Model.TotalLinks</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h6 class="card-subtitle mb-1 text-muted">Synced Links</h6>
                        <p class="card-text fs-4 mb-0">@Model.SyncedLinks</p>
                    </div>
                </div>
            </div>
        </div>
        <form method="post" novalidate>
            <button type="submit" class="btn btn-primary">Run Sync</button>
        </form>
    </div>
</div>
