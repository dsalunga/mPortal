@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AsopInsideViewModel
@* Ported from Inside.ascx (Themes/ASOP). *@

<div class="component-asopinside">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Inside</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Inside component requires configuration.
        </div>
    }
</div>
