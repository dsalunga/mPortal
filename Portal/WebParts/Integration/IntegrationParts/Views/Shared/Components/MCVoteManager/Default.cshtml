@model dynamic

<section class="card" id="mc-vote-manager-@Model.ObjectId" aria-labelledby="mc-vote-manager-heading-@Model.ObjectId">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 id="mc-vote-manager-heading-@Model.ObjectId" class="card-title mb-0"><i class="bi bi-clipboard-data-fill" aria-hidden="true"></i> Vote Manager</h5>
        <div class="btn-group btn-group-sm" role="group" aria-label="Vote filter">
            <button type="button" class="btn btn-outline-secondary active">All</button>
            <button type="button" class="btn btn-outline-success">Approved</button>
            <button type="button" class="btn btn-outline-warning">Pending</button>
            <button type="button" class="btn btn-outline-danger">Rejected</button>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0" aria-label="Votes list">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Voter</th>
                        <th scope="col">Candidate</th>
                        <th scope="col">Score</th>
                        <th scope="col">Status</th>
                        <th scope="col">Date</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-inbox" aria-hidden="true"></i> No votes recorded.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
