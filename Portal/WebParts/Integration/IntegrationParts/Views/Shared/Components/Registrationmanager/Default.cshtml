@model WCMS.WebSystem.WebParts.Integration.ViewComponents.RegistrationmanagerViewModel
@* Ported from RegistrationManager.ascx. *@

<div class="component-registrationmanager">
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th scope="col" style="width:60px" class="text-center">Actions</th>
                    <th scope="col">COUNTRY</th>
                    <th scope="col">LOCAL</th>
                    <th scope="col">CHURCH ID</th>
                    <th scope="col">NAME</th>
                    <th scope="col">AGE</th>
                    <th scope="col">GENDER</th>
                    <th scope="col">DESIGNATION</th>
                    <th scope="col">ARRIVAL</th>
                    <th scope="col">AIRLINE</th>
                    <th scope="col">FLIGHT NO</th>
                    <th scope="col">DEPARTURE</th>
                    <th scope="col">ADDRESS</th>
                    <th scope="col">PLACE TYPE</th>
                    <th scope="col">REG. DATE</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="text-center">
                                <a href="?action=edit&id=@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                            <td>@item.Country</td>
                            <td>@item.Locale</td>
                            <td>@item.ExternalId</td>
                            <td>@item.Name</td>
                            <td>@item.Age</td>
                            <td>@item.Gender</td>
                            <td>@item.Designation</td>
                            <td>@item.ArrivalDate</td>
                            <td>@item.Airline</td>
                            <td>@item.FlightNo</td>
                            <td>@item.DepartureDate</td>
                            <td>@item.Address</td>
                            <td>@item.PlaceType</td>
                            <td>@item.EntryDate</td>
                            <td>@item.Name</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="16" class="text-center text-muted fst-italic">No records found.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalItems > Model.PageSize)
    {
        var pageCount = (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize);
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center mt-3">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage - 1)" aria-label="Previous">&laquo;</a>
                </li>
                @for (int i = 1; i <= pageCount; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= pageCount ? "disabled" : "")">
                    <a class="page-link" href="?page=@(Model.CurrentPage + 1)" aria-label="Next">&raquo;</a>
                </li>
            </ul>
        </nav>
    }
</div>