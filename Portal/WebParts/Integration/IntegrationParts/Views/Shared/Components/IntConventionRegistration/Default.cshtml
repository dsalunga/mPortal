@model WCMS.WebSystem.WebParts.ViewComponents.IntConventionRegistrationModel

<div class="card" id="int-convention-registration-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Convention Registration</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.EventName))
        {
            <div class="mb-3">
                <h6>@Model.EventName</h6>
                <p class="text-muted mb-1">@Model.EventDate</p>
                <p class="text-muted">@Model.Location</p>
            </div>
        }
        <form method="post" novalidate>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="convFirstName" class="form-label">First Name</label>
                    <input type="text" class="form-control" id="convFirstName" name="FirstName" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label for="convLastName" class="form-label">Last Name</label>
                    <input type="text" class="form-control" id="convLastName" name="LastName" required />
                </div>
            </div>
            <div class="mb-3">
                <label for="convEmail" class="form-label">Email</label>
                <input type="email" class="form-control" id="convEmail" name="Email" required />
            </div>
            <div class="mb-3">
                <label for="convPhone" class="form-label">Phone</label>
                <input type="text" class="form-control" id="convPhone" name="Phone" />
            </div>
            @if (Model.SessionOptions != null && Model.SessionOptions.Count > 0)
            {
                <div class="mb-3">
                    <label class="form-label">Sessions</label>
                    @foreach (var session in Model.SessionOptions)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="Sessions" value="@session" id="session-@session.GetHashCode()">
                            <label class="form-check-label" for="session-@session.GetHashCode()">@session</label>
                        </div>
                    }
                </div>
            }
            <button type="submit" class="btn btn-primary">Register</button>
        </form>
    </div>
</div>
