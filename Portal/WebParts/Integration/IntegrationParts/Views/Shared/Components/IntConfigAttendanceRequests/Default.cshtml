@model dynamic

<section class="card" id="int-config-attendance-requests-@Model.ObjectId" aria-labelledby="int-config-attendance-requests-heading">
    <div class="card-header">
        <h5 id="int-config-attendance-requests-heading" class="card-title mb-0"><i class="bi bi-card-checklist" aria-hidden="true"></i> Attendance Requests Configuration</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty((string)Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="status" aria-live="polite">
                @Model.Message
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <form method="post" novalidate aria-label="Attendance requests configuration form">
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="chkShowHistory" name="ShowHistory" value="true" role="switch" />
                <label class="form-check-label" for="chkShowHistory">Show Request History</label>
            </div>
            <div class="mb-3">
                <label for="txtRetentionDays" class="form-label">Request Retention (days)</label>
                <input type="number" id="txtRetentionDays" name="RetentionDays" class="form-control" min="1" value="90" />
            </div>
            <div class="mb-3">
                <label for="ddlDefaultStatus" class="form-label">Default Status</label>
                <select id="ddlDefaultStatus" name="DefaultStatus" class="form-select" aria-label="Select default request status">
                    <option value="pending">Pending</option>
                    <option value="approved">Approved</option>
                </select>
            </div>
            <button type="submit" id="cmdSaveConfig" class="btn btn-primary"><i class="bi bi-check-lg" aria-hidden="true"></i> Save Settings</button>
        </form>
    </div>
</section>
