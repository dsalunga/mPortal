@model WCMS.WebSystem.WebParts.ViewComponents.IntStreamingConsoleModel

<div class="card" id="int-streaming-console-@Model.ObjectId">
    <div class="card-header">
        <h5 class="card-title mb-0">Streaming Console</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
                @Model.Message
            </div>
        }
        <p>Streaming console placeholder content.</p>
    </div>
</div>
