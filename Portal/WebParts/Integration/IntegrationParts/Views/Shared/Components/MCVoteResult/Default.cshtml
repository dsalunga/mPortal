@model dynamic

<section class="card" id="mc-vote-result-@Model.ObjectId" aria-labelledby="mc-vote-result-heading-@Model.ObjectId">
    <div class="card-header">
        <h5 id="mc-vote-result-heading-@Model.ObjectId" class="card-title mb-0"><i class="bi bi-bar-chart-fill" aria-hidden="true"></i> Vote Results</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover mb-0" aria-label="Vote results ranking">
                <thead class="table-light">
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Candidate</th>
                        <th scope="col">Votes</th>
                        <th scope="col">Score</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            <i class="bi bi-inbox" aria-hidden="true"></i> No results available.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
