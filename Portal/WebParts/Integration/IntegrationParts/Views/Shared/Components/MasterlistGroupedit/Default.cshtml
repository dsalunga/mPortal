@model WCMS.WebSystem.WebParts.Integration.ViewComponents.MasterlistGroupeditViewModel
@* Ported from GroupEdit.ascx (Apps/Integration/MasterList). *@

<div class="component-masterlistgroupedit">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Group Edit</em> — ported from legacy WebForms.
