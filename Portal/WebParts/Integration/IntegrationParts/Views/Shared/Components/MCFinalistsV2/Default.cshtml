@model dynamic

<section class="card" id="mc-finalists-v2-@Model.ObjectId" role="region" aria-label="Finalists">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0"><i class="bi bi-star-fill text-warning" aria-hidden="true"></i> Finalists</h5>
        <span class="badge bg-secondary" aria-label="Total finalists">0</span>
    </div>
    <div class="card-body">
        <div class="row g-3" role="list" aria-label="Finalist cards">
            <div class="col-lg-3 col-md-4 col-sm-6" role="listitem">
                <div class="card h-100 shadow-sm border-0">
                    <img src="/images/placeholder-finalist.png" class="card-img-top" alt="Finalist photo" />
                    <div class="card-body text-center p-2">
                        <h6 class="card-title mb-1">Finalist Name</h6>
                        <p class="text-muted small mb-1">Song Title</p>
                        <span class="badge bg-primary">Category</span>
                    </div>
                    <div class="card-footer bg-transparent text-center border-0 pb-3">
                        <button type="button" class="btn btn-sm btn-outline-primary" aria-label="Vote for finalist">
                            <i class="bi bi-hand-thumbs-up" aria-hidden="true"></i> Vote
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
