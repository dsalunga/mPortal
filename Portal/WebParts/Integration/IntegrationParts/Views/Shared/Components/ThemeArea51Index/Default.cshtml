@* Originally: area51/index.ascx *@
@model dynamic

<div id="theme-area51-index-@Model.ObjectId">
    <a href="#area51-index-main-@Model.ObjectId" class="visually-hidden-focusable skip-link">Skip to main content</a>

    <section class="bg-primary text-white py-5" aria-label="Hero">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Hero" })
        </div>
    </section>

    <main id="area51-index-main-@Model.ObjectId" class="container py-4">
        <div class="row">
            <div class="col-md-4">
                @await Component.InvokeAsync("WZone", new { zone = "Column1" })
            </div>
            <div class="col-md-4">
                @await Component.InvokeAsync("WZone", new { zone = "Column2" })
            </div>
            <div class="col-md-4">
                @await Component.InvokeAsync("WZone", new { zone = "Column3" })
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12 text-center">
                @await Component.InvokeAsync("WZone", new { zone = "CallToAction" })
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-3 mt-4" role="contentinfo" aria-label="Site footer">
        <div class="container">
            @await Component.InvokeAsync("WZone", new { zone = "Footer" })
            <p class="text-center text-muted mb-0 mt-2"><small>&copy; @DateTime.Now.Year All rights reserved.</small></p>
        </div>
    </footer>
</div>
