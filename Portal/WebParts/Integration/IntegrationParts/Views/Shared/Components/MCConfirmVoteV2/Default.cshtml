@model WCMS.WebSystem.WebParts.ViewComponents.MCConfirmVoteV2Model

<section class="card" id="mc-confirm-vote-v2-@Model.ObjectId" aria-labelledby="mc-confirm-vote-v2-heading-@Model.ObjectId">
    <div class="card-header bg-success text-white">
        <h5 id="mc-confirm-vote-v2-heading-@Model.ObjectId" class="card-title mb-0"><i class="bi bi-check-circle-fill" aria-hidden="true"></i> Vote Confirmation</h5>
    </div>
    <div class="card-body text-center py-4">
        <div class="mb-3">
            <i class="bi bi-patch-check-fill text-success" style="font-size:3rem;" aria-hidden="true"></i>
        </div>
        <div role="status" aria-live="polite">
            <h6>Thank you for voting!</h6>
            <div class="card mx-auto border-light shadow-sm" style="max-width:320px;">
                <div class="card-body p-3">
                    <p class="mb-1"><strong>Candidate:</strong> Candidate Name</p>
                    <p class="mb-1"><strong>Category:</strong> Category Name</p>
                    <p class="mb-0"><strong>Confirmation:</strong> <code>VOTE-00000</code></p>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-center gap-2 mt-3">
            <button type="button" class="btn btn-primary"><i class="bi bi-arrow-left" aria-hidden="true"></i> Return to Voting</button>
            <button type="button" class="btn btn-outline-secondary"><i class="bi bi-bar-chart" aria-hidden="true"></i> View Results</button>
        </div>
    </div>
</section>
