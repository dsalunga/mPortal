@model WCMS.WebSystem.WebParts.Integration.ViewComponents.AdmincompetitioneditViewModel
@* Ported from AdminCompetitionEdit.ascx. *@

<div class="component-admincompetitionedit">
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="field_Name" class="form-label">Name</label>
            <input type="text" class="form-control" id="field_Name" name="Name" value="@Model.Name" />
        </div>
        <div class="mb-3">
            <label for="field_Judges" class="form-label">Judges</label>
            <input type="text" class="form-control" id="field_Judges" name="Judges" value="@Model.Judges" />
        </div>
        <div class="mb-3">
            <label for="field_Date" class="form-label">Date</label>
            <input type="text" class="form-control" id="field_Date" name="Date" value="@Model.Date" />
        </div>
        <div class="mb-3">
            <label for="field_CboInterpreters" class="form-label">Cbo Interpreters</label>
            <select class="form-select" id="field_CboInterpreters" name="SelectedCboInterpreters">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboInterpretersOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboInterpreters ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label for="field_CboPeoplesChoice" class="form-label">Cbo Peoples Choice</label>
            <select class="form-select" id="field_CboPeoplesChoice" name="SelectedCboPeoplesChoice">
                <option value="">-- Select --</option>
                @foreach (var opt in Model.CboPeoplesChoiceOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.SelectedCboPeoplesChoice ? "selected" : null)">@opt.Text</option>
                }
            </select>
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_Locked" name="Locked" @(Model.Locked ? "checked" : "") />
            <label class="form-check-label" for="field_Locked">Judging Locked</label>
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="field_VotingLocked" name="VotingLocked" @(Model.VotingLocked ? "checked" : "") />
            <label class="form-check-label" for="field_VotingLocked">Voting Locked</label>
        </div>
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary" name="action" value="cmdUpdate">Update</button>
            <button type="submit" class="btn btn-outline-secondary" name="action" value="cmdCancel">Cancel</button>
        </div>
    </form>
</div>