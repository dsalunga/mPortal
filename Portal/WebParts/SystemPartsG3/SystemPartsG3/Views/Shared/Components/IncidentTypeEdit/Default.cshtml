@model WCMS.WebSystem.WebParts.ViewComponents.IncidentTypeEditViewModel

<div class="incident-type-edit">
    <h4 class="mb-3">@(Model.TypeId > 0 ? "Edit" : "Add") Incident Type</h4>

    <form method="post" class="needs-validation" novalidate>
        <input type="hidden" name="TypeId" value="@Model.TypeId" />
        <input type="hidden" name="ObjectId" value="@Model.ObjectId" />

        <div class="mb-3">
            <label for="typeName" class="form-label">Name</label>
            <input type="text" class="form-control" id="typeName" name="Name"
                   value="@Model.Name" required maxlength="255" />
            <div class="invalid-feedback">Please enter a type name.</div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="typeRank" class="form-label">Rank</label>
                <input type="number" class="form-control" id="typeRank" name="Rank"
                       value="@Model.Rank" min="0" />
            </div>

            <div class="col-md-6 mb-3">
                <label for="typeInstanceId" class="form-label">Instance</label>
                <select class="form-select" id="typeInstanceId" name="InstanceId">
                    <option value="0">-- Select Instance --</option>
                </select>
            </div>
        </div>

        <div class="mb-3">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="typeUseSLA" name="UseSLA"
                       value="true" @(Model.UseSLA ? "checked" : "") />
                <label class="form-check-label" for="typeUseSLA">
                    Follow Standard SLA
                </label>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="#" class="btn btn-secondary" data-action="cancel">Cancel</a>
        </div>
    </form>
</div>
