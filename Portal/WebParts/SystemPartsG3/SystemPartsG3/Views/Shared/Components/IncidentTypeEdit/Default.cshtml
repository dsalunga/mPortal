@model dynamic

<div class="incident-type-edit" role="region" aria-label="Incident Type Form">
    <h4 class="mb-3" id="typeEditHeading">@(Model.TypeId != null && (int)Model.TypeId > 0 ? "Edit" : "Add") Incident Type</h4>

    <form method="post" class="needs-validation" novalidate aria-labelledby="typeEditHeading">
        <input type="hidden" name="TypeId" value="@Model.TypeId" />
        <input type="hidden" name="ObjectId" value="@Model.ObjectId" />

        <div class="mb-3">
            <label for="typeName" class="form-label">Name <span class="text-danger" aria-hidden="true">*</span></label>
            <input type="text" class="form-control" id="typeName" name="Name"
                   value="@Model.Name" required maxlength="255" aria-required="true" />
            <div class="invalid-feedback">Please enter a type name.</div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="typeCategory" class="form-label">Category <span class="text-danger" aria-hidden="true">*</span></label>
                <select class="form-select" id="typeCategory" name="CategoryId" required aria-required="true">
                    <option value="">-- Select Category --</option>
                    @if (Model.Categories != null)
                    {
                        foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id" selected="@(Model.CategoryId != null && (int)Model.CategoryId == (int)cat.Id)">@cat.Name</option>
                        }
                    }
                </select>
                <div class="invalid-feedback">Please select a category.</div>
            </div>

            <div class="col-md-6 mb-3">
                <label for="typeSeverity" class="form-label">Severity <span class="text-danger" aria-hidden="true">*</span></label>
                <select class="form-select" id="typeSeverity" name="Severity" required aria-required="true">
                    <option value="">-- Select Severity --</option>
                    <option value="Low" selected="@(Model.Severity == "Low")">Low</option>
                    <option value="Medium" selected="@(Model.Severity == "Medium")">Medium</option>
                    <option value="High" selected="@(Model.Severity == "High")">High</option>
                    <option value="Critical" selected="@(Model.Severity == "Critical")">Critical</option>
                </select>
                <div class="invalid-feedback">Please select a severity level.</div>
            </div>
        </div>

        <div class="mb-3">
            <label for="typeDescription" class="form-label">Description</label>
            <textarea class="form-control" id="typeDescription" name="Description"
                      rows="3">@Model.Description</textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg" aria-hidden="true"></i> Save
            </button>
            <button type="button" class="btn btn-secondary" data-action="cancel">
                <i class="bi bi-x-lg" aria-hidden="true"></i> Cancel
            </button>
        </div>
    </form>
</div>
