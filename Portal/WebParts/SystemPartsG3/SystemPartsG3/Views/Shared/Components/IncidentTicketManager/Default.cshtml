@model dynamic

<div class="incident-ticket-manager" role="region" aria-label="Incident Ticket Management">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 id="ticketManagerHeading">Incident Tickets</h4>
        <button type="button" class="btn btn-primary btn-sm" data-action="add-ticket" aria-label="Add new ticket">
            <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Ticket
        </button>
    </div>

    <div class="mb-3">
        <label for="statusFilter" class="form-label">Filter by Status</label>
        <select class="form-select" id="statusFilter" style="max-width: 250px;" data-action="filter-status" aria-label="Filter tickets by status">
            <option value="-1" selected="@(Model.StatusFilter == -1)">All Statuses</option>
            <option value="0" selected="@(Model.StatusFilter == 0)">Open</option>
            <option value="1" selected="@(Model.StatusFilter == 1)">In Progress</option>
            <option value="2" selected="@(Model.StatusFilter == 2)">Resolved</option>
            <option value="3" selected="@(Model.StatusFilter == 3)">Closed</option>
        </select>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover" aria-labelledby="ticketManagerHeading">
            <thead class="table-light">
                <tr>
                    <th scope="col">Ticket No</th>
                    <th scope="col">Subject</th>
                    <th scope="col">Status</th>
                    <th scope="col">Priority</th>
                    <th scope="col">Assigned To</th>
                    <th scope="col">Created Date</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Tickets == null || Model.Tickets.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No tickets found.</td>
                    </tr>
                }
                else
                {
                    foreach (var ticket in Model.Tickets)
                    {
                        string statusBadge = ticket.Status == 0 ? "bg-primary"
                            : ticket.Status == 1 ? "bg-warning text-dark"
                            : ticket.Status == 2 ? "bg-success"
                            : "bg-secondary";
                        string priorityBadge = ticket.Priority == "Critical" ? "bg-danger"
                            : ticket.Priority == "High" ? "bg-warning text-dark"
                            : ticket.Priority == "Medium" ? "bg-info text-dark"
                            : "bg-secondary";
                        <tr>
                            <td><code>@ticket.TicketNo</code></td>
                            <td>@ticket.Subject</td>
                            <td><span class="badge @statusBadge">@ticket.StatusText</span></td>
                            <td><span class="badge @priorityBadge">@ticket.Priority</span></td>
                            <td>@ticket.AssignedUserName</td>
                            <td>@ticket.DateCreated.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <button type="button" class="btn btn-outline-primary btn-sm" data-action="view-ticket" data-id="@ticket.Id" aria-label="View ticket @ticket.TicketNo">
                                    <i class="bi bi-eye" aria-hidden="true"></i> View
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
