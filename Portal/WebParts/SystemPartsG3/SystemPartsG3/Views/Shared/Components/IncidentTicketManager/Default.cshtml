@model WCMS.WebSystem.WebParts.ViewComponents.IncidentTicketManagerViewModel

<section class="incident-ticket-manager" aria-labelledby="ticketManagerHeading-@Model.ObjectId">
    <header class="d-flex justify-content-between align-items-center mb-3">
        <h4 id="ticketManagerHeading-@Model.ObjectId" class="mb-0">Incident Tickets</h4>
        @if (Model.CanEdit)
        {
            <button type="button" class="btn btn-primary btn-sm" data-action="add-ticket" aria-label="Add new ticket">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Ticket
            </button>
        }
    </header>

    <div class="mb-3">
        <label for="statusFilter-@Model.ObjectId" class="form-label">Filter by Status</label>
        <select class="form-select" id="statusFilter-@Model.ObjectId" style="max-width: 250px;" data-action="filter-status" aria-label="Filter tickets by status">
            <option value="-1" selected="@(Model.StatusFilter == -1)">All Statuses</option>
            <option value="0" selected="@(Model.StatusFilter == 0)">Open</option>
            <option value="1" selected="@(Model.StatusFilter == 1)">In Progress</option>
            <option value="2" selected="@(Model.StatusFilter == 2)">Resolved</option>
            <option value="3" selected="@(Model.StatusFilter == 3)">Closed</option>
        </select>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0" aria-labelledby="ticketManagerHeading-@Model.ObjectId">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">Description</th>
                            <th scope="col">Category</th>
                            <th scope="col">Type</th>
                            <th scope="col">Status</th>
                            <th scope="col">Urgency</th>
                            <th scope="col">Assigned To</th>
                            <th scope="col">Created</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody aria-live="polite">
                        @if (Model.Tickets == null || Model.Tickets.Count == 0)
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4" role="status">No tickets found.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var ticket in Model.Tickets)
                            {
                                string statusBadge = ticket.Status == 0 ? "bg-primary"
                                    : ticket.Status == 1 ? "bg-warning text-dark"
                                    : ticket.Status == 2 ? "bg-success"
                                    : "bg-secondary";
                                string urgencyBadge = ticket.Urgency >= 3 ? "bg-danger"
                                    : ticket.Urgency == 2 ? "bg-warning text-dark"
                                    : ticket.Urgency == 1 ? "bg-info text-dark"
                                    : "bg-secondary";
                                <tr>
                                    <td><code>@ticket.Id</code></td>
                                    <td>@ticket.Description</td>
                                    <td>@ticket.CategoryName</td>
                                    <td>@ticket.TypeName</td>
                                    <td><span class="badge @statusBadge">@ticket.StatusText</span></td>
                                    <td><span class="badge @urgencyBadge">@ticket.UrgencyText</span></td>
                                    <td>@ticket.AssignedUserName</td>
                                    <td><time datetime="@ticket.DateCreated.ToString("yyyy-MM-ddTHH:mm")">@ticket.DateCreated.ToString("yyyy-MM-dd")</time></td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-outline-primary btn-sm" data-action="view-ticket" data-id="@ticket.Id" aria-label="View ticket @ticket.Id">
                                            <i class="bi bi-eye" aria-hidden="true"></i> View
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
