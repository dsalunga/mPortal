@model WCMS.WebSystem.WebParts.ViewComponents.IncidentTicketManagerViewModel

<div class="incident-ticket-manager">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Incident Tickets</h4>
    </div>

    <div class="mb-3">
        <label for="statusFilter" class="form-label">Filter by Status</label>
        <select class="form-select" id="statusFilter" style="max-width: 250px;" data-action="filter-status">
            <option value="-1" selected="@(Model.StatusFilter == -1)">All Statuses</option>
            <option value="0" selected="@(Model.StatusFilter == 0)">Open</option>
            <option value="1" selected="@(Model.StatusFilter == 1)">In Progress</option>
            <option value="2" selected="@(Model.StatusFilter == 2)">Resolved</option>
            <option value="3" selected="@(Model.StatusFilter == 3)">Closed</option>
        </select>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Description</th>
                    <th>Category</th>
                    <th>Type</th>
                    <th>Urgency</th>
                    <th>Status</th>
                    <th>Assigned To</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Tickets.Count == 0)
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            No tickets found.
                        </td>
                    </tr>
                }
                @foreach (var ticket in Model.Tickets)
                {
                    <tr>
                        <td>@ticket.Id</td>
                        <td>@ticket.Description</td>
                        <td>@ticket.CategoryName</td>
                        <td>@ticket.TypeName</td>
                        <td>
                            <span class="badge @(ticket.Urgency >= 3 ? "bg-danger" : ticket.Urgency == 2 ? "bg-warning text-dark" : "bg-info")">
                                @ticket.UrgencyText
                            </span>
                        </td>
                        <td>
                            <span class="badge @(ticket.Status == 0 ? "bg-primary" : ticket.Status == 1 ? "bg-warning text-dark" : ticket.Status == 2 ? "bg-success" : "bg-secondary")">
                                @ticket.StatusText
                            </span>
                        </td>
                        <td>@ticket.AssignedUserName</td>
                        <td>@ticket.DateCreated.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <a href="#" class="btn btn-outline-primary btn-sm" data-action="view-ticket" data-id="@ticket.Id">
                                <i class="bi bi-eye"></i> View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
