@model WCMS.WebSystem.WebParts.ViewComponents.IncidentTicketManagerViewModel

<section class="incident-ticket-manager" aria-labelledby="ticketManagerHeading-@Model.ObjectId">
    <header class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <h4 id="ticketManagerHeading-@Model.ObjectId" class="mb-0">Incident Tickets</h4>
        @if (Model.CanEdit)
        {
            <button type="button" class="btn btn-primary btn-sm" data-action="add-ticket" aria-label="Add new ticket">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Ticket
            </button>
        }
    </header>

    <div class="mb-3">
        <label for="statusFilter-@Model.ObjectId" class="form-label">Filter by Status</label>
        <select class="form-select w-auto" id="statusFilter-@Model.ObjectId" data-action="filter-status" aria-label="Filter tickets by status"
                aria-controls="ticketTable-@Model.ObjectId">
            <option value="-1" @(Model.StatusFilter == -1 ? "selected" : "")>All Statuses</option>
            <option value="0" @(Model.StatusFilter == 0 ? "selected" : "")>Open</option>
            <option value="1" @(Model.StatusFilter == 1 ? "selected" : "")>In Progress</option>
            <option value="2" @(Model.StatusFilter == 2 ? "selected" : "")>Resolved</option>
            <option value="3" @(Model.StatusFilter == 3 ? "selected" : "")>Closed</option>
        </select>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model.Tickets == null || Model.Tickets.Count == 0)
            {
                <div class="text-center py-5" role="status" aria-live="polite">
                    <i class="bi bi-ticket-perforated fs-1 text-muted d-block mb-2" aria-hidden="true"></i>
                    <p class="text-muted mb-0">No tickets found.</p>
                    @if (Model.CanEdit)
                    {
                        <button type="button" class="btn btn-outline-primary btn-sm mt-3" data-action="add-ticket">
                            <i class="bi bi-plus-lg" aria-hidden="true"></i> Create a new ticket
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0" id="ticketTable-@Model.ObjectId"
                           aria-labelledby="ticketManagerHeading-@Model.ObjectId">
                        <caption class="visually-hidden">List of incident tickets</caption>
                        <thead class="table-light">
                            <tr>
                                <th scope="col">ID</th>
                                <th scope="col">Description</th>
                                <th scope="col" class="d-none d-lg-table-cell">Category</th>
                                <th scope="col" class="d-none d-lg-table-cell">Type</th>
                                <th scope="col">Status</th>
                                <th scope="col" class="d-none d-md-table-cell">Urgency</th>
                                <th scope="col" class="d-none d-md-table-cell">Assigned To</th>
                                <th scope="col" class="d-none d-sm-table-cell">Created</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody aria-live="polite">
                            @foreach (var ticket in Model.Tickets)
                            {
                                string statusBadge = ticket.Status switch
                                {
                                    0 => "bg-primary",
                                    1 => "bg-warning text-dark",
                                    2 => "bg-success",
                                    _ => "bg-secondary"
                                };
                                string urgencyBadge = ticket.Urgency switch
                                {
                                    >= 3 => "bg-danger",
                                    2 => "bg-warning text-dark",
                                    1 => "bg-info text-dark",
                                    _ => "bg-secondary"
                                };
                                <tr>
                                    <td><code>@ticket.Id</code></td>
                                    <td class="text-truncate" style="max-width: 200px;">@ticket.Description</td>
                                    <td class="d-none d-lg-table-cell">@ticket.CategoryName</td>
                                    <td class="d-none d-lg-table-cell">@ticket.TypeName</td>
                                    <td><span class="badge @statusBadge">@ticket.StatusText</span></td>
                                    <td class="d-none d-md-table-cell"><span class="badge @urgencyBadge">@ticket.UrgencyText</span></td>
                                    <td class="d-none d-md-table-cell">@ticket.AssignedUserName</td>
                                    <td class="d-none d-sm-table-cell text-nowrap">
                                        <time datetime="@ticket.DateCreated.ToString("yyyy-MM-ddTHH:mm:ss")">@ticket.DateCreated.ToString("yyyy-MM-dd")</time>
                                    </td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-outline-primary btn-sm" data-action="view-ticket" data-id="@ticket.Id" aria-label="View ticket @ticket.Id">
                                            <i class="bi bi-eye" aria-hidden="true"></i><span class="d-none d-lg-inline ms-1">View</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>
