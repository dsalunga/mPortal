@model WCMS.WebSystem.WebParts.ViewComponents.IncidentInstanceManagerViewModel

<section class="incident-instance-manager" aria-labelledby="instanceManagerHeading-@Model.ObjectId">
    <header class="d-flex justify-content-between align-items-center mb-3">
        <h4 id="instanceManagerHeading-@Model.ObjectId" class="mb-0">Incident Instances</h4>
        @if (Model.CanEdit)
        {
            <button type="button" class="btn btn-primary btn-sm" data-action="add-instance" aria-label="Add new incident instance">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Instance
            </button>
        }
    </header>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model.Instances == null || Model.Instances.Count == 0)
            {
                <div class="text-center py-5" role="status">
                    <i class="bi bi-hdd-stack fs-1 text-muted d-block mb-2" aria-hidden="true"></i>
                    <p class="text-muted mb-0">No instances found.</p>
                    @if (Model.CanEdit)
                    {
                        <button type="button" class="btn btn-outline-primary btn-sm mt-3" data-action="add-instance">
                            <i class="bi bi-plus-lg" aria-hidden="true"></i> Create your first instance
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0" aria-labelledby="instanceManagerHeading-@Model.ObjectId">
                        <caption class="visually-hidden">List of incident instances</caption>
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Name</th>
                                <th scope="col">Prefix</th>
                                <th scope="col" class="d-none d-md-table-cell">Base Group</th>
                                <th scope="col" class="text-center d-none d-sm-table-cell">SLA Warning</th>
                                @if (Model.CanEdit)
                                {
                                    <th scope="col" class="text-end">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var instance in Model.Instances)
                            {
                                <tr>
                                    <td><strong>@instance.Name</strong></td>
                                    <td><code>@instance.IncidentPrefix</code></td>
                                    <td class="d-none d-md-table-cell">@instance.BaseGroup</td>
                                    <td class="text-center d-none d-sm-table-cell"><span class="badge bg-info text-dark rounded-pill">@instance.SLAWarningPercentage%</span></td>
                                    @if (Model.CanEdit)
                                    {
                                        <td class="text-end text-nowrap">
                                            <div class="btn-group btn-group-sm" role="group" aria-label="Actions for @instance.Name">
                                                <button type="button" class="btn btn-outline-primary" data-action="view-instance" data-id="@instance.Id" aria-label="View @instance.Name">
                                                    <i class="bi bi-eye" aria-hidden="true"></i><span class="d-none d-lg-inline ms-1">View</span>
                                                </button>
                                                <button type="button" class="btn btn-outline-danger" data-action="delete-instance" data-id="@instance.Id" aria-label="Delete @instance.Name">
                                                    <i class="bi bi-trash" aria-hidden="true"></i><span class="d-none d-lg-inline ms-1">Delete</span>
                                                </button>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>
