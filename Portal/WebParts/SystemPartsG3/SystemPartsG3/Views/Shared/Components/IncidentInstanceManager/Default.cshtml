@model dynamic

<div class="incident-instance-manager" role="region" aria-label="Incident Instance Management">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 id="instanceManagerHeading">Incident Instances</h4>
        @if ((bool)(Model.CanEdit ?? false))
        {
            <button type="button" class="btn btn-primary btn-sm" data-action="add-instance" aria-label="Add new incident instance">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Instance
            </button>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover" aria-labelledby="instanceManagerHeading">
            <thead class="table-light">
                <tr>
                    <th scope="col">Title</th>
                    <th scope="col">Type</th>
                    <th scope="col">Status</th>
                    <th scope="col">Reported By</th>
                    <th scope="col">Date</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Instances == null || Model.Instances.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No instances found.</td>
                    </tr>
                }
                else
                {
                    foreach (var instance in Model.Instances)
                    {
                        string statusVal = ((string)(instance.Status ?? "")).Trim();
                        string statusClass = string.Equals(statusVal, "Open", StringComparison.OrdinalIgnoreCase) ? "bg-primary"
                            : string.Equals(statusVal, "InProgress", StringComparison.OrdinalIgnoreCase) || string.Equals(statusVal, "In Progress", StringComparison.OrdinalIgnoreCase) ? "bg-warning text-dark"
                            : string.Equals(statusVal, "Resolved", StringComparison.OrdinalIgnoreCase) ? "bg-success"
                            : "bg-secondary";
                        <tr>
                            <td>@instance.Title</td>
                            <td>@instance.TypeName</td>
                            <td><span class="badge @statusClass">@instance.Status</span></td>
                            <td>@instance.ReportedBy</td>
                            <td>@instance.DateReported</td>
                            <td class="text-end">
                                <button type="button" class="btn btn-outline-primary btn-sm me-1" data-action="view-instance" data-id="@instance.Id" aria-label="View @instance.Title">
                                    <i class="bi bi-eye" aria-hidden="true"></i> View
                                </button>
                                <button type="button" class="btn btn-outline-danger btn-sm" data-action="delete-instance" data-id="@instance.Id" aria-label="Delete @instance.Title">
                                    <i class="bi bi-trash" aria-hidden="true"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
