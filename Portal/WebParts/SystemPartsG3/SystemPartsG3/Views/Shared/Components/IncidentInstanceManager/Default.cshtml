@model WCMS.WebSystem.WebParts.ViewComponents.IncidentInstanceManagerViewModel

<section class="incident-instance-manager" aria-labelledby="instanceManagerHeading-@Model.ObjectId">
    <header class="d-flex justify-content-between align-items-center mb-3">
        <h4 id="instanceManagerHeading-@Model.ObjectId" class="mb-0">Incident Instances</h4>
        @if (Model.CanEdit)
        {
            <button type="button" class="btn btn-primary btn-sm" data-action="add-instance" aria-label="Add new incident instance">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Instance
            </button>
        }
    </header>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0" aria-labelledby="instanceManagerHeading-@Model.ObjectId">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Prefix</th>
                            <th scope="col">Base Group</th>
                            <th scope="col" class="text-center">SLA Warning</th>
                            @if (Model.CanEdit)
                            {
                                <th scope="col" class="text-end">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Instances == null || Model.Instances.Count == 0)
                        {
                            <tr>
                                <td colspan="@(Model.CanEdit ? 5 : 4)" class="text-center text-muted py-4" role="status">No instances found.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var instance in Model.Instances)
                            {
                                <tr>
                                    <td><strong>@instance.Name</strong></td>
                                    <td><code>@instance.IncidentPrefix</code></td>
                                    <td>@instance.BaseGroup</td>
                                    <td class="text-center"><span class="badge bg-info text-dark">@instance.SLAWarningPercentage%</span></td>
                                    @if (Model.CanEdit)
                                    {
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm" role="group" aria-label="Actions for @instance.Name">
                                                <button type="button" class="btn btn-outline-primary" data-action="view-instance" data-id="@instance.Id" aria-label="View @instance.Name">
                                                    <i class="bi bi-eye" aria-hidden="true"></i> View
                                                </button>
                                                <button type="button" class="btn btn-outline-danger" data-action="delete-instance" data-id="@instance.Id" aria-label="Delete @instance.Name">
                                                    <i class="bi bi-trash" aria-hidden="true"></i> Delete
                                                </button>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
