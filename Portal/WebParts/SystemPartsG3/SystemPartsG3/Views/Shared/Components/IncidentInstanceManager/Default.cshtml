@model WCMS.WebSystem.WebParts.ViewComponents.IncidentInstanceManagerViewModel

<div class="incident-instance-manager">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Incident Instances</h4>
        @if (Model.CanEdit)
        {
            <a href="#" class="btn btn-primary btn-sm" data-action="add-instance">
                <i class="bi bi-plus-lg"></i> Add Instance
            </a>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Prefix</th>
                    <th>Base Group</th>
                    <th>SLA (High / Normal / Low)</th>
                    <th>Warning %</th>
                    @if (Model.CanEdit)
                    {
                        <th class="text-end">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Instances.Count == 0)
                {
                    <tr>
                        <td colspan="@(Model.CanEdit ? 6 : 5)" class="text-center text-muted py-4">
                            No instances found.
                        </td>
                    </tr>
                }
                @foreach (var instance in Model.Instances)
                {
                    <tr>
                        <td>@instance.Name</td>
                        <td><code>@instance.IncidentPrefix</code></td>
                        <td>@instance.BaseGroup</td>
                        <td>@instance.SLAHighDuration / @instance.SLANormalDuration / @instance.SLALowDuration</td>
                        <td>@instance.SLAWarningPercentage%</td>
                        @if (Model.CanEdit)
                        {
                            <td class="text-end">
                                <a href="#" class="btn btn-outline-secondary btn-sm" data-action="edit-instance" data-id="@instance.Id">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a href="#" class="btn btn-outline-danger btn-sm" data-action="delete-instance" data-id="@instance.Id">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
