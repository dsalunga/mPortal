@model WCMS.WebSystem.WebParts.ViewComponents.IncidentTicketViewModel

<article class="incident-ticket-view" aria-labelledby="ticketHeading-@Model.ObjectId">
    <header class="d-flex justify-content-between align-items-center mb-3">
        <h4 id="ticketHeading-@Model.ObjectId" class="mb-0">Ticket #@Model.TicketId</h4>
        @{
            string ticketStatusBadge = Model.Status == 0 ? "bg-primary"
                : Model.Status == 1 ? "bg-warning text-dark"
                : Model.Status == 2 ? "bg-success"
                : "bg-secondary";
        }
        <span class="badge @ticketStatusBadge fs-6" aria-label="Status: @Model.StatusText">@Model.StatusText</span>
    </header>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Ticket Details</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Description</dd>

                <dt class="col-sm-3">Category</dt>
                <dd class="col-sm-9">@Model.CategoryName</dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">@Model.TypeName</dd>

                <dt class="col-sm-3">Urgency</dt>
                <dd class="col-sm-9">
                    @{
                        string urgBadge = Model.Urgency >= 3 ? "bg-danger"
                            : Model.Urgency == 2 ? "bg-warning text-dark"
                            : Model.Urgency == 1 ? "bg-info text-dark"
                            : "bg-secondary";
                    }
                    <span class="badge @urgBadge">@Model.UrgencyText</span>
                </dd>

                <dt class="col-sm-3">Assigned To</dt>
                <dd class="col-sm-9">@Model.AssignedUserName</dd>

                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9"><time datetime="@Model.DateCreated.ToString("yyyy-MM-ddTHH:mm")">@Model.DateCreated.ToString("yyyy-MM-dd HH:mm")</time></dd>

                @if (Model.DateClosed.HasValue)
                {
                    <dt class="col-sm-3">Closed</dt>
                    <dd class="col-sm-9"><time datetime="@Model.DateClosed.Value.ToString("yyyy-MM-ddTHH:mm")">@Model.DateClosed.Value.ToString("yyyy-MM-dd HH:mm")</time></dd>
                }

                @if (Model.ETA.HasValue)
                {
                    <dt class="col-sm-3">ETA</dt>
                    <dd class="col-sm-9"><time datetime="@Model.ETA.Value.ToString("yyyy-MM-ddTHH:mm")">@Model.ETA.Value.ToString("yyyy-MM-dd HH:mm")</time></dd>
                }

                @if (!string.IsNullOrEmpty(Model.TicketGuid))
                {
                    <dt class="col-sm-3">Reference</dt>
                    <dd class="col-sm-9"><code>@Model.TicketGuid</code></dd>
                }

                @if (!string.IsNullOrEmpty(Model.NotifyAlso))
                {
                    <dt class="col-sm-3">Also Notify</dt>
                    <dd class="col-sm-9">@Model.NotifyAlso</dd>
                }
            </dl>
        </div>
    </div>

    @if (Model.CanEdit)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Update Status</h5>
            </div>
            <div class="card-body">
                <form method="post" class="d-flex align-items-end gap-3" aria-label="Update ticket status">
                    <input type="hidden" name="TicketId" value="@Model.TicketId" />
                    <div>
                        <label for="ticketStatusUpdate-@Model.ObjectId" class="form-label">New Status</label>
                        <select class="form-select" id="ticketStatusUpdate-@Model.ObjectId" name="Status" aria-label="Select new status">
                            <option value="0" selected="@(Model.Status == 0)">Open</option>
                            <option value="1" selected="@(Model.Status == 1)">In Progress</option>
                            <option value="2" selected="@(Model.Status == 2)">Resolved</option>
                            <option value="3" selected="@(Model.Status == 3)">Closed</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary" name="action" value="update-status">
                        <i class="bi bi-arrow-repeat" aria-hidden="true"></i> Update Status
                    </button>
                </form>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-header">
            <h5 class="mb-0" id="commentsHeading-@Model.ObjectId">History &amp; Comments</h5>
        </div>
        <div class="card-body" aria-labelledby="commentsHeading-@Model.ObjectId">
            @if (Model.Comments == null || Model.Comments.Count == 0)
            {
                <p class="text-muted" role="status">No comments yet.</p>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var comment in Model.Comments)
                    {
                        <div class="list-group-item px-0" role="article" aria-label="Comment by @comment.Author">
                            <div class="d-flex justify-content-between">
                                <strong>@comment.Author</strong>
                                <small class="text-muted"><time datetime="@comment.DatePosted.ToString("yyyy-MM-ddTHH:mm")">@comment.DatePosted.ToString("yyyy-MM-dd HH:mm")</time></small>
                            </div>
                            <p class="mt-1 mb-0">@comment.Content</p>
                        </div>
                    }
                </div>
            }

            @if (Model.CanEdit)
            {
                <form method="post" class="mt-3" aria-label="Add a comment">
                    <input type="hidden" name="TicketId" value="@Model.TicketId" />
                    <div class="mb-3">
                        <label for="newComment-@Model.ObjectId" class="form-label">Add Comment</label>
                        <textarea class="form-control" id="newComment-@Model.ObjectId" name="CommentContent" rows="3"
                                  required aria-required="true"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm" name="action" value="add-comment">
                        <i class="bi bi-chat-dots" aria-hidden="true"></i> Add Comment
                    </button>
                </form>
            }
        </div>
    </div>

    <nav aria-label="Ticket navigation">
        <button type="button" class="btn btn-secondary" data-action="back" aria-label="Back to ticket list">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to List
        </button>
    </nav>
</article>
