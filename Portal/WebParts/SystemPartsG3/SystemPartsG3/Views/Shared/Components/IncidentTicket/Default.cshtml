@model WCMS.WebSystem.WebParts.ViewComponents.IncidentTicketViewModel

<article class="incident-ticket-view" aria-labelledby="ticketHeading-@Model.ObjectId">
    <header class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <h4 id="ticketHeading-@Model.ObjectId" class="mb-0">
            Ticket <span class="text-muted">#@Model.TicketId</span>
        </h4>
        @{
            string ticketStatusBadge = Model.Status switch
            {
                0 => "bg-primary",
                1 => "bg-warning text-dark",
                2 => "bg-success",
                _ => "bg-secondary"
            };
        }
        <span class="badge @ticketStatusBadge fs-6" aria-label="Status: @Model.StatusText">@Model.StatusText</span>
    </header>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="card-title mb-0"><i class="bi bi-info-circle me-1" aria-hidden="true"></i> Ticket Details</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4 col-md-3">Description</dt>
                <dd class="col-sm-8 col-md-9">@(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</dd>

                <dt class="col-sm-4 col-md-3">Category</dt>
                <dd class="col-sm-8 col-md-9">@(string.IsNullOrEmpty(Model.CategoryName) ? "—" : Model.CategoryName)</dd>

                <dt class="col-sm-4 col-md-3">Type</dt>
                <dd class="col-sm-8 col-md-9">@(string.IsNullOrEmpty(Model.TypeName) ? "—" : Model.TypeName)</dd>

                <dt class="col-sm-4 col-md-3">Urgency</dt>
                <dd class="col-sm-8 col-md-9">
                    @{
                        string urgBadge = Model.Urgency switch
                        {
                            >= 3 => "bg-danger",
                            2 => "bg-warning text-dark",
                            1 => "bg-info text-dark",
                            _ => "bg-secondary"
                        };
                    }
                    <span class="badge @urgBadge">@Model.UrgencyText</span>
                </dd>

                <dt class="col-sm-4 col-md-3">Assigned To</dt>
                <dd class="col-sm-8 col-md-9">@(string.IsNullOrEmpty(Model.AssignedUserName) ? "Unassigned" : Model.AssignedUserName)</dd>

                <dt class="col-sm-4 col-md-3">Created</dt>
                <dd class="col-sm-8 col-md-9"><time datetime="@Model.DateCreated.ToString("yyyy-MM-ddTHH:mm:ss")">@Model.DateCreated.ToString("yyyy-MM-dd HH:mm")</time></dd>

                @if (Model.DateClosed.HasValue)
                {
                    <dt class="col-sm-4 col-md-3">Closed</dt>
                    <dd class="col-sm-8 col-md-9"><time datetime="@Model.DateClosed.Value.ToString("yyyy-MM-ddTHH:mm:ss")">@Model.DateClosed.Value.ToString("yyyy-MM-dd HH:mm")</time></dd>
                }

                @if (Model.ETA.HasValue)
                {
                    <dt class="col-sm-4 col-md-3">ETA</dt>
                    <dd class="col-sm-8 col-md-9"><time datetime="@Model.ETA.Value.ToString("yyyy-MM-ddTHH:mm:ss")">@Model.ETA.Value.ToString("yyyy-MM-dd HH:mm")</time></dd>
                }

                @if (!string.IsNullOrEmpty(Model.TicketGuid))
                {
                    <dt class="col-sm-4 col-md-3">Reference</dt>
                    <dd class="col-sm-8 col-md-9"><code class="user-select-all">@Model.TicketGuid</code></dd>
                }

                @if (!string.IsNullOrEmpty(Model.NotifyAlso))
                {
                    <dt class="col-sm-4 col-md-3">Also Notify</dt>
                    <dd class="col-sm-8 col-md-9">@Model.NotifyAlso</dd>
                }
            </dl>
        </div>
    </div>

    @if (Model.CanEdit)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="card-title mb-0"><i class="bi bi-arrow-repeat me-1" aria-hidden="true"></i> Update Status</h5>
            </div>
            <div class="card-body">
                <form method="post" class="row g-3 align-items-end" aria-label="Update ticket status">
                    <input type="hidden" name="TicketId" value="@Model.TicketId" />
                    <div class="col-sm-auto">
                        <label for="ticketStatusUpdate-@Model.ObjectId" class="form-label">New Status</label>
                        <select class="form-select" id="ticketStatusUpdate-@Model.ObjectId" name="Status" aria-label="Select new status">
                            <option value="0" @(Model.Status == 0 ? "selected" : "")>Open</option>
                            <option value="1" @(Model.Status == 1 ? "selected" : "")>In Progress</option>
                            <option value="2" @(Model.Status == 2 ? "selected" : "")>Resolved</option>
                            <option value="3" @(Model.Status == 3 ? "selected" : "")>Closed</option>
                        </select>
                    </div>
                    <div class="col-sm-auto">
                        <button type="submit" class="btn btn-primary" name="action" value="update-status">
                            <i class="bi bi-arrow-repeat" aria-hidden="true"></i> Update Status
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0" id="commentsHeading-@Model.ObjectId">
                <i class="bi bi-chat-left-text me-1" aria-hidden="true"></i> History &amp; Comments
            </h5>
            @if (Model.Comments != null && Model.Comments.Count > 0)
            {
                <span class="badge bg-secondary rounded-pill">@Model.Comments.Count</span>
            }
        </div>
        <div class="card-body" aria-labelledby="commentsHeading-@Model.ObjectId">
            @if (Model.Comments == null || Model.Comments.Count == 0)
            {
                <div class="text-center py-4" role="status">
                    <i class="bi bi-chat fs-1 text-muted d-block mb-2" aria-hidden="true"></i>
                    <p class="text-muted mb-0">No comments yet.</p>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var comment in Model.Comments)
                    {
                        <div class="list-group-item px-0" role="article" aria-label="Comment by @comment.Author">
                            <div class="d-flex justify-content-between align-items-start">
                                <strong>@comment.Author</strong>
                                <small class="text-muted text-nowrap ms-2">
                                    <time datetime="@comment.DatePosted.ToString("yyyy-MM-ddTHH:mm:ss")">@comment.DatePosted.ToString("yyyy-MM-dd HH:mm")</time>
                                </small>
                            </div>
                            <p class="mt-1 mb-0">@comment.Content</p>
                        </div>
                    }
                </div>
            }

            @if (Model.CanEdit)
            {
                <hr />
                <form method="post" aria-label="Add a comment">
                    <input type="hidden" name="TicketId" value="@Model.TicketId" />
                    <div class="mb-3">
                        <label for="newComment-@Model.ObjectId" class="form-label">Add Comment</label>
                        <textarea class="form-control" id="newComment-@Model.ObjectId" name="CommentContent" rows="3"
                                  required aria-required="true" placeholder="Write your comment..."></textarea>
                        <div class="invalid-feedback">Please enter a comment.</div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm" name="action" value="add-comment">
                        <i class="bi bi-chat-dots" aria-hidden="true"></i> Add Comment
                    </button>
                </form>
            }
        </div>
    </div>

    <nav aria-label="Ticket navigation">
        <button type="button" class="btn btn-outline-secondary" data-action="back" aria-label="Back to ticket list">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to List
        </button>
    </nav>
</article>
