@model dynamic

<div class="incident-type-manager" role="region" aria-label="Incident Type Management">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 id="typeManagerHeading">Incident Types</h4>
        @if ((bool)(Model.CanEdit ?? false))
        {
            <button type="button" class="btn btn-primary btn-sm" data-action="add-type" aria-label="Add new incident type">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Type
            </button>
        }
    </div>

    <div class="mb-3">
        <label for="typeFilter" class="visually-hidden">Filter incident types</label>
        <div class="input-group">
            <span class="input-group-text" aria-hidden="true"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" id="typeFilter" placeholder="Filter types..."
                   value="@Model.FilterText" data-action="filter-types" aria-label="Filter incident types" />
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover" aria-labelledby="typeManagerHeading">
            <thead class="table-light">
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Category</th>
                    <th scope="col">Severity</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Types == null || Model.Types.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No types found.</td>
                    </tr>
                }
                else
                {
                    foreach (var type in Model.Types)
                    {
                        <tr>
                            <td>@type.Name</td>
                            <td>@type.CategoryName</td>
                            <td>
                                @{
                                    string severityClass = type.Severity == "Critical" ? "bg-danger"
                                        : type.Severity == "High" ? "bg-warning text-dark"
                                        : type.Severity == "Medium" ? "bg-info text-dark"
                                        : "bg-secondary";
                                }
                                <span class="badge @severityClass">@type.Severity</span>
                            </td>
                            <td class="text-end">
                                <button type="button" class="btn btn-outline-secondary btn-sm me-1" data-action="edit-type" data-id="@type.Id" aria-label="Edit @type.Name">
                                    <i class="bi bi-pencil" aria-hidden="true"></i> Edit
                                </button>
                                <button type="button" class="btn btn-outline-danger btn-sm" data-action="delete-type" data-id="@type.Id" aria-label="Delete @type.Name">
                                    <i class="bi bi-trash" aria-hidden="true"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
