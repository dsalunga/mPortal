@model WCMS.WebSystem.WebParts.ViewComponents.IncidentTypeManagerViewModel

<div class="incident-type-manager">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Incident Types</h4>
        @if (Model.CanEdit)
        {
            <a href="#" class="btn btn-primary btn-sm" data-action="add-type">
                <i class="bi bi-plus-lg"></i> Add Type
            </a>
        }
    </div>

    <div class="mb-3">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" placeholder="Filter types..."
                   value="@Model.FilterText" data-action="filter-types" />
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Rank</th>
                    <th>SLA</th>
                    <th>Instance</th>
                    @if (Model.CanEdit)
                    {
                        <th class="text-end">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Types.Count == 0)
                {
                    <tr>
                        <td colspan="@(Model.CanEdit ? 5 : 4)" class="text-center text-muted py-4">
                            No types found.
                        </td>
                    </tr>
                }
                @foreach (var type in Model.Types)
                {
                    <tr>
                        <td>@type.Name</td>
                        <td>@type.Rank</td>
                        <td>
                            @if (type.UseSLA)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td>@type.InstanceId</td>
                        @if (Model.CanEdit)
                        {
                            <td class="text-end">
                                <a href="#" class="btn btn-outline-secondary btn-sm" data-action="edit-type" data-id="@type.Id">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
