@model dynamic

<div class="incident-category-edit" role="region" aria-label="Incident Category Form">
    <h4 class="mb-3" id="categoryEditHeading">@(Model.CategoryId != null && (int)Model.CategoryId > 0 ? "Edit" : "Add") Incident Category</h4>

    <form method="post" class="needs-validation" novalidate aria-labelledby="categoryEditHeading">
        <input type="hidden" name="CategoryId" value="@Model.CategoryId" />
        <input type="hidden" name="ObjectId" value="@Model.ObjectId" />

        <div class="mb-3">
            <label for="categoryName" class="form-label">Name <span class="text-danger" aria-hidden="true">*</span></label>
            <input type="text" class="form-control" id="categoryName" name="Name"
                   value="@Model.Name" required maxlength="255" aria-required="true" />
            <div class="invalid-feedback">Please enter a category name.</div>
        </div>

        <div class="mb-3">
            <label for="categoryDescription" class="form-label">Description</label>
            <textarea class="form-control" id="categoryDescription" name="Description"
                      rows="3" aria-describedby="descriptionHelp">@Model.Description</textarea>
            <div id="descriptionHelp" class="form-text">Provide a brief description of this category.</div>
        </div>

        <div class="mb-3">
            <label for="categoryStatus" class="form-label">Status</label>
            <select class="form-select" id="categoryStatus" name="Status" aria-label="Category status">
                <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
            </select>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg" aria-hidden="true"></i> Save
            </button>
            <button type="button" class="btn btn-secondary" data-action="cancel">
                <i class="bi bi-x-lg" aria-hidden="true"></i> Cancel
            </button>
        </div>
    </form>
</div>
