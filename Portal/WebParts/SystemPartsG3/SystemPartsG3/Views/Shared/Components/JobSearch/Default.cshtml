@model dynamic

<div class="job-search" role="region" aria-label="Job Search">
    <h4 class="mb-3" id="jobSearchHeading">Job Search</h4>

    <form method="get" class="mb-4" role="search" aria-labelledby="jobSearchHeading">
        <input type="hidden" name="ObjectId" value="@Model.ObjectId" />

        <div class="row g-3">
            <div class="col-md-3">
                <label for="searchKeyword" class="form-label">Keywords</label>
                <input type="text" class="form-control" id="searchKeyword" name="keyword"
                       value="@Model.SearchKeyword" placeholder="Job title, skills, etc." aria-label="Search by keywords" />
            </div>

            <div class="col-md-3">
                <label for="searchLocation" class="form-label">Location</label>
                <input type="text" class="form-control" id="searchLocation" name="location"
                       value="@Model.SearchLocation" placeholder="City, state, or zip" aria-label="Search by location" />
            </div>

            <div class="col-md-2">
                <label for="searchCategory" class="form-label">Category</label>
                <select class="form-select" id="searchCategory" name="category" aria-label="Filter by category">
                    <option value="">All Categories</option>
                    @if (Model.Categories != null)
                    {
                        foreach (var category in Model.Categories)
                        {
                            <option value="@category" selected="@(Model.SearchCategory == category)">@category</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label for="searchJobType" class="form-label">Job Type</label>
                <select class="form-select" id="searchJobType" name="jobType" aria-label="Filter by job type">
                    <option value="">All Types</option>
                    <option value="Full-time" selected="@(Model.SearchJobType == "Full-time")">Full-time</option>
                    <option value="Part-time" selected="@(Model.SearchJobType == "Part-time")">Part-time</option>
                    <option value="Contract" selected="@(Model.SearchJobType == "Contract")">Contract</option>
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search" aria-hidden="true"></i> Search
                </button>
            </div>
        </div>
    </form>

    @if (Model.TotalResults != null && (int)Model.TotalResults > 0)
    {
        <p class="text-muted mb-3" aria-live="polite">@Model.TotalResults job(s) found</p>
    }

    <!-- Results Grid -->
    <div class="table-responsive">
        <table class="table table-striped table-hover" aria-label="Job search results">
            <thead class="table-light">
                <tr>
                    <th scope="col">Title</th>
                    <th scope="col">Company</th>
                    <th scope="col">Location</th>
                    <th scope="col">Type</th>
                    <th scope="col">Posted Date</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Results == null || Model.Results.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No jobs match your search criteria.</td>
                    </tr>
                }
                else
                {
                    foreach (var job in Model.Results)
                    {
                        <tr>
                            <td><strong>@job.Title</strong></td>
                            <td>@job.Company</td>
                            <td><i class="bi bi-geo-alt" aria-hidden="true"></i> @job.Location</td>
                            <td><span class="badge bg-info text-dark">@job.JobType</span></td>
                            <td>@job.DatePosted</td>
                            <td class="text-end">
                                <a href="#" class="btn btn-outline-primary btn-sm" data-action="view-job" data-id="@job.Id" aria-label="View @job.Title">
                                    <i class="bi bi-eye" aria-hidden="true"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalResults != null && Model.PageSize != null)
    {
        int totalPages = (int)System.Math.Ceiling((double)Model.TotalResults / (double)Model.PageSize);
        if (totalPages > 1)
        {
            <nav aria-label="Job search results pagination" class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="#" data-page="@(Model.CurrentPage - 1)" aria-label="Previous page">Previous</a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")" @(i == Model.CurrentPage ? "aria-current=\"page\"" : "")>
                            <a class="page-link" href="#" data-page="@i" aria-label="Page @i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="#" data-page="@(Model.CurrentPage + 1)" aria-label="Next page">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
