@model WCMS.WebSystem.WebParts.ViewComponents.JobSearchViewModel

<div class="job-search">
    <h4 class="mb-3">Job Search</h4>

    <form method="get" class="mb-4">
        <input type="hidden" name="ObjectId" value="@Model.ObjectId" />

        <div class="row g-3">
            <div class="col-md-4">
                <label for="searchKeyword" class="form-label">Keywords</label>
                <input type="text" class="form-control" id="searchKeyword" name="keyword"
                       value="@Model.SearchKeyword" placeholder="Job title, skills, etc." />
            </div>

            <div class="col-md-3">
                <label for="searchLocation" class="form-label">Location</label>
                <input type="text" class="form-control" id="searchLocation" name="location"
                       value="@Model.SearchLocation" placeholder="City, state, or zip" />
            </div>

            <div class="col-md-3">
                <label for="searchCategory" class="form-label">Category</label>
                <select class="form-select" id="searchCategory" name="category">
                    <option value="">All Categories</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category" selected="@(Model.SearchCategory == category)">@category</option>
                    }
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </div>
    </form>

    @if (Model.TotalResults > 0)
    {
        <p class="text-muted mb-3">@Model.TotalResults job(s) found</p>
    }

    <div class="list-group">
        @if (Model.Results.Count == 0)
        {
            <div class="text-center text-muted py-4">
                <p>No jobs match your search criteria.</p>
            </div>
        }
        @foreach (var job in Model.Results)
        {
            <a href="#" class="list-group-item list-group-item-action" data-action="view-job" data-id="@job.Id">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h5 class="mb-1">@job.Title</h5>
                        <p class="mb-1">@job.Description</p>
                        <small class="text-muted">
                            @if (!string.IsNullOrEmpty(job.Location))
                            {
                                <span><i class="bi bi-geo-alt"></i> @job.Location</span>
                            }
                            @if (!string.IsNullOrEmpty(job.Category))
                            {
                                <span class="ms-3"><i class="bi bi-tag"></i> @job.Category</span>
                            }
                        </small>
                    </div>
                    <small class="text-muted">@job.DatePosted</small>
                </div>
            </a>
        }
    </div>

    @{
        int totalPages = (int)System.Math.Ceiling((double)Model.TotalResults / Model.PageSize);
    }
    @if (totalPages > 1)
    {
        <nav aria-label="Job search results pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="#" data-page="@(Model.CurrentPage - 1)">Previous</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="#" data-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="#" data-page="@(Model.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>
