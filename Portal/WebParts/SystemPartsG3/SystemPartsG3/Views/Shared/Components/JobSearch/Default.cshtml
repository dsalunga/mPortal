@model WCMS.WebSystem.WebParts.ViewComponents.JobSearchViewModel

<section class="job-search" aria-labelledby="jobSearchHeading-@Model.ObjectId">
    <h4 class="mb-3" id="jobSearchHeading-@Model.ObjectId">Job Search</h4>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" role="search" aria-labelledby="jobSearchHeading-@Model.ObjectId">
                <input type="hidden" name="ObjectId" value="@Model.ObjectId" />

                <div class="row g-3 align-items-end">
                    <div class="col-12 col-md-4">
                        <label for="searchKeyword-@Model.ObjectId" class="form-label">Keywords</label>
                        <input type="search" class="form-control" id="searchKeyword-@Model.ObjectId" name="keyword"
                               value="@Model.SearchKeyword" placeholder="Job title, skills, etc." />
                    </div>

                    <div class="col-12 col-md-3">
                        <label for="searchLocation-@Model.ObjectId" class="form-label">Location</label>
                        <input type="text" class="form-control" id="searchLocation-@Model.ObjectId" name="location"
                               value="@Model.SearchLocation" placeholder="City, state, or zip" />
                    </div>

                    <div class="col-12 col-md-3">
                        <label for="searchCategory-@Model.ObjectId" class="form-label">Category</label>
                        <select class="form-select" id="searchCategory-@Model.ObjectId" name="category" aria-label="Filter by job category">
                            <option value="">All Categories</option>
                            @if (Model.Categories != null)
                            {
                                foreach (var category in Model.Categories)
                                {
                                    <option value="@category" @(Model.SearchCategory == category ? "selected" : "")>@category</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-2">
                        <button type="submit" class="btn btn-primary w-100" aria-label="Search jobs">
                            <i class="bi bi-search" aria-hidden="true"></i><span class="d-inline d-md-none ms-1">Search</span>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.TotalResults > 0)
    {
        <p class="text-muted mb-3" aria-live="polite" role="status">
            <strong>@Model.TotalResults</strong> result(s) found
        </p>
    }

    <div class="list-group mb-4" aria-label="Job search results">
        @if (Model.Results == null || Model.Results.Count == 0)
        {
            <div class="text-center py-5" role="status">
                <i class="bi bi-briefcase fs-1 text-muted d-block mb-2" aria-hidden="true"></i>
                <p class="text-muted mb-1">No jobs match your search criteria.</p>
                <p class="text-muted small mb-0">Try adjusting your filters or keywords.</p>
            </div>
        }
        else
        {
            foreach (var job in Model.Results)
            {
                <article class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between align-items-start">
                        <div class="me-3">
                            <h5 class="mb-1">@job.Title</h5>
                            <p class="mb-1">
                                @if (!string.IsNullOrEmpty(job.Category))
                                {
                                    <span class="badge bg-secondary me-1">@job.Category</span>
                                }
                                @if (!string.IsNullOrEmpty(job.Location))
                                {
                                    <span class="text-muted"><i class="bi bi-geo-alt" aria-hidden="true"></i> @job.Location</span>
                                }
                            </p>
                            @if (!string.IsNullOrEmpty(job.Description))
                            {
                                <p class="mb-0 small text-muted">@job.Description</p>
                            }
                        </div>
                        <div class="text-end text-nowrap flex-shrink-0">
                            @if (!string.IsNullOrEmpty(job.DatePosted))
                            {
                                <small class="text-muted d-block mb-2"><time datetime="@job.DatePosted">@job.DatePosted</time></small>
                            }
                            <a href="#" class="btn btn-outline-primary btn-sm" data-action="view-job" data-id="@job.Id" aria-label="View details for @job.Title">
                                <i class="bi bi-eye" aria-hidden="true"></i> View
                            </a>
                        </div>
                    </div>
                </article>
            }
        }
    </div>

    @if (Model.TotalResults > 0 && Model.PageSize > 0)
    {
        int totalPages = (int)System.Math.Ceiling((double)Model.TotalResults / (double)Model.PageSize);
        if (totalPages > 1)
        {
            <nav aria-label="Job search results pagination" class="mt-3">
                <ul class="pagination justify-content-center flex-wrap">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="#" data-page="@(Model.CurrentPage - 1)" aria-label="Go to previous page">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")" @(i == Model.CurrentPage ? "aria-current=\"page\"" : "")>
                            <a class="page-link" href="#" data-page="@i" aria-label="Go to page @i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="#" data-page="@(Model.CurrentPage + 1)" aria-label="Go to next page">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</section>
