@model dynamic

<div class="incident-instance-edit" role="region" aria-label="Incident Instance Form">
    <h4 class="mb-3" id="instanceEditHeading">@(Model.InstanceId != null && (int)Model.InstanceId > 0 ? "Edit" : "Add") Incident Instance</h4>

    <form method="post" class="needs-validation" novalidate aria-labelledby="instanceEditHeading">
        <input type="hidden" name="InstanceId" value="@Model.InstanceId" />
        <input type="hidden" name="ObjectId" value="@Model.ObjectId" />

        <div class="mb-3">
            <label for="instanceTitle" class="form-label">Title <span class="text-danger" aria-hidden="true">*</span></label>
            <input type="text" class="form-control" id="instanceTitle" name="Title"
                   value="@Model.Title" required maxlength="255" aria-required="true" />
            <div class="invalid-feedback">Please enter a title.</div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="instanceType" class="form-label">Type <span class="text-danger" aria-hidden="true">*</span></label>
                <select class="form-select" id="instanceType" name="TypeId" required aria-required="true">
                    <option value="">-- Select Type --</option>
                    @if (Model.Types != null)
                    {
                        foreach (var t in Model.Types)
                        {
                            <option value="@t.Id" selected="@(Model.TypeId != null && (int)Model.TypeId == (int)t.Id)">@t.Name</option>
                        }
                    }
                </select>
                <div class="invalid-feedback">Please select an incident type.</div>
            </div>

            <div class="col-md-6 mb-3">
                <label for="instanceStatus" class="form-label">Status</label>
                <select class="form-select" id="instanceStatus" name="Status" aria-label="Instance status">
                    <option value="Open" selected="@(Model.Status == "Open")">Open</option>
                    <option value="InProgress" selected="@(Model.Status == "InProgress")">In Progress</option>
                    <option value="Resolved" selected="@(Model.Status == "Resolved")">Resolved</option>
                    <option value="Closed" selected="@(Model.Status == "Closed")">Closed</option>
                </select>
            </div>
        </div>

        <div class="mb-3">
            <label for="instanceDescription" class="form-label">Description</label>
            <textarea class="form-control" id="instanceDescription" name="Description"
                      rows="4">@Model.Description</textarea>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="instancePriority" class="form-label">Priority</label>
                <select class="form-select" id="instancePriority" name="Priority" aria-label="Instance priority">
                    <option value="Low" selected="@(Model.Priority == "Low")">Low</option>
                    <option value="Medium" selected="@(Model.Priority == "Medium")">Medium</option>
                    <option value="High" selected="@(Model.Priority == "High")">High</option>
                    <option value="Critical" selected="@(Model.Priority == "Critical")">Critical</option>
                </select>
            </div>

            <div class="col-md-6 mb-3">
                <label for="instanceAssignedTo" class="form-label">Assigned To</label>
                <input type="text" class="form-control" id="instanceAssignedTo" name="AssignedTo"
                       value="@Model.AssignedTo" />
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg" aria-hidden="true"></i> Save
            </button>
            <button type="button" class="btn btn-secondary" data-action="cancel">
                <i class="bi bi-x-lg" aria-hidden="true"></i> Cancel
            </button>
        </div>
    </form>
</div>
