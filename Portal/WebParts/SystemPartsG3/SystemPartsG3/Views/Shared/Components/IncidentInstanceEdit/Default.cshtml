@model WCMS.WebSystem.WebParts.ViewComponents.IncidentInstanceEditViewModel

<section class="incident-instance-edit" aria-labelledby="instanceEditHeading-@Model.ObjectId">
    <h4 class="mb-3" id="instanceEditHeading-@Model.ObjectId">@(Model.InstanceId > 0 ? "Edit" : "Add") Incident Instance</h4>

    <div class="card">
        <div class="card-body">
            <form method="post" class="needs-validation" novalidate aria-labelledby="instanceEditHeading-@Model.ObjectId">
                <input type="hidden" name="InstanceId" value="@Model.InstanceId" />
                <input type="hidden" name="ObjectId" value="@Model.ObjectId" />

                <fieldset class="mb-4">
                    <legend class="h6 border-bottom pb-2">General Information</legend>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="instanceName-@Model.ObjectId" class="form-label">Name <span class="text-danger" aria-hidden="true">*</span></label>
                            <input type="text" class="form-control" id="instanceName-@Model.ObjectId" name="Name"
                                   value="@Model.Name" required maxlength="255" aria-required="true" />
                            <div class="invalid-feedback">Please enter an instance name.</div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="instancePrefix-@Model.ObjectId" class="form-label">Incident Prefix</label>
                            <input type="text" class="form-control" id="instancePrefix-@Model.ObjectId" name="IncidentPrefix"
                                   value="@Model.IncidentPrefix" maxlength="50" aria-describedby="prefixHelp-@Model.ObjectId" />
                            <div id="prefixHelp-@Model.ObjectId" class="form-text">Prefix used for ticket identifiers (e.g., INC).</div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="instanceBaseGroup-@Model.ObjectId" class="form-label">Base Group</label>
                            <input type="text" class="form-control" id="instanceBaseGroup-@Model.ObjectId" name="BaseGroup"
                                   value="@Model.BaseGroup" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="instanceSupportGroupPath-@Model.ObjectId" class="form-label">Support Group Path</label>
                            <input type="text" class="form-control" id="instanceSupportGroupPath-@Model.ObjectId" name="SupportGroupPath"
                                   value="@Model.SupportGroupPath" />
                        </div>
                    </div>
                </fieldset>

                <fieldset class="mb-4">
                    <legend class="h6 border-bottom pb-2">SLA Configuration</legend>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="instanceSLAHigh-@Model.ObjectId" class="form-label">High Duration</label>
                            <div class="input-group">
                                <input type="number" class="form-control" id="instanceSLAHigh-@Model.ObjectId" name="SLAHighDuration"
                                       value="@Model.SLAHighDuration" min="0" aria-describedby="slaHighUnit-@Model.ObjectId" />
                                <span class="input-group-text" id="slaHighUnit-@Model.ObjectId">minutes</span>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label for="instanceSLANormal-@Model.ObjectId" class="form-label">Normal Duration</label>
                            <div class="input-group">
                                <input type="number" class="form-control" id="instanceSLANormal-@Model.ObjectId" name="SLANormalDuration"
                                       value="@Model.SLANormalDuration" min="0" aria-describedby="slaNormalUnit-@Model.ObjectId" />
                                <span class="input-group-text" id="slaNormalUnit-@Model.ObjectId">minutes</span>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label for="instanceSLALow-@Model.ObjectId" class="form-label">Low Duration</label>
                            <div class="input-group">
                                <input type="number" class="form-control" id="instanceSLALow-@Model.ObjectId" name="SLALowDuration"
                                       value="@Model.SLALowDuration" min="0" aria-describedby="slaLowUnit-@Model.ObjectId" />
                                <span class="input-group-text" id="slaLowUnit-@Model.ObjectId">minutes</span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="instanceSLAWarning-@Model.ObjectId" class="form-label">Warning Percentage</label>
                            <div class="input-group">
                                <input type="number" class="form-control" id="instanceSLAWarning-@Model.ObjectId" name="SLAWarningPercentage"
                                       value="@Model.SLAWarningPercentage" min="0" max="100" step="0.1" aria-describedby="slaWarningUnit-@Model.ObjectId" />
                                <span class="input-group-text" id="slaWarningUnit-@Model.ObjectId">%</span>
                            </div>
                        </div>
                    </div>
                </fieldset>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg" aria-hidden="true"></i> Save
                    </button>
                    <button type="button" class="btn btn-secondary" data-action="cancel">
                        <i class="bi bi-x-lg" aria-hidden="true"></i> Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>
