@model dynamic

<div class="incident-category-manager" role="region" aria-label="Incident Category Management">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 id="categoryManagerHeading">Incident Categories</h4>
        @if ((bool)(Model.CanEdit ?? false))
        {
            <button type="button" class="btn btn-primary btn-sm" data-action="add-category" aria-label="Add new incident category">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Category
            </button>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover" aria-labelledby="categoryManagerHeading">
            <thead class="table-light">
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Description</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Categories == null || Model.Categories.Count == 0)
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">No categories found.</td>
                    </tr>
                }
                else
                {
                    foreach (var category in Model.Categories)
                    {
                        <tr>
                            <td>@category.Name</td>
                            <td>@category.Description</td>
                            <td class="text-end">
                                <button type="button" class="btn btn-outline-secondary btn-sm me-1" data-action="edit-category" data-id="@category.Id" aria-label="Edit @category.Name">
                                    <i class="bi bi-pencil" aria-hidden="true"></i> Edit
                                </button>
                                <button type="button" class="btn btn-outline-danger btn-sm" data-action="delete-category" data-id="@category.Id" aria-label="Delete @category.Name">
                                    <i class="bi bi-trash" aria-hidden="true"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
