@model WCMS.WebSystem.WebParts.ViewComponents.IncidentCategoryManagerViewModel

<div class="incident-category-manager">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Incident Categories</h4>
        @if (Model.CanEdit)
        {
            <a href="#" class="btn btn-primary btn-sm" data-action="add-category">
                <i class="bi bi-plus-lg"></i> Add Category
            </a>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Group</th>
                    <th>Rank</th>
                    @if (Model.CanEdit)
                    {
                        <th class="text-end">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Categories.Count == 0)
                {
                    <tr>
                        <td colspan="@(Model.CanEdit ? 5 : 4)" class="text-center text-muted py-4">
                            No categories found.
                        </td>
                    </tr>
                }
                @foreach (var category in Model.Categories)
                {
                    <tr>
                        <td>@category.Name</td>
                        <td>@category.Description</td>
                        <td>@category.GroupId</td>
                        <td>@category.Rank</td>
                        @if (Model.CanEdit)
                        {
                            <td class="text-end">
                                <a href="#" class="btn btn-outline-secondary btn-sm" data-action="edit-category" data-id="@category.Id">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a href="#" class="btn btn-outline-danger btn-sm" data-action="delete-category" data-id="@category.Id">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
