@model dynamic

<div class="jobs-list" role="region" aria-label="Job Listings">
    <h4 class="mb-3" id="jobsListHeading">Job Listings</h4>

    @if (Model.TotalJobs != null && (int)Model.TotalJobs > 0)
    {
        <p class="text-muted mb-3" aria-live="polite">Showing @Model.Jobs.Count of @Model.TotalJobs job(s)</p>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover" aria-labelledby="jobsListHeading">
            <thead class="table-light">
                <tr>
                    <th scope="col">Title</th>
                    <th scope="col">Company</th>
                    <th scope="col">Location</th>
                    <th scope="col">Type</th>
                    <th scope="col">Posted Date</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Jobs == null || Model.Jobs.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No job listings available at this time.</td>
                    </tr>
                }
                else
                {
                    foreach (var job in Model.Jobs)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty((string)job.DetailsUrl))
                                {
                                    <a href="@job.DetailsUrl" data-action="view-job" data-id="@job.Id" aria-label="View details for @job.Title">
                                        <strong>@job.Title</strong>
                                    </a>
                                }
                                else
                                {
                                    <strong>@job.Title</strong>
                                }
                            </td>
                            <td>@job.Company</td>
                            <td><i class="bi bi-geo-alt" aria-hidden="true"></i> @job.Location</td>
                            <td><span class="badge bg-info text-dark">@job.JobType</span></td>
                            <td>@job.DatePosted</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalJobs != null && Model.PageSize != null)
    {
        int totalPages = (int)System.Math.Ceiling((double)Model.TotalJobs / (double)Model.PageSize);
        if (totalPages > 1)
        {
            <nav aria-label="Job listings pagination" class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="#" data-page="@(Model.CurrentPage - 1)" aria-label="Previous page">Previous</a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")" @(i == Model.CurrentPage ? "aria-current=\"page\"" : "")>
                            <a class="page-link" href="#" data-page="@i" aria-label="Page @i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="#" data-page="@(Model.CurrentPage + 1)" aria-label="Next page">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
