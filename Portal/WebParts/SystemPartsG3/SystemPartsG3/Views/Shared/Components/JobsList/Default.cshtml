@model WCMS.WebSystem.WebParts.ViewComponents.JobsListViewModel

<div class="jobs-list">
    <h4 class="mb-3">Job Listings</h4>

    @if (Model.TotalJobs > 0)
    {
        <p class="text-muted mb-3">Showing @Model.Jobs.Count of @Model.TotalJobs job(s)</p>
    }

    <div class="row">
        @if (Model.Jobs.Count == 0)
        {
            <div class="col-12 text-center text-muted py-4">
                <p>No job listings available at this time.</p>
            </div>
        }
        @foreach (var job in Model.Jobs)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@job.Title</h5>
                        <p class="card-text">@job.Description</p>
                        <ul class="list-unstyled text-muted small">
                            @if (!string.IsNullOrEmpty(job.Location))
                            {
                                <li><i class="bi bi-geo-alt"></i> @job.Location</li>
                            }
                            @if (!string.IsNullOrEmpty(job.Department))
                            {
                                <li><i class="bi bi-building"></i> @job.Department</li>
                            }
                            @if (!string.IsNullOrEmpty(job.DatePosted))
                            {
                                <li><i class="bi bi-calendar"></i> Posted: @job.DatePosted</li>
                            }
                        </ul>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@job.DetailsUrl" class="btn btn-outline-primary btn-sm w-100">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @{
        int totalPages = (int)System.Math.Ceiling((double)Model.TotalJobs / Model.PageSize);
    }
    @if (totalPages > 1)
    {
        <nav aria-label="Job listings pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="#" data-page="@(Model.CurrentPage - 1)">Previous</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="#" data-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="#" data-page="@(Model.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>
