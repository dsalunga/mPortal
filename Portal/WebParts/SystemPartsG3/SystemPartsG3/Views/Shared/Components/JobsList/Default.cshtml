@model WCMS.WebSystem.WebParts.ViewComponents.JobsListViewModel

<section class="jobs-list" aria-labelledby="jobsListHeading-@Model.ObjectId">
    <h4 class="mb-3" id="jobsListHeading-@Model.ObjectId">Job Listings</h4>

    @if (Model.TotalJobs > 0)
    {
        <p class="text-muted mb-3" aria-live="polite" role="status">
            Showing <strong>@Model.Jobs.Count</strong> of <strong>@Model.TotalJobs</strong> job(s)
        </p>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model.Jobs == null || Model.Jobs.Count == 0)
            {
                <div class="text-center py-5" role="status">
                    <i class="bi bi-briefcase fs-1 text-muted d-block mb-2" aria-hidden="true"></i>
                    <p class="text-muted mb-1">No job listings available at this time.</p>
                    <p class="text-muted small mb-0">Please check back later for new openings.</p>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush" aria-label="Job listings">
                    @foreach (var job in Model.Jobs)
                    {
                        <article class="list-group-item list-group-item-action">
                            <div class="d-flex w-100 justify-content-between align-items-start">
                                <div class="me-3">
                                    <h5 class="mb-1">
                                        @if (!string.IsNullOrEmpty(job.DetailsUrl))
                                        {
                                            <a href="@job.DetailsUrl" data-action="view-job" data-id="@job.Id" aria-label="View details for @job.Title">@job.Title</a>
                                        }
                                        else
                                        {
                                            @job.Title
                                        }
                                    </h5>
                                    <p class="mb-1">
                                        @if (!string.IsNullOrEmpty(job.Department))
                                        {
                                            <span class="badge bg-secondary me-1">@job.Department</span>
                                        }
                                        @if (!string.IsNullOrEmpty(job.Location))
                                        {
                                            <span class="text-muted"><i class="bi bi-geo-alt" aria-hidden="true"></i> @job.Location</span>
                                        }
                                    </p>
                                    @if (!string.IsNullOrEmpty(job.Description))
                                    {
                                        <p class="mb-0 small text-muted">@job.Description</p>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(job.DatePosted))
                                {
                                    <small class="text-nowrap text-muted flex-shrink-0">
                                        <time datetime="@job.DatePosted">@job.DatePosted</time>
                                    </small>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </div>

    @if (Model.TotalJobs > 0 && Model.PageSize > 0)
    {
        int totalPages = (int)System.Math.Ceiling((double)Model.TotalJobs / (double)Model.PageSize);
        if (totalPages > 1)
        {
            <nav aria-label="Job listings pagination" class="mt-3">
                <ul class="pagination justify-content-center flex-wrap">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="#" data-page="@(Model.CurrentPage - 1)" aria-label="Go to previous page">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")" @(i == Model.CurrentPage ? "aria-current=\"page\"" : "")>
                            <a class="page-link" href="#" data-page="@i" aria-label="Go to page @i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="#" data-page="@(Model.CurrentPage + 1)" aria-label="Go to next page">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</section>
