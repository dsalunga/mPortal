<?xml version="1.0" standalone="yes"?>
<mPortal>
  <xs:schema id="mPortal" xmlns="" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xs:element name="mPortal" msdata:IsDataSet="true" msdata:UseCurrentLocale="true">
      <xs:complexType>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
          <xs:element name="WebMessageQueue">
            <xs:complexType>
              <xs:sequence>
                <xs:element name="Id" type="xs:int" />
                <xs:element name="FromObjectId" type="xs:int" />
                <xs:element name="FromRecordId" type="xs:int" />
                <xs:element name="EmailSubject">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="4000" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="EmailMessage">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="2147483647" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="SmsMessage">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="4000" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="To">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="4000" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="ToFailed">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="4000" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="ToExcluded">
                  <xs:simpleType>
                    <xs:restriction base="xs:string">
                      <xs:maxLength value="4000" />
                    </xs:restriction>
                  </xs:simpleType>
                </xs:element>
                <xs:element name="ToOrBcc" type="xs:int" />
                <xs:element name="DateCreated" type="xs:dateTime" />
                <xs:element name="DateSent" type="xs:dateTime" />
                <xs:element name="Status" type="xs:int" />
                <xs:element name="SendVia" type="xs:int" />
                <xs:element name="EnableMonitor" type="xs:int" />
              </xs:sequence>
            </xs:complexType>
          </xs:element>
        </xs:choice>
      </xs:complexType>
      <xs:unique name="Constraint1" msdata:PrimaryKey="true">
        <xs:selector xpath=".//WebMessageQueue" />
        <xs:field xpath="Id" />
      </xs:unique>
    </xs:element>
  </xs:schema>
</mPortal>