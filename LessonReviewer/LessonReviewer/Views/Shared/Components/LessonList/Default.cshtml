@model WCMS.WebSystem.ViewComponents.LessonListViewModel

<section class="lesson-list" aria-labelledby="lessonListHeading">
    <div class="d-flex align-items-center mb-3 flex-wrap gap-2">
        <h4 id="lessonListHeading" class="mb-0">
            <i class="bi bi-journal-text me-1" aria-hidden="true"></i> Available Lessons
        </h4>
        <div>
            <label for="lessonLangSelect" class="visually-hidden">Filter by language</label>
            <select id="lessonLangSelect" class="form-select form-select-sm d-inline-block" style="width: auto;"
                    onchange="location.href='@(Model.BasePath)?lang=' + this.value"
                    aria-label="Filter lessons by language">
                @foreach (var lang in Model.Languages)
                {
                    var langText = !string.IsNullOrEmpty(lang.Value) ? lang.Value : "All Languages";
                    <option value="@lang.Key" selected="@(lang.Key == Model.SelectedLanguage ? "selected" : null)">@langText</option>
                }
            </select>
        </div>
    </div>

    @if (Model.Lessons.Count == 0)
    {
        <div class="alert alert-info" role="status" aria-live="polite">
            <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
            No lessons available for the selected language.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" aria-describedby="lessonListHeading">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Title</th>
                        <th scope="col">Date</th>
                        <th scope="col">Service</th>
                        <th scope="col">Language</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lesson in Model.Lessons)
                    {
                        <tr>
                            <td class="fw-semibold">@lesson.Title</td>
                            <td>
                                <time datetime="@lesson.Date.ToString("yyyy-MM-dd")">@lesson.Date.ToString("MMM dd, yyyy")</time>
                            </td>
                            <td>@lesson.ServiceType</td>
                            <td>@lesson.Language</td>
                            <td class="text-center">
                                @if (lesson.HasFiles)
                                {
                                    <a href="@Model.BasePath?lessonId=@lesson.Id" class="btn btn-sm btn-primary"
                                       aria-label="Play @lesson.Title">
                                        <i class="bi bi-play-circle me-1" aria-hidden="true"></i> Play
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
