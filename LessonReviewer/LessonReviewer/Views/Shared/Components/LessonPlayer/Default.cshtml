@model WCMS.WebSystem.ViewComponents.LessonPlayerViewModel

<section class="lesson-player" aria-labelledby="lessonPlayerHeading">
    @if (!string.IsNullOrEmpty(Model.ServiceType))
    {
        <h4 id="lessonPlayerHeading" class="mb-3">
            <i class="bi bi-play-circle me-1" aria-hidden="true"></i>
            @Model.ServiceType — <time>@Model.ServiceDate</time>
        </h4>
    }
    else
    {
        <h4 id="lessonPlayerHeading" class="visually-hidden">Lesson Player</h4>
    }

    <div class="player-container mb-3">
        <figure class="ratio ratio-16x9" style="max-width: 800px;">
            <video id="lessonVideo" controls
                   @(Model.Service != null && Model.Service.AllowSeek ? "" : "controlsList=\"noplaybackrate\"")
                   aria-label="Lesson video player"
                   preload="metadata">
                @if (Model.Files.Count > 0)
                {
                    <source src="@Model.Files[0].Url" />
                }
                <p>Your browser does not support the video element. Please update your browser.</p>
            </video>
        </figure>
    </div>

    @if (Model.Files.Count > 1)
    {
        <nav class="playlist mb-3" aria-label="Lesson segments">
            <h5 class="h6 fw-semibold">
                <i class="bi bi-list-ul me-1" aria-hidden="true"></i> Segments
                <span class="badge bg-secondary ms-1">@Model.Files.Count</span>
            </h5>
            <ol class="list-group list-group-numbered">
                @foreach (var file in Model.Files)
                {
                    var label = !string.IsNullOrEmpty(file.Caption) ? file.Caption : file.Filename;
                    <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                        role="button" tabindex="0"
                        onclick="document.getElementById('lessonVideo').src='@file.Url'; document.getElementById('lessonVideo').play();"
                        onkeydown="if(event.key==='Enter'){this.click();}"
                        aria-label="Play segment: @label">
                        <span>@label</span>
                        <i class="bi bi-play-fill text-primary" aria-hidden="true"></i>
                    </li>
                }
            </ol>
        </nav>
    }

    <div class="player-controls mt-3">
        <a href="@Model.BasePath" class="btn btn-outline-secondary btn-sm" aria-label="Return to lesson list">
            <i class="bi bi-arrow-left me-1" aria-hidden="true"></i> Back to Lessons
        </a>
    </div>
</section>
