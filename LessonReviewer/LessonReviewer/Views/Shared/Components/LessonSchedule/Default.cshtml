@model WCMS.WebSystem.ViewComponents.LessonScheduleViewModel
@{
    var firstDay = new DateTime(Model.CurrentMonth.Year, Model.CurrentMonth.Month, 1);
    var daysInMonth = DateTime.DaysInMonth(Model.CurrentMonth.Year, Model.CurrentMonth.Month);
    var startOffset = (int)firstDay.DayOfWeek;
    var today = DateTime.Today;
}

<section class="lesson-schedule" aria-labelledby="scheduleHeading">
    <h4 id="scheduleHeading" class="visually-hidden">Lesson Schedule</h4>

    <nav class="d-flex align-items-center mb-3 flex-wrap gap-2" aria-label="Calendar navigation">
        <button type="button" class="btn btn-outline-secondary btn-sm"
                onclick="location.href='@(Model.BasePath)?month=@(firstDay.AddMonths(-1).ToString("yyyy-MM"))'"
                aria-label="Previous month">
            <i class="bi bi-chevron-left" aria-hidden="true"></i>
        </button>
        <div>
            <label for="scheduleMonth" class="visually-hidden">Month</label>
            <select id="scheduleMonth" class="form-select form-select-sm d-inline-block" style="width: auto;"
                    onchange="location.href='@(Model.BasePath)?month=@(Model.CurrentMonth.Year)-' + this.value.padStart(2,'0')"
                    aria-label="Select month">
                @for (int m = 1; m <= 12; m++)
                {
                    var monthName = new DateTime(Model.CurrentMonth.Year, m, 1).ToString("MMMM");
                    <option value="@m" selected="@(m == Model.CurrentMonth.Month ? "selected" : null)">@monthName</option>
                }
            </select>
        </div>
        <div>
            <label for="scheduleYear" class="visually-hidden">Year</label>
            <select id="scheduleYear" class="form-select form-select-sm d-inline-block" style="width: auto;"
                    onchange="location.href='@(Model.BasePath)?month=' + this.value + '-@(Model.CurrentMonth.Month.ToString("00"))'"
                    aria-label="Select year">
                @for (int y = Model.CurrentMonth.Year - 2; y <= Model.CurrentMonth.Year + 2; y++)
                {
                    <option value="@y" selected="@(y == Model.CurrentMonth.Year ? "selected" : null)">@y</option>
                }
            </select>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm"
                onclick="location.href='@(Model.BasePath)?month=@(firstDay.AddMonths(1).ToString("yyyy-MM"))'"
                aria-label="Next month">
            <i class="bi bi-chevron-right" aria-hidden="true"></i>
        </button>
        <button type="button" class="btn btn-outline-primary btn-sm"
                onclick="location.href='@(Model.BasePath)?month=@(today.ToString("yyyy-MM"))'"
                aria-label="Go to today">
            <i class="bi bi-calendar-check me-1" aria-hidden="true"></i> Today
        </button>
    </nav>

    <div class="table-responsive">
        <table class="table table-bordered" role="grid" aria-label="@Model.CurrentMonth.ToString("MMMM yyyy") lesson schedule">
            <caption class="text-center fs-5 fw-bold caption-top">
                <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>
                @Model.CurrentMonth.ToString("MMMM yyyy")
            </caption>
            <thead class="table-light">
                <tr>
                    <th scope="col" abbr="Sunday" class="fw-bold text-center">Sun</th>
                    <th scope="col" abbr="Monday" class="fw-bold text-center">Mon</th>
                    <th scope="col" abbr="Tuesday" class="fw-bold text-center">Tue</th>
                    <th scope="col" abbr="Wednesday" class="fw-bold text-center">Wed</th>
                    <th scope="col" abbr="Thursday" class="fw-bold text-center">Thu</th>
                    <th scope="col" abbr="Friday" class="fw-bold text-center">Fri</th>
                    <th scope="col" abbr="Saturday" class="fw-bold text-center">Sat</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var day = 1;
                    var totalCells = startOffset + daysInMonth;
                    var rows = (int)Math.Ceiling(totalCells / 7.0);
                }
                @for (var r = 0; r < rows; r++)
                {
                    <tr>
                        @for (var c = 0; c < 7; c++)
                        {
                            var cellIndex = r * 7 + c;
                            if (cellIndex < startOffset || day > daysInMonth)
                            {
                                <td class="text-muted bg-light">&nbsp;</td>
                            }
                            else
                            {
                                var cellDate = new DateTime(Model.CurrentMonth.Year, Model.CurrentMonth.Month, day);
                                var isToday = cellDate.Date == today;
                                var dayEntries = Model.Entries.FindAll(e => e.Date.Date == cellDate.Date);
                                var cellClass = isToday ? "table-info border-primary" : (dayEntries.Count > 0 ? "table-success" : "");
                                <td class="@cellClass" style="min-width: 110px; vertical-align: top;">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <strong class="@(isToday ? "text-primary" : "")">@day</strong>
                                        @if (dayEntries.Count > 0)
                                        {
                                            <span class="badge bg-success rounded-pill" aria-label="@dayEntries.Count lesson(s)">@dayEntries.Count</span>
                                        }
                                    </div>
                                    @foreach (var entry in dayEntries)
                                    {
                                        <div class="small text-truncate mt-1 @entry.CssClass">
                                            <a href="@Model.BasePath?lessonId=@entry.Id" class="text-decoration-none"
                                               aria-label="@entry.Title on @cellDate.ToString("MMMM d")">
                                                <i class="bi bi-play-circle me-1" aria-hidden="true"></i>@entry.Title
                                            </a>
                                        </div>
                                    }
                                </td>
                                day++;
                            }
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
