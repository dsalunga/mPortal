@model WCMS.WebSystem.ViewComponents.LessonScheduleViewModel
@*
    LessonSchedule ViewComponent - Shows lesson schedule/calendar view.
*@
@{
    var firstDay = new DateTime(Model.CurrentMonth.Year, Model.CurrentMonth.Month, 1);
    var daysInMonth = DateTime.DaysInMonth(Model.CurrentMonth.Year, Model.CurrentMonth.Month);
    var startOffset = (int)firstDay.DayOfWeek;
    var today = DateTime.Today;
}
<div class="lesson-schedule">
    <div class="d-flex align-items-center mb-2 flex-wrap gap-1">
        <button type="button" class="btn btn-outline-secondary btn-sm"
                onclick="location.href='@(Model.BasePath)?month=@(firstDay.AddMonths(-1).ToString("yyyy-MM"))'"
                title="Previous Month">&laquo;</button>
        <select class="form-select form-select-sm d-inline-block" style="width: auto;"
                onchange="location.href='@(Model.BasePath)?month=@(Model.CurrentMonth.Year)-' + this.value.padStart(2,'0')">
            @for (int m = 1; m <= 12; m++)
            {
                var monthName = new DateTime(Model.CurrentMonth.Year, m, 1).ToString("MMMM");
                <option value="@m" selected="@(m == Model.CurrentMonth.Month ? "selected" : null)">@monthName</option>
            }
        </select>
        <select class="form-select form-select-sm d-inline-block" style="width: auto;"
                onchange="location.href='@(Model.BasePath)?month=' + this.value + '-@(Model.CurrentMonth.Month.ToString("00"))'">
            @for (int y = Model.CurrentMonth.Year - 2; y <= Model.CurrentMonth.Year + 2; y++)
            {
                <option value="@y" selected="@(y == Model.CurrentMonth.Year ? "selected" : null)">@y</option>
            }
        </select>
        <button type="button" class="btn btn-outline-secondary btn-sm"
                onclick="location.href='@(Model.BasePath)?month=@(firstDay.AddMonths(1).ToString("yyyy-MM"))'"
                title="Next Month">&raquo;</button>
        &nbsp;
        <button type="button" class="btn btn-outline-secondary btn-sm"
                onclick="location.href='@(Model.BasePath)?month=@(today.ToString("yyyy-MM"))'">Today</button>
    </div>
    <table class="table table-bordered" style="border-width: 1px; border-style: solid;">
        <thead>
            <tr>
                <th colspan="7" class="text-center" style="font-size: 12pt; font-weight: bold;">
                    @Model.CurrentMonth.ToString("MMMM yyyy")
                </th>
            </tr>
            <tr>
                <th style="font-weight: bold;">Sun</th>
                <th style="font-weight: bold;">Mon</th>
                <th style="font-weight: bold;">Tue</th>
                <th style="font-weight: bold;">Wed</th>
                <th style="font-weight: bold;">Thu</th>
                <th style="font-weight: bold;">Fri</th>
                <th style="font-weight: bold;">Sat</th>
            </tr>
        </thead>
        <tbody>
            @{
                var day = 1;
                var totalCells = startOffset + daysInMonth;
                var rows = (int)Math.Ceiling(totalCells / 7.0);
            }
            @for (var r = 0; r < rows; r++)
            {
                <tr>
                    @for (var c = 0; c < 7; c++)
                    {
                        var cellIndex = r * 7 + c;
                        if (cellIndex < startOffset || day > daysInMonth)
                        {
                            <td>&nbsp;</td>
                        }
                        else
                        {
                            var cellDate = new DateTime(Model.CurrentMonth.Year, Model.CurrentMonth.Month, day);
                            var isToday = cellDate.Date == today;
                            var dayEntries = Model.Entries.FindAll(e => e.Date.Date == cellDate.Date);
                            var cellClass = (isToday ? "table-info" : "") + (dayEntries.Count > 0 ? " table-success" : "");
                            <td class="@cellClass" style="width: 120px; vertical-align: top;">
                                <strong>@day</strong>
                                @foreach (var entry in dayEntries)
                                {
                                    <div class="small text-truncate @entry.CssClass">
                                        <a href="@Model.BasePath?lessonId=@entry.Id">@entry.Title</a>
                                    </div>
                                }
                            </td>
                            day++;
                        }
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
