@model LessonReviewer.ViewComponents.AdminLoginViewModel
@* Ported from Login.aspx (Admin). *@

<div class="component-adminlogin">
    @if (Model.ObjectId > 0)
    {
        <div class="component-content" data-object-id="@Model.ObjectId" data-record-id="@Model.RecordId">
            <p class="text-muted">
                <em>Login</em> — ported from legacy WebForms.
                Awaiting full UI implementation.
            </p>
        </div>
